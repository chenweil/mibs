-- *  End of unisDot11APUserSecAuthTypeStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11RadioRxStatis64Table Definition
-- *****************************************************************************
unisDot11RadioRxStatis64Table OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11RadioRxStatis64Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the reception statistic for a specific
        radio of AP."
    ::= { unisDot11APStatisGroup 30 }

unisDot11RadioRxStatis64Entry OBJECT-TYPE
    SYNTAX      UnisDot11RadioRxStatis64Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the reception statistic
        data for each radio of a specific AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID
        }
    ::= { unisDot11RadioRxStatis64Table 1 }

UnisDot11RadioRxStatis64Entry ::= SEQUENCE
    {
        unisDot11Rx64FrameDupCnt          Counter64,
        unisDot11Rx64FrameCnt             Counter64,
        unisDot11Rx64UcastFrameCnt        Counter64,
        unisDot11Rx64BcastFrameCnt        Counter64,
        unisDot11Rx64McastFrameCnt        Counter64,
        unisDot11Rx64DiscardFrameCnt      Counter64,
        unisDot11Rx64FragCnt              Counter64,
        unisDot11Rx64FcsErrCnt            Counter64,
        unisDot11Rx64FrameBytes           Counter64,
        unisDot11Rx64UcastFrameBytes      Counter64,
        unisDot11Rx64BcastFrameBytes      Counter64,
        unisDot11Rx64McastFrameBytes      Counter64,
        unisDot11Rx64DiscardFrameBytes    Counter64,
        unisDot11Rx64MgmtFrameCnt         Counter64,
        unisDot11Rx64CtrlFrameCnt         Counter64,
        unisDot11Rx64DataFrameCnt         Counter64,
        unisDot11Rx64DecryptErrorCnt      Counter64,
        unisDot11Rx64AuthenFrameCnt       Counter64,
        unisDot11Rx64AssociateFrameCnt    Counter64,
        unisDot11Rx64PhyErrorCnt          Counter64,
        unisDot11Rx64MICErrorCnt          Counter64,
        unisDot11Rx64DataFrameBytes       Counter64,
        unisDot11Rx64PayloadBytes         Counter64,
        unisDot11Rx64DataFrameBytesCM     Counter64
    }

unisDot11Rx64FrameDupCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
