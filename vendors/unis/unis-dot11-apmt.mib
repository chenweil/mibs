unisDot11BSSRxStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11BSSRxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the reception statistic for a
        specific BSS on a radio."
    ::= { unisDot11APStatisGroup 4 }

unisDot11BSSRxStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11BSSRxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the statistic data for
        each BSS on a specific radio."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID,
            unisDot11WlanID
        }
    ::= { unisDot11BSSRxStatisTable 1 }

