-- *****************************************************************************
-- *  unisDot11APAssocFailStatis3Table Definition
-- *****************************************************************************
unisDot11APAssocFailStatis3Table OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APAssocFailStatis3Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table will provide statistic of association fails for each AP."
    ::= { unisDot11APStatisGroup 22 }

unisDot11APAssocFailStatis3Entry OBJECT-TYPE
    SYNTAX      UnisDot11APAssocFailStatis3Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry will provide statistic of association failure with this AP
         because of different reasons."
    INDEX
        {
            unisDot11CurAPID
       }
    ::= { unisDot11APAssocFailStatis3Table 1 }

UnisDot11APAssocFailStatis3Entry ::= SEQUENCE
    {
        unisDot11APAssocFailStatis3SRCnt                 Counter32,
        unisDot11APAssocFailStatis3NSRCnt                Counter32,
        unisDot11APAssocFailStatis3URCCnt                Counter32,
        unisDot11APAssocFailStatis3RFCnt                 Counter32,
        unisDot11APAssocFailStatis3OtherCnt              Counter32,
        unisDot11APAssocFailStatis3RSSILowCntCM          Counter32
    }

unisDot11APAssocFailStatis3SRCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of association failure because of
         lack of resource."
    ::= { unisDot11APAssocFailStatis3Entry 1 }

unisDot11APAssocFailStatis3NSRCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of association failure because of
         not support rate set."
    ::= { unisDot11APAssocFailStatis3Entry 2 }

unisDot11APAssocFailStatis3URCCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of association failure because of
         unknown reason code."
    ::= { unisDot11APAssocFailStatis3Entry 3 }

unisDot11APAssocFailStatis3RFCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of association failure because of
         re-associate failed."
    ::= { unisDot11APAssocFailStatis3Entry 4 }

unisDot11APAssocFailStatis3OtherCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of association fails because of
         reason not in 802.11 the protocol."
    ::= { unisDot11APAssocFailStatis3Entry 5 }

unisDot11APAssocFailStatis3RSSILowCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of failed associations due to low RSSI."
    ::= { unisDot11APAssocFailStatis3Entry 6 }

-- *****************************************************************************
-- *  End of unisDot11APAssocFailStatis3Table Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APIfStatisByAPIDTable Definition
-- *****************************************************************************
unisDot11APIfStatisByAPIDTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APIfStatisByAPIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the statistics on the interface of the AP."
    ::= { unisDot11APStatisGroup 23 }

unisDot11APIfStatisByAPIDEntry OBJECT-TYPE
    SYNTAX      UnisDot11APIfStatisByAPIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide statistics on the interface of the AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11APIfIndex
        }
    ::= { unisDot11APIfStatisByAPIDTable 1 }

UnisDot11APIfStatisByAPIDEntry ::= SEQUENCE
    {
        unisDot11APIfInPkts2              Counter64,
        unisDot11APIfInNormalPkts2        Counter64,
        unisDot11APIfInErrorPkts2         Counter64,
        unisDot11APIfOutPkts2             Counter64,
        unisDot11APIfInOctets2            Counter64,
        unisDot11APIfOutOctets2           Counter64,
        unisDot11APIfFlowOut2             Unsigned32,
        unisDot11APIfFlowIN2              Unsigned32,
        unisDot11APIfInUcastPkts2         Counter64,
        unisDot11APIfInNUcastPkts2        Counter64,
        unisDot11APIfInDiscardPkts2       Counter64,
        unisDot11APIfOutUcastPkts2        Counter64,
        unisDot11APIfOutNUcastPkts2       Counter64,
        unisDot11APIfOutDiscardPkts2      Counter64,
        unisDot11APIfOutErrorPkts2        Counter64,
        unisDot11APIfUpdownTimes2         Counter32,
        unisDot11APIfStatusKeepTime2      TimeTicks,
        unisDot11APIfOperStatus2          INTEGER,
        unisDot11APIfInBrdcastPkts2       Counter64,
        unisDot11APIfOutBrdcastPkts2      Counter64,
        unisDot11APIfInMulcastPkts2       Counter64,
        unisDot11APIfOutMulcastPkts2      Counter64,
        unisDot11APIfInPayloadOctets2     Counter64,
        unisDot11APIfOutPayloadOctets2    Counter64,
        unisDot11APIfInDataOctets2        Counter64,
        unisDot11APIfOutDataOctets2       Counter64,
        unisDot11APIfAdminStatus          INTEGER,
        unisDot11APIfOperStatusCM         INTEGER
    }

unisDot11APIfInPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of packets received
         on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 1 }

unisDot11APIfInNormalPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of correct
         packets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 2 }

unisDot11APIfInErrorPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of error
         packets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 3 }

unisDot11APIfOutPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of packets
         sent from the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 4 }

unisDot11APIfInOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of octets
         received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 5 }

unisDot11APIfOutOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of octets
         sent from the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 6 }

unisDot11APIfFlowOut2 OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the traffic rate (byte/s) on the uplink interface
         during a sampling period."
    ::= { unisDot11APIfStatisByAPIDEntry 7 }

unisDot11APIfFlowIN2 OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the traffic rate (byte/s) on the downlink interface
         during a sampling period."
    ::= { unisDot11APIfStatisByAPIDEntry 8 }

unisDot11APIfInUcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 9 }

unisDot11APIfInNUcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of non-unicast packets received on the wired
         interface."
    ::= { unisDot11APIfStatisByAPIDEntry 10 }

unisDot11APIfInDiscardPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets discarded on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 11 }

unisDot11APIfOutUcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets send on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 12 }

unisDot11APIfOutNUcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of non-unicast packets send on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 13 }

unisDot11APIfOutDiscardPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of discarded packets send on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 14 }

unisDot11APIfOutErrorPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of error packets send on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 15 }

unisDot11APIfUpdownTimes2 OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the up/down times on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 16 }

unisDot11APIfStatusKeepTime2 OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the last change time on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 17 }

unisDot11APIfOperStatus2 OBJECT-TYPE
    SYNTAX  INTEGER {
                       up(1),        -- ready to pass packets
                       down(2),
                       testing(3),   -- in some test mode
                       unknown(4),   -- status can not be determined
                                     -- for some reason.
                       dormant(5),
                       notPresent(6),    -- some component is missing
                       lowerLayerDown(7) -- down due to state of
                                         -- lower-layer interface(s)
                    }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the operational state of the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 18 }

unisDot11APIfInBrdcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of broadcast packets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 19 }

unisDot11APIfOutBrdcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of broadcast packets sent on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 20 }

unisDot11APIfInMulcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of multicast packets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 21 }

unisDot11APIfOutMulcastPkts2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of multicast packets sent on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 22 }

unisDot11APIfInPayloadOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of actual octets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 23 }

unisDot11APIfOutPayloadOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of actual octets sent on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 24 }

unisDot11APIfInDataOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of actual data octets received on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 25 }

unisDot11APIfOutDataOctets2 OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of actual data octets sent on the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 26 }

unisDot11APIfAdminStatus OBJECT-TYPE
    SYNTAX  INTEGER {
                up(1),       -- ready to forward packets
                down(2),
                testing(3)   -- in a test mode
            }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
            "Expected state of the interface.  In testing state the
            interface does not forward any operational packets.  When
             a managed system is initialized, all interfaces start with
            unisDot11APIfAdminStatus in the down state.  As a result
            of either explicit management action or per configuration
            information retained by the managed system,
            unisDot11APIfAdminStatus is then changed to either the up
             or testing state or remains in the down state."
    ::= { unisDot11APIfStatisByAPIDEntry 27 }

unisDot11APIfOperStatusCM OBJECT-TYPE
    SYNTAX  INTEGER {
                       up(1),        -- ready to forward packets
                       down(2),
                       testing(3),   -- in a test mode
                       admindown(4)  -- shutdown by administrator
                    }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Operational status of the interface."
    ::= { unisDot11APIfStatisByAPIDEntry 28 }

-- *****************************************************************************
-- *  End of unisDot11APIfStatisTable1 Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APUserSecAuthStatisTable Definition
-- *****************************************************************************
unisDot11APUserSecAuthStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APUserSecAuthStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the user authentication statistic for this AP."
    ::= { unisDot11APStatisGroup 24 }

unisDot11APUserSecAuthStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APUserSecAuthStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the user authentication statistic
        for this AP."
    INDEX
        {
            unisDot11CurAPID
       }
    ::= { unisDot11APUserSecAuthStatisTable 1 }

UnisDot11APUserSecAuthStatisEntry ::= SEQUENCE
    {
        unisDot11APUserAuthCurNumber             Integer32,
        unisDot11APUserConnFailCnt               Counter32,
        unisDot11APUserAuthReqCnt                Counter32,
        unisDot11APUserAuthSuccCnt               Counter32,
        unisDot11APUserAuthFailCnt               Counter32,
        unisDot11AllUserOnlineTime               TimeTicks
    }

unisDot11APUserAuthCurNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current number of user authenticated with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 1 }

unisDot11APUserConnFailCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of user disconnected with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 2 }

unisDot11APUserAuthReqCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of user authentication request with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 3 }

unisDot11APUserAuthSuccCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of successful authenticated users with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 4 }

unisDot11APUserAuthFailCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of user authentication failures with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 5 }

unisDot11AllUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all successful authenticated users with this AP."
    ::= { unisDot11APUserSecAuthStatisEntry 6 }

-- *****************************************************************************
-- *  End of unisDot11APUserSecAuthStatisEntry Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APUserInfoStatisTable Definition
-- *****************************************************************************
unisDot11APUserInfoStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APUserInfoStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the user information statistic of this AP."
    ::= { unisDot11APStatisGroup 25 }

unisDot11APUserInfoStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APUserInfoStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the user information statistic
        of this AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11APUserMacAddr
        }
    ::= { unisDot11APUserInfoStatisTable 1 }

UnisDot11APUserInfoStatisEntry ::= SEQUENCE
    {
        unisDot11APUserMacAddr                  MacAddress,
        unisDot11APUserIpAddr                   IpAddress,
        unisDot11APUserLoginName                OCTET STRING,
        unisDot11APUserLoginTime                OCTET STRING,
        unisDot11APUserOnlineTime               TimeTicks,
        unisDot11APUserLoginNameCM              OCTET STRING,
        unisDot11APUserAuthTypeCM               INTEGER,
        unisDot11APUserTxPacketCntCM            Counter32,
        unisDot11APUserTxBytesCM                Counter64,
        unisDot11APUserRxPacketCntCM            Counter32,
        unisDot11APUserRxBytesCM                Counter64
    }

unisDot11APUserMacAddr OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the mac address of user logging to this AP."
    ::= { unisDot11APUserInfoStatisEntry 1 }

unisDot11APUserIpAddr OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ip address of user logging to this AP."
    ::= { unisDot11APUserInfoStatisEntry 2 }

unisDot11APUserLoginName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the login name of user logging to this AP."
    ::= { unisDot11APUserInfoStatisEntry 3 }

unisDot11APUserLoginTime OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the login time of user with this AP."
    ::= { unisDot11APUserInfoStatisEntry 4 }

unisDot11APUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of user with this AP."
    ::= { unisDot11APUserInfoStatisEntry 5 }

unisDot11APUserLoginNameCM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the login name of user logging to this AP."
    ::= { unisDot11APUserInfoStatisEntry 6 }

unisDot11APUserAuthTypeCM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            authFree(1),
            associateAuth(2),
            portalAuth(3),
            autoAuth(4)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the authentication type of user with this AP.
        authFree       - There is no need others authentiaction, user will
        surf internet after association.
        associateAuth  - Include WEP PSK authentication.
        portalAuth     - The authentication lunched by portal pop-up program.
        autoAuth       - 802.1X authentication."
    ::= { unisDot11APUserInfoStatisEntry 7 }

unisDot11APUserTxPacketCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total count of packets sent to online users."
    ::= { unisDot11APUserInfoStatisEntry 8 }

unisDot11APUserTxBytesCM OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total bytes sent to online users."
    ::= { unisDot11APUserInfoStatisEntry 9 }

unisDot11APUserRxPacketCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total count of packets received from online users."
    ::= { unisDot11APUserInfoStatisEntry 10 }

unisDot11APUserRxBytesCM OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total bytes received from online users."
    ::= { unisDot11APUserInfoStatisEntry 11 }

-- *****************************************************************************
-- *  End of unisDot11APUserInfoStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APReassocStatis2Table Definition
-- *****************************************************************************
unisDot11APReassocStatis2Table OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APReassocStatis2Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table will provide statistic of reassociation for each AP."
    ::= { unisDot11APStatisGroup 26 }

unisDot11APReassocStatis2Entry OBJECT-TYPE
    SYNTAX      UnisDot11APReassocStatis2Entry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry will provide statistic of reassociation with this AP
         because of different reasons."
    INDEX
        {
            unisDot11CurAPID
        }
    ::= { unisDot11APReassocStatis2Table 1 }

UnisDot11APReassocStatis2Entry ::= SEQUENCE
    {
        unisDot11APReassocFailStatis2Cnt                 Counter32
    }

unisDot11APReassocFailStatis2Cnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of reassociation failure because of
         lack of resource."
    ::= { unisDot11APReassocStatis2Entry 1 }

-- *****************************************************************************
-- *  End of unisDot11APReassocStatis2Table Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11TrafficTable Definition
-- *****************************************************************************
unisDot11TrafficTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11TrafficEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table describes user's traffic based on ssid"
    ::= { unisDot11APStatisGroup 27 }

unisDot11TrafficEntry OBJECT-TYPE
    SYNTAX      UnisDot11TrafficEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the traffc information of a ssid."
    INDEX
        {
            unisDot11SSIDIndex
        }
    ::= { unisDot11TrafficTable 1 }

UnisDot11TrafficEntry ::= SEQUENCE
    {
        unisDot11SSIDIndex             OCTET STRING,
        unisDot11UpPacketNumber        Counter64,
        unisDot11UpByteNumber          Counter64,
        unisDot11DownPacketNumber      Counter64,
        unisDot11DownByteNumber        Counter64
    }

unisDot11SSIDIndex OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the SSID."
    ::= { unisDot11TrafficEntry 1 }

unisDot11UpPacketNumber OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the packet count of up link."
    ::= { unisDot11TrafficEntry 2 }

unisDot11UpByteNumber OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the byte count of up link."
    ::= { unisDot11TrafficEntry 3 }

unisDot11DownPacketNumber OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the packet count of down link."
    ::= { unisDot11TrafficEntry 4 }

unisDot11DownByteNumber OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the byte count of down link."
    ::= { unisDot11TrafficEntry 5 }

-- *****************************************************************************
-- *  End of unisDot11TrafficTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APEchoStatisTable Definition
-- *****************************************************************************
unisDot11APEchoStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APEchoInfoStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the Echo statistic of this AP."
    ::= { unisDot11APStatisGroup 28 }

unisDot11APEchoInfoStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APEchoInfoStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the Echo statistic
        of this AP."
    INDEX
        {
            unisDot11CurAPID
        }
    ::= { unisDot11APEchoStatisTable 1 }

UnisDot11APEchoInfoStatisEntry ::= SEQUENCE
    {
        unisDot11APEchoAvgDelay                 Integer32,
        unisDot11APEchoRequestCnt               Counter64,
        unisDot11APEchoRespLossCnt              Counter64
    }

unisDot11APEchoAvgDelay OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "millisecond"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the average time delay of heart beat in this AP."
    ::= { unisDot11APEchoInfoStatisEntry 1 }

unisDot11APEchoRequestCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the count of echo request in this AP."
    ::= { unisDot11APEchoInfoStatisEntry 2 }

unisDot11APEchoRespLossCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the loss count of echo response in this AP."
    ::= { unisDot11APEchoInfoStatisEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11APEchoStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APUserSecAuthTypeStatisTable Definition
-- *****************************************************************************
unisDot11APUserSecAuthTypeStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APUserSecAuthTypeStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the user authentication type statistic for this AP."
    ::= { unisDot11APStatisGroup 29 }

unisDot11APUserSecAuthTypeStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APUserSecAuthTypeStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the user authentication type statistic
        for this AP."
    INDEX
        {
            unisDot11CurAPID
        }
    ::= { unisDot11APUserSecAuthTypeStatisTable 1 }

UnisDot11APUserSecAuthTypeStatisEntry ::= SEQUENCE
    {
        unisDot11APPortalOnlineUserNum          Integer32,
        unisDot11APAuthFreeOnlineUserNum        Integer32,
        unisDot11APAssocAuthOnlineUserNum       Integer32,
        unisDot11APMacAuthOnlineUserNum         Integer32,
        unisDot11APAllPortalUserOnlineTime      TimeTicks,
        unisDot11APAllAuthFreeUserOnlineTime    TimeTicks,
        unisDot11APAllAssocAuthUserOnlineTime   TimeTicks,
        unisDot11APAllMacAuthUserOnlineTime     TimeTicks,
        unisDot11APPortalUserLostCnntCnt        Counter32,
        unisDot11APAuthFreeUserLostCnntCnt      Counter32,
        unisDot11APAssocAuthUserLostCnntCnt     Counter32,
        unisDot11APMacAuthUserLostCnntCnt       Counter32,
        unisDot11APPortalAuthReqCnt             Counter32,
        unisDot11APAssocAuthReqCnt              Counter32,
        unisDot11APMacAuthReqCnt                Counter32,
        unisDot11APPortalAuthSucCnt             Counter32,
        unisDot11APAssocAuthSucCnt              Counter32,
        unisDot11APMacAuthSucCnt                Counter32,
        unisDot11APPortalAuthReqFailCnt         Counter32,
        unisDot11APAssocAuthReqFailCnt          Counter32,
        unisDot11APMacAuthReqFailCnt            Counter32,
        unisDot11APAutoAuthOnlineUserNumCM      Integer32,
        unisDot11APAllAutoAuthUserOnlineTimeCM  TimeTicks,
        unisDot11APAutoAuthUserLostCnntCntCM    Counter32,
        unisDot11APAutoAuthReqCntCM             Counter32,
        unisDot11APAutoAuthSucCntCM             Counter32,
        unisDot11APAutoAuthReqFailCntCM         Counter32
    }

unisDot11APPortalOnlineUserNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of online portal users of this AP, including
        MAC-trigger and IMSIAuth users."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 1 }

unisDot11APAuthFreeOnlineUserNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online number of user free authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 2 }

unisDot11APAssocAuthOnlineUserNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of online users authenticated by associated
        authentication with this AP, excluding AutoAuth users."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 3 }

unisDot11APMacAuthOnlineUserNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online number of user MAC address authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 4 }

unisDot11APAllPortalUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all user portal authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 5 }

unisDot11APAllAuthFreeUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all user free authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 6 }

unisDot11APAllAssocAuthUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all user associated authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 7 }

unisDot11APAllMacAuthUserOnlineTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all user MAC address authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 8 }

unisDot11APPortalUserLostCnntCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the lost connective count of user portal authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 9 }

unisDot11APAuthFreeUserLostCnntCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the lost connective count of user free authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 10 }

unisDot11APAssocAuthUserLostCnntCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the lost connective count of user associate authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 11 }

unisDot11APMacAuthUserLostCnntCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the lost connective count of user MAC address authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 12 }

unisDot11APPortalAuthReqCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the request count of user portal authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 13 }

unisDot11APAssocAuthReqCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the request count of user associate authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 14 }

unisDot11APMacAuthReqCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the request count of user MAC address authenticated with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 15 }

unisDot11APPortalAuthSucCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user portal authenticated successed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 16 }

unisDot11APAssocAuthSucCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user associate authenticated successed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 17 }

unisDot11APMacAuthSucCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user MAC address authenticated successed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 18 }

unisDot11APPortalAuthReqFailCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user portal authenticated failed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 19 }

unisDot11APAssocAuthReqFailCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user associate authenticated failed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 20 }

unisDot11APMacAuthReqFailCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of user MAC address authenticated failed with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 21 }

unisDot11APAutoAuthOnlineUserNumCM OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of online users authenticated by auto authentication
        with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 22 }

unisDot11APAllAutoAuthUserOnlineTimeCM OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of users authenticated by auto authentication
        with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 23 }

unisDot11APAutoAuthUserLostCnntCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the disconnection count of AutoAuth users."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 24 }

unisDot11APAutoAuthReqCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of AutoAuth requests with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 25 }

unisDot11APAutoAuthSucCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of successful AutoAuth authentications with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 26 }

unisDot11APAutoAuthReqFailCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of failed AutoAuth requests with this AP."
    ::= { unisDot11APUserSecAuthTypeStatisEntry 27 }

