    {
        unisDot11BSSRxFrameCnt             Counter32,
        unisDot11BSSRxFrameBytes           Counter32,
        unisDot11BSSRxDataFrameCnt         Counter32,
        unisDot11BSSRxDataFrameBytes       Counter32,
        unisDot11BSSRxAssociateFrameCnt    Counter32,
        unisDot11BSSRxFrameErrorRatio      Integer32,
        unisDot11BSSRxPayloadBytes         Counter32,
        unisDot11BSSRxUniFrameCnt          Counter32,
        unisDot11BSSRxNonUniFrameCnt       Integer32,
        unisDot11BSSRxAuthenFrameCnt       Counter32,
        unisDot11BSSRxFrameErrCntCM        Counter32
    }

unisDot11BSSRxFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
