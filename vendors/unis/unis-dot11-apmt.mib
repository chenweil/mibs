    DESCRIPTION
        "The initial revision of this MIB module."
    ::= { unisDot11 2 }

-- *****************************************************************************
-- *  Major sections
-- *****************************************************************************
--  AP Object Group
--  DEFINED AS "The group to provide the basic information for APs.
--  In order to support fit and fat AP, it uses tables to keep
--  information.  For fat AP, if it is needful, it could add more
--  tables to keep information."
unisDot11APObjectGroup OBJECT IDENTIFIER   ::= { unisDot11APMT 1 }

--  AP Object Group has the following children:
--  unisDot11APObjectStatusTable           ::= { unisDot11APObjectGroup 1 }
--  unisDot11APObjectTable                 ::= { unisDot11APObjectGroup 2 }
--  unisDot11APRadioTable                  ::= { unisDot11APObjectGroup 3 }
--  unisDot11APBSSTable                    ::= { unisDot11APObjectGroup 4 }
--  unisDot11APModelTable                  ::= { unisDot11APObjectGroup 5 }
--  unisDot11APIfTable                     ::= { unisDot11APObjectGroup 6 }
--  unisDot11APSSIDObjectTable             ::= { unisDot11APObjectGroup 7 }
--  unisDot11APSysInfoTable                ::= { unisDot11APObjectGroup 8 }
--  unisDot11APIdleListTable               ::= { unisDot11APObjectGroup 9 }
--  unisDot11APSysInfoByAPIDTable          ::= { unisDot11APObjectGroup 10 }
--  unisDot11WTUAPInfoTable                ::= { unisDot11APObjectGroup 11 }

--  AP Statistic Group
--  DEFINED AS "The group to provide the statistic information of Rx
--  and Tx for AP."
unisDot11APStatisGroup OBJECT IDENTIFIER   ::= { unisDot11APMT 2 }

--  AP Statistic Group has the following children:
--  unisDot11APRxStatisTable               ::= { unisDot11APStatisGroup 1 }
--  unisDot11APTxStatisTable               ::= { unisDot11APStatisGroup 2 }
--  unisDot11APAssocStatisTable            ::= { unisDot11APStatisGroup 3 }
--  unisDot11BSSRxStatisTable              ::= { unisDot11APStatisGroup 4 }
--  unisDot11BSSTxStatisTable              ::= { unisDot11APStatisGroup 5 }
--  unisDot11BSSAssocStatisTable           ::= { unisDot11APStatisGroup 6 }
--  unisDot11APLinkStatisTable             ::= { unisDot11APStatisGroup 7 }
--  unisDot11RadioAssocStatisTable         ::= { unisDot11APStatisGroup 8 }
--  unisDot11RadioMngFrameStatisTable      ::= { unisDot11APStatisGroup 9 }
--  unisDot11APAuthFailStatisTable         ::= { unisDot11APStatisGroup 10 }
--  unisDot11APAssocFailStatisTable        ::= { unisDot11APStatisGroup 11 }
--  unisDot11APReassocStatisTable          ::= { unisDot11APStatisGroup 12 }
--  unisDot11APUserAuthStatisTable         ::= { unisDot11APStatisGroup 13 }
--  unisDot11APDeauthStatisTable           ::= { unisDot11APStatisGroup 14 }
--  unisDot11APDeassocStatisTable          ::= { unisDot11APStatisGroup 15 }
--  unisDot11APAssocFailStatis2Table       ::= { unisDot11APStatisGroup 16 }
--  unisDot11APIfStatisTable               ::= { unisDot11APStatisGroup 17 }
--  unisDot11RadioMngFrmStatisTable        ::= { unisDot11APStatisGroup 18 }
--  unisDot11APPacketSizeStatisTable       ::= { unisDot11APStatisGroup 19 }
--  unisDot11APPacketRateStatisTable       ::= { unisDot11APStatisGroup 20 }
--  unisDot11APPacketMCSRateStatisTable    ::= { unisDot11APStatisGroup 21 }
--  unisDot11APAssocFailStatis3Table       ::= { unisDot11APStatisGroup 22 }
--  unisDot11APIfStatisByAPIDTable         ::= { unisDot11APStatisGroup 23 }
--  unisDot11APUserSecAuthStatisTable      ::= { unisDot11APStatisGroup 24 }
--  unisDot11APUserInfoStatisTable         ::= { unisDot11APStatisGroup 25 }
--  unisDot11APReassocStatis2Table         ::= { unisDot11APStatisGroup 26 }
--  unisDot11TrafficTable                  ::= { unisDot11APStatisGroup 27 }
--  unisDot11APEchoStatisTable             ::= { unisDot11APStatisGroup 28 }
--  unisDot11APUserSecAuthTypeStatisTable  ::= { unisDot11APStatisGroup 29 }
--  unisDot11RadioRxStatis64Table          ::= { unisDot11APStatisGroup 30 }
--  unisDot11RadioTxStatis64Table          ::= { unisDot11APStatisGroup 31 }
--  unisDot11BSSRxStatis64Table            ::= { unisDot11APStatisGroup 32 }
--  unisDot11BSSTxStatis64Table            ::= { unisDot11APStatisGroup 33 }
--  unisDot11APPacketMCSRateStatis2Table   ::= { unisDot11APStatisGroup 34 }
--  unisDot11APUserSecAuthStatisCMTable    ::= { unisDot11APStatisGroup 35 }
--  unisDot11APUserInfoStatis2CMTable      ::= { unisDot11APStatisGroup 36 }

--  AP Event Notification
--  DEFINED AS " The group to provide AP management notification."
unisDot11APMtNotifyGroup OBJECT IDENTIFIER ::= { unisDot11APMT 3 }

-- *****************************************************************************
-- *  unisDot11APObjectStatusTable Definition
-- *****************************************************************************
unisDot11APObjectStatusTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APObjectStatusEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the general information about APs in
        different status."
    ::= { unisDot11APObjectGroup 1 }

unisDot11APObjectStatusEntry OBJECT-TYPE
    SYNTAX      UnisDot11APObjectStatusEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the general information of an AP."
    INDEX
        {
            unisDot11APID
        }
    ::= { unisDot11APObjectStatusTable 1 }

UnisDot11APObjectStatusEntry ::= SEQUENCE
    {
        unisDot11APID                  UnisDot11ObjectIDType,
        unisDot11APIPAddress           IpAddress,
        unisDot11APMacAddress          MacAddress,
        unisDot11APOperationStatus     INTEGER,
        unisDot11APTemplateNameOfAP    OCTET STRING,
        unisDot11APReset               TruthValue,
        unisDot11APCpuUsage            Integer32,
        unisDot11APConnectionType      INTEGER,
        unisDot11APLastImgDownloadTime DateAndTime,
        unisDot11APIPv6Address         OCTET STRING,
        unisDot11APLastRegisterTime    DateAndTime,
        unisDot11APResetCM             INTEGER,
        unisDot11APIPv6PrefixLen       Integer32,
        unisDot11APFactoryDataResetCM  INTEGER
    }

unisDot11APID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "To uniquely identify each AP, and relation-ship between unisDot11APID
        and AP device will be static."
    ::= { unisDot11APObjectStatusEntry 1 }

unisDot11APIPAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IP address of an AP."
    ::= { unisDot11APObjectStatusEntry 2 }

unisDot11APMacAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the MAC address of an AP."
    ::= { unisDot11APObjectStatusEntry 3 }

unisDot11APOperationStatus OBJECT-TYPE
    SYNTAX      INTEGER
        {
            join(1),
            joinConfirm(2),
            download(3),
            config(4),
            run(5)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents operational status of AP.
        The following values are supported:
        join         - AP is joining to AC.
        joinConfirm  - AC confirm whether permit AP to join.
        download     - AP is downloading software from AC.
        config       - AP and AC exchange configuration before AP
        - provide WLAN service.
        run          - The WLAN service is ready."
    ::= { unisDot11APObjectStatusEntry 4 }

unisDot11APTemplateNameOfAP OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the name of current AP template configured for AP."
    ::= { unisDot11APObjectStatusEntry 5 }

unisDot11APReset OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When read the value from the node
        2: Represents the AP cannot be reset.
        1: Represents the AP can be reset.
        When write the value to the node
        1: Represents resetting the AP.  Other values are not supported"
    ::= { unisDot11APObjectStatusEntry 6 }

unisDot11APCpuUsage OBJECT-TYPE
    SYNTAX      Integer32(0..100)
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current CPU usage for AP."
    ::= { unisDot11APObjectStatusEntry 7 }

unisDot11APConnectionType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            master(1),
            slave(2),
            notAvailable(3)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current connection type."
    ::= { unisDot11APObjectStatusEntry 8 }

unisDot11APLastImgDownloadTime OBJECT-TYPE
    SYNTAX      DateAndTime
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the time at which the device last downloaded image."
    ::= { unisDot11APObjectStatusEntry 9 }

unisDot11APIPv6Address OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IPv6 address of AP."
    ::= { unisDot11APObjectStatusEntry 10 }

unisDot11APLastRegisterTime OBJECT-TYPE
    SYNTAX      DateAndTime
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the time at which the device last registered with AC."
    ::= { unisDot11APObjectStatusEntry 11 }

unisDot11APResetCM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            normal(0),
            restart(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When reading the value from the node
        normal  - Represents the AP cannot be reset.
        restart - Represents the AP can be reset.
        When writing the value to the node
        restart - Represents resetting the AP.  Other values are not supported."
    ::= { unisDot11APObjectStatusEntry 12 }

unisDot11APIPv6PrefixLen OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the prefix length of an AP IPv6 address."
    ::= { unisDot11APObjectStatusEntry 13 }

unisDot11APFactoryDataResetCM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            normal(0),
            restart(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When reading the value from the node
        normal  - Represents the AP cannot be reset.
        restart - Represents the AP can be reset.
        When writing the value to the node
        restart - Represents resetting the AP.  Other values are not supported."
    ::= { unisDot11APObjectStatusEntry 14 }

-- *****************************************************************************
-- *  End of UnisDot11APObjectStatusTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APObjectTable Definition
-- *****************************************************************************
unisDot11APObjectTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APObjectEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide information for APs in the running status."
    ::= { unisDot11APObjectGroup 2 }

unisDot11APObjectEntry OBJECT-TYPE
    SYNTAX      UnisDot11APObjectEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains information of an AP in run status."
    INDEX
        {
            unisDot11APObjID
        }
    ::= { unisDot11APObjectTable 1 }

UnisDot11APObjectEntry ::= SEQUENCE
    {
        unisDot11APObjID                    UnisDot11ObjectIDType,
        unisDot11CurrAPIPAddress            IpAddress,
        unisDot11CurrAPMacAddress           MacAddress,
        unisDot11CurrACPortIndex            Integer32,
        unisDot11CurrAPMACMode              UnisDot11MACModeType,
        unisDot11CurrAPTemplateName         OCTET STRING,
        unisDot11CurrAPStationAssocCount    Integer32,
        unisDot11CurrAPName                 OCTET STRING,
        unisDot11CurrAPModelName            OCTET STRING,
        unisDot11CurrAPImageName            OCTET STRING,
        unisDot11CurrAPSoftwareVersion      OCTET STRING,
        unisDot11CurrAPIPNetMask            IpAddress,
        unisDot11CurrRadioModeSupport       Integer32,
        unisDot11CurrIfNumber               Integer32,
        unisDot11CurrAPElementID            Integer32,
        unisDot11CurrAPMode                 INTEGER,
        unisDot11CurrAPIPv6Address          OCTET STRING,
        unisDot11CurrAPSSIDNumber           Integer32,
        unisDot11CurrAPManufacturer         OCTET STRING,
        unisDot11CurrAPMemorySize           Integer32,
        unisDot11CurrAPMemSizeInBytes       Integer32,
        unisDot11CurrAPFlashSize            Integer32,
        unisDot11CurrAPFlashSizeInBytes     Integer32,
        unisDot11CurrAPReleasedVersion      OCTET STRING,
        unisDot11CurrRadioModeSupport2      Integer32,
        unisDot11CurrAPCPUTypeCM            OCTET STRING,
        unisDot11CurrAPMemoryTypeCM         OCTET STRING,
        unisDot11CurrAPBSSIDNumberCM        Integer32,
        unisDot11CurrAPIPv6PrefixLen        Integer32
    }

unisDot11APObjID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "To uniquely identify each AP, and relation-ship between unisDot11APObjID
        and AP device will be static."
    ::= { unisDot11APObjectEntry 1 }

unisDot11CurrAPIPAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IP address of an AP."
    ::= { unisDot11APObjectEntry 2 }

unisDot11CurrAPMacAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the MAC address of an AP."
    ::= { unisDot11APObjectEntry 3 }

unisDot11CurrACPortIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the port on the AC, by which the traffic of this AP comes
        through.  NMS could refer it to access information kept in the
        MIB-2."
    ::= { unisDot11APObjectEntry 4 }

unisDot11CurrAPMACMode OBJECT-TYPE
    SYNTAX      UnisDot11MACModeType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents what MAC mode defined in the CAPWAP is applied.
        For fat AP, the value will be fatap."
    ::= { unisDot11APObjectEntry 5 }

unisDot11CurrAPTemplateName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the name of current AP template."
    ::= { unisDot11APObjectEntry 6 }

unisDot11CurrAPStationAssocCount OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of stations which are associating
        to AP."
    ::= { unisDot11APObjectEntry 7 }

unisDot11CurrAPName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the name of AP."
    ::= { unisDot11APObjectEntry 8 }

unisDot11CurrAPModelName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents index of WTP model,with it to get AP model information."
    ::= { unisDot11APObjectEntry 9 }

unisDot11CurrAPImageName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the image file name of AP."
    ::= { unisDot11APObjectEntry 10 }

unisDot11CurrAPSoftwareVersion OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the software version of AP."
    ::= { unisDot11APObjectEntry 11 }

unisDot11CurrAPIPNetMask OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IP netmask of AP."
    ::= { unisDot11APObjectEntry 12 }

unisDot11CurrRadioModeSupport OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents which radio type supported by the AP.
        The WLAN system support the following possible radio type.
        dot11a(1),
        dot11b(2),
        dot11g(4),
        dot11n(8),
        dot11an(16),
        dot11gn(32),
        dot11ac(64),
        dot11gac(128)
        For a AP,it could support multiple radio types at
        the same time.So the value of object could combine multiple value
        of radio type above.
        For example:
        For one AP which support both b and g mode radio, when getting the value
        from the node, the value is 6(2 + 4)."
    ::= { unisDot11APObjectEntry 13 }

unisDot11CurrIfNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents number of interface of the AP."
    ::= { unisDot11APObjectEntry 14 }

unisDot11CurrAPElementID OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
    "Represents the AP element ID."
    ::= { unisDot11APObjectEntry 15 }

unisDot11CurrAPMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            bridge(1),
            route(2)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the forward mode of the AP."
    ::= { unisDot11APObjectEntry 16 }

unisDot11CurrAPIPv6Address OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IPv6 address of AP."
    ::= { unisDot11APObjectEntry 17 }

unisDot11CurrAPSSIDNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of SSID configured on AP."
    ::= { unisDot11APObjectEntry 18 }

unisDot11CurrAPManufacturer OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "By the 'SMI Network Management Private Enterprise Codes'
        assigned by the IANA, NMS could know which vendor manufactures
        the AP."
    ::= { unisDot11APObjectEntry 19 }

unisDot11CurrAPMemorySize OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP memory."
    ::= { unisDot11APObjectEntry 20 }

unisDot11CurrAPMemSizeInBytes OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP memory."
    ::= { unisDot11APObjectEntry 21 }

unisDot11CurrAPFlashSize OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "Kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP flash."
    ::= { unisDot11APObjectEntry 22 }

unisDot11CurrAPFlashSizeInBytes OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the size of AP flash."
    ::= { unisDot11APObjectEntry 23 }

unisDot11CurrAPReleasedVersion OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the released version of AP."
    ::= { unisDot11APObjectEntry 24 }

unisDot11CurrRadioModeSupport2 OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents which radio type supported by the AP.
        The WLAN system support the following possible radio type.
        dot11a(1),
        dot11b(2),
        dot11g(4),
        dot11an(8),
        dot11gn(16),
        dot11gac(32),
        dot11ac(64)
        For a AP,it could support multiple radio types at
        the same time.So the value of object could combine multiple value
        of radio type above.
        For example:
        For one AP which support both b and g mode radio, when getting the value
        from the node, the value is 6(2 + 4)."
    ::= { unisDot11APObjectEntry 25 }

unisDot11CurrAPCPUTypeCM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CPU type of AP."
    ::= { unisDot11APObjectEntry 26 }

unisDot11CurrAPMemoryTypeCM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the memory card type of AP."
    ::= { unisDot11APObjectEntry 27 }

unisDot11CurrAPBSSIDNumberCM OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of BSSID configured on AP."
    ::= { unisDot11APObjectEntry 28 }

unisDot11CurrAPIPv6PrefixLen OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the prefix length of an AP IPv6 address."
    ::= { unisDot11APObjectEntry 29 }
-- *****************************************************************************
-- *  End of unisDot11APObjectTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APRadioTable Definition
-- *****************************************************************************
unisDot11APRadioTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APRadioEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will describe the radio information of AP.  The AP here will
        be in running status."
    ::= { unisDot11APObjectGroup 3 }

unisDot11APRadioEntry OBJECT-TYPE
    SYNTAX      UnisDot11APRadioEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the information of each radio of a specific AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID
        }
    ::= { unisDot11APRadioTable 1 }

UnisDot11APRadioEntry ::= SEQUENCE
    {
        unisDot11CurAPID            OCTET STRING,
        unisDot11RadioID            Integer32,
        unisDot11AdminStatus        TruthValue,
        unisDot11OperStatus         TruthValue,
        unisDot11Channel            UnisDot11ChannelScopeType,
        unisDot11TxPowerLevel       UnisDot11TxPwrLevelScopeType,
        unisDot11APRadioIfIndex     Integer32,
        unisDot11AntennaGain        Integer32,
        unisDot11MaxBandwidth       Integer32,
        unisDot11ResourceUseRatio   Integer32,
        unisDot11RadioModeSupport   Unsigned32,
        unisDot11TxPowerLevel2      Integer32,
        unisDot11PowerMgmtStatus    TruthValue,
        unisDot11ChannelSwitchTimes Counter32,
        unisDot11AntennaType        OCTET STRING,
        unisDot11DiversitySelectionRx     TruthValue,
        unisDot11MaxTxPwrLvl              OCTET STRING,
        unisDot11PwrAttRange              Integer32,
        unisDot11AvgRxSignalStrength      Integer32,
        unisDot11HighestRxSignalStrength  Integer32,
        unisDot11LowestRxSignalStrength   Integer32,
        unisDot11RadioIfUpdownTimes       Counter32,
        unisDot11RadioIfLastChange        TimeTicks,
        unisDot11RadioModeSupport2        Unsigned32,
        unisDot11OperStatusCM             INTEGER,
        unisDot11AirPrimChnlBusy          Integer32,
        unisDot11AirPrimChnlTxBusy        Integer32,
        unisDot11AirPrimChnlRxBusy        Integer32,
        unisDot11AirExtChnlBusy           Integer32
    }

unisDot11CurAPID OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..64))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "To uniquely identify a AP in running status."
    ::= { unisDot11APRadioEntry 1 }

unisDot11RadioID OBJECT-TYPE
    SYNTAX      Integer32(0..2147483647)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents each radio."
    ::= { unisDot11APRadioEntry 2 }

unisDot11AdminStatus OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the administrator status of radio."
    ::= { unisDot11APRadioEntry 3 }

unisDot11OperStatus OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the operational status of radio."
    ::= { unisDot11APRadioEntry 4 }

unisDot11Channel OBJECT-TYPE
    SYNTAX      UnisDot11ChannelScopeType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current channel allocation for radio."
    ::= { unisDot11APRadioEntry 5 }

unisDot11TxPowerLevel OBJECT-TYPE
    SYNTAX      UnisDot11TxPwrLevelScopeType
    UNITS       "dbm"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current transmit power level for radio."
    ::= { unisDot11APRadioEntry 6 }

unisDot11APRadioIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the interface index for the radio."
    ::= { unisDot11APRadioEntry 7 }

unisDot11AntennaGain OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "dBi"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the current gain for antenna."
    ::= { unisDot11APRadioEntry 8 }

unisDot11MaxBandwidth OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "Mbps"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the maximum bandwidth for the radio."
    ::= { unisDot11APRadioEntry 9 }

unisDot11ResourceUseRatio OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ratio of radio resource usage."
    ::= { unisDot11APRadioEntry 10 }

unisDot11RadioModeSupport OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents radio type supported by the radio.
        The WLAN system supports the following possible radio type:
        dot11a(1),
        dot11b(2),
        dot11g(4),
        dot11gn(16),
        dot11an(32),
        dot11ac(64),
        dot11gac(128)
        For the radio, it could support multiple radio types at
        the same time.  So the value of this object could combine multiple
        values of radio type above.
        For example:
        For one radio which supports both dot11b and dot11g mode, when get
        value from the object, the value is 6(2 + 4)."
    ::= { unisDot11APRadioEntry 11 }

unisDot11TxPowerLevel2 OBJECT-TYPE
    SYNTAX      Integer32(1..8)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The TxPowerLevel N currently being used to transmit data."
    ::= { unisDot11APRadioEntry 12 }

unisDot11PowerMgmtStatus OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents status of power management of the radio."
    ::= { unisDot11APRadioEntry 13 }

unisDot11ChannelSwitchTimes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the channel switch times."
    ::= { unisDot11APRadioEntry 14 }

unisDot11AntennaType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents type of the antenna which radio used."
    ::= { unisDot11APRadioEntry 15 }

unisDot11DiversitySelectionRx OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the diversity selection received."
    ::= { unisDot11APRadioEntry 16 }

unisDot11MaxTxPwrLvl OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the maximum transmit power."
    ::= { unisDot11APRadioEntry 17 }

unisDot11PwrAttRange OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the range of power attenuation."
    ::= { unisDot11APRadioEntry 18 }

unisDot11AvgRxSignalStrength OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "dBm"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the average received signal strength."
    ::= { unisDot11APRadioEntry 19 }

unisDot11HighestRxSignalStrength OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "dBm"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the highest received signal strength."
    ::= { unisDot11APRadioEntry 20 }

unisDot11LowestRxSignalStrength OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "dBm"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the lowest received signal strength."
    ::= { unisDot11APRadioEntry 21 }

unisDot11RadioIfUpdownTimes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the up/down times on radio interface."
    ::= { unisDot11APRadioEntry 22 }

unisDot11RadioIfLastChange OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents time at last change that occurred on radio interface."
    ::= { unisDot11APRadioEntry 23 }

unisDot11RadioModeSupport2 OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents radio type supported by the radio.
        The WLAN system supports the following possible radio type:
        dot11a(1),
        dot11b(2),
        dot11g(4),
        dot11an(8),
        dot11gn(16),
        dot11gac(32),
        dot11ac(64)
        For the radio, it could support multiple radio types at
        the same time.  So the value of this object could combine multiple
        values of radio type above.
        For example:
        For one radio which supports both dot11b and dot11g mode, when get
        value from the object, the value is 6(2 + 4)."
    ::= { unisDot11APRadioEntry 24 }

unisDot11OperStatusCM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            up(1),
            down(2),
            testing(3),
            admindown(4)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the operational status of radio."
    ::= { unisDot11APRadioEntry 25 }

unisDot11AirPrimChnlBusy OBJECT-TYPE
    SYNTAX      Integer32(0..100 | 255)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
    "Represents air interface utilization on the primary channel.
    The value 255 represents an invalid value."
    ::= { unisDot11APRadioEntry 26 }

unisDot11AirPrimChnlTxBusy OBJECT-TYPE
    SYNTAX      Integer32(0..100 | 255)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
    "Represents air interface utilization for signal sending on the
    primary channel.
    The value 255 represents an invalid value."
    ::= { unisDot11APRadioEntry 27 }

unisDot11AirPrimChnlRxBusy OBJECT-TYPE
    SYNTAX      Integer32(0..100 | 255)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
    "Represents air interface utilization for signal receiving on the
    primary channel.
    The value 255 represents an invalid value."
    ::= { unisDot11APRadioEntry 28 }

unisDot11AirExtChnlBusy OBJECT-TYPE
    SYNTAX      Integer32(0..100 | 255)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
    "Represents air interface utilization on the secondary channel.
    The value 255 represents an invalid value."
    ::= { unisDot11APRadioEntry 29 }
-- *****************************************************************************
-- *  End of unisDot11APRadioTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APBSSTable Definition
-- *****************************************************************************
unisDot11APBSSTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APBSSEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "After AP connect to AC and get AP template configuration,
        it will create BSS data structure for each radio.
        The table will describe BSS information of AP and service
        policy as per BSS."
    ::= { unisDot11APObjectGroup 4 }

unisDot11APBSSEntry OBJECT-TYPE
    SYNTAX      UnisDot11APBSSEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains information of each BSS for specific radio."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID,
            unisDot11WlanID
        }
    ::= { unisDot11APBSSTable 1 }

UnisDot11APBSSEntry ::= SEQUENCE
    {
        unisDot11WlanID             Integer32,
        unisDot11BSSID              MacAddress,
        unisDot11CurrSvcPolicyID    UnisDot11ServicePolicyIDType,
        unisDot11SSID               OCTET STRING,
        unisDot11CurrSSIDResourceUseRatio             Integer32,
        unisDot11APEssVlanId                          Integer32
    }

unisDot11WlanID OBJECT-TYPE
    SYNTAX      Integer32(0..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents ID of a specific ESS."
    ::= { unisDot11APBSSEntry 1 }

unisDot11BSSID OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "As MAC Address format, it is to identify BSS."
    ::= { unisDot11APBSSEntry 2 }

unisDot11CurrSvcPolicyID OBJECT-TYPE
    SYNTAX      UnisDot11ServicePolicyIDType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ID of each service policy used by the AP."
    ::= { unisDot11APBSSEntry 3 }

unisDot11SSID OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the SSID corresponding to this BSS."
    ::= { unisDot11APBSSEntry 4 }

unisDot11CurrSSIDResourceUseRatio OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ratio of resource usage of curr SSID"
    ::= { unisDot11APBSSEntry 5 }

unisDot11APEssVlanId OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the VlanID of the interface ESS
        corresponding to this BSS."
    ::= { unisDot11APBSSEntry 6 }
-- *****************************************************************************
-- *  End of unisDot11APBSSTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APModelTable Definition
-- *****************************************************************************
unisDot11APModelTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APModelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table defines the capability information for a specific
        kind of AP."
    ::= { unisDot11APObjectGroup 5 }

unisDot11APModelEntry OBJECT-TYPE
    SYNTAX      UnisDot11APModelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains capability information for a specific kind
        of AP."
    INDEX
        {
            IMPLIED unisDot11APModelAlias
        }
    ::= { unisDot11APModelTable 1 }

UnisDot11APModelEntry ::= SEQUENCE
    {
        unisDot11APModelAlias         OCTET STRING,
        unisDot11APModelName          OCTET STRING,
        unisDot11RadioNumSupport      UnisDot11RadioScopeType,
        unisDot11StationNumSupport    Integer32,
        unisDot11MACModeSupport       UnisDot11MACModeType,
        unisDot11APManufacturer       OCTET STRING,
        unisDot11APCPUType            OCTET STRING,
        unisDot11APCPUClockSpeed      Unsigned32,
        unisDot11APMemoryType         OCTET STRING,
        unisDot11APMemorySize         Unsigned32,
        unisDot11APFlashType          OCTET STRING,
        unisDot11APFlashSize          Unsigned32,
        unisDot11APMemSize            Gauge32,
        unisDot11APFlashSizeInBytes   Unsigned32,
        unisDot11WsmAPLicenseType     INTEGER
    }

unisDot11APModelAlias OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..127))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents alias of AP model name."
    ::= { unisDot11APModelEntry 1 }

unisDot11APModelName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents AP model name(like WA2100)."
    ::= { unisDot11APModelEntry 2 }

unisDot11RadioNumSupport OBJECT-TYPE
    SYNTAX      UnisDot11RadioScopeType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how many radios the specific AP model
        could support."
    ::= { unisDot11APModelEntry 3 }

unisDot11StationNumSupport OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how many station could be supported by a specific
        AP model."
    ::= { unisDot11APModelEntry 4 }

unisDot11MACModeSupport OBJECT-TYPE
    SYNTAX      UnisDot11MACModeType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the MAC mode type could be supported by a specific
        AP model."
    DEFVAL      { split }
    ::= { unisDot11APModelEntry 5 }

unisDot11APManufacturer OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "By the 'SMI Network Management Private Enterprise Codes'
        assigned by the IANA, NMS could know which vendor manufactures
        the AP."
    ::= { unisDot11APModelEntry 6 }

unisDot11APCPUType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CPU type of AP"
    ::= { unisDot11APModelEntry 7 }

unisDot11APCPUClockSpeed OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "Hz"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the clock speed of CPU."
    ::= { unisDot11APModelEntry 8 }

unisDot11APMemoryType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the memory card type of AP"
    ::= { unisDot11APModelEntry 9 }

unisDot11APMemorySize OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP memory card."
    ::= { unisDot11APModelEntry 20 }

unisDot11APFlashType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the flash card type of AP"
    ::= { unisDot11APModelEntry 11 }

unisDot11APFlashSize OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP flash card."
    ::= { unisDot11APModelEntry 12 }

unisDot11APMemSize OBJECT-TYPE
    SYNTAX      Gauge32
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of AP memory card."
    ::= { unisDot11APModelEntry 13 }

unisDot11APFlashSizeInBytes OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the size of AP flash card in bytes."
    ::= { unisDot11APModelEntry 14 }

unisDot11WsmAPLicenseType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            normal(1),
            wtu(2),
            wt(3),
            iot(4),
            other(5)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents AP license type for iMc WSM."
    ::= { unisDot11APModelEntry 15 }


-- *****************************************************************************
-- *  End of unisDot11APModelTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APIfTable Definition
-- *****************************************************************************
unisDot11APIfTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table represents the AP interface information."
    ::= { unisDot11APObjectGroup 6 }

unisDot11APIfEntry OBJECT-TYPE
    SYNTAX      UnisDot11APIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide data for the interface of AP."
    INDEX
        {
            unisDot11APObjID,
            unisDot11APIfIndex
        }
    ::= { unisDot11APIfTable 1 }

UnisDot11APIfEntry ::= SEQUENCE
    {
        unisDot11APIfIndex         Integer32,
        unisDot11APIfDescr         OCTET STRING,
        unisDot11APIfType          Integer32,
        unisDot11APIfMtu           Integer32,
        unisDot11APIfPHYAddress    OCTET STRING,
        unisDot11APIfSpeed         Integer32,
        unisDot11APIfInDataRate    Integer32,
        unisDot11APIfOutDataRate   Integer32,
        unisDot11APIfSpeedKbps     Gauge32,
        unisDot11APIfTypeCM        Integer32
    }

unisDot11APIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the index for an interface."
    ::= { unisDot11APIfEntry 1 }

unisDot11APIfDescr OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the interface description for an interface."
    ::= { unisDot11APIfEntry 2 }

unisDot11APIfType OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the interface type for an interface."
    ::= { unisDot11APIfEntry 3 }

unisDot11APIfMtu OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents size of the largest datagram which can
        be sent/received on the interface, specified in octets."
    ::= { unisDot11APIfEntry 4 }

unisDot11APIfPHYAddress OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the PHY address of interface."
    ::= { unisDot11APIfEntry 5 }

unisDot11APIfSpeed OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "Mbps"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents maximum bandwidth of this interface."
    ::= { unisDot11APIfEntry 6 }

unisDot11APIfInDataRate OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "Kbps"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the average input data rate of this interface in
        latest 300 seconds."
    ::= { unisDot11APIfEntry 7 }

unisDot11APIfOutDataRate OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "Kbps"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the average output data rate of this interface in
        latest 300 seconds."
    ::= { unisDot11APIfEntry 8 }

unisDot11APIfSpeedKbps OBJECT-TYPE
    SYNTAX      Gauge32
    UNITS       "kbps"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents maximum bandwidth of this interface."
    ::= { unisDot11APIfEntry 9 }

unisDot11APIfTypeCM OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the interface type."
    ::= { unisDot11APIfEntry 10 }

-- *****************************************************************************
-- *  End of unisDot11APIfTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APSSIDObjectTable Definition
-- *****************************************************************************
unisDot11APSSIDObjectTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APSSIDObjectEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table provides BSSID number configuration information
         based on SSID."
    ::= { unisDot11APObjectGroup 7 }

unisDot11APSSIDObjectEntry OBJECT-TYPE
    SYNTAX      UnisDot11APSSIDObjectEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides BSSID number configuration information
         of a SSID."
    INDEX
        {
            unisDot11APConfigSPID
        }
    ::= { unisDot11APSSIDObjectTable 1 }

UnisDot11APSSIDObjectEntry ::= SEQUENCE
    {
        unisDot11APConfigSPID              UnisDot11ServicePolicyIDType,
        unisDot11APConfigSSIDName          UnisDot11SSIDStringType,
        unisDot11APConfigBSSIDNum          Integer32,
        unisDot11APConfigPortalStaNum      Integer32,
        unisDot11APAssocStaNum             Integer32
    }

unisDot11APConfigSPID OBJECT-TYPE
    SYNTAX      UnisDot11ServicePolicyIDType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the service policy ID."
    ::= { unisDot11APSSIDObjectEntry 1 }

unisDot11APConfigSSIDName OBJECT-TYPE
    SYNTAX      UnisDot11SSIDStringType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the SSID name of this service policy."
    ::= { unisDot11APSSIDObjectEntry 2 }

unisDot11APConfigBSSIDNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of BSSID that be configured
         with current SSID."
    ::= { unisDot11APSSIDObjectEntry 3 }

unisDot11APConfigPortalStaNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of associated protal
        stations with current SSID."
    ::= { unisDot11APSSIDObjectEntry 4 }

unisDot11APAssocStaNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of associated stations with current SSID."
    ::= { unisDot11APSSIDObjectEntry 5 }

-- *****************************************************************************
-- *  End of unisDot11APSSIDObjectTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APSysInfoTable Definition
-- *****************************************************************************
unisDot11APSysInfoTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APSysInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the system information of the AP."
    ::= { unisDot11APObjectGroup 8 }

unisDot11APSysInfoEntry OBJECT-TYPE
    SYNTAX      UnisDot11APSysInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides system information of an AP."
    INDEX
        {
            unisDot11APElementIndex
        }
    ::= { unisDot11APSysInfoTable 1 }

UnisDot11APSysInfoEntry ::= SEQUENCE
    {
        unisDot11APSysUpTime           TimeTicks,
        unisDot11APCPURTUsage          Integer32,
        unisDot11APCPUAvgUsage         Integer32,
        unisDot11APMemRTUsage          Integer32,
        unisDot11APMemAvgUsage         Integer32,
        unisDot11APIPAddressGateway    IpAddress,
        unisDot11APACAssociateStatus   INTEGER,
        unisDot11APManuBuildInfo       OCTET STRING,
        unisDot11APFlashFreeSize       Unsigned32,
        unisDot11APTemperature         Integer32
    }

unisDot11APSysUpTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how long AP has been powered on."
    ::= { unisDot11APSysInfoEntry 1 }

unisDot11APCPURTUsage OBJECT-TYPE
    SYNTAX      Integer32(0..100)
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CPU real time usage for AP."
    ::= { unisDot11APSysInfoEntry 2 }

unisDot11APCPUAvgUsage OBJECT-TYPE
    SYNTAX      Integer32(0..100)
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CPU average usage for AP."
    ::= { unisDot11APSysInfoEntry 3 }

unisDot11APMemRTUsage OBJECT-TYPE
    SYNTAX      Integer32(0..100)
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the memory real time usage for AP."
    ::= { unisDot11APSysInfoEntry 4 }

unisDot11APMemAvgUsage OBJECT-TYPE
    SYNTAX      Integer32(0..100)
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the average memory usage for AP."
    ::= { unisDot11APSysInfoEntry 5 }

unisDot11APIPAddressGateway OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IP address gateway for AP."
    ::= { unisDot11APSysInfoEntry 6 }

unisDot11APACAssociateStatus OBJECT-TYPE
    SYNTAX      INTEGER
        {
            associated(1),
            deassociated(2),
            downloadingImage(3)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents associate status of AP and AC."
    ::= { unisDot11APSysInfoEntry 7 }

unisDot11APManuBuildInfo OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..255))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the device version information for AP."
    ::= { unisDot11APSysInfoEntry 8 }

unisDot11APFlashFreeSize OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the free size of AP flash card."
    ::= { unisDot11APSysInfoEntry 9 }

unisDot11APTemperature OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the device temperature information for AP."
    ::= { unisDot11APSysInfoEntry 10 }

