-- *****************************************************************************
unisDot11APPacketMCSRateStatis2Table  OBJECT-TYPE
    SYNTAX        SEQUENCE OF UnisDot11APPacketMCSRateStatis2Entry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "This table provides packet statistics based on MCS rate."
    ::= { unisDot11APStatisGroup 34 }

unisDot11APPacketMCSRateStatis2Entry  OBJECT-TYPE
    SYNTAX        UnisDot11APPacketMCSRateStatis2Entry
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "Each entry provides packet statistics based on MCS rate for each radio
        of a specific AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID,
            unisDot11APPacketMCS2Rate
        }
    ::= { unisDot11APPacketMCSRateStatis2Table 1 }

UnisDot11APPacketMCSRateStatis2Entry  ::=SEQUENCE
    {
        unisDot11APPacketMCS2Rate          Integer32,
        unisDot11APRXPacketMCSRate2Count   Counter64,
        unisDot11APTXPacketMCSRate2Count   Counter64
    }

unisDot11APPacketMCS2Rate    OBJECT-TYPE
    SYNTAX        Integer32 (1..2000000000)
    MAX-ACCESS    not-accessible
    STATUS        current
    DESCRIPTION
        "Represents data transmission rate(Tenfold as actual rate)."
    ::= { unisDot11APPacketMCSRateStatis2Entry 1 }

unisDot11APRXPacketMCSRate2Count    OBJECT-TYPE
    SYNTAX        Counter64
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION
        "Represents the count of packets received based on data transmission rate."
    ::= { unisDot11APPacketMCSRateStatis2Entry 2 }

unisDot11APTXPacketMCSRate2Count    OBJECT-TYPE
    SYNTAX        Counter64
    MAX-ACCESS    read-only
    STATUS        current
    DESCRIPTION
        "Represents the count of packets transmitted base on data transmission rate."
    ::= { unisDot11APPacketMCSRateStatis2Entry 3 }

-- *****************************************************************************
-- *  End of unisDot11APPacketMcsRateStatis2Table Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APUserSecAuthStatisCMTable Definition
-- *****************************************************************************
unisDot11APUserSecAuthStatisCMTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APUserSecAuthStatisCMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the user authentication statistics."
    ::= { unisDot11APStatisGroup 35 }

unisDot11APUserSecAuthStatisCMEntry OBJECT-TYPE
    SYNTAX      UnisDot11APUserSecAuthStatisCMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table provides the user authentication statistics
        of AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID,
            unisDot11WlanID
       }
    ::= { unisDot11APUserSecAuthStatisCMTable 1 }

UnisDot11APUserSecAuthStatisCMEntry ::= SEQUENCE
    {
        unisDot11APUserConnFailCntCM              Counter32,
        unisDot11APUserAuthReqCntCM               Counter32,
        unisDot11APUserAuthSuccCntCM              Counter32,
        unisDot11APUserAuthFailCntCM              Counter32,
        unisDot11AllUserOnlineTimeCM              TimeTicks
    }

unisDot11APUserConnFailCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the failed connection count of users with this AP."
    ::= { unisDot11APUserSecAuthStatisCMEntry 1 }

unisDot11APUserAuthReqCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of user authentication requests with this AP."
    ::= { unisDot11APUserSecAuthStatisCMEntry 2 }

unisDot11APUserAuthSuccCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of successful user authentications with this AP."
    ::= { unisDot11APUserSecAuthStatisCMEntry 3 }

unisDot11APUserAuthFailCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of failed user authentications with this AP."
    ::= { unisDot11APUserSecAuthStatisCMEntry 4 }

unisDot11AllUserOnlineTimeCM OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the online time of all users with this AP."
    ::= { unisDot11APUserSecAuthStatisCMEntry 5 }

-- *****************************************************************************
-- *  End of unisDot11APUserSecAuthStatisCMTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APUserInfoStatis2CMTable Definition
-- *****************************************************************************
unisDot11APUserInfoStatis2CMTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APUserInfoStatis2CMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the authentication user information statistic
        of this AP."
    ::= { unisDot11APStatisGroup 36 }

unisDot11APUserInfoStatis2CMEntry OBJECT-TYPE
    SYNTAX      UnisDot11APUserInfoStatis2CMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the authentication user information
        statistic of this AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11APUserMacAddr2CM
        }
    ::= { unisDot11APUserInfoStatis2CMTable 1 }

UnisDot11APUserInfoStatis2CMEntry ::= SEQUENCE
    {
        unisDot11APUserMacAddr2CM                  MacAddress,
        unisDot11APUserIpAddr2CM                   IpAddress,
        unisDot11APUserLoginName2CM                OCTET STRING,
        unisDot11APUserLoginTime2CM                OCTET STRING,
        unisDot11APUserOnlineTime2CM               TimeTicks,
        unisDot11APUserAuthType2CM                 INTEGER,
        unisDot11APUserTxPacketCnt2CM              Counter32,
        unisDot11APUserTxBytes2CM                  Counter64,
        unisDot11APUserRxPacketCnt2CM              Counter32,
        unisDot11APUserRxBytes2CM                  Counter64,
        unisDot11APUserIPv6Addr2CM                 OCTET STRING,
        unisDot11APUserMac2CM                      MacAddress,
        unisDot11APUserInCirValueCM                Counter32,
        unisDot11APUserOutCirValueCM               Counter32
    }

unisDot11APUserMacAddr2CM OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the mac address of authentication user logging to this AP."
    ::= { unisDot11APUserInfoStatis2CMEntry 1 }

unisDot11APUserIpAddr2CM OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ip address of authentication user logging to this AP."
    ::= { unisDot11APUserInfoStatis2CMEntry 2 }

unisDot11APUserLoginName2CM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the login name of authentication user logging to this AP."
    ::= { unisDot11APUserInfoStatis2CMEntry 3 }

unisDot11APUserLoginTime2CM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the login time of authentication user with this AP."
    ::= { unisDot11APUserInfoStatis2CMEntry 4 }

unisDot11APUserOnlineTime2CM OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how long authentication user has been online."
    ::= { unisDot11APUserInfoStatis2CMEntry 5 }

unisDot11APUserAuthType2CM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            authFree(1),
            associateAuth(2),
            portalAuth(3),
            autoAuth(4)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the authentication type of user with this AP.
        authFree       - There is no need others authentiaction, user will
        surf internet after association.
        associateAuth  - Include WEP PSK authentication.
        portalAuth     - The authentication lunched by portal pop-up program.
        autoAuth       - 802.1X authentication."
    ::= { unisDot11APUserInfoStatis2CMEntry 6 }

unisDot11APUserTxPacketCnt2CM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total count of packets sent to online users."
    ::= { unisDot11APUserInfoStatis2CMEntry 7 }

unisDot11APUserTxBytes2CM OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total bytes sent to online users."
    ::= { unisDot11APUserInfoStatis2CMEntry 8 }

unisDot11APUserRxPacketCnt2CM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total count of packets received from online users."
    ::= { unisDot11APUserInfoStatis2CMEntry 9 }

unisDot11APUserRxBytes2CM OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total bytes received from online users."
    ::= { unisDot11APUserInfoStatis2CMEntry 10 }

unisDot11APUserIPv6Addr2CM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IPv6 address of online users."
    ::= { unisDot11APUserInfoStatis2CMEntry 11 }

unisDot11APUserMac2CM OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the mac address of authentication user logging to this AP."
    ::= { unisDot11APUserInfoStatis2CMEntry 12 }

unisDot11APUserInCirValueCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CIR of inbound direction of this user."
    ::= { unisDot11APUserInfoStatis2CMEntry 13 }

unisDot11APUserOutCirValueCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CIR of outbound direction of this user."
    ::= { unisDot11APUserInfoStatis2CMEntry 14 }

-- *****************************************************************************
-- *  End of unisDot11APUserInfoStatis2CMTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  AP Management Notifications Definition
-- *****************************************************************************
-- AP Management Notification

        unisDot11APMtTraps OBJECT IDENTIFIER
    ::= { unisDot11APMtNotifyGroup 0 }

unisDot11APMtWorkModeChgTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID,
            unisDot11APChgWorkMode,
            unisDot11APMtTrapAPMacAddress
        }
    STATUS      current
    DESCRIPTION
        "The notification will be sent when AP changes the work mode, and
         unisDot11APWorkMode suggests which work mode will be used by AP."
    ::= { unisDot11APMtTraps 1 }

unisDot11APMtCfgErrorTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID,
            unisDot11RadioID,
            unisDot11APMtTrapCfgErrReason
        }
    STATUS      current
    DESCRIPTION
        "The notification will represent errors caused by the
        configuration operation of AP."
    ::= { unisDot11APMtTraps 2 }

unisDot11APMtRadioFailTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID,
            unisDot11RadioID,
            unisDot11APMtTrapRadioFailReason
        }
    STATUS      current
    DESCRIPTION
        "The notification will notify which the operational status
        of radio becomes down."
    ::= { unisDot11APMtTraps 3 }

unisDot11APMtRadioFailRecoverTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID,
            unisDot11RadioID
        }
    STATUS      current
    DESCRIPTION
        "The notification will notify the operational status of which radio
        becomes up again."
    ::= { unisDot11APMtTraps 4 }

unisDot11APMtRdoChanlChgTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID,
            unisDot11RadioID,
            unisDot11APChannelChgMode,
            unisDot11APMtTrapOldChannel,
            unisDot11APMtTrapNewChannel,
            unisDot11APMtChanlChgCount,
            unisDot11APMtTrapAPMacAddress
        }
    STATUS      current
    DESCRIPTION
        "The notification will represent which radio changes the channel."
    ::= { unisDot11APMtTraps 5 }

unisDot11APMtTimeSynFail NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11APID
        }
    STATUS      current
    DESCRIPTION
        "The notification will be sent when AC and AP failed to
        synchronize their time."
