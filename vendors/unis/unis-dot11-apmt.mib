    STATUS      current
    DESCRIPTION
        "Represents the total number of current associated stations which have
        passed portal or 1x authentication with this BSS."
    ::= { unisDot11BSSAssocStatisEntry 8 }

-- *****************************************************************************
-- *  End of unisDot11BSSAssocStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APLinkStatisTable Definition
-- *****************************************************************************
unisDot11APLinkStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APLinkStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the link statistic for AP."
    ::= { unisDot11APStatisGroup 7 }

unisDot11APLinkStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APLinkStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides the link statistic of the AP."
    INDEX
        {
            unisDot11CurAPID
        }
    ::= { unisDot11APLinkStatisTable 1 }

UnisDot11APLinkStatisEntry ::= SEQUENCE
    {
        unisDot11UpLinkUpDownTimes          Counter32,
        unisDot11DownLinkUpDownTimes        Counter32,
        unisDot11PrivateSrvRxFrameBytes     Counter64,
        unisDot11PrivateSrvTxFrameBytes     Counter64,
        unisDot11APInternetAllRxBytes       Counter64,
        unisDot11APInternetAllTxBytes       Counter64,
        unisDot11APLocalAllRxBytes          Counter64,
        unisDot11APLocalAllTxBytes          Counter64
    }

unisDot11UpLinkUpDownTimes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents up/down times of uplink interface of the AP."
    ::= { unisDot11APLinkStatisEntry 1 }

unisDot11DownLinkUpDownTimes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents up/down times of downlink interface of the AP."
    ::= { unisDot11APLinkStatisEntry 2 }

unisDot11PrivateSrvRxFrameBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Traffic bytes received from private services."
    ::= { unisDot11APLinkStatisEntry 3 }

unisDot11PrivateSrvTxFrameBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Traffic bytes sent to private services."
    ::= { unisDot11APLinkStatisEntry 4 }

unisDot11APInternetAllRxBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Internet traffic bytes received from stations."
    ::= { unisDot11APLinkStatisEntry 5 }

unisDot11APInternetAllTxBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Internet traffic bytes sent to stations."
    ::= { unisDot11APLinkStatisEntry 6 }

unisDot11APLocalAllRxBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Local traffic bytes received from stations."
    ::= { unisDot11APLinkStatisEntry 7 }

unisDot11APLocalAllTxBytes OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Local traffic bytes sent to stations."
    ::= { unisDot11APLinkStatisEntry 8 }
-- *****************************************************************************
-- *  End of unisDot11APLinkStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11RadioAssocStatisTable Definition
-- *****************************************************************************
unisDot11RadioAssocStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11RadioAssocStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the station association statistic for radio."
    ::= { unisDot11APStatisGroup 8 }

unisDot11RadioAssocStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11RadioAssocStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the statistic data of station
        association for radio."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID
        }
    ::= { unisDot11RadioAssocStatisTable 1 }

UnisDot11RadioAssocStatisEntry ::= SEQUENCE
    {
        unisDot11RadioStaAssocSum          Counter32,
        unisDot11RadioStaAssocFailSum      Counter32,
        unisDot11RadioStaReassocSum        Counter32,
        unisDot11RadioStaAssocRejectSum    Counter32,
        unisDot11RadioStaExDeAssocSum      Counter32,
        unisDot11RadioStaCurAssocSum       Integer32
    }

unisDot11RadioStaAssocSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station association
        with this radio."
    ::= { unisDot11RadioAssocStatisEntry 1 }

unisDot11RadioStaAssocFailSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station
        association failure with this radio."
    ::= { unisDot11RadioAssocStatisEntry 2 }

unisDot11RadioStaReassocSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station re-association
        with this radio."
    ::= { unisDot11RadioAssocStatisEntry 3 }

unisDot11RadioStaAssocRejectSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station association rejected
        on account of resource limit with this radio."
    ::= { unisDot11RadioAssocStatisEntry 4 }

unisDot11RadioStaExDeAssocSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of exceptional station de-authentication
        (Without sending a de-authentication to AP) with this radio."
    ::= { unisDot11RadioAssocStatisEntry 5 }

unisDot11RadioStaCurAssocSum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of current associated stations
        with this radio."
    ::= { unisDot11RadioAssocStatisEntry 6 }
-- *****************************************************************************
-- *  End of unisDot11RadioAssocStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11RadioMngFrameStatisTable Definition
-- *****************************************************************************
unisDot11RadioMngFrameStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11RadioMngFrameStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the management frame statistic for this radio."
    ::= { unisDot11APStatisGroup 9 }

unisDot11RadioMngFrameStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11RadioMngFrameStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the management
        frame statistic for this radio."
    INDEX
        {
            unisDot11RadioStatisIndex,
            unisDot11MngFrameType
        }
    ::= { unisDot11RadioMngFrameStatisTable 1 }

UnisDot11RadioMngFrameStatisEntry ::= SEQUENCE
    {
        unisDot11RadioStatisIndex            UnisDot11RadioElementIndex,
        unisDot11MngFrameType                INTEGER,
        unisDot11MngFrameCnt                 Counter32
    }

unisDot11RadioStatisIndex OBJECT-TYPE
    SYNTAX      UnisDot11RadioElementIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents index of radio."
    ::= { unisDot11RadioMngFrameStatisEntry 1 }

unisDot11MngFrameType   OBJECT-TYPE
    SYNTAX      INTEGER
        {
            assocReq(1),
            assocResp(2),
            reassocReq(3),
            reassocResp(4),
            probeReq(5),
            probeResp(6),
            beacon(7),
            atim(8),
            disassociation(9),
            authentication(10),
            deauthentication(11),
            action(12)
        }
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the type of the management frame on this radio."
    ::= { unisDot11RadioMngFrameStatisEntry 2 }

unisDot11MngFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of each type for management frame on this
        radio."
    ::= { unisDot11RadioMngFrameStatisEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11RadioMngFrameStatisTable Definition
-- *****************************************************************************

