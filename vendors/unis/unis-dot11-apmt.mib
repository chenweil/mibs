-- *****************************************************************************
-- *  unisDot11RadioMngFrmStatisTable Definition
-- *****************************************************************************
unisDot11RadioMngFrmStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11RadioMngFrmStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the management frame statistic of this radio."
    ::= { unisDot11APStatisGroup 18 }

unisDot11RadioMngFrmStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11RadioMngFrmStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the management
         frame statistic of this radio."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID,
            unisDot11MngFrmType
        }
    ::= { unisDot11RadioMngFrmStatisTable 1 }

UnisDot11RadioMngFrmStatisEntry ::= SEQUENCE
    {
        unisDot11MngFrmType                 INTEGER,
        unisDot11MngFrmCnt                  Counter32
    }

unisDot11MngFrmType  OBJECT-TYPE
    SYNTAX      INTEGER
        {
            assocReq(1),
            assocResp(2),
            reassocReq(3),
            reassocResp(4),
            probeReq(5),
            probeResp(6),
            beacon(7),
            atim(8),
            disassociation(9),
            authentication(10),
            deauthentication(11),
            action(12)
        }
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the type of the management frame on this radio."
    ::= { unisDot11RadioMngFrmStatisEntry 1 }

unisDot11MngFrmCnt  OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of each type of management frame on this
         radio."
    ::= { unisDot11RadioMngFrmStatisEntry 2 }
-- *****************************************************************************
-- *  End of unisDot11RadioMngFrmStatisTable Definition
-- *****************************************************************************


-- *****************************************************************************
-- *  unisDot11APPacketSizeStatisTable Definition
-- *****************************************************************************
unisDot11APPacketSizeStatisTable  OBJECT-TYPE
        SYNTAX        SEQUENCE OF UnisDot11APPacketSizeStatisEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
                "This table provides packets statistic base on size."
        ::= { unisDot11APStatisGroup 19 }

unisDot11APPacketSizeStatisEntry  OBJECT-TYPE
        SYNTAX        UnisDot11APPacketSizeStatisEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
                "Each entry provides packets statistic base on size for each radio
                 of a specific AP."
        INDEX
            {
                unisDot11CurAPID,
                unisDot11RadioID,
                unisDot11APPacketSize
            }
        ::= { unisDot11APPacketSizeStatisTable 1 }

UnisDot11APPacketSizeStatisEntry    ::=SEQUENCE
        {
            unisDot11APPacketSize          INTEGER,
            unisDot11APRXPacketSizeCount   Counter64,
            unisDot11APTXPacketSizeCount   Counter64
        }

unisDot11APPacketSize    OBJECT-TYPE
        SYNTAX    INTEGER
            {
                sizeLevel1(1),
                sizeLevel2(2),
                sizeLevel3(3),
                sizeLevel4(4)
            }
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "This node represents packet size:
                    sizeLevel1 : size <= 128
                    sizeLevel2 : 128 < size <= 512
                    sizeLevel3 : 512 < size <= 1024
                    sizeLevel4 : size > 1024"
    ::= { unisDot11APPacketSizeStatisEntry 1 }

unisDot11APRXPacketSizeCount    OBJECT-TYPE
        SYNTAX        Counter64
        MAX-ACCESS    read-only
        STATUS        current
        DESCRIPTION
                "Represents the count of packets reception base on frame size."
    ::= { unisDot11APPacketSizeStatisEntry 2 }

unisDot11APTXPacketSizeCount    OBJECT-TYPE
        SYNTAX        Counter64
        MAX-ACCESS    read-only
        STATUS        current
        DESCRIPTION
                "Represents the count of packets transmission base on frame size."
    ::= { unisDot11APPacketSizeStatisEntry 3 }
-- *****************************************************************************
-- *  End of unisDot11APPacketSizeStatisTable Definition
-- *****************************************************************************

