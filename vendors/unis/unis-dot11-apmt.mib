-- *****************************************************************************
unisDot11WTUAPInfoTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WTUAPInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides relationship information between wireless terminator units (WTUs) and WTs."
    ::= { unisDot11APObjectGroup 11 }

unisDot11WTUAPInfoEntry OBJECT-TYPE
    SYNTAX      UnisDot11WTUAPInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides relationship information between a WTU and a WT."
    INDEX
        {
            unisDot11ContainerSerialID,
            unisDot11WTUAPSerialID
        }
    ::= { unisDot11WTUAPInfoTable 1 }

UnisDot11WTUAPInfoEntry ::= SEQUENCE
    {
        unisDot11ContainerSerialID    UnisDot11ObjectIDType,
        unisDot11WTUAPSerialID        UnisDot11ObjectIDType,
        unisDot11WTUAPSubSlotID       Unsigned32
    }

unisDot11ContainerSerialID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Serial ID that uniquely identifies a WT."
    ::= { unisDot11WTUAPInfoEntry 1 }

unisDot11WTUAPSerialID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Serial ID that uniquely identifies a WTU."
    ::= { unisDot11WTUAPInfoEntry 2 }

unisDot11WTUAPSubSlotID OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the sub-slot ID of a WTU."
    ::= { unisDot11WTUAPInfoEntry 3 }

