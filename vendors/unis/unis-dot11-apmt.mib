-- *****************************************************************************
-- *  unisDot11APIfStatisTable Definition
-- *****************************************************************************
unisDot11APIfStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APIfStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the statistics on the interface of the AP."
    ::= { unisDot11APStatisGroup 17 }

unisDot11APIfStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APIfStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide statistics on the interface of the AP."
    INDEX
        {
            unisDot11APElementIndex,
            unisDot11APIfIndex
        }
    ::= { unisDot11APIfStatisTable 1 }

UnisDot11APIfStatisEntry ::= SEQUENCE
    {
        unisDot11APIfInPkts              Counter32,
        unisDot11APIfInNormalPkts        Counter32,
        unisDot11APIfInErrorPkts         Counter32,
        unisDot11APIfOutPkts             Counter32,
        unisDot11APIfInOctets            Counter32,
        unisDot11APIfOutOctets           Counter32,
        unisDot11APIfFlowOut             Unsigned32,
        unisDot11APIfFlowIN              Unsigned32,
        unisDot11APIfInUcastPkts         Counter32,
        unisDot11APIfInNUcastPkts        Counter32,
        unisDot11APIfInDiscardPkts       Counter32,
        unisDot11APIfOutUcastPkts        Counter32,
        unisDot11APIfOutNUcastPkts       Counter32,
        unisDot11APIfOutDiscardPkts      Counter32,
        unisDot11APIfOutErrorPkts        Counter32,
        unisDot11APIfUpdownTimes         Counter32,
        unisDot11APIfStatusKeepTime      TimeTicks,
        unisDot11APIfOperStatus          INTEGER,
        unisDot11APIfInBrdcastPkts       Counter64,
        unisDot11APIfOutBrdcastPkts      Counter64,
        unisDot11APIfInMulcastPkts       Counter64,
        unisDot11APIfOutMulcastPkts      Counter64,
        unisDot11APIfInPayloadOctets     Counter64,
        unisDot11APIfOutPayloadOctets    Counter64
    }

unisDot11APIfInPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of packets received
         on the interface."
    ::= { unisDot11APIfStatisEntry 1 }

unisDot11APIfInNormalPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of correct
         packets received on the interface."
    ::= { unisDot11APIfStatisEntry 2 }

unisDot11APIfInErrorPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of error
         packets received on the interface."
    ::= { unisDot11APIfStatisEntry 3 }

unisDot11APIfOutPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of packets
         sent from the interface."
    ::= { unisDot11APIfStatisEntry 4 }

unisDot11APIfInOctets OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of octets
         received on the interface."
    ::= { unisDot11APIfStatisEntry 5 }

unisDot11APIfOutOctets OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of octets
         sent from the interface."
    ::= { unisDot11APIfStatisEntry 6 }

unisDot11APIfFlowOut OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the traffic rate (byte/s) on the uplink interface
         during a sampling period."
    ::= { unisDot11APIfStatisEntry 7 }

unisDot11APIfFlowIN OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the traffic rate (byte/s) on the downlink interface
         during a sampling period."
    ::= { unisDot11APIfStatisEntry 8 }

unisDot11APIfInUcastPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets received on the interface."
    ::= { unisDot11APIfStatisEntry 9 }

unisDot11APIfInNUcastPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of non-unicast packets received on the wired
         interface."
    ::= { unisDot11APIfStatisEntry 10 }

unisDot11APIfInDiscardPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets discarded on the interface."
    ::= { unisDot11APIfStatisEntry 11 }

unisDot11APIfOutUcastPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast packets send on the interface."
    ::= { unisDot11APIfStatisEntry 12 }

unisDot11APIfOutNUcastPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of non-unicast packets send on the interface."
    ::= { unisDot11APIfStatisEntry 13 }

unisDot11APIfOutDiscardPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of discarded packets send on the interface."
    ::= { unisDot11APIfStatisEntry 14 }

unisDot11APIfOutErrorPkts OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of error packets send on the interface."
    ::= { unisDot11APIfStatisEntry 15 }

unisDot11APIfUpdownTimes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the up/down times on the interface."
    ::= { unisDot11APIfStatisEntry 16 }

unisDot11APIfStatusKeepTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the last change time on the interface."
    ::= { unisDot11APIfStatisEntry 17 }

unisDot11APIfOperStatus OBJECT-TYPE
    SYNTAX  INTEGER {
                       up(1),        -- ready to pass packets
                       down(2),
                       testing(3),   -- in some test mode
                       unknown(4),   -- status can not be determined
                                     -- for some reason.
                       dormant(5),
                       notPresent(6),    -- some component is missing
                       lowerLayerDown(7) -- down due to state of
                                         -- lower-layer interface(s)
                    }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the operational state of the interface."
    ::= { unisDot11APIfStatisEntry 18 }

unisDot11APIfInBrdcastPkts OBJECT-TYPE
