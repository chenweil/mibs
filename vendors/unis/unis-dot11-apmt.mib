-- *****************************************************************************
-- *  unisDot11APRxStatisTable Definition
-- *****************************************************************************
unisDot11APRxStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APRxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the receiving statistic for a specific
        radio of AP."
    ::= { unisDot11APStatisGroup 1 }

unisDot11APRxStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APRxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the statistic data for
        each radio of a specific AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID
        }
    ::= { unisDot11APRxStatisTable 1 }

UnisDot11APRxStatisEntry ::= SEQUENCE
    {
        unisDot11RxFrameDupCnt          Counter32,
        unisDot11RxFrameCnt             Counter32,
        unisDot11RxUcastFrameCnt        Counter32,
        unisDot11RxBcastFrameCnt        Counter32,
        unisDot11RxMcastFrameCnt        Counter32,
        unisDot11RxDiscardFrameCnt      Counter32,
        unisDot11RxFragCnt              Counter32,
        unisDot11RxFcsErrCnt            Counter32,
        unisDot11RxFrameBytes           Counter32,
        unisDot11RxUcastFrameBytes      Counter32,
        unisDot11RxBcastFrameBytes      Counter32,
        unisDot11RxMcastFrameBytes      Counter32,
        unisDot11RxDiscardFrameBytes    Counter32,
        unisDot11RxMgmtFrameCnt         Counter32,
        unisDot11RxCtrlFrameCnt         Counter32,
        unisDot11RxDataFrameCnt         Counter32,
        unisDot11RxDecryptErrorCnt      Counter32,
        unisDot11RxAuthenFrameCnt       Counter32,
        unisDot11RxAssociateFrameCnt    Counter32,
        unisDot11RxFrameErrorRatio      Integer32,
        unisDot11RxPhyErrorCnt          Counter32,
        unisDot11RxMICErrorCnt          Counter32,
        unisDot11RxDataFrameBytes       Counter32,
        unisDot11RadioRxAverSnr         Integer32,
        unisDot11RxPayloadBytes         Counter32,
        unisDot11RxTrafficSpeed         Integer32,
        unisDot11RxUcastDataFrameCnt    Counter64,
        unisDot11RxNUcastDataFrameCnt   Counter64,
        unisDot11RxTotalDiscardFrameCnt Counter64,
        unisDot11RxTotalIPCheckErrPacketCnt    Counter64,
        unisDot11RxSignalStrengthPacketCntCM   OCTET STRING,
        unisDot11RxDataFrameCntCM              Counter32,
        unisDot11RxTotalFrameCnt               Counter64
    }

unisDot11RxFrameDupCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of duplicate frames reception."
    ::= { unisDot11APRxStatisEntry 1 }

unisDot11RxFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of frames reception."
    ::= { unisDot11APRxStatisEntry 2 }

unisDot11RxUcastFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast frames reception."
    ::= { unisDot11APRxStatisEntry 3 }

unisDot11RxBcastFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of broadcast frames reception."
    ::= { unisDot11APRxStatisEntry 4 }

unisDot11RxMcastFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of multicast frames reception."
    ::= { unisDot11APRxStatisEntry 5 }

unisDot11RxDiscardFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of frames discarded by AP."
    ::= { unisDot11APRxStatisEntry 6 }

unisDot11RxFragCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of frame fragments reception."
    ::= { unisDot11APRxStatisEntry 7 }

unisDot11RxFcsErrCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of FCS error frames reception."
    ::= { unisDot11APRxStatisEntry 8 }

unisDot11RxFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of frames reception."
    ::= { unisDot11APRxStatisEntry 9 }

unisDot11RxUcastFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of unicast frames reception."
    ::= { unisDot11APRxStatisEntry 10 }

unisDot11RxBcastFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of broadcast frames reception."
    ::= { unisDot11APRxStatisEntry 11 }

unisDot11RxMcastFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of multicast frames reception."
    ::= { unisDot11APRxStatisEntry 12 }

unisDot11RxDiscardFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of frames discarded by AP."
    ::= { unisDot11APRxStatisEntry 13 }

unisDot11RxMgmtFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of management frames reception."
    ::= { unisDot11APRxStatisEntry 14 }

unisDot11RxCtrlFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of control frames reception."
    ::= { unisDot11APRxStatisEntry 15 }

unisDot11RxDataFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of data frames reception."
    ::= { unisDot11APRxStatisEntry 16 }

unisDot11RxDecryptErrorCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of decryption error."
    ::= { unisDot11APRxStatisEntry 17 }

unisDot11RxAuthenFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of authentication frame reception."
    ::= { unisDot11APRxStatisEntry 18 }

unisDot11RxAssociateFrameCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of associate frame reception."
    ::= { unisDot11APRxStatisEntry 19 }

unisDot11RxFrameErrorRatio OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "onepercent"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the ratio of error frame."
    ::= { unisDot11APRxStatisEntry 20 }

unisDot11RxPhyErrorCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of physical reception error."
    ::= { unisDot11APRxStatisEntry 21 }

unisDot11RxMICErrorCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of MIC verification error."
    ::= { unisDot11APRxStatisEntry 22 }

unisDot11RxDataFrameBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of data frames reception."
    ::= { unisDot11APRxStatisEntry 23 }

unisDot11RadioRxAverSnr OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the average signal noise rate of this radio."
    ::= { unisDot11APRxStatisEntry 24 }

unisDot11RxPayloadBytes OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the payload bytes of data frames reception."
    ::= { unisDot11APRxStatisEntry 25 }

unisDot11RxTrafficSpeed OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "byte/s"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the bytes of frames reception per second."
    ::= { unisDot11APRxStatisEntry 26 }

unisDot11RxUcastDataFrameCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of unicast data frames reception."
    ::= { unisDot11APRxStatisEntry 27 }

unisDot11RxNUcastDataFrameCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of non-unicast data frames reception."
    ::= { unisDot11APRxStatisEntry 28 }

unisDot11RxTotalDiscardFrameCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of total frames discarded by radio."
    ::= { unisDot11APRxStatisEntry 29 }

unisDot11RxTotalIPCheckErrPacketCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of IP checksum error packets
        received through the current radio."
    ::= { unisDot11APRxStatisEntry 30 }

unisDot11RxSignalStrengthPacketCntCM OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the count of received packets according to signal strength."
    ::= { unisDot11APRxStatisEntry 31 }

unisDot11RxDataFrameCntCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of received data frames, excluding retransmitted
        frames."
    ::= { unisDot11APRxStatisEntry 32 }

unisDot11RxTotalFrameCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of packets
        received through the current radio."
    ::= { unisDot11APRxStatisEntry 33 }

-- *****************************************************************************
-- *  End of unisDot11APRxStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11APTxStatisTable Definition
-- *****************************************************************************
unisDot11APTxStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APTxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the transmission statistic for a
        specific radio of AP."
    ::= { unisDot11APStatisGroup 2 }

unisDot11APTxStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APTxStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the statistic data for
        each radio of a specific AP."
    INDEX
        {
            unisDot11CurAPID,
            unisDot11RadioID
        }
    ::= { unisDot11APTxStatisTable 1 }

UnisDot11APTxStatisEntry ::= SEQUENCE
    {
        unisDot11TxFragCnt              Counter32,
        unisDot11FailedCnt              Counter32,
        unisDot11RetryCnt               Counter32,
        unisDot11MultiRetryCnt          Counter32,
        unisDot11RtsSuccessCnt          Counter32,
        unisDot11RtsFailCnt             Counter32,
        unisDot11AckFailCnt             Counter32,
        unisDot11TxFrameCnt             Counter32,
        unisDot11TxUcastFrameCnt        Counter32,
        unisDot11TxBcastFrameCnt        Counter32,
        unisDot11TxMcastFrameCnt        Counter32,
        unisDot11TxDiscardFrameCnt      Counter32,
        unisDot11TxFrameBytes           Counter32,
        unisDot11TxUcastFrameBytes      Counter32,
        unisDot11TxBcastFrameBytes      Counter32,
        unisDot11TxMcastFrameBytes      Counter32,
        unisDot11TxDiscardFrameBytes    Counter32,
        unisDot11TxAuthenFrameCnt       Counter32,
        unisDot11TxAssociateFrameCnt    Counter32,
        unisDot11TxFrameRetryRatio      Integer32,
        unisDot11TxDataFrameCnt         Counter32,
        unisDot11TxDataFrameBytes       Counter32,
        unisDot11TxMSDUCnt              Counter32,
        unisDot11TxDiscardMSDUCnt       Counter32,
        unisDot11RetryMSDUCnt           Counter32,
        unisDot11TxPayloadBytes         Counter32,
        unisDot11TxTrafficSpeed         Integer32,
        unisDot11TxErrFrameRatio        Integer32,
        unisDot11TxFrameRate            Integer32,
        unisDot11TxMgtFrameCnt          Counter32,
        unisDot11TxCtrlFrameCnt         Counter32,
        unisDot11TxMACErrCnt            Counter32,
        unisDot11TxErrFrameCnt          Counter32,
        unisDot11TxUcastDataFrameCnt    Counter64,
        unisDot11TxNUcastDataFrameCnt   Counter64,
        unisDot11TxTotalFrameCnt        Counter64
    }

unisDot11TxFragCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of fragmented frames transmission."
    ::= { unisDot11APTxStatisEntry 1 }

unisDot11FailedCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of transmission failures."
    ::= { unisDot11APTxStatisEntry 2 }

unisDot11RetryCnt OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of transmit retries."
    ::= { unisDot11APTxStatisEntry 3 }

unisDot11MultiRetryCnt OBJECT-TYPE
