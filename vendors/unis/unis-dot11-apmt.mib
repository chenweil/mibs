-- *****************************************************************************
-- *  unisDot11APAssocStatisTable Definition
-- *****************************************************************************
unisDot11APAssocStatisTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11APAssocStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will provide the station association statistic for AP."
    ::= { unisDot11APStatisGroup 3 }

unisDot11APAssocStatisEntry OBJECT-TYPE
    SYNTAX      UnisDot11APAssocStatisEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry of the table will provide the statistic data of station
        association for AP."
    INDEX
        {
            unisDot11CurAPID
        }
    ::= { unisDot11APAssocStatisTable 1 }

UnisDot11APAssocStatisEntry ::= SEQUENCE
    {
        unisDot11ApStationAssocSum          Counter32,
        unisDot11ApStationAssocFailSum      Counter32,
        unisDot11ApStationReassocSum        Counter32,
        unisDot11ApStationAssocRejectSum    Counter32,
        unisDot11ApStationExDeAuthenSum     Counter32,
        unisDot11ApStationCurAssocSum       Integer32,
        unisDot11ApStaCurAuthSuccSum        Integer32,
        unisDot11AllStationUpSumTime        Counter32,
        unisDot11ApStationAssocReqSum       Counter32,
        unisDot11AllStationUpSumTimeTicks   TimeTicks,
        unisDot11ApStationReassocReqSum     Counter32,
        unisDot11ApStationReassocFailSum    Counter32,
        unisDot11ApStationAssocRespSum       Counter32
    }

unisDot11ApStationAssocSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station association
        with this AP."
    ::= { unisDot11APAssocStatisEntry 1 }

unisDot11ApStationAssocFailSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station
        association failure with this AP."
    ::= { unisDot11APAssocStatisEntry 2 }

unisDot11ApStationReassocSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station reassociation with this AP."
    ::= { unisDot11APAssocStatisEntry 3 }

unisDot11ApStationAssocRejectSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station association rejected
        on account of resource limit with this AP."
    ::= { unisDot11APAssocStatisEntry 4 }

unisDot11ApStationExDeAuthenSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of exceptional station deauthentication
        (Without sending a deauthentication to AP) with this AP."
    ::= { unisDot11APAssocStatisEntry 5 }

unisDot11ApStationCurAssocSum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of current associated stations
        with this AP."
    ::= { unisDot11APAssocStatisEntry 6 }

unisDot11ApStaCurAuthSuccSum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the successful number of station authentication
        with this AP."
    ::= { unisDot11APAssocStatisEntry 7 }

unisDot11AllStationUpSumTime OBJECT-TYPE
    SYNTAX      Counter32
    UNITS       "minute"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the sum of duration of all stations which associate with
         this AP."
    ::= { unisDot11APAssocStatisEntry 8 }

unisDot11ApStationAssocReqSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of station association request with this AP."
    ::= { unisDot11APAssocStatisEntry 9 }

unisDot11AllStationUpSumTimeTicks OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the sum of duration of all stations which associate with
         this AP."
    ::= { unisDot11APAssocStatisEntry 10 }

unisDot11ApStationReassocReqSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station reassociation request
        with this AP."
    ::= { unisDot11APAssocStatisEntry 11 }

unisDot11ApStationReassocFailSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of station reassociation failure
        with this AP."
    ::= { unisDot11APAssocStatisEntry 12 }

unisDot11ApStationAssocRespSum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the number of this AP response with station association."
    ::= { unisDot11APAssocStatisEntry 13 }

-- *****************************************************************************
-- *  End of unisDot11APAssocStatisTable Definition
-- *****************************************************************************

-- *****************************************************************************
