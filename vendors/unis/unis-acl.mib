--
-- Nodes of unisPfilter2ApplyTable
--
        unisPfilter2ApplyTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisPfilter2ApplyEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of packet filter application.
                It's not supported to set default action on an entity,
                but supported to enable hardware count of default action
                on an entity.
                "
            ::= { unisAclPacketFilterObjects 6 }

        unisPfilter2ApplyEntry OBJECT-TYPE
            SYNTAX UnisPfilter2ApplyEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Packet filter application information entry."
            INDEX
            {
                unisPfilter2ApplyObjType,
                unisPfilter2ApplyObjIndex,
                unisPfilter2ApplyDirection,
                unisPfilter2ApplyAclType,
                unisPfilter2ApplyAclIndex
            }
            ::= { unisPfilter2ApplyTable 1 }

        UnisPfilter2ApplyEntry ::=
        SEQUENCE
        {
            unisPfilter2ApplyObjType
                INTEGER,
            unisPfilter2ApplyObjIndex
                Integer32,
            unisPfilter2ApplyDirection
                DirectionType,
            unisPfilter2ApplyAclType
                INTEGER,
            unisPfilter2ApplyAclIndex
                OCTET STRING,
            unisPfilter2ApplyHardCount
                TruthValue,
            unisPfilter2ApplySequence
                Unsigned32,
            unisPfilter2ApplyCountClear
                CounterClear,
            unisPfilter2ApplyRowStatus
                RowStatus
        }

        unisPfilter2ApplyObjType OBJECT-TYPE
            SYNTAX INTEGER
            {
                interface(1),
                vlan(2),
                global(3)
            }
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The object type of packet filter application.
                interface: Apply an ACL to the interface to filter packets.
                vlan: Apply an ACL to the VLAN to filter packets.
                global: Apply an ACL globally to filter packets.
                "
            ::= { unisPfilter2ApplyEntry 1 }

        unisPfilter2ApplyObjIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The object ID of packet filter application.
                Interface: interface index, equal to ifIndex
                VLAN: VLAN ID, 1..4094
                Global: 0
                "
            ::= { unisPfilter2ApplyEntry 2 }

        unisPfilter2ApplyDirection OBJECT-TYPE
            SYNTAX DirectionType
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The direction of packet filter application."
            ::= { unisPfilter2ApplyEntry 3 }

        unisPfilter2ApplyAclType OBJECT-TYPE
            SYNTAX INTEGER
            {
                ipv4(1),
                ipv6(2),
                default(3),
                mac(4),
                user(5)
            }
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "ACL Type: IPv4, IPv6, default action, MAC, and user.
                Take default action as a special ACL group.
                "
            ::= { unisPfilter2ApplyEntry 4 }

        unisPfilter2ApplyAclIndex OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(1..63))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The index of ACL group used by packet-filter.
                If the specified string comprises only digits, it is converted
                into a numerical sequence in decimal notation, and regarded as
                an ACL group index or a default action.  If the string is a
                character string beginning with an English letter, it is
                regarded as an ACL group name.

                Group index range and default action:
                    Basic type: 2000..2999
                    Advanced type: 3000..3999
                    MAC type: 4000..4999
                    User type: 5000..5999
                    Default action type: 0
                "
            ::= { unisPfilter2ApplyEntry 5 }

        unisPfilter2ApplyHardCount OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Hardware count flag.
                true: enable hardware count
                false: disable hardware count
                "
            DEFVAL { false }
            ::= { unisPfilter2ApplyEntry 6 }

        unisPfilter2ApplySequence OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The configure sequence of packet filter application."
            ::= { unisPfilter2ApplyEntry 7 }

        unisPfilter2ApplyCountClear OBJECT-TYPE
            SYNTAX CounterClear
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Clear the value of counters."
            DEFVAL { nouse }
            ::= { unisPfilter2ApplyEntry 8 }

        unisPfilter2ApplyRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisPfilter2ApplyEntry 9 }

