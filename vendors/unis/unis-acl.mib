        unisPfilterInterface OBJECT-TYPE
            SYNTAX OCTET STRING
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The interface which policy apply."
            ::= { unisAclPacketfilterTrapObjects 1 }

        unisPfilterDirection OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Inbound or outbound."
            ::= { unisAclPacketfilterTrapObjects 2 }

        unisPfilterACLNumber OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "ACL number."
            ::= { unisAclPacketfilterTrapObjects 3 }

        unisPfilterAction OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Permit or deny."
            ::= { unisAclPacketfilterTrapObjects 4 }

        unisMACfilterSourceMac OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Source MAC address."
            ::= { unisAclPacketfilterTrapObjects 5 }

        unisMACfilterDestinationMac OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Destination MAC address."
            ::= { unisAclPacketfilterTrapObjects 6 }

        unisPfilterPacketNumber OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The number of packets permitted or denied by ACL."
            ::= { unisAclPacketfilterTrapObjects 7 }

        unisPfilterReceiveInterface OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The interface where packet come from."
            ::= { unisAclPacketfilterTrapObjects 8 }

        unisAclPacketIfName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The name of the interface on which the packet is matched."
            ::= { unisAclPacketfilterTrapObjects 9 }

        unisAclPacketDirection OBJECT-TYPE
            SYNTAX DirectionType
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The direction the packet is going."
            ::= { unisAclPacketfilterTrapObjects 10 }

        unisAclPacketBAGG OBJECT-TYPE
            SYNTAX Integer32 (0..2048)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The bridge-aggregation-interface ID the interface belongs to.
                "
            DEFVAL { 0 }
            ::= { unisAclPacketfilterTrapObjects 11 }

        unisAclPacketVlanID OBJECT-TYPE
            SYNTAX Integer32 (1..4094)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The vlan the interface belongs to."
            ::= { unisAclPacketfilterTrapObjects 12 }

        unisAclPacketSrcIP OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Source IP address of IPv4/IPv6 packet."
            ::= { unisAclPacketfilterTrapObjects 13 }

        unisAclPacketDstIP OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Destination IP address of IPv4/IPv6 packet."
            ::= { unisAclPacketfilterTrapObjects 14 }

        unisAclPacketProtocol  OBJECT-TYPE
            SYNTAX Integer32 (0..255)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The protocol of IPv4/IPv6 packet.
                icmp(1),
                tcp(6),
                udp(17),
                igmp(2),
                gre(47),
                ospf(89),
                ipinip(4),
                icmp6(58),
                ipv6_ah(51),
                ipv6_esp(50)
                "
            ::= { unisAclPacketfilterTrapObjects 15 }

        unisAclPacketDscp  OBJECT-TYPE
            SYNTAX DSCPValue
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "DSCP of IPv4/IPv6 packet."
            DEFVAL { 255 }
            ::= { unisAclPacketfilterTrapObjects 16 }

        unisAclPacketFlowLabel  OBJECT-TYPE
            SYNTAX Unsigned32   (0..1048575|4294967295)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Flow label value of IPv6 packet."
            DEFVAL { 4294967295 }
            ::= { unisAclPacketfilterTrapObjects 17 }

        unisAclPacketIcmpIgmpType  OBJECT-TYPE
            SYNTAX Integer32   (0..255|65535)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The type of ICMP or IGMP packet."
            DEFVAL { 65535 }
            ::= { unisAclPacketfilterTrapObjects 18 }

        unisAclPacketIcmpIgmpCode  OBJECT-TYPE
            SYNTAX Integer32   (0..255|65535)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The code of ICMP or IGMP packet."
            DEFVAL { 65535 }
            ::= { unisAclPacketfilterTrapObjects 19 }

        unisAclPacketTcpFlags  OBJECT-TYPE
            SYNTAX INTEGER
            {
                tcpack(1),
                tcpfin(2),
                tcppsh(3),
                tcprst(4),
                tcpsyn(5),
                tcpurg(6),
                invalid(255)
            }

            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The flags of TCP packet.
                tcpack(1),
                tcpfin(2),
                tcppsh(3),
                tcprst(4),
                tcpsyn(5),
                tcpurg(6),
                invalid(255)
                "
            DEFVAL { 255 }
            ::= { unisAclPacketfilterTrapObjects 20 }

        unisAclPacketSrcPort  OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Source port of TCP or UDP packet."
            DEFVAL { 0 }
            ::= { unisAclPacketfilterTrapObjects 21 }

        unisAclPacketDstPort  OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Destination port of TCP or UDP packet."
            DEFVAL { 65535 }
            ::= { unisAclPacketfilterTrapObjects 22 }

        unisAclPacketSrcMacAddr  OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Source MAC address of Ethernet packet."
            ::= { unisAclPacketfilterTrapObjects 23 }

        unisAclPacketDstMacAddr  OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "Destination MAC address of Ethernet packet."
            ::= { unisAclPacketfilterTrapObjects 24 }

        unisAclPacketMacTypeLen  OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The Ethertype or 802.3 length of Ethernet packet."
            DEFVAL { 0 }
            ::= { unisAclPacketfilterTrapObjects 25 }

        unisAclPacketVlanPCP  OBJECT-TYPE
            SYNTAX  Integer32    (0..7|255)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "802.1p priority code point of Ethernet packet."
            DEFVAL { 255 }
            ::= { unisAclPacketfilterTrapObjects 26 }

--
-- Nodes of unisPacketfilterTrap
--

        unisAclPacketfilterTrap OBJECT IDENTIFIER ::= { unisAcl 5 }

        unisPfilterTrapPrefix OBJECT IDENTIFIER ::= { unisAclPacketfilterTrap 0 }

        unisMACfilterTrap NOTIFICATION-TYPE
            OBJECTS
            {
                unisPfilterInterface,
                unisPfilterDirection,
                unisPfilterACLNumber,
                unisPfilterAction,
                unisMACfilterSourceMac,
                unisMACfilterDestinationMac,
                unisPfilterPacketNumber,
                unisPfilterReceiveInterface
            }
            STATUS current
            DESCRIPTION
                "This notification is generated when a packet was processed
                by MAC address filter, but not every packet will generate one
                notification, the same notification only generate once in 30
                seconds.
                "
            ::= { unisPfilterTrapPrefix 1 }

        unisAclRuleMatchCount NOTIFICATION-TYPE
            OBJECTS
            {
                unisPfilter2ApplyObjType,
                unisPfilter2ApplyObjIndex,
                unisPfilter2ApplyDirection,
                unisPfilter2ApplyAclType,
                unisPfilter2ApplyAclIndex,
                unisPfilter2AclRuleIndex,
                unisPfilter2AclRuleMatchPackets
            }
            STATUS current
            DESCRIPTION
                "This notification is generated periodically due to a timer.
                The interval of the timer is configured in unisAclIntervalTable.
                The notification details the entries about the packet-filter
                object, the matched ACL rule and the number of matching packets.
                "
            ::= { unisPfilterTrapPrefix 2 }

        unisAclFirstIPv4PktCaptured NOTIFICATION-TYPE
            OBJECTS
            {
                unisPfilter2ApplyAclIndex,
                unisPfilter2AclRuleIndex,
                unisAclPacketIfName,
                unisAclPacketDirection,
                unisAclPacketBAGG,
                unisAclPacketVlanID,
                unisAclPacketSrcIP,
                unisAclPacketDstIP,
                unisAclPacketProtocol,
                unisAclPacketDscp,
                unisAclPacketIcmpIgmpType,
                unisAclPacketIcmpIgmpCode,
                unisAclPacketTcpFlags,
                unisAclPacketSrcPort,
                unisAclPacketDstPort
            }
            STATUS current
            DESCRIPTION
                "This notification is generated immediately when the first
                packet of the matched IPv4 flow is captured.  Other packets
                of the matched flow won't be captured.
                "
            ::= { unisPfilterTrapPrefix 3 }

        unisAclFirstIPv6PktCaptured NOTIFICATION-TYPE
            OBJECTS
            {
                unisPfilter2ApplyAclIndex,
                unisPfilter2AclRuleIndex,
                unisAclPacketIfName,
                unisAclPacketDirection,
                unisAclPacketBAGG,
                unisAclPacketVlanID,
                unisAclPacketSrcIP,
                unisAclPacketDstIP,
                unisAclPacketProtocol,
                unisAclPacketDscp,
                unisAclPacketFlowLabel,
                unisAclPacketIcmpIgmpType,
                unisAclPacketIcmpIgmpCode,
                unisAclPacketTcpFlags,
                unisAclPacketSrcPort,
                unisAclPacketDstPort
            }
            STATUS current
            DESCRIPTION
                "This notification is generated immediately when the first
                packet of the matched IPv6 flow is captured.  Other packets
                of the matched flow won't be captured.
                "
            ::= { unisPfilterTrapPrefix 4 }

        unisAclFirstEthernetPktCaptured NOTIFICATION-TYPE
            OBJECTS
            {
                unisPfilter2ApplyAclIndex,
                unisPfilter2AclRuleIndex,
                unisAclPacketIfName,
                unisAclPacketDirection,
                unisAclPacketBAGG,
                unisAclPacketVlanID,
                unisAclPacketSrcMacAddr,
                unisAclPacketDstMacAddr,
                unisAclPacketMacTypeLen,
                unisAclPacketVlanPCP
            }
            STATUS current
            DESCRIPTION
                "This notification is generated immediately when the first
                packet of the matched Ethernet flow is captured.  Other packets
                of the matched flow won't be captured.
                "
            ::= { unisPfilterTrapPrefix 5 }

--
-- Nodes of unisAclTrapObjects
--

        unisAclTrapObjects OBJECT IDENTIFIER ::= { unisAcl 6 }

        unisAclResourceTypeName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(1..255))
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The name of TCAM resources."
            ::= { unisAclTrapObjects 1 }

        unisAclResourceUsage OBJECT-TYPE
            SYNTAX Integer32 (1..100)
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The current usage of TCAM resources."
            ::= { unisAclTrapObjects 2 }

        unisAclResourceUsedEntries OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The used number of entries on TCAM."
            ::= { unisAclTrapObjects 3 }

        unisAclResourceTotalEntries OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The total number of entries on TCAM."
            ::= { unisAclTrapObjects 4 }

        unisAclResourceChassisID OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The chassis number.  On a centralized or distributed device,
                 the value for this node is always zero."
            ::= { unisAclTrapObjects 5 }

       unisAclResourceSlotID OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS accessible-for-notify
            STATUS current
            DESCRIPTION
                "The slot number.  On a centralized device, the value for
                 this node is always zero."
            ::= { unisAclTrapObjects 6 }

--
-- Nodes of unisAclResourceTrap
--

        unisAclTrap OBJECT IDENTIFIER ::= { unisAcl 7 }

        unisAclTrapPrefix OBJECT IDENTIFIER ::= { unisAclTrap 0 }

        unisAclResourceTrap NOTIFICATION-TYPE
            OBJECTS
            {
                unisAclResourceTypeName,
                unisAclResourceUsage,
                unisAclResourceUsedEntries,
                unisAclResourceTotalEntries,
                unisAclMib2ResourceThreshold,
                unisAclResourceChassisID,
                unisAclResourceSlotID
            }
            STATUS current
            DESCRIPTION
                "This notification is generated when the number of entries on TCAM
                 becomes equal to or greater than a preset threshold level"
            ::= { unisAclTrapPrefix 1 }

END
