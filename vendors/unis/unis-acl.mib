        unisAclLinkTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclLinkEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Create link acl."
            ::= { unisAclMibObjects 7 }

        unisAclLinkEntry OBJECT-TYPE
            SYNTAX UnisAclLinkEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The entry of the link acl table."
            INDEX { unisAclLinkAclNum, unisAclLinkSubitem }
            ::= { unisAclLinkTable 1 }

        UnisAclLinkEntry ::=
            SEQUENCE {
                unisAclLinkAclNum
                    Integer32,
                unisAclLinkSubitem
                    Integer32,
                unisAclLinkAct
                    INTEGER,
                unisAclLinkProtocol
                    INTEGER,
                unisAclLinkFormatType
                    INTEGER,
                unisAclLinkVlanTag
                    INTEGER,
                unisAclLinkVlanPri
                    Integer32,
                unisAclLinkSrcVlanId
                    Integer32,
                unisAclLinkSrcMac
                    MacAddress,
                unisAclLinkSrcMacWild
                    MacAddress,
                unisAclLinkSrcIfIndex
                    Integer32,
                unisAclLinkSrcAny
                    TruthValue,
                unisAclLinkDestVlanId
                    Integer32,
                unisAclLinkDestMac
                    MacAddress,
                unisAclLinkDestMacWild
                    MacAddress,
                unisAclLinkDestIfIndex
                    Integer32,
                unisAclLinkDestAny
                    TruthValue,
                unisAclLinkTimeRangeName
                    OCTET STRING,
                unisAclLinkEnable
                    TruthValue,
                unisAclLinkRowStatus
                    RowStatus,
                unisAclLinkTypeCode
                    OCTET STRING,
                unisAclLinkTypeMask
                    OCTET STRING,
                unisAclLinkLsapCode
                    OCTET STRING,
                unisAclLinkLsapMask
                    OCTET STRING,
                unisAclLinkL2LabelRangeOp
                    INTEGER,
                unisAclLinkL2LabelRangeBegin
                    Integer32,
                unisAclLinkL2LabelRangeEnd
                    Integer32,
                unisAclLinkMplsExp
                    Integer32
             }

        unisAclLinkAclNum OBJECT-TYPE
            SYNTAX Integer32 (0|4000..4999|10000..12999)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The index of link-based acl group."
            ::= { unisAclLinkEntry 1 }

        unisAclLinkSubitem OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The subindex of link-based acl group."
            ::= { unisAclLinkEntry 2 }

        unisAclLinkAct OBJECT-TYPE
            SYNTAX INTEGER
            {
                permit(1),
                deny(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The action of link-based acl group."
            ::= { unisAclLinkEntry 3 }

        unisAclLinkProtocol OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                ip(2048),
                arp(2054),
                rarp(32821),
                mpls(34887),
                pppoeControl(34915),
                pppoeData(34916)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The layer 2 protocol-type of link acl rule."
            DEFVAL { invalid }
            ::= { unisAclLinkEntry 4 }

        unisAclLinkFormatType OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                ethernetII(1),
                snap(2),
                ieee802Dot3And2(3),
                ieee802Dot3(4)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Format type of link acl rule."
            ::= { unisAclLinkEntry 5 }

        unisAclLinkVlanTag OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                tagged(1),
                untagged(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of vlan tag of link acl rule."
            ::= { unisAclLinkEntry 6 }

        unisAclLinkVlanPri OBJECT-TYPE
            SYNTAX Integer32 (0..7 | 255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Vlan priority of link acl rule."
            ::= { unisAclLinkEntry 7 }

        unisAclLinkSrcVlanId OBJECT-TYPE
            SYNTAX Integer32 (0..4094)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source vlan ID of link acl rule."
            ::= { unisAclLinkEntry 8 }

        unisAclLinkSrcMac OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source mac of link acl rule."
            ::= { unisAclLinkEntry 9 }

        unisAclLinkSrcMacWild OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source mac wildzard of link acl rule."
            ::= { unisAclLinkEntry 10 }

        unisAclLinkSrcIfIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source IfIndex of link acl rule."
            ::= { unisAclLinkEntry 11 }

        unisAclLinkSrcAny OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of matching any source."
            ::= { unisAclLinkEntry 12 }

        unisAclLinkDestVlanId OBJECT-TYPE
            SYNTAX Integer32 (0..4094)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination vlan ID of link acl rule."
            ::= { unisAclLinkEntry 13 }

        unisAclLinkDestMac OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination mac of link acl rule."
            ::= { unisAclLinkEntry 14 }

        unisAclLinkDestMacWild OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination mac wildzard of link acl rule."
            ::= { unisAclLinkEntry 15 }

        unisAclLinkDestIfIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination IfIndex of link acl rule."
            ::= { unisAclLinkEntry 16 }

        unisAclLinkDestAny OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of matching any destination."
            ::= { unisAclLinkEntry 17 }

        unisAclLinkTimeRangeName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The Time-range of link-based acl rule."
            ::= { unisAclLinkEntry 18 }

        unisAclLinkEnable OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The rule is active or not.
                 true : active
                 false : inactive
                "
            ::= { unisAclLinkEntry 19 }

        unisAclLinkRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus, now support three state: CreateAndGo, Active, Destroy."
            ::= { unisAclLinkEntry 20 }

            unisAclLinkTypeCode   OBJECT-TYPE
            SYNTAX OCTET STRING ( SIZE(0..32) )
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The type of layer 2 protocol.0x0000...0xffff."
            ::= { unisAclLinkEntry 21 }

            unisAclLinkTypeMask   OBJECT-TYPE
            SYNTAX OCTET STRING ( SIZE(0..32) )
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The mask of layer 2 protocol.0x0000...0xffff."
            ::= { unisAclLinkEntry 22 }

            unisAclLinkLsapCode   OBJECT-TYPE
            SYNTAX     OCTET STRING (SIZE(0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The type of LSAP.0x0000...0xffff."
            ::= { unisAclLinkEntry 23 }

        unisAclLinkLsapMask   OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The mask of LSAP.0x0000...0xffff."
            ::= { unisAclLinkEntry 24 }

        unisAclLinkL2LabelRangeOp OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                lt(1),
                eq(2),
                gt(3),
                neq(4),
                range(5)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Operation symbol of the MPLS label.
                 If the symbol is range(5), the objects unisAclLinkL2LabelRangeBegin and
                 unisAclLinkL2LabelRangeEnd should have different values indicating a range.
                 Otherwise, only unisAclLinkL2LabelRangeBegin counts,
                 object unisAclLinkL2LabelRangeEnd is ignored.

                 invalid(0) -- unavailable
                 lt(1) -- less than
                 eq(2) -- equal
                 gt(3) -- great than
                 neq(4) -- not equal
                 range(5) -- a range with two ends included
                "
            ::= { unisAclLinkEntry 25 }

        unisAclLinkL2LabelRangeBegin OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The beginning of VPLS VC label."
            ::= { unisAclLinkEntry 26 }

        unisAclLinkL2LabelRangeEnd OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The end of VPLS VC label."
            ::= { unisAclLinkEntry 27 }

        unisAclLinkMplsExp OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value of MPLS-packet's Exp."
            ::= { unisAclLinkEntry 28 }
--
-- unisAclUserTable
--
        unisAclUserTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclUserEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Create user acl."
            ::= { unisAclMibObjects 8 }

        unisAclUserEntry OBJECT-TYPE
            SYNTAX UnisAclUserEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The entry of user acl table."
            INDEX { unisAclUserAclNum, unisAclUserSubitem }
            ::= { unisAclUserTable 1 }

        UnisAclUserEntry ::=
            SEQUENCE {
                unisAclUserAclNum
                    Integer32,
                unisAclUserSubitem
                    Integer32,
                unisAclUserAct
                    INTEGER,
                unisAclUserFormatType
                    INTEGER,
                unisAclUserVlanTag
                    INTEGER,
                unisAclUserRuleStr
                    OCTET STRING,
                unisAclUserRuleMask
                    OCTET STRING,
                unisAclUserTimeRangeName
                    OCTET STRING,
                unisAclUserEnable
                    TruthValue,
                unisAclUserRowStatus
                    RowStatus
             }

        unisAclUserAclNum OBJECT-TYPE
            SYNTAX Integer32 (0|5000..5999|10000..12999)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The number of the user acl."
            ::= { unisAclUserEntry 1 }

        unisAclUserSubitem OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The subitem of the user acl."
            ::= { unisAclUserEntry 2 }

        unisAclUserAct OBJECT-TYPE
            SYNTAX INTEGER
            {
                permit(1),
                deny(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The action of the user acl."
            ::= { unisAclUserEntry 3 }

        unisAclUserFormatType OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                ethernetII(1),
                snap(2),
                ieee802Dot2And3(3),
                ieee802Dot4(4)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Format type."
            DEFVAL { invalid }
            ::= { unisAclUserEntry 4 }

        unisAclUserVlanTag OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                tagged(1),
                untagged(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Vlan tag exits or not."
            DEFVAL { invalid }
            ::= { unisAclUserEntry 5 }

        unisAclUserRuleStr OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (1..80))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Rule string."
            ::= { unisAclUserEntry 6 }

        unisAclUserRuleMask OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (1..80))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Rule mask."
            ::= { unisAclUserEntry 7 }

        unisAclUserTimeRangeName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The Time-range of the user defined acl."
            ::= { unisAclUserEntry 8 }

        unisAclUserEnable OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The rule is active or not.
                 true : active
                 false : inactive
                "
            ::= { unisAclUserEntry 9 }

        unisAclUserRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus, now support three state: CreateAndGo, Active, Destroy."
            ::= { unisAclUserEntry 10 }
--
-- unisAclActiveTable
--
        unisAclActiveTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclActiveEntry
