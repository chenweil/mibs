            ::= { unisAclActiveEntry 5 }

        unisAclActiveUserAclSubitem OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The subitem of the user acl."
            ::= { unisAclActiveEntry 6 }

        unisAclActiveIpAclNum OBJECT-TYPE
            SYNTAX Integer32 (0|2000..3999|10000..12999)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The number of the IP acl."
            ::= { unisAclActiveEntry 7 }

        unisAclActiveIpAclSubitem OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The subitem of the IP acl."
            ::= { unisAclActiveEntry 8 }

        unisAclActiveLinkAclNum OBJECT-TYPE
            SYNTAX Integer32 (0|4000..4999|10000..12999)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The num of the link acl."
            ::= { unisAclActiveEntry 9 }

        unisAclActiveLinkAclSubitem OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The subitem of the link acl."
            ::= { unisAclActiveEntry 10 }

        unisAclActiveRuntime OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Is run or not."
            ::= { unisAclActiveEntry 11 }

        unisAclActiveRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus, now support three state: CreateAndGo, Active, Destroy."
            ::= { unisAclActiveEntry 12 }

--
-- unisAclIDSTable
--
        unisAclIDSTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclIDSEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Configure the rule for IDS."
            ::= { unisAclMibObjects 10 }

        unisAclIDSEntry OBJECT-TYPE
            SYNTAX UnisAclIDSEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The entry of acl ids table."
            INDEX { IMPLIED unisAclIDSName}
            ::= { unisAclIDSTable 1 }

        UnisAclIDSEntry ::=
            SEQUENCE {
                unisAclIDSName
                    OCTET STRING,
                unisAclIDSSrcMac
                    MacAddress,
                unisAclIDSDestMac
                    MacAddress,
                unisAclIDSSrcIp
                    IpAddress,
                unisAclIDSSrcWild
                    IpAddress,
                unisAclIDSDestIp
                    IpAddress,
                unisAclIDSDestWild
                    IpAddress,
                unisAclIDSSrcPort
                    Integer32,
                unisAclIDSDestPort
                    Integer32,
                unisAclIDSProtocol
                    Integer32,
                unisAclIDSDenyTime
                    Unsigned32,
                unisAclIDSAct
                    INTEGER,
                unisAclIDSRowStatus
                    RowStatus
             }

        unisAclIDSName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (1..32))
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The name index of the IDS table."
            ::= { unisAclIDSEntry 1 }

        unisAclIDSSrcMac OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source mac of IDS acl rule."
            ::= { unisAclIDSEntry 2 }


        unisAclIDSDestMac OBJECT-TYPE
            SYNTAX MacAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination mac of IDS acl rule."
            ::= { unisAclIDSEntry 3 }

           unisAclIDSSrcIp OBJECT-TYPE
            SYNTAX IpAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source IP-address of IDS acl rule."
            ::= { unisAclIDSEntry 4 }

        unisAclIDSSrcWild OBJECT-TYPE
            SYNTAX IpAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source IP-address wild of IDS acl rule."
            ::= { unisAclIDSEntry 5 }

           unisAclIDSDestIp OBJECT-TYPE
            SYNTAX IpAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination IP-address of IDS acl rule."
            ::= { unisAclIDSEntry 6 }

        unisAclIDSDestWild OBJECT-TYPE
            SYNTAX IpAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Destination IP-address wild of IDS acl rule."
            ::= { unisAclIDSEntry 7 }

            unisAclIDSSrcPort OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The fourth layer source port."
            ::= { unisAclIDSEntry 8 }

        unisAclIDSDestPort OBJECT-TYPE
            SYNTAX Integer32 (0..65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The fourth layer destination port."
            ::= { unisAclIDSEntry 9 }

            unisAclIDSProtocol OBJECT-TYPE
            SYNTAX Integer32 (0..255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The protocol-type of advanced acl group.
                 <1-255>  Protocol number
                  gre      GRE tunneling(47)
                  icmp     Internet Control Message Protocol(1)
                  igmp     Internet Group Management Protocol(2)
                  ip       Any IP protocol
                  ipinip   IP in IP tunneling(4)
                  ospf     OSPF routing protocol(89)
                  tcp      Transmission Control Protocol (6)
                  udp      User Datagram Protocol (17)
                 "
            ::= { unisAclIDSEntry 10 }

        unisAclIDSDenyTime OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The maximum number of seconds which deny for this acl rule."
            DEFVAL { 0 }
            ::= { unisAclIDSEntry 11 }


        unisAclIDSAct OBJECT-TYPE
            SYNTAX INTEGER
            {
                permit(1),
                deny(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The action of IDS acl rule."
            ::= { unisAclIDSEntry 12 }

        unisAclIDSRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus, now supports three states:  CreateAndGo, Active, and Destroy."
            ::= { unisAclIDSEntry 13 }
--
-- Nodes of unisAclMib2Objects
--
        unisAclMib2Objects OBJECT IDENTIFIER ::= { unisAcl 2 }
--
-- Nodes of unisAclMib2GlobalGroup
--
        unisAclMib2GlobalGroup OBJECT IDENTIFIER ::= { unisAclMib2Objects 1 }

        unisAclMib2NodesGroup OBJECT IDENTIFIER ::= { unisAclMib2GlobalGroup 1 }

        unisAclMib2Mode OBJECT-TYPE
            SYNTAX INTEGER
            {
                linkBased(1),
                ipBased(2)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "The applying mode of ACL."
            ::= { unisAclMib2NodesGroup 1 }

        unisAclMib2Version OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The version of this file.
                 The output value has the format of 'xx'or 'xxx'.
                 For example: 10 means 1.0; 125 means 12.5.
                "
            ::= { unisAclMib2NodesGroup 2 }

        unisAclMib2ObjectsCapabilities OBJECT-TYPE
            SYNTAX BITS
            {
                unisAclMib2Mode(0),
                unisAclVersion(1),
                unisAclMib2ObjectsCapabilities(2),
                unisAclMib2CapabilityTable(3),
                unisAclNumberGroupTable(4),
                unisAclIPAclBasicTable(5),
                unisAclIPAclAdvancedTable(6),
                unisAclMACTable(7),
                unisAclEnUserTable(8),
                unisAclMib2ProcessingStatus(9)
            }
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The objects of unisAclMib2Objects."
            ::= { unisAclMib2NodesGroup 3 }

        unisAclMib2ProcessingStatus OBJECT-TYPE
            SYNTAX INTEGER
            {
                processing(1),
                done(2)
            }
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The processing status of ACL operation."
            ::= { unisAclMib2NodesGroup 4 }

        unisAclMib2ResourceThreshold OBJECT-TYPE
            SYNTAX Integer32 (0..100)
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "The threshold of TCAM resources.
                 The value 0 indicates that cancelling the TCAM resource notification function."
            ::= { unisAclMib2NodesGroup 5 }

        unisAclMib2ResourceLogInterval OBJECT-TYPE
            SYNTAX Integer32 (1..60)
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "The value of interval.  It must be in the range of 1 to 60.
                 Default value is 5."
            ::= { unisAclMib2NodesGroup 6 }

        unisAclMib2CapabilityTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclMib2CapabilityEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The capability of mib2."
            ::= { unisAclMib2GlobalGroup 2 }

        unisAclMib2CapabilityEntry OBJECT-TYPE
            SYNTAX UnisAclMib2CapabilityEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The information of Capability of mib2."
            INDEX { unisAclMib2EntityType,
                    unisAclMib2EntityIndex,
                    unisAclMib2ModuleIndex,
                    unisAclMib2CharacteristicsIndex
                  }
            ::= { unisAclMib2CapabilityTable 1 }

        UnisAclMib2CapabilityEntry ::=
            SEQUENCE
            {
                unisAclMib2EntityType
                    INTEGER,
                unisAclMib2EntityIndex
                    Integer32,
                unisAclMib2ModuleIndex
                    INTEGER,
                unisAclMib2CharacteristicsIndex
                    Integer32,
                unisAclMib2CharacteristicsDesc
                    OCTET STRING,
                unisAclMib2CharacteristicsValue
                    Unsigned32
            }

        unisAclMib2EntityType OBJECT-TYPE
            SYNTAX INTEGER
            {
                system(1),
                interface(2)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The type of entity.
                 system: The entity is systemic level.
                 interface: The entity is interface level.
                "
            ::= { unisAclMib2CapabilityEntry 1 }

        unisAclMib2EntityIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The index of entity.
                 If unisAclMib2EntityType is system, the value of this object is 0.

                 If unisAclMib2EntityType is interface,
                 the value of this object is equal to 'ifIndex'.
                "
            ::= { unisAclMib2CapabilityEntry 2 }

        unisAclMib2ModuleIndex OBJECT-TYPE
            SYNTAX INTEGER
            {
                layer3(1),
                layer2(2),
                userDefined(3)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The module index of ACL."
            ::= { unisAclMib2CapabilityEntry 3 }

        unisAclMib2CharacteristicsIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The characteristics index of mib2.
                 See DESCRIPTION of unisAclMib2CharacteristicsValue
                 to get detail information about the value of this object.
                "
            ::= { unisAclMib2CapabilityEntry 4 }

        unisAclMib2CharacteristicsDesc OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The description of characteristics."
            ::= { unisAclMib2CapabilityEntry 5 }

        unisAclMib2CharacteristicsValue OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The value of capability of this object.
                 TypeOfRuleStringValue : notSupport(0) and the length of
                 RuleString.

                 TypeOfCodeValue : OnlyOneNotSupport(0),
                                   MoreThanOneNotSupport(1)
                 If unisAclMib2CharacteristicsValue is 'moreThanOneNotSupport',
                 unisAclMib2CharacteristicsDesc must be used to depict which
                 protocols are not supported.  The output value of
                 unisAclMib2CharacteristicsDesc has the format of 'a,b'.
                 For example, 'ip,rarp'.

                 layer3 Module:
                 Index    Characteristics           value
                 1        SourceIPAddress           notSupport(0)
                 2        DestinationIPAddress      notSupport(0)
                 3        SourcePort                notSupport(0)
                 4        DestinationPort           notSupport(0)
                 5        IPPrecedence              notSupport(0)
                 6        TOS                       notSupport(0)
                 7        DSCP                      notSupport(0)
                 8        TCPFlag                   notSupport(0)
                 9        FragmentFlag              notSupport(0)
                 10       Log                       notSupport(0)
                 11       RuleMatchCounter          notSupport(0)
                 12       ResetRuleMatchCounter     notSupport(0)
                 13       VPN                       notSupport(0)
                 15       protocol                  notSupport(0)
                 16       AddressFlag               notSupport(0)

                 layer2 Module:
                 Index    Characteristics           value
                 1        ProtocolType              TypeOfCodeValue
                 2        SourceMAC                 notSupport(0)
                 3        DestinationMAC            notSupport(0)
                 4        LSAPType                  TypeOfCodeValue
                 5        CoS                       notSupport(0)

                 UserDefined Module:
                 Index    Characteristics           value
                 1        UserDefaultOffset         TypeOfRuleStringValue
                 2        UserL2RuleOffset          TypeOfRuleStringValue
                 3        UserMplsOffset            TypeOfRuleStringValue
                 4        UserIPv4Offset            TypeOfRuleStringValue
                 5        UserIPv6Offset            TypeOfRuleStringValue
                 6        UserL4Offset              TypeOfRuleStringValue
                 7        UserL5Offset              TypeOfRuleStringValue
                "
            ::= { unisAclMib2CapabilityEntry 6 }

--
-- Nodes of number group
--
        unisAclNumberGroupTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclNumberGroupEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of the number acl group information."
            ::= { unisAclMib2GlobalGroup 3 }

        unisAclNumberGroupEntry OBJECT-TYPE
            SYNTAX UnisAclNumberGroupEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Number acl group information entry."
            INDEX { unisAclNumberGroupType, unisAclNumberGroupIndex }
            ::= { unisAclNumberGroupTable 1 }

        UnisAclNumberGroupEntry ::=
            SEQUENCE
            {
                unisAclNumberGroupType
                    INTEGER,
                unisAclNumberGroupIndex
                    Integer32,
                unisAclNumberGroupRowStatus
                    RowStatus,
                unisAclNumberGroupMatchOrder
                    INTEGER,
                unisAclNumberGroupStep
                    Integer32,
                unisAclNumberGroupDescription
                    OCTET STRING,
                unisAclNumberGroupCountClear
                    CounterClear,
                unisAclNumberGroupRuleCounter
                    Counter32,
                unisAclNumberGroupName
                    OCTET STRING
            }
        unisAclNumberGroupType OBJECT-TYPE
            SYNTAX INTEGER
            {
                ipv4(1),
                ipv6(2),
                mac(3),
                user(4)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The type of number group.
                 Basic ACL and Advanced ACL support ipv4 and ipv6.
                 The range of Basic ACL is from 2000 to 2999.
                 The range of Advanced ACL is from 3000 to 3999.

                 Simple ACL supports ipv6 only.
                 The range of Simple ACL is from 10000 to 42767.

                 MAC ACL support mac only.
                 The range of MAC ACL is from 4000 to 4999.

                 User-defined ACL support user only.
                 The range of user-defined ACL is from 5000 to 5999.
                "
            ::= { unisAclNumberGroupEntry 1 }

        unisAclNumberGroupIndex OBJECT-TYPE
            SYNTAX Integer32 (2000..5999|10000..42767)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The group index of number acl.
                 Basic type:2000..2999
                 Advanced type:3000..3999
                 MAC type:4000..4999
                 User type:5000..5999
                 Simple type:10000..42767
                "
            ::= { unisAclNumberGroupEntry 2 }

        unisAclNumberGroupRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisAclNumberGroupEntry 3 }

        unisAclNumberGroupMatchOrder OBJECT-TYPE
            SYNTAX INTEGER
            {
                config(1),
                auto(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The match-order of number acl group."
            DEFVAL { config }
            ::= { unisAclNumberGroupEntry 4 }

        unisAclNumberGroupStep OBJECT-TYPE
            SYNTAX Integer32 (1..20)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The step of rule index."
            DEFVAL { 5 }
            ::= { unisAclNumberGroupEntry 5 }

        unisAclNumberGroupDescription OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..127))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Description of this acl group."
            ::= { unisAclNumberGroupEntry 6 }

        unisAclNumberGroupCountClear OBJECT-TYPE
            SYNTAX CounterClear
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Reset the value of counters of this group."
            DEFVAL { nouse }
            ::= { unisAclNumberGroupEntry 7 }

        unisAclNumberGroupRuleCounter OBJECT-TYPE
            SYNTAX Counter32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The rule count of number acl group."
            ::= { unisAclNumberGroupEntry 8 }

        unisAclNumberGroupName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..63))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Name of this acl group."
            ::= { unisAclNumberGroupEntry 9 }

--
-- Nodes of named ACL group
--
       unisAclNamedGroupTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclNamedGroupEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of the named ACL group."
            ::= { unisAclMib2GlobalGroup 4 }

        unisAclNamedGroupEntry OBJECT-TYPE
            SYNTAX UnisAclNamedGroupEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Named ACL group entry."
            INDEX
            {
                unisAclNumberGroupType,
                unisAclNamedGroupCategory,
                unisAclNamedGroupName
            }
            ::= { unisAclNamedGroupTable 1 }

        UnisAclNamedGroupEntry ::=
            SEQUENCE
            {
                unisAclNamedGroupCategory
                    INTEGER,
                unisAclNamedGroupName
                    OCTET STRING,
                unisAclNamedGroupRowStatus
                    RowStatus,
                unisAclNamedGroupMatchOrder
                    INTEGER,
                unisAclNamedGroupStep
                    Integer32,
                unisAclNamedGroupDescription
                    OCTET STRING,
                unisAclNamedGroupCountClear
                    CounterClear,
                unisAclNamedGroupRuleCounter
                    Counter32
            }

        unisAclNamedGroupCategory OBJECT-TYPE
            SYNTAX INTEGER
            {
                invalid(0),
                basic(1),
                advanced(2)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The category of number group.  1 indicates basic ACL, 2 indicates
                advanced ACL."
            ::= { unisAclNamedGroupEntry 1 }

        unisAclNamedGroupName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(1..63))
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Name of an ACL group, a case-insensitive string of 1 to 63
                characters.  It must start with an English letter.
                "
            ::= { unisAclNamedGroupEntry 2 }

        unisAclNamedGroupRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisAclNamedGroupEntry 3 }

        unisAclNamedGroupMatchOrder OBJECT-TYPE
            SYNTAX INTEGER
            {
                config(1),
                auto(2)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The match-order of name acl group."
            DEFVAL { config }
            ::= { unisAclNamedGroupEntry 4 }

       unisAclNamedGroupStep OBJECT-TYPE
            SYNTAX Integer32 (1..20)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The numbering step of the increment of the rule index."
            DEFVAL { 5 }
            ::= { unisAclNamedGroupEntry 5 }

        unisAclNamedGroupDescription OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..127))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Description of this ACL group."
            ::= { unisAclNamedGroupEntry 6 }

        unisAclNamedGroupCountClear OBJECT-TYPE
            SYNTAX CounterClear
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Reset the statistics counter of this group."
            DEFVAL { nouse }
            ::= { unisAclNamedGroupEntry 7 }

        unisAclNamedGroupRuleCounter OBJECT-TYPE
            SYNTAX Counter32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The amount of rules of this group."
            ::= { unisAclNamedGroupEntry 8 }

--
-- Node of unisAclIPv6Group
--
        unisAclIPAclGroup OBJECT IDENTIFIER ::= { unisAclMib2Objects 2 }

--
-- Nodes of unisAclIPAclBasicTable
--

        unisAclIPAclBasicTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclIPAclBasicEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of basic rule group.
                 If some objects of this table are not supported by some products,
                 these objects can't be created, changed or applied.
                 Default value of these objects will be returned when they are read.
                "
            ::= { unisAclIPAclGroup 2 }

        unisAclIPAclBasicEntry OBJECT-TYPE
            SYNTAX UnisAclIPAclBasicEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Basic rule group information."
            INDEX { unisAclNumberGroupType,
                    unisAclNumberGroupIndex,
                    unisAclIPAclBasicRuleIndex
                  }
            ::= { unisAclIPAclBasicTable 1 }

        UnisAclIPAclBasicEntry ::=
            SEQUENCE
            {
                unisAclIPAclBasicRuleIndex
                    Integer32,
                unisAclIPAclBasicRowStatus
                    RowStatus,
                unisAclIPAclBasicAct
                    RuleAction,
                unisAclIPAclBasicSrcAddrType
                    InetAddressType,
                unisAclIPAclBasicSrcAddr
                    InetAddress,
                unisAclIPAclBasicSrcPrefix
                    InetAddressPrefixLength,
                unisAclIPAclBasicSrcAny
                    TruthValue,
                unisAclIPAclBasicSrcWild
                    IpAddress,
                unisAclIPAclBasicTimeRangeName
                    OCTET STRING,
                unisAclIPAclBasicFragmentFlag
                    FragmentFlag,
                unisAclIPAclBasicLog
                    TruthValue,
                unisAclIPAclBasicCount
                    Unsigned32,
                unisAclIPAclBasicCountClear
                    CounterClear,
                unisAclIPAclBasicEnable
                    TruthValue,
                unisAclIPAclBasicVpnInstanceName
                    OCTET STRING,
                unisAclIPAclBasicComment
                    OCTET STRING,
                unisAclIPAclBasicCounting
                    TruthValue,
                unisAclIPAclBasicRouteTypeAny
                    TruthValue,
                unisAclIPAclBasicRouteTypeValue
                    Integer32
            }

        unisAclIPAclBasicRuleIndex OBJECT-TYPE
            SYNTAX Integer32 (0..65534)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The rule index of basic acl group."
            ::= { unisAclIPAclBasicEntry 1 }

        unisAclIPAclBasicRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisAclIPAclBasicEntry 2 }

        unisAclIPAclBasicAct OBJECT-TYPE
            SYNTAX RuleAction
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The action of basic acl rule."
            ::= { unisAclIPAclBasicEntry 3 }

        unisAclIPAclBasicSrcAddrType OBJECT-TYPE
            SYNTAX InetAddressType
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The IP addresses type of IP pool."
            ::= { unisAclIPAclBasicEntry 4 }

        unisAclIPAclBasicSrcAddr OBJECT-TYPE
            SYNTAX InetAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value of a local IP address is available for this association.

                 The type of this address is determined by the value of
                 unisAclIPAclBasicSrcAddrType.
                "
            ::= { unisAclIPAclBasicEntry 5 }

        unisAclIPAclBasicSrcPrefix OBJECT-TYPE
            SYNTAX InetAddressPrefixLength
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Denotes the length of a generic Internet network address prefix.
                 A value of n corresponds to an IP address mask
                 that has n contiguous 1-bits from the most significant bit (MSB)
                 and all other bits set to 0.
                "
            ::= { unisAclIPAclBasicEntry 6 }

        unisAclIPAclBasicSrcAny OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of matching any IP address."
            DEFVAL { true }
            ::= { unisAclIPAclBasicEntry 7 }

        unisAclIPAclBasicSrcWild OBJECT-TYPE
            SYNTAX IpAddress
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Source IPv4 address wildcard mask.
                 Only IPv4 Basic Rule supports this object.
                 Default value is '0.0.0.0'.
                "
            ::= { unisAclIPAclBasicEntry 8 }

        unisAclIPAclBasicTimeRangeName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The Time-range of basic acl rule.
                 Default value is zero-length.
                "
            ::= { unisAclIPAclBasicEntry 9 }

        unisAclIPAclBasicFragmentFlag OBJECT-TYPE
            SYNTAX FragmentFlag
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of matching fragmented packets."
            DEFVAL { invalid }
            ::= { unisAclIPAclBasicEntry 10 }

        unisAclIPAclBasicLog OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The packet will be logged when it matches the rule."
            DEFVAL { false }
            ::= { unisAclIPAclBasicEntry 11 }

        unisAclIPAclBasicCount OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The count of matches by the rule."
            ::= { unisAclIPAclBasicEntry 12 }

        unisAclIPAclBasicCountClear OBJECT-TYPE
            SYNTAX CounterClear
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Reset the value of counter."
            DEFVAL { nouse }
            ::= { unisAclIPAclBasicEntry 13 }

        unisAclIPAclBasicEnable OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The rule is active or not.
                 true : active
                 false : inactive
                "
            DEFVAL { false }
            ::= { unisAclIPAclBasicEntry 14 }

        unisAclIPAclBasicVpnInstanceName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The VPN name, to which the rule will be applied.
                 Default value is zero-length.
                "
            ::= { unisAclIPAclBasicEntry 15 }

        unisAclIPAclBasicComment OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..127))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The description of ACL rule.
                 Default value is Zero-length String.
                "
            ::= { unisAclIPAclBasicEntry 16 }

        unisAclIPAclBasicCounting OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The packet will be counted when it matches the rule.
                 It is disabled by default.
                "
            DEFVAL { false }
            ::= { unisAclIPAclBasicEntry 17 }

        unisAclIPAclBasicRouteTypeAny OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The flag of matching any type of routing header of IPv6 packet.
                "
            DEFVAL { false }
            ::= { unisAclIPAclBasicEntry 18 }

        unisAclIPAclBasicRouteTypeValue OBJECT-TYPE
            SYNTAX Integer32 (0..255|65535)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Match specific type of routing header of IPv6 packet."
            DEFVAL { 65535 }
            ::= { unisAclIPAclBasicEntry 19 }

--
-- Notes of unisAclIPAclAdvancedTable
--
        unisAclIPAclAdvancedTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclIPAclAdvancedEntry
            MAX-ACCESS not-accessible
            STATUS current
