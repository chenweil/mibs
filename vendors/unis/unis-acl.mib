--
-- Node of unisAclResourceGroup
--
        unisAclResourceGroup OBJECT IDENTIFIER ::= { unisAclMib2Objects 5 }
--
-- Nodes of unisAclResourceUsageTable
--
        unisAclResourceUsageTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclResourceUsageEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The table shows ACL resource usage information.  Support for
                resource types that are denoted by unisAclResourceType object
                varies with products.  If a type is not supported, the
                corresponding row for the type will not be instantiated
                in this table.
                "
            ::= { unisAclResourceGroup 1 }

        unisAclResourceUsageEntry OBJECT-TYPE
            SYNTAX UnisAclResourceUsageEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Each row contains a brief description of the resource type,
                a port range associated with the chip, total, reserved, and
                configured amount of resource of this type, the percent of
                resource that has been allocated, and so on.
                "
            INDEX
            {
                unisAclResourceChassis,
                unisAclResourceSlot,
                unisAclResourceChip,
                unisAclResourceType
            }
            ::= { unisAclResourceUsageTable 1 }

        UnisAclResourceUsageEntry ::=
            SEQUENCE
            {
                unisAclResourceChassis
                    Unsigned32,
                unisAclResourceSlot
                    Unsigned32,
                unisAclResourceChip
                    Unsigned32,
                unisAclResourceType
                    Integer32,
                unisAclPortRange
                    OCTET STRING,
                unisAclResourceTotal
                    Unsigned32,
                unisAclResourceReserved
                    Unsigned32,
                unisAclResourceConfigured
                    Unsigned32,
                unisAclResourceUsagePercent
                    Unsigned32,
                unisAclResourceTypeDescription
                    OCTET STRING
            }

        unisAclResourceChassis OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The chassis number.  On a centralized or distributed device,
                the value for this node is always zero.
                "
            ::= { unisAclResourceUsageEntry 1 }

        unisAclResourceSlot OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The slot number.  On a centralized device, the value for
                this node is always zero."
            ::= { unisAclResourceUsageEntry 2 }

        unisAclResourceChip OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The chip number.  On a single chip device, the value for
                this node is always zero."
            ::= { unisAclResourceUsageEntry 3 }

        unisAclResourceType OBJECT-TYPE
            SYNTAX Integer32 (1..255)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The resource type."
            ::= { unisAclResourceUsageEntry 4 }

        unisAclPortRange OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..255))
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The port range associated with the chip.  Commas are used to
                separate multiple port ranges, for example, Ethernet1/2 to
                Ethernet1/12, Ethernet1/31 to Ethernet1/48.
                "
            ::= { unisAclResourceUsageEntry 5 }

        unisAclResourceTotal OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Total TCAM entries of the resource type."
            ::= { unisAclResourceUsageEntry 6 }

        unisAclResourceReserved OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The amount of reserved TCAM entries of the resource type."
            ::= { unisAclResourceUsageEntry 7 }

        unisAclResourceConfigured OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The amount of configured TCAM entries of the resource type."
            ::= { unisAclResourceUsageEntry 8 }

        unisAclResourceUsagePercent OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The percent of TCAM entries that have been used for
                this resource type.
                "
            ::= { unisAclResourceUsageEntry 9 }

        unisAclResourceTypeDescription OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(0..31))
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The description of this resource type."
            ::= { unisAclResourceUsageEntry 10 }

--
-- Node of unisAclIntervalGroup
--
        unisAclIntervalGroup OBJECT IDENTIFIER ::= { unisAclMib2Objects 6 }
--
-- Nodes of unisAclIntervalTable
--
        unisAclIntervalTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisAclIntervalEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Log interval table."
            ::= { unisAclIntervalGroup 1 }

        unisAclIntervalEntry OBJECT-TYPE
            SYNTAX UnisAclIntervalEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Log interval entry."
            INDEX
            {
                unisAclIntervalType
            }
            ::= { unisAclIntervalTable 1 }

        UnisAclIntervalEntry ::=
            SEQUENCE
            {
                unisAclIntervalType
                    INTEGER,
                unisAclIntervalValue
                    Integer32,
                unisAclIntervalRowStatus
                    RowStatus
            }

        unisAclIntervalType OBJECT-TYPE
            SYNTAX INTEGER
            {
                logging(1),
                trap(2)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The types of the interval specified for generating
                packet filtering logs or traps.
                "
            ::= { unisAclIntervalEntry 1 }

        unisAclIntervalValue OBJECT-TYPE
            SYNTAX Integer32 (5..1440)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value of interval.
                It must be a multiple of 5 and in the range of 5 to 1440.
                "
            ::= { unisAclIntervalEntry 2 }

        unisAclIntervalRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisAclIntervalEntry 3 }

--
-- Node of unisAclPacketFilterObjects
--
        unisAclPacketFilterObjects OBJECT IDENTIFIER ::= { unisAcl 3 }

        unisPfilterScalarGroup OBJECT IDENTIFIER ::= { unisAclPacketFilterObjects 1 }

        unisPfilterDefaultAction OBJECT-TYPE
            SYNTAX INTEGER
            {
                permit(1),
                deny(2)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "The default action of packet filter.
                By default, the packet filter permits packets that do not match
                any ACL rule to pass.
                "
            ::= { unisPfilterScalarGroup 1 }

        unisPfilterProcessingStatus OBJECT-TYPE
            SYNTAX INTEGER
            {
                processing(1),
                done(2)
            }
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "This object shows the status of the system when applying packet
                filter.  It is forbidden to set or read in unisAclPacketFilterObjects
                MIB module when the value is processing.
                "
            ::= { unisPfilterScalarGroup 2 }

--
-- Nodes of unisPfilterApplyTable
--
        unisPfilterApplyTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisPfilterApplyEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of packet filter application.
                It's not supported to set default action on an entity,
                but supported to enable hardware count of default action
                on an entity.
                "
            ::= { unisAclPacketFilterObjects 2 }

        unisPfilterApplyEntry OBJECT-TYPE
            SYNTAX UnisPfilterApplyEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Packet filter application information entry."
            INDEX
            {
                unisPfilterApplyObjType,
                unisPfilterApplyObjIndex,
                unisPfilterApplyDirection,
                unisPfilterApplyAclType,
                unisPfilterApplyAclIndex
            }
            ::= { unisPfilterApplyTable 1 }

        UnisPfilterApplyEntry ::=
        SEQUENCE
        {
            unisPfilterApplyObjType
                INTEGER,
            unisPfilterApplyObjIndex
                Integer32,
            unisPfilterApplyDirection
                DirectionType,
            unisPfilterApplyAclType
                INTEGER,
            unisPfilterApplyAclIndex
                Integer32,
            unisPfilterApplyHardCount
                TruthValue,
            unisPfilterApplySequence
                Unsigned32,
            unisPfilterApplyCountClear
                CounterClear,
            unisPfilterApplyRowStatus
                RowStatus
        }

        unisPfilterApplyObjType OBJECT-TYPE
            SYNTAX INTEGER
            {
                interface(1),
                vlan(2),
                global(3)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The object type of packet filter application.
                interface: Apply an ACL to the interface to filter packets.
                vlan: Apply an ACL to the VLAN to filter packets.
                global: Apply an ACL globally to filter packets.
                "
            ::= { unisPfilterApplyEntry 1 }

        unisPfilterApplyObjIndex OBJECT-TYPE
            SYNTAX Integer32 (0..2147483647)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The object ID of packet filter application.
                Interface: interface index, equal to ifIndex
                VLAN: VLAN ID, 1..4094
                Global: 0
                "
            ::= { unisPfilterApplyEntry 2 }

        unisPfilterApplyDirection OBJECT-TYPE
            SYNTAX DirectionType
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The direction of packet filter application."
            ::= { unisPfilterApplyEntry 3 }

        unisPfilterApplyAclType OBJECT-TYPE
            SYNTAX INTEGER
            {
                ipv4(1),
                ipv6(2),
                default(3),
                mac(4),
                user(5)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "ACL Type: IPv4, IPv6, default action, MAC, and user.
                Take default action as a special ACL group.
                "
            ::= { unisPfilterApplyEntry 4 }

        unisPfilterApplyAclIndex OBJECT-TYPE
            SYNTAX Integer32  (0|2000..5999)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The ACL group index.
                Basic type: 2000..2999
                Advanced type: 3000..3999
                MAC type: 4000..4999
                User type: 5000..5999
                Default action type: 0
                "
            ::= { unisPfilterApplyEntry 5 }

        unisPfilterApplyHardCount OBJECT-TYPE
            SYNTAX TruthValue
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Hardware count flag.
                true: enable hardware count
                false: disable hardware count
                "
            DEFVAL { false }
            ::= { unisPfilterApplyEntry 6 }

        unisPfilterApplySequence OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The configure sequence of packet filter application."
            ::= { unisPfilterApplyEntry 7 }

        unisPfilterApplyCountClear OBJECT-TYPE
            SYNTAX CounterClear
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Clear the value of counters."
            ::= { unisPfilterApplyEntry 8 }

        unisPfilterApplyRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisPfilterApplyEntry 9 }

