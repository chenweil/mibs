        UnisAclMACEntry ::=
            SEQUENCE
            {
                unisAclMACRuleIndex
                    Integer32,
                unisAclMACRowStatus
                    RowStatus,
                unisAclMACAct
                    RuleAction,
                unisAclMACTypeCode
                    OCTET STRING,
                unisAclMACTypeMask
                    OCTET STRING,
                unisAclMACSrcMac
                    MacAddress,
                unisAclMACSrcMacWild
                    MacAddress,
                unisAclMACDestMac
                    MacAddress,
                unisAclMACDestMacWild
                    MacAddress,
                unisAclMACLsapCode
                    OCTET STRING,
                unisAclMACLsapMask
                    OCTET STRING,
                unisAclMACCos
                    Integer32,
                unisAclMACTimeRangeName
                    OCTET STRING,
                unisAclMACCount
                    Unsigned32,
                unisAclMACCountClear
                    CounterClear,
                unisAclMACEnable
                    TruthValue,
                unisAclMACComment
                    OCTET STRING,
                unisAclMACLog
                    TruthValue,
                unisAclMACCounting
                    TruthValue
            }

        unisAclMACRuleIndex OBJECT-TYPE
            SYNTAX Integer32 (0..65534)
            MAX-ACCESS not-accessible
            STATUS current
