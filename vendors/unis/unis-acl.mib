                    Integer32,
                unisAclIPAclAdvancedPrecedence
                    Integer32,
                unisAclIPAclAdvancedTos
                    Integer32,
                unisAclIPAclAdvancedDscp
                    DSCPValue,
                unisAclIPAclAdvancedTimeRangeName
                    OCTET STRING,
                unisAclIPAclAdvancedTCPFlag
                    TCPFlag,
                unisAclIPAclAdvancedFragmentFlag
                    FragmentFlag,
                unisAclIPAclAdvancedLog
                    TruthValue,
                unisAclIPAclAdvancedCount
                    Unsigned32,
                unisAclIPAclAdvancedCountClear
                    CounterClear,
                unisAclIPAclAdvancedEnable
                    TruthValue,
                unisAclIPAclAdvancedVpnInstanceName
                    OCTET STRING,
                unisAclIPAclAdvancedComment
                    OCTET STRING,
                unisAclIPAclAdvancedReflective
