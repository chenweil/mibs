--  Conformance information
--
    unisDHCPServerMIBConformance OBJECT IDENTIFIER ::= { unisDHCPServerMib 2 }

    unisDHCPServerMIBCompliances OBJECT IDENTIFIER ::= { unisDHCPServerMIBConformance 1 }

    unisDHCPServerMIBGroups OBJECT IDENTIFIER ::= { unisDHCPServerMIBConformance 2 }

--  Units of conformance
--
    unisDHCPServerMIBGroup OBJECT-GROUP
