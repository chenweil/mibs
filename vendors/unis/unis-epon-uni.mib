        The multicast vlan ID which is active.
        "
    ::= { unisEponUniMulticastCtrlInfoEntry 1 }

unisEponUniMultActAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  not-accessible
    STATUS      current
