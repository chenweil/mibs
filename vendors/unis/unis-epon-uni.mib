        "
    ::= { unisEponUniMulticastCtrlInfoEntry 2 }

unisEponUniMultActAccessRule OBJECT-TYPE
    SYNTAX      INTEGER
        {
            deny(1),
            permit(2),
            preview(3)
        }
    MAX-ACCESS  read-only
