    {
        unisEponUniMultActVlan          Integer32,
        unisEponUniMultActAddress       IpAddress,
        unisEponUniMultActAccessRule    INTEGER,
        unisEponUniMultActPreTimes      Integer32,
        unisEponUniMultActPreRemain     Integer32
    }

unisEponUniMultActVlan OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
