--
-- unisUniPoeTable
--

unisUniPoeTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisUniPoeEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        This table is used for configuring the PoE function for UNIs.
        "
    ::= { unisEponUniSysMan 20 }

unisUniPoeEntry OBJECT-TYPE
    SYNTAX      UnisUniPoeEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The entry of the unisUniPoeTable.
        "
    INDEX
        {
            ifIndex,
            unisEponUniIndex
        }
    ::= { unisUniPoeTable 1 }

UnisUniPoeEntry ::= SEQUENCE
    {
        unisUniPoeEnable            TruthValue,
        unisUniPoeMode              INTEGER,
        unisUniPoePriority          INTEGER,
        unisUniPoeMaxPowerClass     INTEGER,
        unisUniPoeMaxPowerValue     Integer32,
        unisUniPoeLegacyEnable      TruthValue
    }

unisUniPoeEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Enable PoE for an UNI.
        "
    DEFVAL { false }
    ::= { unisUniPoeEntry 1 }

unisUniPoeMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            signal(0),
            spare(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Set the PoE mode for an UNI.
        "
    DEFVAL { 0 }
    ::= { unisUniPoeEntry 2 }

unisUniPoePriority OBJECT-TYPE
    SYNTAX      INTEGER
        {
            high(0),
            critical(1),
            low(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Set the PoE priority for an UNI.
        "
    DEFVAL { 0 }
    ::= { unisUniPoeEntry 3 }

unisUniPoeMaxPowerClass OBJECT-TYPE
    SYNTAX      INTEGER
        {
            default(0),
            class0(1),
            class1(2),
            class2(3),
            class3(4),
            class4(5),
            undefined(255)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Set the PoE max power class for an UNI.
        "
    DEFVAL { 0 }
    ::= { unisUniPoeEntry 4 }

unisUniPoeMaxPowerValue OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "mW"
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Set the PoE max power value for an UNI.
        "
    DEFVAL { 0 }
    ::= { unisUniPoeEntry 5 }

unisUniPoeLegacyEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Enable PoE legacy PD detection for an UNI.
        "
    ::= { unisUniPoeEntry 6 }

--
-- unisUniPoeInfoTable
--

unisUniPoeInfoTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisUniPoeInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        This table is used for getting UNIs' PoE information.
        "
    ::= { unisEponUniSysMan 21 }

unisUniPoeInfoEntry OBJECT-TYPE
    SYNTAX      UnisUniPoeInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The entry of the unisUniPoeInfoTable.
        "
    INDEX
        {
            ifIndex,
            unisEponUniIndex
        }
    ::= { unisUniPoeInfoTable 1 }

UnisUniPoeInfoEntry ::= SEQUENCE
    {
        unisUniPoeInfoCapability    INTEGER,
        unisUniPoeInfoEnable        TruthValue,
        unisUniPoeInfoLegacyEnable  TruthValue,
        unisUniPoeInfoMode          INTEGER,
        unisUniPoeInfoPriority      INTEGER,
        unisUniPoeInfoMaxPwrClass   INTEGER,
        unisUniPoeInfoMaxPwrValue   Integer32,
        unisUniPoeInfoPdClass       INTEGER,
        unisUniPoeInfoPwrSuppStat   INTEGER,
        unisUniPoeInfoSignalErrCnt  Integer32,
        unisUniPoeInfoPwrDeniedCnt  Integer32,
        unisUniPoeInfoPwrOverCnt    Integer32,
        unisUniPoeInfoCurOverCnt    Integer32,
        unisUniPoeInfoPdUndetectCnt Integer32,
        unisUniPoeInfoMaxPower      Integer32,
        unisUniPoeInfoCurOutputPwr  Integer32,
        unisUniPoeInfoAvgOutputPwr  Integer32,
        unisUniPoeInfoPeakOutputPwr Integer32
    }

unisUniPoeInfoCapability OBJECT-TYPE
    SYNTAX      INTEGER
        {
            incapable(0),
            capable(1)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE capability.
        "
    ::= { unisUniPoeInfoEntry 1 }

unisUniPoeInfoEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE enabling status.
        "
    ::= { unisUniPoeInfoEntry 2 }

unisUniPoeInfoLegacyEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE legacy PD detection enabling status.
        "
    DEFVAL { 0 }
    ::= { unisUniPoeInfoEntry 3 }

unisUniPoeInfoMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            signal(0),
            spare(1)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE mode.
        "
    ::= { unisUniPoeInfoEntry 4 }

unisUniPoeInfoPriority OBJECT-TYPE
    SYNTAX      INTEGER
        {
            high(0),
            critical(1),
            low(2)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE priority.
        "
    ::= { unisUniPoeInfoEntry 5 }

unisUniPoeInfoMaxPwrClass OBJECT-TYPE
    SYNTAX      INTEGER
        {
            default(0),
            class0(1),
            class1(2),
            class2(3),
            class3(4),
            class4(5),
            undefined(255)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE max power class.
        "
    ::= { unisUniPoeInfoEntry 6 }

unisUniPoeInfoMaxPwrValue OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "mW"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE max power value.
        "
    ::= { unisUniPoeInfoEntry 7 }

unisUniPoeInfoPdClass OBJECT-TYPE
    SYNTAX      INTEGER
        {
            default(0),
            class0(1),
            class1(2),
            class2(3),
            class3(4),
            class4(5),
            undefined(255)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE powered device class.
        "
    ::= { unisUniPoeInfoEntry 8 }

unisUniPoeInfoPwrSuppStat OBJECT-TYPE
    SYNTAX      INTEGER
        {
            noNeed(0),
            searching(1),
            power(2),
            force(3),
            forceFailed(4),
            powerFailed(5)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        UNI PoE power supply status.
        "
    ::= { unisUniPoeInfoEntry 9 }

unisUniPoeInfoSignalErrCnt OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
