--
-- unisEponUni NOTIFICATION
--

unisEponUniTrap OBJECT IDENTIFIER ::= { unisEponUni 2 }

unisEponUniTrapPrefix OBJECT IDENTIFIER ::= { unisEponUniTrap 0 }

unisEponUniLinkUpTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponUniAdminStatus
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponUniLinkUpTrap notification is sent
        when the UNI up event is detected
        and the transmitting switch is turned on.
        "
    ::= { unisEponUniTrapPrefix 1 }

unisEponUniLinkDownTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponUniAdminStatus
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponUniLinkDownTrap notification is sent
        when the UNI down event is detected
        and the transmitting switch is turned on.
        "
    ::= { unisEponUniTrapPrefix 2 }

unisEponUniLoopBackDetectedTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponUniVlan
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponUniLoopBackDetectedTrap notification is sent
        when the UNI loopback event is detected.
        "
    ::= { unisEponUniTrapPrefix 3 }
unisEponUniLoopBackRecoveredTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponUniVlan
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponUniLoopBackRecoveredTrap notification is sent
        when the UNI loopback is recovered.
        "
    ::= { unisEponUniTrapPrefix 4 }

unisEponCTCAlarmTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponCTCAlarmID,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponCTCAlarmInfo
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponCTCAlarmTrap notification is sent
        when an ONU CTC alarm is detected.
        "
    ::= { unisEponUniTrapPrefix 5 }

unisEponCTCAlarmRecoverTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponCTCAlarmID,
            unisEponUniIndex,
            unisEponUniDescr,
            unisEponCTCAlarmInfo
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponCTCAlarmRecoverTrap notification is sent
        when an ONU CTC alarm is cleared.
        "
    ::= { unisEponUniTrapPrefix 6 }

END
