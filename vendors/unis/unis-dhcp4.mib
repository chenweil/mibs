unisDhcpServer2ExpiredEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2ExpiredEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry of objects for displaying information
         of expired IP for DHCP server pools."
    INDEX { unisDhcpServer2PoolIndex, unisDhcpServer2ExpiredIP }
    ::= { unisDhcpServer2ExpiredTable 1 }

UnisDhcpServer2ExpiredEntry ::=
