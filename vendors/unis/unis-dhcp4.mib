        {
            unisDhcpServer2FreeStart             InetAddressIPv4,
            unisDhcpServer2FreeEnd               InetAddressIPv4
        }

unisDhcpServer2FreeStart OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Start IP of free IP range."
    ::= { unisDhcpServer2FreeEntry 1 }

unisDhcpServer2FreeEnd OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "End IP of free IP range."
