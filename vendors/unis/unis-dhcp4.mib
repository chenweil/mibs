-- =============================================================================
-- 12th Table of unisDhcpServer2Tables: unisDhcpServer2ConflictTable
-- =============================================================================
unisDhcpServer2ConflictTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2ConflictEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for displaying the information of conflict
         IP for DHCP server."
    ::= { unisDhcpServer2Tables 12 }

unisDhcpServer2ConflictEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2ConflictEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry for displaying the information of
         conflict IP for DHCP server."
    INDEX { unisDhcpServer2PoolIndex, unisDhcpServer2ConflictIP }
    ::= { unisDhcpServer2ConflictTable 1 }

UnisDhcpServer2ConflictEntry ::=
    SEQUENCE
        {
            unisDhcpServer2ConflictIP            InetAddressIPv4,
            unisDhcpServer2ConflictType          INTEGER,
            unisDhcpServer2ConflictTime          OCTET STRING,
            unisDhcpServer2ConflictRowStatus     RowStatus
        }

unisDhcpServer2ConflictIP OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Conflict IP."
    ::= { unisDhcpServer2ConflictEntry 1 }

unisDhcpServer2ConflictType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            detectByServer(1),
            detectByClient(2)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Type of the detection of conflict IP.
         'detectByServer' denotes that the conflict is detected
         by DHCP server.
         'detectByClient' denotes that the conflict is detected
         by DHCP client."
    ::= { unisDhcpServer2ConflictEntry 2 }

unisDhcpServer2ConflictTime OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..19))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Time when the conflict is detected.
         The structure of the OCTET STRING is
         month/day/year hour:munite:second
         (MM/DD/YYYY hh:mm:ss)."
    ::= { unisDhcpServer2ConflictEntry 3 }

unisDhcpServer2ConflictRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Only destroy action is allow to use."
    ::= { unisDhcpServer2ConflictEntry 4 }

-- =============================================================================
-- 13th Table of unisDhcpServer2Tables: unisDhcpServer2ExpiredTable
-- =============================================================================
unisDhcpServer2ExpiredTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDhcpServer2ExpiredEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
