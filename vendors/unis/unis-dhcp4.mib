        {
            unisDhcpServer2ExpiredIP                  InetAddressIPv4,
            unisDhcpServer2ExpiredClientId            OCTET STRING,
            unisDhcpServer2ExpiredTime                OCTET STRING,
            unisDhcpServer2ExpiredRowStatus           RowStatus
        }

unisDhcpServer2ExpiredIP OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Expired IP address."
    ::= { unisDhcpServer2ExpiredEntry 1 }

unisDhcpServer2ExpiredClientId OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(4..254))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Client identifier or hardware address."
    ::= { unisDhcpServer2ExpiredEntry 2 }

unisDhcpServer2ExpiredTime OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..19))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Expired time.
         The structure of the OCTET STRING is
         month/day/year hour:munite:second
         (MM/DD/YYYY hh:mm:ss)."
    ::= { unisDhcpServer2ExpiredEntry 3 }

unisDhcpServer2ExpiredRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Only destroy action is allow to use."
    ::= { unisDhcpServer2ExpiredEntry 4 }

-- =============================================================================
-- 14th Table of unisDhcpServer2Tables: unisDhcpServer2IPInUseTable
-- =============================================================================
unisDhcpServer2IPInUseTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDhcpServer2IPInUseEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table for displaying the information of IP in use
         for DHCP Server pools. "
    ::= { unisDhcpServer2Tables 14 }

unisDhcpServer2IPInUseEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2IPInUseEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry of objects for displaying information
         of IP in use for DHCP server pools."
    INDEX { unisDhcpServer2PoolIndex, unisDhcpServer2IPInUseIP }
    ::= { unisDhcpServer2IPInUseTable 1 }

UnisDhcpServer2IPInUseEntry ::=
    SEQUENCE
        {
            unisDhcpServer2IPInUseIP                  InetAddressIPv4,
            unisDhcpServer2IPInUseClientId            OCTET STRING,
            unisDhcpServer2IPInUseHardAddr            OCTET STRING,
            unisDhcpServer2IPInUseHardType            INTEGER,
            unisDhcpServer2IPInUseVlanId              Unsigned32,
            unisDhcpServer2IPInUseEndLease            OCTET STRING,
            unisDhcpServer2IPInUseType                INTEGER,
            unisDhcpServer2IPInUseIfIndex             InterfaceIndexOrZero,
            unisDhcpServer2IPInUseRowStatus           RowStatus,
            unisDhcpServer2IPInUseSecondVlanId        Unsigned32
        }

unisDhcpServer2IPInUseIP OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Ip address in use."
    ::= { unisDhcpServer2IPInUseEntry 1 }

unisDhcpServer2IPInUseClientId OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0|4..254))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Client identifier."
    ::= { unisDhcpServer2IPInUseEntry 2 }

unisDhcpServer2IPInUseHardAddr OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0|4..39))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Hardware address."
    ::= { unisDhcpServer2IPInUseEntry 3 }

unisDhcpServer2IPInUseHardType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            default(1),
            ethernet(2),
            tokenRing(3)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Hardware address type."
    ::= { unisDhcpServer2IPInUseEntry 4 }

unisDhcpServer2IPInUseVlanId OBJECT-TYPE
    SYNTAX      Unsigned32(1..4094|65535)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "User's VLAN ID.

         65535 means that a client doesn't have VLAN ID or have an
         invalid VLAN ID."
    ::= { unisDhcpServer2IPInUseEntry 5 }

unisDhcpServer2IPInUseEndLease OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..19))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "End time of lease.
         The structure of the OCTET STRING is
         month/day/year hour:munite:second
         (MM/DD/YYYY hh:mm:ss)."
    ::= { unisDhcpServer2IPInUseEntry 6 }

unisDhcpServer2IPInUseType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            staticUnallocated(1),
            staticOffered(2),
            staticCommitted(3),
            autoOffered(4),
            autoCommitted(5)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Type of binding."
    ::= { unisDhcpServer2IPInUseEntry 7 }

unisDhcpServer2IPInUseIfIndex OBJECT-TYPE
    SYNTAX      InterfaceIndexOrZero
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Interface index information.
         If the value of this object is zero,
         the interface is unknown."
    ::= { unisDhcpServer2IPInUseEntry 8 }

unisDhcpServer2IPInUseRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Only destroy action is allow to use."
    ::= { unisDhcpServer2IPInUseEntry 9 }

unisDhcpServer2IPInUseSecondVlanId OBJECT-TYPE
    SYNTAX      Unsigned32(1..4094|65535)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "User's second VLAN ID.

         65535 means that a client doesn't have second VLAN ID or has an
         invalid second VLAN ID."
    ::= { unisDhcpServer2IPInUseEntry 10 }

-- =============================================================================
-- 15th Table of unisDhcpServer2Tables: unisDhcpServer2DefOptGrpTable
-- =============================================================================
unisDhcpServer2DefOptGrpTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2DefOptGrpEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table containing option group of the DHCP server pool for user
         classes."
    ::= { unisDhcpServer2Tables 15 }

unisDhcpServer2DefOptGrpEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2DefOptGrpEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry containing option group of DHCP pools for user classes."
    INDEX {
            unisDhcpServer2PoolIndex,
            unisDhcpServer2DefOptGrpClass
          }
    ::= { unisDhcpServer2DefOptGrpTable 1 }

UnisDhcpServer2DefOptGrpEntry ::=
    SEQUENCE
        {
            unisDhcpServer2DefOptGrpClass        OCTET STRING,
            unisDhcpServer2DefOptGrpId           Integer32,
            unisDhcpServer2DefOptGrpStatus       RowStatus
        }

unisDhcpServer2DefOptGrpClass OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..63))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "User class name."
    ::= { unisDhcpServer2DefOptGrpEntry 1 }

unisDhcpServer2DefOptGrpId OBJECT-TYPE
    SYNTAX      Integer32 (1..32768)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The option group ID."
    ::= { unisDhcpServer2DefOptGrpEntry 2 }

unisDhcpServer2DefOptGrpStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active, createAndGo, destroy.

         If the value of this object is set to 'createAndGo',
         unisDhcpServer2DefOptGrpId must also be set."
    ::= { unisDhcpServer2DefOptGrpEntry 3 }

-- =============================================================================
-- 16th Table of unisDhcpServer2Tables: unisDhcpServer2ValidClassTable
-- =============================================================================
unisDhcpServer2ValidClassTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2ValidClassEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table containing valid user classes for DHCP server pool."
    ::= { unisDhcpServer2Tables 16 }

unisDhcpServer2ValidClassEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2ValidClassEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry containing valid user classes for DHCP server pool."
    INDEX {
      unisDhcpServer2PoolIndex,
      unisDhcpServer2ValidClassName
    }
    ::= { unisDhcpServer2ValidClassTable 1 }

UnisDhcpServer2ValidClassEntry ::=
    SEQUENCE
        {
            unisDhcpServer2ValidClassName            OCTET STRING,
            unisDhcpServer2ValidClassStatus          RowStatus
        }

unisDhcpServer2ValidClassName OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..63))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "User class name."
    ::= { unisDhcpServer2ValidClassEntry 1 }

unisDhcpServer2ValidClassStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active, createAndGo, destroy."
    ::= { unisDhcpServer2ValidClassEntry 2 }

-- =============================================================================
-- 17th Table of unisDhcpServer2Tables: unisDhcpServer2RuleHwAddrTable
-- =============================================================================
unisDhcpServer2RuleHwAddrTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2RuleHwAddrEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for configuring hardware address rules used to match DHCP
         users."
    ::= { unisDhcpServer2Tables 17 }

unisDhcpServer2RuleHwAddrEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2RuleHwAddrEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry for configuring hardware address rules used to match DHCP
         users."
    INDEX
        {
          unisDhcpServer2ClassName,
          unisDhcpServer2RuleHwAddrNumber
        }
    ::= { unisDhcpServer2RuleHwAddrTable 1 }

UnisDhcpServer2RuleHwAddrEntry ::=
    SEQUENCE
        {
            unisDhcpServer2RuleHwAddrNumber           Integer32,
            unisDhcpServer2RuleHwAddress              OCTET STRING,
            unisDhcpServer2RuleHwAddrMask             OCTET STRING,
            unisDhcpServer2RuleHwAddrType             Integer32,
            unisDhcpServer2RuleHwAddrStatus           RowStatus
        }

unisDhcpServer2RuleHwAddrNumber OBJECT-TYPE
    SYNTAX      Integer32(1..16)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Rule number."
    ::= { unisDhcpServer2RuleHwAddrEntry 1 }

unisDhcpServer2RuleHwAddress OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(4..39))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Hardware address for a rule.

         The structure of the OCTET STRING is H-H-H... while H indicates 4
         hexadecimal characters except that the last H indicates 2 or 4
         hexadecimal characters.

         The SET operation to this object ought to be with the SET operation
         of unisDhcpServer2RuleHwAddrMask together, and any SET operation
         alone to this object will be regarded as an invalid operation."
    ::= { unisDhcpServer2RuleHwAddrEntry 2 }

unisDhcpServer2RuleHwAddrMask OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(4..39))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Mask of hardware address for a rule.

         The structure of the OCTET STRING is the same with
         unisDhcpServer2RuleHwAddress.

         The SET operation to this object ought to be with the SET operation
         of unisDhcpServer2RuleHwAddress together, and any SET operation
         alone to this object will be regarded as an invalid operation."
    ::= { unisDhcpServer2RuleHwAddrEntry 3 }

unisDhcpServer2RuleHwAddrType OBJECT-TYPE
    SYNTAX      Integer32(1..255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Hardware type for a rule.

         The codes of all hardware types see ARP section in RFC 1700.

         The SET operation alone to this object will be regarded as an
         invalid operation."
    DEFVAL { 1 }
    ::= { unisDhcpServer2RuleHwAddrEntry 4 }

unisDhcpServer2RuleHwAddrStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active, createAndGo, destroy.

         If the value of this object is set to 'createAndGo',
         unisDhcpServer2RuleHwAddrAddress and unisDhcpServer2RuleHwAddrMask
         must also be set."
    ::= { unisDhcpServer2RuleHwAddrEntry 5 }

-- =============================================================================
-- 18th Table of unisDhcpServer2Tables: unisDhcpServer2OptionGroupTable
-- =============================================================================
unisDhcpServer2OptionGroupTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2OptionGroupEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for creating DHCP server option groups."
    ::= { unisDhcpServer2Tables 18 }

unisDhcpServer2OptionGroupEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2OptionGroupEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry containing objects for creating or deleting an option
         group."
    INDEX { unisDhcpServer2OptionGroupId }
    ::= { unisDhcpServer2OptionGroupTable 1 }

UnisDhcpServer2OptionGroupEntry ::=
    SEQUENCE
        {
            unisDhcpServer2OptionGroupId         Integer32,
            unisDhcpServer2OptionGroupStatus     RowStatus
        }

unisDhcpServer2OptionGroupId OBJECT-TYPE
    SYNTAX      Integer32 (1..32768)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The option group ID."
    ::= { unisDhcpServer2OptionGroupEntry 1 }

unisDhcpServer2OptionGroupStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active, createAndGo, destroy."
    ::= { unisDhcpServer2OptionGroupEntry 2 }

-- =============================================================================
-- 19th Table of unisDhcpServer2Tables: unisDhcpServer2OptionTable
-- =============================================================================
unisDhcpServer2OptionTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2OptionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for configuring options in an option group."
    ::= { unisDhcpServer2Tables 19 }

unisDhcpServer2OptionEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2OptionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry containing objects for configuring an option in an option
         group."
    INDEX
        {
          unisDhcpServer2OptionGroupId,
          unisDhcpServer2OptionCode
        }
    ::= { unisDhcpServer2OptionTable 1 }

UnisDhcpServer2OptionEntry ::=
    SEQUENCE
        {   unisDhcpServer2OptionCode         Integer32,
            unisDhcpServer2OptionType         INTEGER,
            unisDhcpServer2OptionAscii        OCTET STRING,
            unisDhcpServer2OptionHexStr       OCTET STRING,
            unisDhcpServer2OptionIPStr        OCTET STRING,
            unisDhcpServer2OptionRowStatus    RowStatus
        }

unisDhcpServer2OptionCode OBJECT-TYPE
    SYNTAX      Integer32 (2..254)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Option code."
    ::= { unisDhcpServer2OptionEntry 1 }

unisDhcpServer2OptionType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            ascii(1),
            hex(2),
            ip(3)
        }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Option type.

         'ascii' means using the ascii string that is defined by
         unisDhcpServer2OptionAscii to fill in the option.

         'hex' means using the hex string that is defined by
         unisDhcpServer2OptionHexStr to fill in the option.

         'ip' means using the IP string that is defined by
         unisDhcpServer2OptionIPStr to fill in the option."
    ::= { unisDhcpServer2OptionEntry 2 }

unisDhcpServer2OptionAscii    OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..255))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Ascii string of an option.

         If unisDhcpServer2OptionType is set with 'ascii', this object must
         be set with a non-zero length string."
    ::= { unisDhcpServer2OptionEntry 3 }

unisDhcpServer2OptionHexStr    OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..510))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Hex string of an option.

         The length of the string must be even.  If
         unisDhcpServer2OptionType is set with 'hex', this object must be
         set with a non-zero length string."
    ::= { unisDhcpServer2OptionEntry 4 }

unisDhcpServer2OptionIPStr    OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..127))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "IP string of an option.

         IP addresses are space separated and the leading or trailing space
         will be trimmed.

         1 to 8 IP addresses can be configured simultaneously.

         If unisDhcpServer2OptionType is set with 'ip', this object must be
         set with a non-zero length string that must contain at least one IP
         address."
    ::= { unisDhcpServer2OptionEntry 5 }

unisDhcpServer2OptionRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active, createAndGo, destroy.

         If the value of this object is set to 'createAndGo',
         unisDhcpServer2OptionType must also be set."
    ::= { unisDhcpServer2OptionEntry 6 }

-- =============================================================================
-- 20th Table of unisDhcpServer2Tables: unisDhcpServer2PoolStatTable
-- =============================================================================
unisDhcpServer2PoolStatTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDhcpServer2PoolStatEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table for displaying the statistics of
         a DHCP Server pool."
    ::= { unisDhcpServer2Tables 20 }

unisDhcpServer2PoolStatEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2PoolStatEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry of objects for displaying the statistics of
         a DHCP Server pool."
    INDEX { unisDhcpServer2PoolIndex }
    ::= { unisDhcpServer2PoolStatTable 1 }

UnisDhcpServer2PoolStatEntry ::=
    SEQUENCE
        {
            unisDhcpServer2PoolUsage                  Unsigned32,
            unisDhcpServer2PoolReqCnt                 Counter64,
            unisDhcpServer2PoolReqSuccCnt             Counter64,
            unisDhcpServer2PoolDiscoverCnt            Counter64,
            unisDhcpServer2PoolOfferCnt               Counter64,
            unisDhcpServer2PoolAckCnt                 Counter64,
            unisDhcpServer2PoolIPTotalNum             Unsigned32,
            unisDhcpServer2PoolIPUsedNum              Unsigned32,
            unisDhcpServer2PoolIPIdleNum              Unsigned32,
            unisDhcpServer2PoolIPExcludeNum           Unsigned32,
            unisDhcpServer2PoolConflictNum            Unsigned32,
            unisDhcpServer2PoolAutoBindNum            Unsigned32,
            unisDhcpServer2PoolManualBindNum          Unsigned32,
            unisDhcpServer2PoolExpiredBindNum         Unsigned32,
            unisDhcpServer2PoolNameInfo               OCTET STRING
        }

unisDhcpServer2PoolUsage OBJECT-TYPE
    SYNTAX      Unsigned32(0..100)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The percentage of IP addresses in use
         of the DHCP server pool."
    ::= { unisDhcpServer2PoolStatEntry 1 }

unisDhcpServer2PoolReqCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of address allocation
         requests which matched the DHCP pool and
         were received by the DHCP server."
    ::= { unisDhcpServer2PoolStatEntry 2 }

unisDhcpServer2PoolReqSuccCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of address allocation
         requests success responses which matched
         the DHCP pool and were sent by the DHCP server."
    ::= { unisDhcpServer2PoolStatEntry 3 }

unisDhcpServer2PoolDiscoverCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of DISCOVER packets which
         matched the DHCP pool and were received by the
         DHCP server."
    ::= { unisDhcpServer2PoolStatEntry 4 }

unisDhcpServer2PoolOfferCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of OFFER packets which
         matched the DHCP pool and were sent by the
         DHCP server."
    ::= { unisDhcpServer2PoolStatEntry 5 }

unisDhcpServer2PoolAckCnt OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of ACK packets which
         matched the DHCP pool and were sent by the
         DHCP server."
    ::= { unisDhcpServer2PoolStatEntry 6 }

unisDhcpServer2PoolIPTotalNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of addresses in the
         DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 7 }

unisDhcpServer2PoolIPUsedNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of used addresses in the
         DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 8 }

unisDhcpServer2PoolIPIdleNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of idle addresses in the
         DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 9 }

unisDhcpServer2PoolIPExcludeNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of addresses excluded from address
         allocation in the DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 10 }

unisDhcpServer2PoolConflictNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of conflicting addresses in the
         DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 11 }

unisDhcpServer2PoolAutoBindNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of auto binding addresses in the
         DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 12 }

unisDhcpServer2PoolManualBindNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of manual binding addresses in
         the DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 13 }

unisDhcpServer2PoolExpiredBindNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of expired addresses in
         the DHCP pool."
    ::= { unisDhcpServer2PoolStatEntry 14 }

unisDhcpServer2PoolNameInfo OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..63))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "DHCP server pool name."
    ::= { unisDhcpServer2PoolStatEntry 15 }

-- =============================================================================
-- DHCP relay scalar object definition begin
-- =============================================================================
    unisDhcpRelay2ScalarObjects   OBJECT IDENTIFIER ::= { unisDhcp4 3 }

-- =============================================================================
-- unisDhcpRelay2ScalarObjects: unisDhcpRelay2ConfigGroup
-- =============================================================================
unisDhcpRelay2ConfigGroup  OBJECT IDENTIFIER ::= { unisDhcpRelay2ScalarObjects 1 }

unisDhcpRelay2UserInfoRecord OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "If the value is 'true', user information will be recorded."
    DEFVAL { false }
    ::= { unisDhcpRelay2ConfigGroup 1 }

unisDhcpRelay2UserInfoRefresh OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "If the value is 'true', user information will be refreshed
         on timer."
    DEFVAL { true }
    ::= { unisDhcpRelay2ConfigGroup 2 }

unisDhcpRelay2UserInfoFlushTime OBJECT-TYPE
    SYNTAX      Unsigned32(0..120)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "User information refresh interval in seconds.

         If the value of the object is set to 0, the interval is
         calculated automatically by the number of user
         information entries."
    DEFVAL { 0 }
    ::= { unisDhcpRelay2ConfigGroup 3 }

unisDhcpRelay2ReleaseAddr   OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..47))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "User address to be released.

         The structure of the OCTET STRING is
         IP address:VPN name.
         If the VPN instance name is NOT specified,
         the IP address is in public network."
    ::= { unisDhcpRelay2ConfigGroup 4 }

-- =============================================================================
-- unisDhcpRelay2ScalarObjects: unisDhcpRelay2StatisticsGroup
-- =============================================================================
unisDhcpRelay2StatisticsGroup  OBJECT IDENTIFIER ::= { unisDhcpRelay2ScalarObjects 2 }

unisDhcpRelay2RxClientNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the packets received from DHCP
         clients by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 1 }

unisDhcpRelay2TxClientNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the packets transmitted to
         DHCP clients by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 2 }

unisDhcpRelay2RxServerNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the packets received from
         DHCP Servers by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 3 }

unisDhcpRelay2TxServerNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the packets transmitted to
         DHCP Servers by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 4 }

unisDhcpRelay2BadNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the bad packets received."
    ::= { unisDhcpRelay2StatisticsGroup 5 }

unisDhcpRelay2BootpRequestNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the BOOTREQUEST packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 6 }

unisDhcpRelay2DiscoverNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPDISCOVER packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 7 }

unisDhcpRelay2RequestNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPREQUEST packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 8 }

unisDhcpRelay2DeclineNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPDECLINE packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 9 }

unisDhcpRelay2ReleaseNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPRELEASE packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 10 }

unisDhcpRelay2InformNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPINFORM packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 11 }

unisDhcpRelay2BootpReplyNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the BOOTREPLY packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 12 }

unisDhcpRelay2OfferNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPOFFER packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 13 }

unisDhcpRelay2AckNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPACK packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 14 }

unisDhcpRelay2NakNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The total number of the DHCPNAK packets handled
         by DHCP relay."
    ::= { unisDhcpRelay2StatisticsGroup 15 }

-- =============================================================================
-- DHCP relay table definition.
-- =============================================================================
    unisDhcpRelay2Tables OBJECT IDENTIFIER ::= { unisDhcp4 4 }

-- =============================================================================
-- 1st Table of unisDhcpRelay2Tables: unisDhcpRelay2IfConfigTable
-- =============================================================================
unisDhcpRelay2IfConfigTable  OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpRelay2IfConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for configuring relay functions for interfaces."
    ::= { unisDhcpRelay2Tables 1 }

unisDhcpRelay2IfConfigEntry  OBJECT-TYPE
    SYNTAX      UnisDhcpRelay2IfConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry for configuring relay functions for an interface."
    INDEX { ifIndex }
    ::= { unisDhcpRelay2IfConfigTable 1 }

UnisDhcpRelay2IfConfigEntry ::=
    SEQUENCE
        {
            unisDhcpRelay2IfSelectRelay              TruthValue,
            unisDhcpRelay2IfCheckMac                 TruthValue,
            unisDhcpRelay2IfOpt82Enable              TruthValue,
            unisDhcpRelay2IfOpt82Strategy            INTEGER,
            unisDhcpRelay2IfOpt82CIDMode             INTEGER,
            unisDhcpRelay2IfOpt82CIDNodeType         INTEGER,
            unisDhcpRelay2IfOpt82CIDNodeStr          OCTET STRING,
            unisDhcpRelay2IfOpt82CIDStr              OCTET STRING,
            unisDhcpRelay2IfOpt82CIDFormat           INTEGER,
            unisDhcpRelay2IfOpt82RIDMode             INTEGER,
            unisDhcpRelay2IfOpt82RIDStr              OCTET STRING,
            unisDhcpRelay2IfOpt82RIDFormat           INTEGER
        }

unisDhcpRelay2IfSelectRelay    OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "If the value is 'true', the DHCP relay function
         would be enabled on this interface."
    DEFVAL      { false }
    ::= { unisDhcpRelay2IfConfigEntry 1 }

unisDhcpRelay2IfCheckMac    OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "If the value is 'true', the function of checking MAC address
         of packets received from the interface would be enabled."
    DEFVAL      { false }
    ::= { unisDhcpRelay2IfConfigEntry 2 }

unisDhcpRelay2IfOpt82Enable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "If DHCP relay supports option 82 functions, the
         value is 'true'.
         If DHCP relay does NOT support option 82 functions,
         the value is 'false'."
    DEFVAL      { false }
    ::= { unisDhcpRelay2IfConfigEntry 3 }

unisDhcpRelay2IfOpt82Strategy     OBJECT-TYPE
    SYNTAX      INTEGER
    {
        drop(1),
        keep(2),
        replace(3)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The strategies of DHCP relay handling option 82.

         'drop' indicates DHCP relay discarding the request
         packet including option 82.

         'keep' indicates DHCP relay accepting the request
         packet without any change of the option 82.

         'replace' indicates DHCP relay accepting the
         request packet on condition that it generates a new
         option 82 to replace the original one."
    DEFVAL      { replace }
    ::= { unisDhcpRelay2IfConfigEntry 4 }

unisDhcpRelay2IfOpt82CIDMode OBJECT-TYPE
    SYNTAX      INTEGER
    {
        normal(1),
        verbose(2),
        userDefine(3)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The mode of the circuit ID suboption of DHCP option 82.

         'normal' is the standard mode.

         'verbose' is the detailed mode.

         'userDefine' is the user-defined mode.

         If the value of this object is set to 'userDefine',
         unisDhcpRelay2IfOpt82CIDStr must also be set."
    DEFVAL      { normal }
    ::= { unisDhcpRelay2IfConfigEntry 5 }

unisDhcpRelay2IfOpt82CIDNodeType OBJECT-TYPE
    SYNTAX      INTEGER
    {
        invalid(1),
        mac(2),
        sysname(3),
        userDefine(4)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Type of access node identifier that is used to fill
         in the circuit ID suboption of option 82 when the value
         of unisDhcpRelay2IfOpt82CIDMode is set to 'verbose'.

         The SET operation of this object must be with the SET
         operation of unisDhcpRelay2IfOpt82CIDMode.

         'invalid' indicates that the node identifier is NOT used
         to fill in the circuit ID suboption of option 82.
         If the value of unisDhcpRelay2IfOpt82CIDMode is NOT 'verbose',
         the value of this object is set to 'invalid' automatically.
         Otherwise the value of this object cannot be set to 'invalid'.

         'mac' indicates that the node identifier is filled in with
         the MAC of DHCP relay input interface.
         If the value of unisDhcpRelay2IfOpt82CIDMode is set to
         'verbose', the default value of this object is 'mac'.

         'sysname' indicates that the node identifier is filled in with
         the sysname of the DHCP relay device.

         'userDefine' indicates that the node identifier is filled in with
         the string defined by the object of unisDhcpRelay2IfOpt82CIDNodeStr.
         If the value is set to 'userDefine', the value of
         unisDhcpRelay2IfOpt82CIDNodeStr must be set to a non-zero
         length string simultaneously."
    ::= { unisDhcpRelay2IfConfigEntry 6 }

unisDhcpRelay2IfOpt82CIDNodeStr      OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..50))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
         "The string defined by user to fill in the
          node identifier in the verbose mode.

          If the value of unisDhcpRelay2IfOpt82CIDMode is NOT 'verbose',
          or the value of unisDhcpRelay2IfOpt82CIDNodeType is
          NOT 'userDefine', it is set with a zero-length string
          automatically.
          Otherwise it must be set with a non-zero length string.

          The SET operation of this object must be with the SET
          operation of unisDhcpRelay2IfOpt82CIDMode and
          unisDhcpRelay2IfOpt82CIDNodeType."
    ::= { unisDhcpRelay2IfConfigEntry 7 }

unisDhcpRelay2IfOpt82CIDStr      OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0|3..63))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The string defined by user to fill in the circuit ID
         suboption of option 82 in the user-define mode.

         If the value of unisDhcpRelay2IfOpt82CIDMode is NOT 'userDefine',
         it is set to a zero-length string automatically.
         Otherwise it must be set with a non-zero length string.

         The SET operation of this object must be with the SET
         operation of unisDhcpRelay2IfOpt82CIDMode."
    ::= { unisDhcpRelay2IfConfigEntry 8 }

unisDhcpRelay2IfOpt82CIDFormat    OBJECT-TYPE
    SYNTAX      INTEGER
    {
        hex(1),
        ascii(2),
        undefine(3)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The format of the circuit ID suboption of DHCP
         option 82.

         'hex' is the hex format.

         'ascii' is the ascii format.

         'undefine' is the undefine format.

         If the value of unisDhcpRelay2IfOpt82CIDMode is
         'normal', the value of this object is set to 'hex'
         automatically and cannot be set to 'undefine'.

         If the value of unisDhcpRelay2IfOpt82CIDMode is
         'verbose', the default value of this object is 'undefine'.

         If the value of unisDhcpRelay2IfOpt82CIDMode is
         'userDefine', the value of this object is set to
         'ascii' automatically and cannot be set to other value.

         The SET operation of this object must be with the SET
         operation of unisDhcpRelay2IfOpt82CIDMode."
    ::= { unisDhcpRelay2IfConfigEntry 9 }

unisDhcpRelay2IfOpt82RIDMode OBJECT-TYPE
    SYNTAX      INTEGER
    {
        normal(1),
        sysname(2),
        userDefine(3)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The mode of the remote ID suboption of DHCP
         option 82.

         'normal' is the standard mode.

         'sysname' is the sysname mode.

         'userDefine' is the user-defined mode.

         If the value of this object is set to 'userDefine',
         unisDhcpRelay2IfOpt82RIDStr must also be set."
    DEFVAL      { normal }
    ::= { unisDhcpRelay2IfConfigEntry 10 }

unisDhcpRelay2IfOpt82RIDStr  OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE(0..63))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The string defined by user to fill in the
         remote ID in the user-defined mode.

         If the value of unisDhcpRelay2IfOpt82RIDMode is NOT
         'userDefine', it is set to a zero-length string automatically.
         Otherwise it must be set with a non-zero length string.

         The SET operation of this object must be with the SET
         operation of unisDhcpRelay2IfOpt82RIDMode."
    ::= { unisDhcpRelay2IfConfigEntry 11 }

unisDhcpRelay2IfOpt82RIDFormat    OBJECT-TYPE
    SYNTAX      INTEGER
    {
        hex(1),
        ascii(2)
    }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The format of the remote ID suboption of DHCP option 82.

         'hex' is the hex format.

         'ascii' is the ascii format.

         If the value of unisDhcpRelay2IfOpt82RIDMode is
         'sysname' or 'userDefine', this object is set with 'ascii'
         automatically and cannot be set with other value.

         If the value of unisDhcpRelay2IfOpt82RIDMode is 'normal',
         the default value of this object is 'hex'.

         The SET operation of this object must be with the SET
         operation of unisDhcpRelay2IfOpt82RIDMode."
    ::= { unisDhcpRelay2IfConfigEntry 12 }

-- =============================================================================
-- 2nd Table of unisDhcpRelay2Tables: unisDhcpRelay2SrvAddrTable
-- =============================================================================
unisDhcpRelay2SrvAddrTable  OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpRelay2SrvAddrEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for configuring a DHCP
         server address on the interface."
    ::= { unisDhcpRelay2Tables 2 }

unisDhcpRelay2SrvAddrEntry  OBJECT-TYPE
    SYNTAX      UnisDhcpRelay2SrvAddrEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry for configuring a DHCP
         server address on the interface."
    INDEX
        {
            ifIndex,
            unisDhcpRelay2SrvAddrIP
        }
    ::= { unisDhcpRelay2SrvAddrTable 1 }

UnisDhcpRelay2SrvAddrEntry ::=
    SEQUENCE
        {
            unisDhcpRelay2SrvAddrIP                InetAddressIPv4,
            unisDhcpRelay2SrvAddrRowStatus         RowStatus
        }

unisDhcpRelay2SrvAddrIP    OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Ip address of DHCP server."
    ::= { unisDhcpRelay2SrvAddrEntry 1 }

unisDhcpRelay2SrvAddrRowStatus    OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Operation status of this table entry.
         Three actions are used: active,
         createAndGo, destroy."
    ::= { unisDhcpRelay2SrvAddrEntry 2 }

-- =============================================================================
-- 3rd Table of unisDhcpRelay2Tables: unisDhcpRelay2UserInfoTable
-- =============================================================================
unisDhcpRelay2UserInfoTable   OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpRelay2UserInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table containing the user information of DHCP client."
    ::= { unisDhcpRelay2Tables 3 }

unisDhcpRelay2UserInfoEntry  OBJECT-TYPE
    SYNTAX      UnisDhcpRelay2UserInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry containing the user information of DHCP client."
    INDEX
    {
        unisDhcpRelay2UserInfoVpnIndex,
        unisDhcpRelay2UserInfoIpAddr
    }
    ::= { unisDhcpRelay2UserInfoTable 1 }

UnisDhcpRelay2UserInfoEntry   ::=
    SEQUENCE
    {
        unisDhcpRelay2UserInfoVpnIndex      Unsigned32,
        unisDhcpRelay2UserInfoIpAddr        InetAddressIPv4,
        unisDhcpRelay2UserInfoMacAddr       MacAddress,
        unisDhcpRelay2UserInfoIfIndex       InterfaceIndexOrZero,
        unisDhcpRelay2UserInfoRowStatus     RowStatus
    }

unisDhcpRelay2UserInfoVpnIndex OBJECT-TYPE
    SYNTAX      Unsigned32(0 .. 65534)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "VPN index of the DHCP client."
    ::= { unisDhcpRelay2UserInfoEntry 1 }

unisDhcpRelay2UserInfoIpAddr     OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "DHCP client's IP address."
    ::= { unisDhcpRelay2UserInfoEntry 2 }

unisDhcpRelay2UserInfoMacAddr    OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "DHCP client's MAC address."
    ::= { unisDhcpRelay2UserInfoEntry 3 }

unisDhcpRelay2UserInfoIfIndex      OBJECT-TYPE
    SYNTAX      InterfaceIndexOrZero
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The index of the interface that DHCP client adhered to.
         0 means that no interface information is recorded in the
         user information entry."
    ::= { unisDhcpRelay2UserInfoEntry 4 }

unisDhcpRelay2UserInfoRowStatus     OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Operation status of this table entry.
         Only destroy action is allow to use."
    ::= { unisDhcpRelay2UserInfoEntry 5 }

-- =============================================================================
-- DHCP server trap objects definition.
-- =============================================================================
unisDhcpServer2Traps OBJECT IDENTIFIER ::= { unisDhcp4 5 }

unisDhcpServer2TrapNotify OBJECT IDENTIFIER ::= { unisDhcpServer2Traps 0 }

unisDhcpServer2AddrExhaust NOTIFICATION-TYPE
    OBJECTS
    {
        unisDhcpServer2PoolIndex,
        unisDhcpServer2PoolName
    }
    STATUS      current
    DESCRIPTION
        "This trap is generated when addresses are exhausted
         in the DHCP pool."
    ::= { unisDhcpServer2TrapNotify 1 }

unisDhcpServer2AddrExhaustRecov NOTIFICATION-TYPE
    OBJECTS
    {
        unisDhcpServer2PoolIndex,
        unisDhcpServer2PoolName
    }
    STATUS      current
    DESCRIPTION
        "This trap is generated when the DHCP pool recovers from
         address exhaustion."
    ::= { unisDhcpServer2TrapNotify 2 }

unisDhcpServer2IpUsageOverflow NOTIFICATION-TYPE
    OBJECTS
    {
        unisDhcpServer2PoolIndex,
        unisDhcpServer2PoolName
    }
    STATUS      current
    DESCRIPTION
        "This trap is generated when the IP address usage of DHCP
         server pool above the threshold.  The value of the IP address
         usage is sampled for every 5 minutes."
    ::= { unisDhcpServer2TrapNotify 3 }

unisDhcpServer2AllocOverflow NOTIFICATION-TYPE
    STATUS      current
    DESCRIPTION
        "This trap is generated when the success rate of allocation
         of DHCP server IP address in 5 minutes below the threshold."
    ::= { unisDhcpServer2TrapNotify 4 }

unisDhcpServer2IpUsageOverflowRecov NOTIFICATION-TYPE
    OBJECTS
    {
        unisDhcpServer2PoolIndex,
        unisDhcpServer2PoolName
    }
    STATUS      current
    DESCRIPTION
        "This trap is generated when the IP address usage of DHCP
         server pool reduced to 90% of the threshold.
         The value of the IP address usage is sampled for every 5 minutes."
    ::= { unisDhcpServer2TrapNotify 5 }

END
