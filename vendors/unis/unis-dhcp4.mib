unisDhcpServer2ForbidTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDhcpServer2ForbidEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table for configuring forbidden IP range to DHCP server."
    ::= { unisDhcpServer2Tables 10 }

unisDhcpServer2ForbidEntry OBJECT-TYPE
    SYNTAX      UnisDhcpServer2ForbidEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry for configuring forbidden IP range to DHCP server."
    INDEX
        {
            unisDhcpServer2ForbidVpnName,
            unisDhcpServer2ForbidStart,
            unisDhcpServer2ForbidEnd
        }
    ::= { unisDhcpServer2ForbidTable 1 }

UnisDhcpServer2ForbidEntry ::=
    SEQUENCE
        {
            unisDhcpServer2ForbidVpnName      OCTET STRING,
            unisDhcpServer2ForbidStart        InetAddressIPv4,
            unisDhcpServer2ForbidEnd          InetAddressIPv4,
            unisDhcpServer2ForbidRowStatus    RowStatus
        }

unisDhcpServer2ForbidVpnName OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..31))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Name of the VPN instance that the forbidden IP range
         binds to.

         If the value of this object is 0x1, the network that
         the forbidden IP range belongs to is the public network."
    ::= { unisDhcpServer2ForbidEntry 1 }

unisDhcpServer2ForbidStart OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Start IP of forbidden IP range."
    ::= { unisDhcpServer2ForbidEntry 2 }

unisDhcpServer2ForbidEnd OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "End IP of forbidden IP range."
    ::= { unisDhcpServer2ForbidEntry 3 }

unisDhcpServer2ForbidRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "RowStatus.  Three actions are used: active,
         createAndGo, destroy."
    ::= { unisDhcpServer2ForbidEntry 4 }

