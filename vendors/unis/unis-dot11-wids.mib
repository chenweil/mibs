unisDot11StaticBlackListTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11StaticBlackListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the information of static blacklist."
    ::= { unisDot11WIDSConfigGroup 7 }

unisDot11StaticBlackListEntry OBJECT-TYPE
    SYNTAX      UnisDot11StaticBlackListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the information of static blacklist."
    INDEX
        {
            unisDot11StaticBlackListMAC
        }
    ::= { unisDot11StaticBlackListTable 1 }

UnisDot11StaticBlackListEntry ::= SEQUENCE
    {
        unisDot11StaticBlackListMAC          MacAddress,
        unisDot11StaticBlackListRowStatus    RowStatus
    }

unisDot11StaticBlackListMAC OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the MAC addresses in static blacklist."
    ::= { unisDot11StaticBlackListEntry 1 }

unisDot11StaticBlackListRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
