    ::= { unisDot11StaticWhiteListTable 1 }

UnisDot11StaticWhiteListEntry ::= SEQUENCE
    {
        unisDot11StaticWhiteListMAC          MacAddress,
        unisDot11StaticWhiteListRowStatus    RowStatus
    }

unisDot11StaticWhiteListMAC OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the MAC addresses in whitelist."
    ::= { unisDot11StaticWhiteListEntry 1 }

unisDot11StaticWhiteListRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11StaticWhiteListEntry 2 }
-- *****************************************************************************
-- * End of unisDot11StaticWhiteListTable Definition
