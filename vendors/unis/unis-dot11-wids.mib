--        unisDot11WIDSAtkMac, unisDot11WIDSAtkFrameType
--        to unisDot11WIDSTrapVarObjects.
--  V1.5  2009-07-29 modified by heziqi
--        Add new node unisDot11WIDSDevSnr for unisDot11WIDSDetectedDevTable.
--  V1.6  2010-01-07 modified by Wang Shaojie
--        Add new node unisDot11RogueAPFirstDetectTmStr,
--        unisDot11RogueAPLastDetectTmStr to unisDot11WIDSRogueAPTable
--        Add new node unisDot11RogueStaFirstDetectTmStr,
--        unisDot11RogueStaLastDetectTmStr to unisDot11WIDSRogueStaTable
--        Add unisDot11WIDSAtkChannel, unisDot11WIDSAtkTime,
--        unisDot11WIDSAtkDestMac to unisDot11WIDSTrapVarObjects.
--        2010-03-18 Modified by Deng Gaoliang
--        Add unisDot11BlackListTable
--        2010-05-31 Modified by LiuChen
--        Add new node unisDot11DynBlackListTimeTicks to
--        unisDot11DynBlackListTable.
--        Add new node unisDot11BlackListTimeTicks to
--        unisDot11BlackListTable.
--  V1.7  2011-10-28 modified by jiaolibin
--        Add unisDot11WIDSFirstTrapTime to unisDot11WIDSTrapVarObjects and
--        varialbe bingings unisDot11WIDSFirstTrapTime for unisDot11WIDSFloodTrap,
--        unisDot11WIDSSpoofTrap,unisDot11WIDSWeakIVTrap.
-- =============================================================================
UNIS-DOT11-WIDS-MIB DEFINITIONS ::= BEGIN

IMPORTS
        TruthValue,
        MacAddress,
        RowStatus,
        DateAndTime,
        TEXTUAL-CONVENTION
    FROM SNMPv2-TC
        MODULE-IDENTITY,
        OBJECT-TYPE,
        NOTIFICATION-TYPE,
        Integer32,
        Unsigned32,
        TimeTicks
    FROM SNMPv2-SMI
        unisDot11,
        UnisDot11SSIDStringType,
        UnisDot11ChannelScopeType,
        UnisDot11RadioScopeType,
        UnisDot11ObjectIDType,
        UnisDot11RadioType
    FROM UNIS-DOT11-REF-MIB;

unisDot11WIDS MODULE-IDENTITY
    LAST-UPDATED "201005311800Z"        -- May 31, 2010 at 18:00 GMT
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
        "This MIB provides information about WIDS feature.

        GLOSSARY

        Wireless Intrusion Detection Sensor (WIDS)
        WIDS is designed to be employed in an area that is serviced
        by an existing wireless network.
        It aids in the early detection of malicious outsider attacks
        and intrusions via wireless networks.

        Rogue AP
        A rogue access point is any Wi-Fi access point connected to
        the network without authorization.
        As it is not authorized, if there is any weakness in
        the AP, the hacker will have chance to compromise the
        network.

        Rogue Station
        It is similiar to Rogue AP, while it is a station.

        Monitor AP
        An AP will scan or listen to the air, and try to detect
        wireless attack in the network.
        Some AP products will work only in monitor role, while some
        AP products could switch between normal AP role (only
        provide wireless access service)and monitor AP role.

        Ad Hoc Mode
        Station could work under Ad hoc mode, then they
        could directly do peer-to-peer communication without
        other device support."

    REVISION "201005311800Z"        -- May 31, 2010 at 18:00 GMT
    DESCRIPTION
        "Modified to add new nodes."
    REVISION "200907291800Z"        -- Jul 29, 2009 at 18:00 GMT
    DESCRIPTION
        "Modified to add new nodes."
    REVISION "200905072000Z"        -- May 7, 2009 at 20:00 GMT
    DESCRIPTION
        "Add new nodes and table to support new featrues of WIDS."
    REVISION "200807251900Z"        -- July 23, 2008 at 19:00 GMT
    DESCRIPTION
        "Add new nodes to support new featrues of WIDS."
    REVISION "200706191900Z"        -- June 19, 2007 at 19:00 GMT
    DESCRIPTION
        "To fix bugs in the MIB file."
    REVISION "200705161900Z"        -- May 16, 2007 at 19:00 GMT
    DESCRIPTION
        "To fix bugs in the MIB file."
    REVISION "200608201900Z"        -- August 20, 2006 at 19:00 GMT
    DESCRIPTION
        "The initial revision of this MIB module."
    ::= { unisDot11 5 }

-- ==================================================================
-- Textual Conventions
-- ==================================================================

UnisDot11WIDSDevType ::=  TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION
        "The type of device detected."
    SYNTAX      INTEGER
        {
            client(1),
            ap(2),
            adhoc(3),
            wirelessBridge(4),
            unknown(5)
        }

UnisDot11WIDSDevPermitType ::=  TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION
        "Represents whether the detected device is permitted or a rogue."
    SYNTAX      INTEGER
        {
            permit(1),
            rogue(2)
        }

UnisDot11WIDSAtkType ::=  TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION
        "The type of attack.
         This object has following defined values:
         'act': Action Frame
         'asr': Association Request
         'aur': Authentication Request
         'daf': Deauthentication Frame
         'dar': Disassociation Request
         'ndf': Null Data Frame
         'pbr': Probe Request
         'rar': Reassociation Request
         'saf': Spoofed Disassociation Frame
         'sdf': Spoofed Deauthentication Frame
         'wiv': Weak IV Detected"
    SYNTAX      INTEGER
        {
            act(1),
            asr(2),
            aur(3),
            daf(4),
            dar(5),
            ndf(6),
            pbr(7),
            rar(8),
            saf(9),
            sdf(10),
            wiv(11),
            unknown(12)
        }


-- *****************************************************************************
-- *  Major sections
-- *****************************************************************************
--  WIDS Configuration Group
--  DEFINED AS "The group to provide the configuration information
--  for WIDS."
unisDot11WIDSConfigGroup OBJECT IDENTIFIER       ::= { unisDot11WIDS 1 }
--  The Configuration Group has the following children:
unisDot11WIDSGlobalConfigGroup OBJECT IDENTIFIER
    ::= { unisDot11WIDSConfigGroup 1 }
--  unisDot11WIDSPermitVendorTable         ::= { unisDot11WIDSConfigGroup 2 }
--  unisDot11WIDSPermitSSIDTable           ::= { unisDot11WIDSConfigGroup 3 }
--  unisDot11WIDSIgnoreListTable           ::= { unisDot11WIDSConfigGroup 4 }
--  unisDot11WIDSAttackListTable           ::= { unisDot11WIDSConfigGroup 5 }

--  WIDS detection Group
--  DEFINED AS "The group to provide the detection information
--  for WIDS."
unisDot11WIDSDetectGroup OBJECT IDENTIFIER ::= { unisDot11WIDS 2 }
--  The detection Group has the following children:
--  unisDot11WIDSRogueAPTable              ::= { unisDot11WIDSDetectGroup 1 }
--  unisDot11WIDSRogueAPExtTable           ::= { unisDot11WIDSDetectGroup 2 }
--  unisDot11WIDSRogueStaTable             ::= { unisDot11WIDSDetectGroup 3 }
--  unisDot11WIDSRogueStaExtTable          ::= { unisDot11WIDSDetectGroup 4 }

--  WIDS Notification
--  DEFINED AS "The notification for WIDS feature."
unisDot11WIDSNotifyGroup OBJECT IDENTIFIER ::= { unisDot11WIDS 3 }

-- *****************************************************************************
-- *  unisDot11WIDSGlobalConfigGroup Definition
-- *****************************************************************************
unisDot11WIDSScanMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            all(1),
            auto(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the scope of channels to be scanned.
        The following value are supported
        all(1)            - Do scan on all the channels.
        auto(2)           - Do scan for the channels that automatically
        selected by WIDS."
    DEFVAL      { auto }
    ::= { unisDot11WIDSGlobalConfigGroup 1 }

unisDot11WIDSScanChannelList OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..128))
    MAX-ACCESS  read-write
    STATUS      obsolete
    DESCRIPTION
        "Represents the channel scope to be scanned when
        unisDot11WIDSScanMode is configurated as channelSpec mode.
        Each channel value will be separated by comma character."
    ::= { unisDot11WIDSGlobalConfigGroup 2 }

unisDot11CntMsrMode OBJECT-TYPE
    SYNTAX      BITS
        {
            rogue(0),
            adhoc(1),
            config(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the countermeasures mode."
    ::= { unisDot11WIDSGlobalConfigGroup 3 }

unisDot11DevAgingTime OBJECT-TYPE
    SYNTAX      Integer32(300..1800)
    UNITS       "second"
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the age time for entries in the detected device table.
         If an entry is not detected within the interval, it is deleted from
         the detected device table.  If the deleted entry is that of a rogue, it
         is added into the rogue history table."
    ::= { unisDot11WIDSGlobalConfigGroup 4 }

unisDot11DynBlkListEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether the dynamic blacklist feature is enabled or not.
         'true'  : Enable the dynamic blacklist feature to filter out unwanted
                   clients, which will not get associated.
         'false' : Disable the dynamic blacklist feature."
    ::= { unisDot11WIDSGlobalConfigGroup 5 }

unisDot11DynBlkListLifeTime OBJECT-TYPE
    SYNTAX      Integer32(60..3600)
    UNITS       "second"
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the lifetime for dynamic blacklist entries.
         If a dynamic blacklist entry is not detected within the lifetime, the
         entry will be removed from the dynamic blacklist.
         The lifetime becomes active only if dynamic blacklist feature is
         enabled."
    ::= { unisDot11WIDSGlobalConfigGroup 6 }

unisDot11FloodAtkDctEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether detection of flood attack is enabled or not.
         'true'  : Enable the detection of flood attack.
         'false' : Disable the detection of flood attack."
    ::= { unisDot11WIDSGlobalConfigGroup 7 }

unisDot11SpoofAtkDctEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether detection of Spoof attack is enabled or not.
         'true'  : Enable the detection of Spoof attack.
         'false' : Disable the detection of Spoof attack."
    ::= { unisDot11WIDSGlobalConfigGroup 8 }

unisDot11WeakIVAtkDctEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether detection of weak-iv attack is enabled or not.
         'true'  : Enable the detection of weak-iv attack.
         'false' : Disable the detection of weak-iv attack."
    ::= { unisDot11WIDSGlobalConfigGroup 9 }

unisDot11ResetWIDSRogueHistory OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear all entries from the rogue history table.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 10 }

unisDot11ResetWIDSHistroy OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the history information of attacks
         detected in the WLAN system.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 11 }

unisDot11ResetWIDSStatistics OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the statistics of attacks detected in the
         WLAN system.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 12 }

unisDot11ResetAllDynBlkList OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to remove all entries from the dynamic blacklist.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 13 }

unisDot11ResetAllStcBlkList OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to remove all entries from the static blacklist.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 14 }

unisDot11ResetAllWhtBlkList OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to remove all entries from the static whitelist.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 15 }

unisDot11ResetAllDctRogueAP OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the information of all detected rogue APs.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 16 }

unisDot11ResetAllDctRogueSta OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the information of all detected rogue
         clients.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 17 }

unisDot11ResetAllDctAdhoc OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the information of all detected ad hoc
         devices.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 18 }

unisDot11ResetAllDctDevice OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the information of all detected devices.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 19 }

unisDot11ResetAllDctSSID OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object is used to clear the information of all detected SSIDs.
         It will return false for get operation."
    ::= { unisDot11WIDSGlobalConfigGroup 20 }

unisDot11WidsFloodInterval OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "second"
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The interval of WIDS flood detection."
    DEFVAL      { 1 }
    ::= { unisDot11WIDSGlobalConfigGroup 21 }

unisDot11WidsBlackListThreshold OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When flood attack exceeds the value of this node,
         the MAC address will be added into black list."
    DEFVAL      { 100 }
    ::= { unisDot11WIDSGlobalConfigGroup 22 }

unisDot11SSIDFilterOnOff OBJECT-TYPE
    SYNTAX      INTEGER
        {
            on(1),
            off(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether the SSID permit feature is enabled or not."
    DEFVAL      { on }
    ::= { unisDot11WIDSGlobalConfigGroup 23 }

unisDot11BSSIDFilterOnOff OBJECT-TYPE
    SYNTAX      INTEGER
        {
            on(1),
            off(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents whether the BSSID permit feature is enabled or not."
    DEFVAL      { on }
    ::= { unisDot11WIDSGlobalConfigGroup 24 }

-- **********************************************************************
-- * End of unisDot11WIDSGlobalConfigGroup Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11WIDSPermitVendorTable Definition
-- *****************************************************************************
unisDot11WIDSPermitVendorTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WIDSPermitVendorEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the permitted vendor list, and each vendor
        will be identified by OUI.
        The legal device should be made by the permitted vendors."
    ::= { unisDot11WIDSConfigGroup 2 }

unisDot11WIDSPermitVendorEntry OBJECT-TYPE
    SYNTAX      UnisDot11WIDSPermitVendorEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides the information of permitted vendor."
    INDEX
        {
            unisDot11VendorOUI
        }
    ::= { unisDot11WIDSPermitVendorTable 1 }

UnisDot11WIDSPermitVendorEntry ::= SEQUENCE
    {
        unisDot11VendorOUI                OCTET STRING,
        unisDot11PermitVendorRowStatus    RowStatus,
        unisDot11VendorName               OCTET STRING
    }

unisDot11VendorOUI OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(3))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the vendor OUI information of the wireless device."
    ::= { unisDot11WIDSPermitVendorEntry 1 }

unisDot11PermitVendorRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIDSPermitVendorEntry 2 }

unisDot11VendorName OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..127))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the vendor name of the wireless device."
    ::= { unisDot11WIDSPermitVendorEntry 3 }
-- *****************************************************************************
-- * End of unisDot11WIDSPermitVendorTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11WIDSPermitSSIDTable Definition
-- *****************************************************************************
unisDot11WIDSPermitSSIDTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WIDSPermitSSIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table represents the list of SSID could be permitted in
         the wireless network."
    ::= { unisDot11WIDSConfigGroup 3 }

unisDot11WIDSPermitSSIDEntry OBJECT-TYPE
    SYNTAX      UnisDot11WIDSPermitSSIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry provides the information of permitted SSID."
    INDEX
        {
            unisDot11PermitSSID
        }
    ::= { unisDot11WIDSPermitSSIDTable 1 }

UnisDot11WIDSPermitSSIDEntry ::= SEQUENCE
    {
        unisDot11PermitSSID             UnisDot11SSIDStringType,
        unisDot11PermitSSIDRowStatus    RowStatus,
        unisDot11PermitSSIDDetected     TruthValue
    }

unisDot11PermitSSID OBJECT-TYPE
    SYNTAX      UnisDot11SSIDStringType(SIZE(0..127))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the permitted SSID in the wireless network."
    ::= { unisDot11WIDSPermitSSIDEntry 1 }

unisDot11PermitSSIDRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIDSPermitSSIDEntry 2 }

unisDot11PermitSSIDDetected OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents whether the permitted SSID is detected or not."
    ::= { unisDot11WIDSPermitSSIDEntry 3 }
-- *****************************************************************************
-- * End of unisDot11WIDSPermitSSIDTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11WIDSIgnoreListTable Definition
-- *****************************************************************************
unisDot11WIDSIgnoreListTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WIDSIgnoreListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the MAC address list of stations or APs,
        and WIDS always take them as legal stations or APs."
    ::= { unisDot11WIDSConfigGroup 4 }

unisDot11WIDSIgnoreListEntry OBJECT-TYPE
    SYNTAX      UnisDot11WIDSIgnoreListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the MAC address of station or AP,
        and WIDS always take it as legal station or AP."
    INDEX
        {
            unisDot11IgnoreMAC
        }
    ::= { unisDot11WIDSIgnoreListTable 1 }

UnisDot11WIDSIgnoreListEntry ::= SEQUENCE
    {
        unisDot11IgnoreMAC              MacAddress,
        unisDot11IgnoreListRowStatus    RowStatus,
        unisDot11IgnoreMACDetected      TruthValue,
        unisDot11IgnoreDevType          UnisDot11WIDSDevType
    }

unisDot11IgnoreMAC OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the MAC address of station or AP, and WIDS always
        take it as legal station or AP."
    ::= { unisDot11WIDSIgnoreListEntry 1 }

unisDot11IgnoreListRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIDSIgnoreListEntry 2 }

unisDot11IgnoreMACDetected OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents whether the MAC address detected or not."
    ::= { unisDot11WIDSIgnoreListEntry 3 }

unisDot11IgnoreDevType OBJECT-TYPE
    SYNTAX      UnisDot11WIDSDevType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the type of the MAC address detected.
         The value of this object always is unknown if the MAC address is not
         detected."
    ::= { unisDot11WIDSIgnoreListEntry 4 }
-- *****************************************************************************
-- * End of unisDot11WIDSIgnoreListTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11WIDSAttackListTable Definition
-- *****************************************************************************
unisDot11WIDSAttackListTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WIDSAttackListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table provides the MAC address list of rogue APs or rogue
        stations, the WIDS will take countermeasure as per the MAC
        address list."
    ::= { unisDot11WIDSConfigGroup 5 }

unisDot11WIDSAttackListEntry OBJECT-TYPE
    SYNTAX      UnisDot11WIDSAttackListEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the MAC address of rogue AP or rogue station,
        and the countermeasure will be taken for it."
    INDEX
        {
            unisDot11AttackDeviceMac
        }
    ::= { unisDot11WIDSAttackListTable 1 }

UnisDot11WIDSAttackListEntry ::= SEQUENCE
    {
        unisDot11AttackDeviceMac        MacAddress,
        unisDot11AttackListRowStatus    RowStatus,
        unisDot11AttackDevDetected      TruthValue,
        unisDot11AttackDevType          UnisDot11WIDSDevType
    }

unisDot11AttackDeviceMac OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the MAC address of rogue AP or rogue station,
        and the countermeasure will be taken for it."
    ::= { unisDot11WIDSAttackListEntry 1 }

unisDot11AttackListRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIDSAttackListEntry 2 }

unisDot11AttackDevDetected OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents whether the assigned MAC address in attack list is detected
         or not."
    ::= { unisDot11WIDSAttackListEntry 3 }

unisDot11AttackDevType OBJECT-TYPE
    SYNTAX      UnisDot11WIDSDevType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the type of detected MAC address in attack list.  If the
         MAC address is not detected, it will return unknown(5) for get
         operation."
    ::= { unisDot11WIDSAttackListEntry 4 }
-- *****************************************************************************
-- * End of unisDot11WIDSAttackListTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11StaticWhiteListTable Definition
