            18:  unisCBQoSRedirectCfgInfoTable
            19:  unisCBQoSPriorityMapCfgInfoTable
            20:  unisCBQoSPolicyCfgInfoTable
            21:  unisCBQoSPolicyClassCfgInfoTable
            22:  unisCBQoSIfApplyPolicyTable
            23:  unisCBQoSAtmPvcApplyPolicyTable
            24:  unisCBQoSVlanApplyPolicyTable
            25:  unisCBQoSFrClassApplyPolicyTable
            26:  unisCBQoSFrPvcApplyPolicyTable
            27:  unisCBQoSIfCbqRunInfoTable
            28:  unisCBQoSIfClassMatchRunInfoTable
            29:  unisCBQoSIfCarRunInfoTable
            30:  unisCBQoSIfGtsRunInfoTable
