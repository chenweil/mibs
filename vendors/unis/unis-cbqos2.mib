unisCBQoSNestPolicyCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSNestPolicyCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Nest policy configuration entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSNestPolicyCfgInfoTable 1 }

UnisCBQoSNestPolicyCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSNestPolicyName
            OCTET STRING,
        unisCBQoSNestPolicyRowStatus
            RowStatus
    }

unisCBQoSNestPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE(1..31))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Name of the nested policy."
    ::= { unisCBQoSNestPolicyCfgInfoEntry 1 }

unisCBQoSNestPolicyRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus"
    ::= { unisCBQoSNestPolicyCfgInfoEntry 2 }

--
-- nodes of unisCBQoSMirrorIfCfgInfoTable
