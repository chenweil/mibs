-- Interface CBQ statistics

unisCBQoSIfCbqRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSIfCbqRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of interface CBQ Running statistics.
         When policy using queue behavior is applied on
         interface the interface will using Class Based Queuing."
    ::= { unisCBQoSIfStaticsObjects 1 }

unisCBQoSIfCbqRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSIfCbqRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Interface CBQ statistics entry."
    INDEX { unisCBQoSIfApplyPolicyIfIndex }
    ::= { unisCBQoSIfCbqRunInfoTable 1 }

UnisCBQoSIfCbqRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSIfCbqQueueSize
            Integer32,
        unisCBQoSIfCbqDiscard
            Counter64,
        unisCBQoSIfCbqEfQueueSize
            Integer32,
        unisCBQoSIfCbqAfQueueSize
            Integer32,
        unisCBQoSIfCbqBeQueueSize
            Integer32,
        unisCBQoSIfCbqBeActiveQueueNum
            Integer32,
        unisCBQoSIfCbqBeMaxActiveQueueNum
            Integer32,
        unisCBQoSIfCbqBeTotalQueueNum
            Integer32,
        unisCBQoSIfCbqAfAllocatedQueueNum
            Integer32
    }

unisCBQoSIfCbqQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Packet number of CBQ queue"
    ::= { unisCBQoSIfCbqRunInfoEntry 1 }

unisCBQoSIfCbqDiscard OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The number of discarded packets which couldn't be enqueued."
    ::= { unisCBQoSIfCbqRunInfoEntry 2 }

unisCBQoSIfCbqEfQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Packet number of EF queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 3 }

unisCBQoSIfCbqAfQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Packet number of AF queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 4 }

unisCBQoSIfCbqBeQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Packet number of BE queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 5 }

unisCBQoSIfCbqBeActiveQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The Packet number of Active BE Queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 6 }

unisCBQoSIfCbqBeMaxActiveQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The max Packet number of Active BE Queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 7 }

unisCBQoSIfCbqBeTotalQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The total Packet number of BE Queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 8 }

unisCBQoSIfCbqAfAllocatedQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The Allocated Packet number of AF Queue."
    ::= { unisCBQoSIfCbqRunInfoEntry 9 }

