            Integer32,
        unisCBQoSMirrorIfBackupIfStatus
            INTEGER,
        unisCBQoSMirrorIfRowStatus
            RowStatus
    }

unisCBQoSMirrorIfMainIfIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "IfIndex of mirror interface."
    ::= { unisCBQoSMirrorIfCfgInfoEntry 1 }

unisCBQoSMirrorIfMainIfStatus OBJECT-TYPE
    SYNTAX INTEGER
    {
        inactive(1),
        active(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Status of main interface."
    DEFVAL {active}
    ::= { unisCBQoSMirrorIfCfgInfoEntry 2 }

unisCBQoSMirrorIfBackupIfIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IfIndex of backup mirror interface."
    ::= { unisCBQoSMirrorIfCfgInfoEntry 3 }

unisCBQoSMirrorIfBackupIfStatus OBJECT-TYPE
    SYNTAX INTEGER
    {
        inactive(1),
        active(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Status of backup interface."
    DEFVAL {active}
    ::= { unisCBQoSMirrorIfCfgInfoEntry 4 }

unisCBQoSMirrorIfRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSMirrorIfCfgInfoEntry 5 }

--
-- nodes of unisCBQoSColoredRemarkCfgTable
--
unisCBQoSColoredRemarkCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSColoredRemarkCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of colored remarking feature configuration information."
    ::= { unisCBQoSBehaviorObjects 21 }

unisCBQoSColoredRemarkCfgEntry OBJECT-TYPE
    SYNTAX UnisCBQoSColoredRemarkCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Colored remarking configuration information entry."
    INDEX { unisCBQoSBehaviorIndex, unisCBQoSColoredRemarkType, unisCBQoSColoredRemarkColor }
    ::= { unisCBQoSColoredRemarkCfgTable 1 }

UnisCBQoSColoredRemarkCfgEntry ::=
    SEQUENCE
    {
        unisCBQoSColoredRemarkType
            RemarkType,
        unisCBQoSColoredRemarkColor
            INTEGER,
        unisCBQoSColoredRemarkValue
            Integer32,
        unisCBQoSColoredRemarkRowStatus
            RowStatus
    }

unisCBQoSColoredRemarkType OBJECT-TYPE
    SYNTAX RemarkType
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Remark type."
    ::= { unisCBQoSColoredRemarkCfgEntry 1 }

unisCBQoSColoredRemarkColor OBJECT-TYPE
    SYNTAX INTEGER
    {
        green(1),
        yellow(2),
        red(3)
    }
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Remark color."
    ::= { unisCBQoSColoredRemarkCfgEntry 2 }

unisCBQoSColoredRemarkValue OBJECT-TYPE
    SYNTAX Integer32 (0..4095)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Value to remark:
         for IpPrecedence: 0~7
         for Dscp: 0~63
         for MplsExp: 0~7
         for Vlan8021p: 0~7
         for AtmClp: 0~1
         for FrDe: 0~1
         for VlanID: 1~4094
         for QosLocalID: 1~4095
         for DropPrecedence: 0~2
         for LocalPrecedence: 0~7
         for TopMostVlanID: 1~4094
         for SecondMplsExp: 0~7
        "
    ::= { unisCBQoSColoredRemarkCfgEntry 3 }

unisCBQoSColoredRemarkRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus"
    ::= { unisCBQoSColoredRemarkCfgEntry 4 }

