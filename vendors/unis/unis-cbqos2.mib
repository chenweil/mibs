unisCBQoSWredClassCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSWredClassCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of WRED configuration information."
    ::= { unisCBQoSBehaviorObjects 9 }

unisCBQoSWredClassCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSWredClassCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
