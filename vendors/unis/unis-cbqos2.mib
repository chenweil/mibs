UNIS-CBQOS2-MIB DEFINITIONS ::= BEGIN

IMPORTS
    unisCommon
        FROM UNIS-OID-MIB
    Integer32, Counter64, Unsigned32, OBJECT-TYPE, MODULE-IDENTITY, NOTIFICATION-TYPE
        FROM SNMPv2-SMI
    InetAddressType, InetAddress
        FROM INET-ADDRESS-MIB           -- [RFC3291]
    TEXTUAL-CONVENTION, RowStatus, TruthValue
        FROM SNMPv2-TC;

unisCBQos2 MODULE-IDENTITY
    LAST-UPDATED "201905290000Z"        --May 29, 2019 at 00:00 GMT
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
        "This MIB contains objects to manage configuration and
         monitor running state for Class Based QoS feature.

            *********************************
                    MIB Tables
            **********************************
         This MIB consists of the following tables:
            1 :  unisCBQoSClassifierCfgInfoTable
            2 :  unisCBQoSMatchRuleCfgInfoTable
            3 :  unisCBQoSMatchCpProtoCfgTable
            4 :  unisCBQoSMatchCpGroupCfgTable
            5 :  unisCBQoSBehaviorCfgInfoTable
            6 :  unisCBQoSCarCfgInfoTable
            7 :  unisCBQoSAggregativeCarCfgInfoTable
            8 :  unisCBQoSGtsCfgInfoTable
            9 :  unisCBQoSRemarkCfgInfoTable
            10:  unisCBQoSQueueCfgInfoTable
            11:  unisCBQoSWredCfgInfoTable
