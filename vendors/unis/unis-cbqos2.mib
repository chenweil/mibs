--
-- nodes of unisCBQoSRedirectCfgInfoTable
--
unisCBQoSRedirectCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSRedirectCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of redirect configuration information."
    ::= { unisCBQoSBehaviorObjects 15 }

unisCBQoSRedirectCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSRedirectCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Redirect configuration information entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSRedirectCfgInfoTable 1 }

UnisCBQoSRedirectCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSRedirectType
            INTEGER,
        unisCBQoSRedirectIfIndex
            Integer32,
        unisCBQoSRedirectIpAddressType
            InetAddressType,
        unisCBQoSRedirectIpAddress1
            InetAddress,
        unisCBQoSRedirectIpAddress2
            InetAddress,
        unisCBQoSRedirectRowStatus
            RowStatus,
        unisCBQoSRedirectIpv6Interface1
            Integer32,
        unisCBQoSRedirectIpv6Interface2
            Integer32,
        unisCBQoSRedirectIfVlanID
            Integer32
    }

unisCBQoSRedirectType OBJECT-TYPE
    SYNTAX INTEGER
    {
        cpu(1),
        interface(2),
        nextHop(3)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The type of redirect."
    ::= { unisCBQoSRedirectCfgInfoEntry 1 }

unisCBQoSRedirectIfIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "ifIndex.
         Only the value of unisCBQoSRedirectType is interface,
         can be set this node.
        "
    DEFVAL { 0 }
    ::= { unisCBQoSRedirectCfgInfoEntry 2 }

unisCBQoSRedirectIpAddressType OBJECT-TYPE
    SYNTAX InetAddressType
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "A value that represents a type of Internet address.
          unknown(0)  An unknown address type.  This value MUST
             be used if the value of the corresponding
             InetAddress object is a zero-length string.
             It may also be used to indicate an IP address
             which is not in one of the formats defined
             below.

          ipv4(1)     An IPv4 address as defined by the
             InetAddressIPv4 textual convention.

          ipv6(2)     A global IPv6 address as defined by the
             InetAddressIPv6 textual convention.

          ipv4z(3)    A non-global IPv4 address including a zone
             index as defined by the InetAddressIPv4z
             textual convention.

          ipv6z(4)    A non-global IPv6 address including a zone
             index as defined by the InetAddressIPv6z
             textual convention.

          dns(16)     A DNS domain name as defined by the
             InetAddressDNS textual convention.
          Now supports ipv4 and ipv6.
          Only the value of unisCBQoSRedirectType is next-hop,
          can be set this node and unisCBQoSRedirectIpAddress1 or unisCBQoSRedirectIpAddress2.
        "
    DEFVAL { unknown }
    ::= { unisCBQoSRedirectCfgInfoEntry 3 }

unisCBQoSRedirectIpAddress1 OBJECT-TYPE
    SYNTAX InetAddress
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IP Address.
         If the value of unisCBQoSRedirectType is not next-hop,
         zero-length string will be returned when getting.
         If the value of unisCBQoSRedirectIpAddressType is ipv6,
         this node is set necessarily.
        "
    ::= { unisCBQoSRedirectCfgInfoEntry 4 }

unisCBQoSRedirectIpAddress2 OBJECT-TYPE
    SYNTAX InetAddress
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IP Address.
         If the value of unisCBQoSRedirectType is not next-hop,
         zero-length string will be returned when getting.
         If the value of unisCBQoSRedirectIpAddressType is ipv6,
         this node is set optionally.
        "
    ::= { unisCBQoSRedirectCfgInfoEntry 5 }

unisCBQoSRedirectRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSRedirectCfgInfoEntry 6 }

unisCBQoSRedirectIpv6Interface1 OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IfIndex for ipv6 next hop .
         If and only if the value of unisCBQoSRedirectIpAddressType is ipv6
         and unisCBQoSRedirectIpAddress1 is set,
         this node can be set.
        "
    DEFVAL { 0 }
    ::= { unisCBQoSRedirectCfgInfoEntry 7 }

unisCBQoSRedirectIpv6Interface2 OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IfIndex for ipv6 next hop .
         If and only if the value of unisCBQoSRedirectIpAddressType is ipv6
         and unisCBQoSRedirectIpAddress2 is set,
         this node can be set.
        "
    DEFVAL { 0 }
    ::= { unisCBQoSRedirectCfgInfoEntry 8 }

unisCBQoSRedirectIfVlanID OBJECT-TYPE
    SYNTAX Integer32 (0..4094 |65535)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "VLAN-ID to tag.
         If and only if the value of unisCBQoSRedirectType is interface,
         this node can be set.
        "
    DEFVAL { 65535 }
    ::= { unisCBQoSRedirectCfgInfoEntry 9 }

--
-- nodes of unisCBQoSPriorityMapCfgInfoTable
--
unisCBQoSPriorityMapCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSPriorityMapCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of priority map configuration information."
    ::= { unisCBQoSBehaviorObjects 16 }

unisCBQoSPriorityMapCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSPriorityMapCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "priority map configuration information entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSPriorityMapCfgInfoTable 1 }

UnisCBQoSPriorityMapCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSPriorityMapImportType
            INTEGER,
        unisCBQoSPriorityMapExportType
            INTEGER,
        unisCBQoSPriorityMapGroupIndex
            Integer32,
        unisCBQoSPriorityMapGroupName
            OCTET STRING,
        unisCBQoSPriorityMapAuto
            INTEGER,
        unisCBQoSPriorityMapRowStatus
            RowStatus
    }

unisCBQoSPriorityMapImportType OBJECT-TYPE
    SYNTAX INTEGER
    {
        invalid(1),
        dscp(2),
        dot1p(3),
        exp(4),
        ipPrecedence(5),
        localPrecedence(6),
        dropPrecedence(7)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Import type of map."
    DEFVAL { invalid }
    ::= { unisCBQoSPriorityMapCfgInfoEntry 1 }

unisCBQoSPriorityMapExportType OBJECT-TYPE
    SYNTAX INTEGER
    {
        invalid(1),
        dscp(2),
        dot1p(3),
        exp(4),
        ipPrecedence(5),
        localPrecedence(6),
        dropPrecedence(7)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Export type of map."
    DEFVAL { invalid }
    ::= { unisCBQoSPriorityMapCfgInfoEntry 2 }

unisCBQoSPriorityMapGroupIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Index of map group.
         Map group is managed by UNIS-IFQOS2-MIB.
        "
    ::= { unisCBQoSPriorityMapCfgInfoEntry 3 }

unisCBQoSPriorityMapGroupName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE(0..31))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Name of map group.
         Map group is managed by UNIS-IFQOS2-MIB.
        "
    ::= { unisCBQoSPriorityMapCfgInfoEntry 4 }

unisCBQoSPriorityMapAuto OBJECT-TYPE
    SYNTAX INTEGER
    {
        invalid(1),
        autoDscp(2),
        autoDot1p(3),
        autoMplsExp(4),
        autoIp(5)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Type of priority MAP."
    DEFVAL { invalid }
    ::= { unisCBQoSPriorityMapCfgInfoEntry 5 }

unisCBQoSPriorityMapRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSPriorityMapCfgInfoEntry 6 }

--
-- nodes of unisCBQoSMirrorCfgInfoTable
--
unisCBQoSMirrorCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSMirrorCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of flow mirror configuration information."
    ::= { unisCBQoSBehaviorObjects 17 }

unisCBQoSMirrorCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSMirrorCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Flow mirror configuration information entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSMirrorCfgInfoTable 1 }

UnisCBQoSMirrorCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSMirrorType
            INTEGER,
        unisCBQoSMirrorIfIndex
            OCTET STRING,
        unisCBQoSMirrorVlanID
            Integer32,
        unisCBQoSMirrorRowStatus
            RowStatus
    }

unisCBQoSMirrorType OBJECT-TYPE
    SYNTAX INTEGER
    {
        interface(1),
        cpu(2),
        vlan(3)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Type of flow mirror."
    ::= { unisCBQoSMirrorCfgInfoEntry 1 }

unisCBQoSMirrorIfIndex OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..255))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "IfIndex of destination interface.
         Only the value of unisCBQoSMirrorType is interface,
         can be set this node.
         For example: 1#11#111#1111 means the flow mirror
         destination ifindex is 1,11,111 and 1111.
         '#' is list separator for all IfIndex value.
        "
    ::= { unisCBQoSMirrorCfgInfoEntry 2 }

unisCBQoSMirrorVlanID OBJECT-TYPE
    SYNTAX Integer32 (0..4094)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Destination vlan of flow mirror,
         Only the value of unisCBQoSMirrorType is vlan,
         can be set this node.
        "
    ::= { unisCBQoSMirrorCfgInfoEntry 3 }

unisCBQoSMirrorRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSMirrorCfgInfoEntry 4 }

--
-- nodes of unisCBQoSNestCfgInfoTable
--
unisCBQoSNestCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSNestCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Insert a service VLAN tag or customer VLAN tag into a packet.
        A VLAN tag contains the VLAN ID field and the 802.1p priority
        field.  Both the service VLAN ID and the customer VLAN ID can
        not be set at the same time.  One of them must be set.  The
        802.1p priority of the service VLAN tag and that of the
        customer VLAN tag can be set optionally.  However, both of
        them can not be set at the same time.  The new setting
        overwrites the previous one."
    ::= { unisCBQoSBehaviorObjects 18 }

unisCBQoSNestCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSNestCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "VLAN nesting table entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSNestCfgInfoTable 1 }

UnisCBQoSNestCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSNestServiceVlanID
            Integer32,
        unisCBQoSNestServiceDot1pValue
            Integer32,
        unisCBQoSNestCustomerVlanID
            Integer32,
        unisCBQoSNestCustomerDot1pValue
            Integer32,
        unisCBQoSNestRowStatus
            RowStatus
    }

unisCBQoSNestServiceVlanID OBJECT-TYPE
    SYNTAX Integer32 (1..4094|65535)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "VLAN ID of the service VLAN tag to be inserted.  If the
        customer VLAN tag has been configured, 65535 is returned
        for the service VLAN ID.  The service VLAN ID can not be
        set to 65535."
    ::= { unisCBQoSNestCfgInfoEntry 1 }

unisCBQoSNestServiceDot1pValue OBJECT-TYPE
    SYNTAX Integer32 (0..7|65535)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "802.1p priority value in the service VLAN tag to be inserted.
        If the 802.1p priority is not set, 65535 is returned.  The
        802.1p priority value can not be set to 65535."
    ::= { unisCBQoSNestCfgInfoEntry 2 }

unisCBQoSNestCustomerVlanID OBJECT-TYPE
    SYNTAX Integer32 (1..4094|65535)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "VLAN ID of the customer VLAN tag to be inserted.  If the
        service VLAN tag has been configured, 65535 is returned for
        the customer VLAN ID.  The customer VLAN ID can not be set
        to 65535."
    ::= { unisCBQoSNestCfgInfoEntry 3 }

unisCBQoSNestCustomerDot1pValue OBJECT-TYPE
    SYNTAX Integer32 (0..7|65535)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "802.1p priority value in the customer VLAN tag to be inserted.
        If the 802.1p priority is not set, 65535 is returned.  The
        802.1p priority value can not be set to 65535."
    ::= { unisCBQoSNestCfgInfoEntry 4 }

unisCBQoSNestRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus"
    ::= { unisCBQoSNestCfgInfoEntry 5 }

-- Nest Policy

unisCBQoSNestPolicyCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSNestPolicyCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "This table is used for configuring nest policy."
