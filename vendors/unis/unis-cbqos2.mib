-- unisCBQoSPolicyObjects

unisCBQoSPolicyObjects OBJECT IDENTIFIER ::= { unisCBQoSObjects 3 }

-- Traffic Policy Next Index

unisCBQoSPolicyIndexNext OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object contains an appropriate value to be used for
         unisCBQoSPolicyIndex when creating rows in the
         unisCBQoSPolicyCfgInfoTable."
    ::= { unisCBQoSPolicyObjects 1 }

-- Traffic Policy

unisCBQoSPolicyCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSPolicyCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of QoS policy configuration information."
    ::= { unisCBQoSPolicyObjects 2 }

unisCBQoSPolicyCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSPolicyCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Traffic policy configuration information entry."
    INDEX { unisCBQoSPolicyIndex }
    ::= { unisCBQoSPolicyCfgInfoTable 1 }

UnisCBQoSPolicyCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSPolicyIndex
            Integer32,
        unisCBQoSPolicyName
            OCTET STRING,
        unisCBQoSPolicyClassCount
            Integer32,
        unisCBQoSPolicyConfigMode
            INTEGER,
        unisCBQoSPolicyType
            INTEGER,
        unisCBQoSPolicyClassNextIndex
            Integer32,
        unisCBQoSPolicyRowStatus
            RowStatus
    }

unisCBQoSPolicyIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Index of Traffic Policy."
    ::= { unisCBQoSPolicyCfgInfoEntry 1 }

unisCBQoSPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Name of Traffic Policy."
    ::= { unisCBQoSPolicyCfgInfoEntry 2 }

unisCBQoSPolicyClassCount OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The counter of policy classes of policy."
    ::= { unisCBQoSPolicyCfgInfoEntry 3 }

unisCBQoSPolicyConfigMode OBJECT-TYPE
    SYNTAX INTEGER
    {
        unavailable(0),
        config(1),
        auto(2)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Configuration mode of Traffic Policy.
         Only hardware QoS support this node.
         'unavailable' is returned only when getting value from software QoS.
         'unavailable' can't be set."
    DEFVAL {config}
    ::= { unisCBQoSPolicyCfgInfoEntry 4 }

unisCBQoSPolicyType OBJECT-TYPE
    SYNTAX INTEGER
    {
        systemDefined(1),
        userDefined(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Type of policy."
    ::= { unisCBQoSPolicyCfgInfoEntry 5 }

unisCBQoSPolicyClassNextIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object contains an appropriate value to be used for
         unisCBQoSPolicyClassIndex when creating rows in the
         unisCBQoSPolicyClassCfgInfoTable.
        "
    ::= { unisCBQoSPolicyCfgInfoEntry 6 }

unisCBQoSPolicyRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSPolicyCfgInfoEntry 7 }

-- Classifier-Behavior in QoS policy

unisCBQoSPolicyClassCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSPolicyClassCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of QoS Policy classifier-behavior configuration information."
    ::= { unisCBQoSPolicyObjects 3 }

unisCBQoSPolicyClassCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSPolicyClassCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Traffic policy classifier-behavior configuration information entry."
    INDEX { unisCBQoSPolicyIndex, unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSPolicyClassCfgInfoTable 1 }

UnisCBQoSPolicyClassCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSPolicyClassIndex
            Integer32,
        unisCBQoSPolicyClassClassifierIndex
            Integer32,
        unisCBQoSPolicyClassClassifierName
            OCTET STRING,
        unisCBQoSPolicyClassBehaviorIndex
            Integer32,
        unisCBQoSPolicyClassBehaviorName
            OCTET STRING,
        unisCBQoSPolicyClassPrecedence
            Integer32,
        unisCBQoSPolicyClassRowStatus
            RowStatus,
        unisCBQoSPolicyClassMode
            INTEGER,
        unisCBQoSPolicyClassCfgOrder
            Integer32
    }

unisCBQoSPolicyClassIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "PolicyClass Index in a QoS policy."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 1 }

unisCBQoSPolicyClassClassifierIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Index of classifier applied by a policy.
         It should exist in unisCBQoSClassifierCfgInfoTable."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 2 }

unisCBQoSPolicyClassClassifierName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Name of classifier applied by a policy.
         It is corresponding to unisCBQoSPolicyClassClassifierIndex."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 3 }

unisCBQoSPolicyClassBehaviorIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Index of Behavior applied by a policy.
         It should exist in unisCBQoSBehaviorCfgInfoTable."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 4 }

unisCBQoSPolicyClassBehaviorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Name of Behavior applied by a policy.
         It is corresponding to unisCBQoSPolicyClassBehaviorIndex."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 5 }

unisCBQoSPolicyClassPrecedence OBJECT-TYPE
    SYNTAX Integer32 (0..16383|2147483647)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The Precedence of the class in the policy.
         Only hardware QoS support this node.
         2147483647 is returned only when getting value from software QoS.
         2147483647 can't be set."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 6 }

unisCBQoSPolicyClassRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 7 }

unisCBQoSPolicyClassMode OBJECT-TYPE
    SYNTAX INTEGER
    {
        modeNo(1),
        modeDot1q(2),
        modeQppb(3),
        modeIpSourceGuard(4),
        modeVoiceVlan(5),
        modeDCBX(6)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Set the mode of the classifier-behavior association.  The
        default mode modeNo is a normal mode.
        modeDot1q indicates that the association is used for VLAN mapping.
        modeQppb indicates that the association is used for BGP routing policy.
        modeIpSourceGuard indicates that the association is used for packets
        undergo IP source guard.
        modeVoiceVlan indicates that the association is used for voice data
        packets.
        modeDCBX indicates that the association is used for DCBX.
        "
    DEFVAL {modeNo}
    ::= { unisCBQoSPolicyClassCfgInfoEntry 8 }

unisCBQoSPolicyClassCfgOrder OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "A QoS policy contains multiple classifier-behavior
        associations.  A node indicates the configuration order of
        the corresponding classifier-behavior association."
    ::= { unisCBQoSPolicyClassCfgInfoEntry 9 }

