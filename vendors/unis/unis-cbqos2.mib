            49:  unisCBQoSFrPvcWredRunInfoTable
            50:  unisCBQoSFrPvcAccountingRunInfoTable
            51:  unisCBQoSIfVlanClassMatchRunInfoTable
            52:  unisCBQoSIfVlanAccountingRunInfoTable
            53:  unisCBQoSMirrorCfgInfoTable
            54:  unisCBQoSGlobalApplyTable
            55:  unisCBQoSCpApplyPolicyTable
            56:  unisCBQoSNestCfgInfoTable
            57:  unisCBQoSNestPolicyCfgInfoTable
            58:  unisCBQoSMirrorIfCfgInfoTable
            59:  unisCBQoSColoredRemarkCfgTable
            60:  unisCBQoSPrimapCfgInfoTable
            61:  unisCBQoSColorMapDpCfgInfoTable
            62:  unisCBQoSApplyObjectTable
            63:  unisCBQoSIntApplyObjectTable
            64:  unisCBQoSVlanApplyObjectTable
            65:  unisCBQoSPvcApplyObjectTable
            66:  unisCBQoSNestPolicyApplyObjectTable
            67:  unisCBQoSCpApplyObjectTable
            68:  unisCBQoSCbqRunInfoTable
            69:  unisCBQoSClassMatchRunInfoTable
            70:  unisCBQoSCarRunInfoTable
            71:  unisCBQoSGtsRunInfoTable
            72:  unisCBQoSRemarkRunInfoTable
            73:  unisCBQoSQueueRunInfoTable
            74:  unisCBQoSWredRunInfoTable
            75:  unisCBQoSAccountingRunInfoTable
            76:  unisCBQoSPolicyAccRunInfoTable
            77:  unisCBQoSApplyingStatusObjects
            78:  unisCBQoSNotifications
        "
    REVISION "201905290000Z"        --May 29, 2019 at 00:00 GMT
    DESCRIPTION
        "Modify the value range of unisCBQoSQueueBandwidthValue from 1~10000000 to 1~100000000."
    REVISION "201810310000Z"        --October 31, 2018 at 00:00 GMT
    DESCRIPTION
        "Add unisCBQoSCarGreenpps to unisCBQoSCarRunInfoEntry.
         Add unisCBQoSCarGreenbps to unisCBQoSCarRunInfoEntry.
         Add unisCBQoSCarRedpps to unisCBQoSCarRunInfoEntry.
         Add unisCBQoSCarRedbps to unisCBQoSCarRunInfoEntry.
         Add unisCBQoSCarYellowpps to unisCBQoSCarRunInfoEntry.
         Add unisCBQoSCarYellowbps to unisCBQoSCarRunInfoEntry."
    REVISION "201801040000Z"        --January 4, 2018 at 00:00 GMT
    DESCRIPTION
        "Add unisCBQoSPolicyAccRunInfoTable."
    REVISION "201710100000Z"        --October 10, 2017 at 00:00 GMT
    DESCRIPTION
        "Add unisCBQoSAccountingPktpps to UnisCBQoSAccountingRunInfoEntry.
         Add unisCBQoSAccountingPktbps to UnisCBQoSAccountingRunInfoEntry."
    REVISION "201703020000Z"        --March 02, 2017 at 00:00 GMT
    DESCRIPTION
        "Add unisCBQoSCarClassName to unisCBQoSCarRunInfoEntry."
    REVISION "201602240000Z"        -- Feb 24, 2016 at 00:00 GMT
    DESCRIPTION
        "Add enumeration matchRuleVxlan to MatchRuleType.
         Modify the description of unisCBQoSMatchRuleStringValue."
    REVISION "201207020000Z"        -- July 02, 2012 at 00:00 GMT
    DESCRIPTION
        "Modified to add new tables and new nodes."
    REVISION "200507300000Z"        -- July 30, 2005 at 00:00 GMT
    DESCRIPTION
        "The initial revision of this MIB module."
    ::= { unisQos2 2 }

unisQos2 OBJECT IDENTIFIER ::= { unisCommon 65 }

--
-- type definitions in the traffic classifier
--

-- MatchRuleType
MatchRuleType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Type of Match Rule."
    SYNTAX INTEGER
    {
        matchRuleAny(1),
        matchRuleIpv4Acl(2),
        matchRuleIPv6Acl(3) ,
        matchRuleIPv4Protocol(4),
        matchRuleIPv6Protocol(5),
        matchRuleIPXProtocol(6),
        matchRuleDscp(7),
        matchRuleIpPre(8),
        matchRuleVlan8021p(9),
        matchRuleMplsExp(10),
        matchRuleAtmClp(11),
        matchRuleFrDe(12),
        matchRuleSourceMac(13),
        matchRuleDestinationMac(14),
        matchRuleQosLocalID(15),
        matchRuleClassifier(16),
        matchRuleInboundInterface(17),
        matchRuleRtpPort(18),
        matchRuleSourceIp(19),
        matchRuleVlanID(20),
        matchRuleTopMostVlanID(21),
        matchRuleLocalPrecedence(22),
        matchRuleDropPriority(23),
        matchRuleBittorrent(24),
        matchRuleServiceDot1p(25),
        matchRuleMplsLabel(26),
        matchRuleSecondMplsLabel(27),
        matchRuleSecondMplsExp(28),
        matchRulePacketLength(29),
        matchRuleArpProtocol(30),
        matchRuleForwardingLayer(31),
        matchRuleMacAcl(32),
        matchRuleUserAcl(33),
        matchRuleVxlan(34)
    }
--
-- end of type definitions in the traffic classifier
--

--
-- type definitions in the traffic behavior
--

-- CarAction
CarAction ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "The actions taken when packets conforming or exceeding
         the configured committed information rate(CIR)."
    SYNTAX INTEGER
    {
        invalid(0),
        pass(1),
        continue(2),
        discard(3),
        remark(4),
        remark-ip-continue(5),
        remark-ip-pass(6),
        remark-mplsexp-continue(7),
        remark-mplsexp-pass(8),
        remark-dscp-continue(9),
        remark-dscp-pass(10),
        remark-dot1p-continue(11),
        remark-dot1p-pass(12),
        remark-atm-clp-continue(13),
        remark-atm-clp-pass(14),
        remark-fr-de-continue(15),
        remark-fr-de-pass(16),
        remark-local-pre-pass(17),
        remark-drop-pre-pass(18)
    }

-- RemarkType
RemarkType ::= TEXTUAL-CONVENTION
    STATUS  current
    DESCRIPTION
        "Type of remark."
    SYNTAX INTEGER
    {
        typeIpPrecedence(1),
        typeDscp(2),
        typeMplsExp(3),
        typeVlan8021p(4),
        typeAtmClp(5),
        typeFrDe(6),
        typeVlanID(7),
        typeQosLocalID(8),
        typeDropPrecedence(9),
        typeLocalPrecedence(10),
        typeTopMostVlanID(11),
        typeSecondMplsExp(12)
    }

-- WredType
WredType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "WRED type."
    SYNTAX INTEGER
    {
        typeIpPrecBased(1),
        typeDscpBased(2),
        typeDropLevelBased(3),
        typeAtmClpBased(4),
        typeVlan8021pBased(5),
        typeMplsExpBased(6)
    }

-- QueueType
QueueType ::= TEXTUAL-CONVENTION
    STATUS  current
    DESCRIPTION
        "Queueing Type:
         EF:(1)
         AF:(2)
         WFQ:(3)
        "
    SYNTAX INTEGER
    {
        ef(1),
        af(2),
        wfq(3)
    }

-- QueueBandwidthUnit
QueueBandwidthUnit ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Bandwidth Unit:
         Absolute, Unit : Kbps(1)
         Percent, Unit : %(2)
         RemainPercent, Unit : %(3)
        "
    SYNTAX INTEGER
    {
        unitUnavailable(0),
        unitAbsolute(1),
        unitPercent(2),
        unitRemainPercent(3)
    }

--
-- end of type definitions in the traffic behavior
--

--
-- type definitions in the policy
--

-- Direction
DirectionType ::= TEXTUAL-CONVENTION
    STATUS  current
    DESCRIPTION
        "The direction of policy apply on at interface."
    SYNTAX  INTEGER
    {
        inbound(1),
        outbound(2)
    }

-- ApplyObjectType
ApplyObjectType ::= TEXTUAL-CONVENTION
    STATUS  current
    DESCRIPTION
        "Type of QoS apply object."
    SYNTAX  INTEGER
    {
        interface(1),
        vlan(2),
        atmPvc(3),
        frDlci(4),
        controlPlane(5)
    }

--
-- end of type definitions in policy
--

--
-- Node definitions
--
unisCBQoSObjects OBJECT IDENTIFIER ::= { unisCBQos2 1 }

-- unisCBQoSClassifierObjects

unisCBQoSClassifierObjects OBJECT IDENTIFIER ::= { unisCBQoSObjects 1 }

-- Traffic Classifier Next Index
unisCBQoSClassifierIndexNext OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object contains an appropriate value to be used for
         unisCBQoSClassifierIndex when creating rows in the
         unisCBQoSClassifierCfgInfoTable.
        "
    ::= { unisCBQoSClassifierObjects 1 }

-- Traffic Classifier

unisCBQoSClassifierCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSClassifierCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of Traffic Classifier configuration information."
    ::= { unisCBQoSClassifierObjects 2 }

unisCBQoSClassifierCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSClassifierCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Traffic Classifier Configuration Information Entry."
    INDEX { unisCBQoSClassifierIndex }
    ::= { unisCBQoSClassifierCfgInfoTable 1 }

UnisCBQoSClassifierCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSClassifierIndex
            Integer32,
        unisCBQoSClassifierName
            OCTET STRING,
        unisCBQoSClassifierRuleCount
            Integer32,
        unisCBQoSClassifierOperator
            INTEGER,
        unisCBQoSClassifierLayer
            INTEGER,
        unisCBQoSClassifierType
            INTEGER,
        unisCBQosClassifierMatchRuleNextIndex
            Integer32,
        unisCBQoSClassifierRowStatus
            RowStatus
    }

unisCBQoSClassifierIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Index of Traffic Classifier.  Begin with 0."
    ::= { unisCBQoSClassifierCfgInfoEntry 1 }

unisCBQoSClassifierName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Name of Traffic Classifier."
    ::= { unisCBQoSClassifierCfgInfoEntry 2 }

unisCBQoSClassifierRuleCount OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The counter of match rules of Traffic classifier."
    ::= { unisCBQoSClassifierCfgInfoEntry 3 }

unisCBQoSClassifierOperator OBJECT-TYPE
    SYNTAX INTEGER
    {
        and(1),
        or(2)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Operator of the match rules of traffic classifier.
         Software QoS supports and, or.
         Hardware QoS supports and.
        "
    DEFVAL { and }
    ::= { unisCBQoSClassifierCfgInfoEntry 4 }

unisCBQoSClassifierLayer OBJECT-TYPE
    SYNTAX INTEGER
    {
        unavailable(1),
        l2(2),
        l3(3),
        both(4)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Configuration layer of traffic classifier.
         Only hardware QoS support it.
         1(unavailable) is returned only when getting value from software QoS.
         1(unavailable) can't be set.
        "
    DEFVAL { l3 }
    ::= { unisCBQoSClassifierCfgInfoEntry 5 }

unisCBQoSClassifierType OBJECT-TYPE
    SYNTAX INTEGER
    {
        systemDefined(1),
        userDefined(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The type of classifier."
    ::= { unisCBQoSClassifierCfgInfoEntry 6 }

unisCBQosClassifierMatchRuleNextIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object contains an appropriate value to be used for
         unisCBQoSMatchRuleIndex when creating rows in the
         unisCBQoSMatchRuleCfgInfoTable.
        "
    ::= { unisCBQoSClassifierCfgInfoEntry 7 }

unisCBQoSClassifierRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSClassifierCfgInfoEntry 8 }

-- Match rule

unisCBQoSMatchRuleCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSMatchRuleCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of Match Rule configuration information."
    ::= { unisCBQoSClassifierObjects 3 }

unisCBQoSMatchRuleCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSMatchRuleCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Match Rule Configuration Information Entry."
    INDEX { unisCBQoSClassifierIndex, unisCBQoSMatchRuleIndex }
    ::= { unisCBQoSMatchRuleCfgInfoTable 1 }

UnisCBQoSMatchRuleCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSMatchRuleIndex
            Integer32,
        unisCBQoSMatchRuleIfNot
            INTEGER,
        unisCBQoSMatchRuleType
            MatchRuleType,
        unisCBQoSMatchRuleStringValue
            OCTET STRING,
        unisCBQoSMatchRuleIntValue1
            Unsigned32,
        unisCBQoSMatchRuleIntValue2
            Unsigned32,
        unisCBQoSMatchIpAddressType
            InetAddressType,
        unisCBQoSMatchIpAddress
            InetAddress,
        unisCBQoSMatchRuleRowStatus
            RowStatus
    }

unisCBQoSMatchRuleIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Index of Match Rule."
    ::= { unisCBQoSMatchRuleCfgInfoEntry 1 }

unisCBQoSMatchRuleIfNot OBJECT-TYPE
    SYNTAX INTEGER
    {
        match(1),
        matchNot(2)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Whether the if-match rule is a match or matchNot statement.
         Software QoS supports match, matchNot.
         Hardware QoS supports match.
        "
    DEFVAL { match }
    ::= { unisCBQoSMatchRuleCfgInfoEntry 2 }

unisCBQoSMatchRuleType OBJECT-TYPE
    SYNTAX MatchRuleType
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Type of Match Rule."
    ::= { unisCBQoSMatchRuleCfgInfoEntry 3 }

unisCBQoSMatchRuleStringValue OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..255))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Value of Match Rule.
         IPv4 ACL: SIZE (1..63) ACL name
         MAC ACL: SIZE (1..63) MAC ACL name
         User ACL: SIZE (1..63) User ACL name
         IPv6 ACL: SIZE (1..63) IPv6 ACL name
         SourceMAC: SIZE (12) HHHHHHHHHHHH
           for example: 010102020303 means the match rule is
                        'if-match source-mac 0101-0202-0303'
         DestinationMAC: SIZE (12) HHHHHHHHHHHH
           for example: 010102020303 means the match rule is
                        'if-match destination-mac 0101-0202-0303'
         Classifier: SIZE (1..31) classifier name
         InboundInterface: SIZE (1..47) interface description
         TopMostVlanID, VlanID: SIZE(1..109), up to 10 values can be input;
           for example: 1##5#11#111##114#1111 means the match rule is
                        'if-match vlanid 1 to 5 11 111 to 114 1111'
         SourceIp: SIZE (12) HHHHHHHHHHHH
           for example: 010102020303 means the match rule is
                        'if-match source-ip mac-address 0101-0202-0303'
         MplsLabel: SIZE (1..63), up to 8 values can be input;
           for example: 1#11#111#1111 means the match rule is
                        'if-match mpls-label 1 11 111 1111';
                        1##1111 means the match rule is
                        'if-match mpls-label 1 to 1111';
         SecondMplsLabel: SIZE (1..63), up to 8 values can be input;
           for example: 1#11#111#1111 means the match rule is
                        'if-match mpls-label 1 11 111 1111';
                        1##1111 means the match rule is
                        'if-match mpls-label 1 to 1111';
         VxlanID: SIZE(1..8) Vxlan ID or any
           for example: 20 means the match rule is
                        'if-match vxlan 20';
                        any means the match rule is
                        'if-match vxlan any';
         other types: Set is not permitted.  Zero-length string will
                      be returned when getting.
        "
    ::= { unisCBQoSMatchRuleCfgInfoEntry 4 }

unisCBQoSMatchRuleIntValue1 OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Value of Match Rule.
         IPv4 ACL: 2000~3999
         MAC ACL: 4000~4999
         User ACL: 5000~5999
         IPv6 ACL: 2000~3999; 10000~42767
         Software QoS: 2000~3999
         Hardware Qos: 10000~42767
         RtpPort: start-port: 2000~65535
         IpPrec: value: 0~7, up to 8 values can be input.  The bit set to
                 1 of the last 8 bits of unisCBQoSMatchRuleIntValue1 is
                 used to indicate the value 0~7.
           for example: 0x53(Binary format is 01010011)
                        means the match rule is 'if-match ip-prec 0 1 4 6'
         Dscp: value:0~63, up to 8 values can be input.
               The bit set to 1 of unisCBQoSMatchRuleIntValue1 is used
               to indicate the value 32~63.
               The bit set to 1 of unisCBQoSMatchRuleIntValue2 is used to
               indicate the value 0~31.
           for example: 0x80000003 means the match rule is 'if-match
                        dscp 32 33 63'
         Vlan8021p: value:0~7, up to 8 values can be input.  The bit set
                    to 1 of the last 8 bits of unisCBQoSMatchRuleIntValue1
                    is used to indicate the value 0~7.
           for example: 0x53(Binary format is 01010011) means the
                        match rule is 'if-match customer-dot1p 0 1 4 6'
         MplsExp: value:0~7, up to 8 values can be input.  The bit set to 1
                  of the last 8 bits of unisCBQoSMatchRuleIntValue1 is used
                  to indicate the 8 value 0~7.
           for example: 0x53(Binary format is 01010011) means the
                        match rule is 'if-match mpls 0 1 4 6'
         SourceIp: 1~4095
         QosLocalID: 1~4095
         AtmClp: 0~1
         FrDe: 0~1
         LocalPrecedence: 0~7, up to 8 values can be input.  The bit set to
                          1 of the last 8 bits of unisCBQoSMatchRuleIntValue1
                          is used to indicate the value 0~7.
           for example: 0x53(Binary format is 01010011) means the match
                        rule is 'if-match localprecedence 0 1 4 6'
         DropPriority: 0~2, up to 3 values can be input.  The bit set to 1
                       of the last 3 bits of unisCBQoSMatchRuleIntValue1 is
                       used to indicate the value 0~2.
         ServiceDot1p: 0~7, up to 8 values can be input.
                       The bit set to 1 of the last 8 bits of
                       unisCBQoSMatchRuleIntValue1 is used to indicate
                       the value 0~7.
           for example: 0x53(Binary format is 01010011) means the match
                        rule is 'if-match service-dot1p 0 1 4 6'
         SecondMplsExp: value:0~7, up to 8 values can be input.  The bit
                        set to 1 of the last 8 bits of unisCBQoSMatchRuleIntValue1
                        is used to indicate the 8 value 0~7.
           for example: 0x53(Binary format is 01010011) means the
                        match rule is 'if-match mpls 0 1 4 6'
         PacketLength: 1~2000.  unisCBQoSMatchRuleIntValue1 is used to
                       indicate the minimum value, unisCBQoSMatchRuleIntValue2
                       is used to indicate the maximum value.
         ForwardingLayer: {bridge(1), route(2)}
         other types: Set is not permitted.  0xffffffff will be returned
                      when getting.
        "
    ::= { unisCBQoSMatchRuleCfgInfoEntry 5 }

unisCBQoSMatchRuleIntValue2 OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Value of Match Rule.
         RtpPort: end-port: 2000~65535
         Dscp: value:0~63, up to 8 values can be input.
               The bit set to 1 of unisCBQoSMatchRuleIntValue1 is used to indicate the value 32~63.
               The bit set to 1 of unisCBQoSMatchRuleIntValue2 is used to indicate the value 0~31.
               for example: 0x80000003 means the match rule is 'if-match dscp 0 1 31'
         PacketLength: 1~2000.  unisCBQoSMatchRuleIntValue1 is used to
                       indicate the minimum value, unisCBQoSMatchRuleIntValue2
                       is used to indicate the maximum value.
         other types: Set is not permitted.  0xffffffff will be returned when getting.
        "
    ::= { unisCBQoSMatchRuleCfgInfoEntry 6 }

unisCBQoSMatchIpAddressType OBJECT-TYPE
    SYNTAX InetAddressType
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "A value that represents a type of Internet address.
          unknown(0)  An unknown address type.  This value MUST
            be used if the value of the corresponding
            InetAddress object is a zero-length string.
            It may also be used to indicate an IP address
            which is not in one of the formats defined below.

         ipv4(1)     An IPv4 address as defined by the
                InetAddressIPv4 textual convention.

         ipv6(2)     A global IPv6 address as defined by the
                InetAddressIPv6 textual convention.

         ipv4z(3)    A non-global IPv4 address including a zone
                index as defined by the InetAddressIPv4z textual convention.

         ipv6z(4)    A non-global IPv6 address including a zone
                index as defined by the InetAddressIPv6z textual convention.

         dns(16)     A DNS domain name as defined by the
                InetAddressDNS textual convention.

         Value of match rule.
         SourceIp support this node.
         other types: Set is not permitted.  Unknown will be returned when getting.
        "
    ::= { unisCBQoSMatchRuleCfgInfoEntry 7 }

unisCBQoSMatchIpAddress OBJECT-TYPE
    SYNTAX InetAddress
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Denotes a generic Internet address.
         SourceIP support this node.
         other types: Set is not permitted.  NULL will be returned when getting.
        "
    ::= { unisCBQoSMatchRuleCfgInfoEntry 8 }

unisCBQoSMatchRuleRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSMatchRuleCfgInfoEntry 9 }

-- unisCBQoSMatchCpProtoCfgTable

unisCBQoSMatchCpProtoCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSMatchCpProtoCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of Matching CpProtocol Rule configuration information."
    ::= { unisCBQoSClassifierObjects 4 }

unisCBQoSMatchCpProtoCfgEntry OBJECT-TYPE
    SYNTAX UnisCBQoSMatchCpProtoCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Matching CpProtocol Rule Configuration Information Entry."
    INDEX { unisCBQoSClassifierIndex, unisCBQoSMatchRuleIndex }
    ::= { unisCBQoSMatchCpProtoCfgTable 1 }

UnisCBQoSMatchCpProtoCfgEntry ::=
    SEQUENCE
    {
        unisCBQoSMatchCpProtoIfNot
            INTEGER,
        unisCBQoSMatchCpProtoValue
            OCTET STRING,
        unisCBQoSMatchCpProtoRowStatus
            RowStatus
    }

unisCBQoSMatchCpProtoIfNot OBJECT-TYPE
    SYNTAX INTEGER
    {
        match(1),
        matchNot(2)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Whether the if-match rule is a match or matchNot statement.
         Software QoS supports match, matchNot.
         Hardware QoS supports match.
        "
    DEFVAL { match }
    ::= { unisCBQoSMatchCpProtoCfgEntry 1 }

unisCBQoSMatchCpProtoValue OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..255))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Value of Cp Protocol, SIZE (1..23).  Up to 8 values can be input.
           for example: 1#2#3#4#5 means the match rule is
                        'if-match control-plane protocol arp arp-snooping
                        bgp bgp4+ bpdu-tunnel';
        arp: 1
        arp-snooping: 2
        bgp: 3
        bgp4+: 4
        bpdu-tunnel: 5
        cdp: 6
        cfd: 7
        dhcp: 8
        dhcp-snooping: 9
        dhcp6: 10
        dldp: 11
        dot1x: 12
        gmrp: 13
        gvrp: 14
        http: 15
        https: 16
        icmp: 17
        icmp6: 18
        igmp: 19
        igmp-snooping: 20
        irdp: 21
        isis: 22
        lacp: 23
        ldp: 24
        ldp6: 25
        lldp: 26
        mld: 27
        msdp: 28
        ntp: 29
        oam: 30
        ospf-multicast: 31
        ospf-unicast: 32
        ospf3-multicast: 33
        ospf3-unicast: 34
        pagp: 35
        pim-multicast: 36
        pim-unicast: 37
        pim6-multicast: 38
        pim6-unicast: 39
        portal: 40
        pppoe-negotiation: 41
        pvst: 42
        radius: 43
        rip: 44
        ripng: 45
        rrpp: 46
        rsvp: 47
        smart-link: 48
        snmp: 49
        stp: 50
        tacas: 51
        udld: 52
        udp-helper: 53
        vrrp: 54
        vrrp6: 55
        vtp: 56
        ip-option: 57
        ipv6-option: 58
        ssh: 59
        telnet: 60"
    ::= { unisCBQoSMatchCpProtoCfgEntry 2 }

unisCBQoSMatchCpProtoRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSMatchCpProtoCfgEntry 3 }

-- unisCBQoSMatchCpGroupCfgTable

unisCBQoSMatchCpGroupCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSMatchCpGroupCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of matching Cp protocol group rule configuration information."
    ::= { unisCBQoSClassifierObjects 5 }

unisCBQoSMatchCpGroupCfgEntry OBJECT-TYPE
    SYNTAX UnisCBQoSMatchCpGroupCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Matching Cp protocol group Rule Configuration Information Entry."
    INDEX { unisCBQoSClassifierIndex, unisCBQoSMatchRuleIndex }
    ::= { unisCBQoSMatchCpGroupCfgTable 1 }

UnisCBQoSMatchCpGroupCfgEntry ::=
    SEQUENCE
    {
        unisCBQoSMatchCpGroupIfNot
            INTEGER,
        unisCBQoSMatchCpGroupValue
            INTEGER,
        unisCBQoSMatchCpGroupRowStatus
            RowStatus
    }

unisCBQoSMatchCpGroupIfNot OBJECT-TYPE
    SYNTAX INTEGER
    {
        match(1),
        matchNot(2)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Whether the if-match rule is a match or matchNot statement.
         Software QoS supports match, matchNot.
         Hardware QoS supports match.
        "
    DEFVAL { match }
    ::= { unisCBQoSMatchCpGroupCfgEntry 1 }

unisCBQoSMatchCpGroupValue OBJECT-TYPE
    SYNTAX INTEGER
    {
        critical(1),
        important(2),
        management(3),
        normal(4),
        redirect(5),
        monitor(6),
        exception(7)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Type of Cp protocol group.
        "
    ::= { unisCBQoSMatchCpGroupCfgEntry 2 }

unisCBQoSMatchCpGroupRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSMatchCpGroupCfgEntry 3 }

-- unisCBQoSBehaviorObjects

unisCBQoSBehaviorObjects OBJECT IDENTIFIER ::= { unisCBQoSObjects 2 }

-- Traffic Behavior Next Index

unisCBQoSBehaviorIndexNext OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object contains an appropriate value to be used for
         unisCBQoSBehaviorIndex when creating rows in the
         unisCBQoSBehaviorCfgInfoTable."
    ::= { unisCBQoSBehaviorObjects 1 }

-- Traffic Behavior

unisCBQoSBehaviorCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSBehaviorCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of Traffic Behavior configuration information."
    ::= { unisCBQoSBehaviorObjects 2 }

unisCBQoSBehaviorCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSBehaviorCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Traffic Behavior Configuration Information Entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSBehaviorCfgInfoTable 1 }

UnisCBQoSBehaviorCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSBehaviorIndex
            Integer32,
        unisCBQoSBehaviorName
            OCTET STRING,
        unisCBQoSBehaviorType
            INTEGER,
        unisCBQoSBehaviorRowStatus
            RowStatus
    }

unisCBQoSBehaviorIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Index of Traffic Behavior."
    ::= { unisCBQoSBehaviorCfgInfoEntry 1 }

unisCBQoSBehaviorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Name of Traffic Behavior."
    ::= { unisCBQoSBehaviorCfgInfoEntry 2 }

unisCBQoSBehaviorType OBJECT-TYPE
    SYNTAX INTEGER
    {
        systemDefined(1),
        userDefined(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Type of behavior."
    ::= { unisCBQoSBehaviorCfgInfoEntry 3 }

unisCBQoSBehaviorRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSBehaviorCfgInfoEntry 4 }

-- CAR

unisCBQoSCarCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSCarCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of CAR feature configuration information."
    ::= { unisCBQoSBehaviorObjects 3 }

unisCBQoSCarCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSCarCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "CAR Configuration Information Entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSCarCfgInfoTable 1 }

UnisCBQoSCarCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSCarCir
            Unsigned32,
        unisCBQoSCarCbs
            Unsigned32,
        unisCBQoSCarEbs
            Unsigned32,
        unisCBQoSCarPir
            Unsigned32,
        unisCBQoSCarPbs
            Unsigned32,
        unisCBQoSCarGreenAction
            CarAction,
        unisCBQoSCarGreenRemarkValue
            Integer32,
        unisCBQoSCarYellowAction
            CarAction,
        unisCBQoSCarYellowRemarkValue
            Integer32,
        unisCBQoSCarRedAction
            CarAction,
        unisCBQoSCarRedRemarkValue
            Integer32,
        unisCBQoSCarPolicedPriorityMapType
            INTEGER,
        unisCBQoSCarRowStatus
            RowStatus
    }

unisCBQoSCarCir OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Committed Information Rate.  Unit: kbps."
    ::= { unisCBQoSCarCfgInfoEntry 1 }

unisCBQoSCarCbs OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Committed Burst Size.  Unit: byte."
    ::= { unisCBQoSCarCfgInfoEntry 2 }

unisCBQoSCarEbs OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Excess Burst Size.  Unit: byte.
         Only software QoS support this node.
         4294967295 is returned only when getting value from hardware QoS.
         4294967295 can't be set."
    DEFVAL {0}
    ::= { unisCBQoSCarCfgInfoEntry 3 }

unisCBQoSCarPir OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Peak Information Rate.  Unit: kbps.
         Only hardware QoS support this node.
         4294967295 is returned only when getting value from software QoS.
         4294967295 can't be set."
    ::= { unisCBQoSCarCfgInfoEntry 4 }

unisCBQoSCarPbs OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Peak Burst Size.  Unit: byte.
         Only hardware QoS support this node.
         4294967295 is returned only when getting value from software QoS.
         4294967295 can't be set."
    ::= { unisCBQoSCarCfgInfoEntry 5 }

unisCBQoSCarGreenAction OBJECT-TYPE
    SYNTAX CarAction
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Green Action
         Hardware QoS : pass, discard, remark.
         Software QoS : pass, discard, remark IP Precedence, remark DSCP, remark MPLS EXP.
        "
    DEFVAL {pass}
    ::= { unisCBQoSCarCfgInfoEntry 6 }

unisCBQoSCarGreenRemarkValue OBJECT-TYPE
    SYNTAX Integer32 (0..63|255)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The value is to remark When green action is remarking.
         For remarking DSCP, the range is 0~63;
         For remarking IP Precedence and MPLS EXP, the range is 0~7;
         Only software QoS support this node.
         255 is returned only when getting value from hardware QoS or
         when action being pass, discard of software QoS.
         255 can't be set.
        "
    ::= { unisCBQoSCarCfgInfoEntry 7 }

unisCBQoSCarYellowAction OBJECT-TYPE
    SYNTAX CarAction
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Yellow Action:
         Only hardware QoS support this node.  Hardware QoS support pass, discard, remark.
         invalid is returned only when getting value from software QoS.
         invalid can't be set.
        "
    DEFVAL {remark}
    ::= { unisCBQoSCarCfgInfoEntry 8 }

unisCBQoSCarYellowRemarkValue OBJECT-TYPE
    SYNTAX Integer32 (0..63|255)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The value is to remark When red action is remarking.
         For remarking DSCP, the range is 0~63;
         For remarking IP Precedence and MPLS EXP, the range is 0~7;
         Only software QoS support this node.
         255 is returned only when getting value from hardware QoS or
         when action being pass, discard of software QoS.
         255 can't be set."
    ::= { unisCBQoSCarCfgInfoEntry 9 }

unisCBQoSCarRedAction OBJECT-TYPE
    SYNTAX CarAction
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Red Action:
         Hardware QoS : pass, discard, remark.
         Software QoS : pass, discard, remark IP Precedence, remark DSCP, remark MPLS EXP.
        "
    DEFVAL {discard}
    ::= { unisCBQoSCarCfgInfoEntry 10 }

unisCBQoSCarRedRemarkValue OBJECT-TYPE
    SYNTAX Integer32 (0..63|255)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The value is to remark When red action is remarking.
         For remarking DSCP, the range is 0~63;
         For remarking IP Precedence and MPLS EXP, the range is 0~7;
         Only software QoS support this node.
         255 is returned only when getting value from hardware QoS or
         when action being pass, discard of software QoS.
         255 can't be set."
    ::= { unisCBQoSCarCfgInfoEntry 11 }

unisCBQoSCarPolicedPriorityMapType OBJECT-TYPE
    SYNTAX INTEGER
    {
        none(0),
        policed-service-map(1),
        local-precedence-dot1p-map(2),
        drop-precedence-map(3)
    }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Type of priority map."
    DEFVAL { none }
    ::= { unisCBQoSCarCfgInfoEntry 12 }

unisCBQoSCarRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSCarCfgInfoEntry 13 }

--
-- nodes of aggregative CAR applyed behavior
--
unisCBQoSAggregativeCarCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSAggregativeCarCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of aggregative CAR applied CBQ feature configuration information.
         Aggregative CAR is managed by UNIS-IFQOS2-MIB.  So, you can use UNIS-IFQOS2-MIB
         to get some details information about aggregative CAR.
        "
    ::= { unisCBQoSBehaviorObjects 4 }

unisCBQoSAggregativeCarCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSAggregativeCarCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Aggregative CAR feature applied CBQ configuration information entry."
    INDEX { unisCBQoSBehaviorIndex,
            unisCBQoSCarAggregativeCarIndex }
    ::= { unisCBQoSAggregativeCarCfgInfoTable 1 }

UnisCBQoSAggregativeCarCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSCarAggregativeCarIndex
            Integer32,
        unisCBQoSCarAggregativeCarName
            OCTET STRING,
        unisCBQoSAggregativeCarRowStatus
            RowStatus
    }

unisCBQoSCarAggregativeCarIndex OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Index of aggregative CAR.
         It is equal to unisIfQoSAggregativeCarIndex at UNIS-IFQOS2-MIB.
        "
    ::= { unisCBQoSAggregativeCarCfgInfoEntry 1 }

unisCBQoSCarAggregativeCarName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE(1..31))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Name of aggregative CAR.
         It is equal to unisIfQoSAggregativeCarName at UNIS-IFQOS2-MIB.
        "
    ::= { unisCBQoSAggregativeCarCfgInfoEntry 2 }

unisCBQoSAggregativeCarRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "RowStatus."
    ::= { unisCBQoSAggregativeCarCfgInfoEntry 3 }

-- GTS

unisCBQoSGtsCfgInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSGtsCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of GTS feature configuration information."
    ::= { unisCBQoSBehaviorObjects 5 }

unisCBQoSGtsCfgInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSGtsCfgInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "GTS Configuration Information Entry."
    INDEX { unisCBQoSBehaviorIndex }
    ::= { unisCBQoSGtsCfgInfoTable 1 }

UnisCBQoSGtsCfgInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSGtsCir
            Unsigned32,
        unisCBQoSGtsCbs
            Unsigned32,
        unisCBQoSGtsEbs
            Unsigned32,
        unisCBQoSGtsQueueLength
            Integer32,
        unisCBQoSGtsRowStatus
            RowStatus,
        unisCBQoSGtsPir
            Unsigned32
    }

unisCBQoSGtsCir OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Committed Information Rate.  Unit: kbps"
    ::= { unisCBQoSGtsCfgInfoEntry 1 }

unisCBQoSGtsCbs OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Committed Burst Size.  Unit: byte
         default: max(cir*1/2,15000)"
    ::= { unisCBQoSGtsCfgInfoEntry 2 }

unisCBQoSGtsEbs OBJECT-TYPE
