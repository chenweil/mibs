        unisCBQoSVlanAccountingBytes
            Counter64
    }

unisCBQoSVlanAccountingPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets."
    ::= { unisCBQoSVlanAccountingRunInfoEntry 1 }

unisCBQoSVlanAccountingBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes."
    ::= { unisCBQoSVlanAccountingRunInfoEntry 2 }

-- Index Object
unisCBQoSApplyPolicyIndexObjects OBJECT IDENTIFIER
    ::= { unisCBQoSApplyPolicyStaticsObjects 5 }

--
-- ApplyObjectTable
--
unisCBQoSApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of QoS apply object index.  It provides the function
         of querying the information of QoS apply object, which
         consists of interface type, interface index, ATM PVC, FR DLCI
         and nesting policy index, using QoS apply object index."
    ::= { unisCBQoSApplyPolicyIndexObjects 1 }

unisCBQoSApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS apply object index entry."
    INDEX { unisCBQoSApplyObjectIndex }
    ::= { unisCBQoSApplyObjectTable 1 }

UnisCBQoSApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSApplyObjectIndex
            Unsigned32,
        unisCBQoSApplyObjectType
            ApplyObjectType,
        unisCBQoSApplyObjectDirection
            DirectionType,
        unisCBQoSApplyObjectMainSite
            Unsigned32,
        unisCBQoSApplyObjectSubChannel
            Unsigned32,
        unisCBQoSApplyObjectSubClass
            Unsigned32,
        unisCBQoSApplyObjectSubClassSec
            Unsigned32
    }

unisCBQoSApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS apply object index.  It represents the unique identifier
         of QoS policy applied position.  It generates when QoS policy
         is applied considering ifIndex, VLAN ID, ATM PVC, FR DLCI and
         policy nesting."
    ::= { unisCBQoSApplyObjectEntry 1 }

unisCBQoSApplyObjectType OBJECT-TYPE
    SYNTAX ApplyObjectType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Apply object type."
    ::= { unisCBQoSApplyObjectEntry 2 }

unisCBQoSApplyObjectDirection OBJECT-TYPE
    SYNTAX DirectionType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The direction of QoS apply object."
    ::= { unisCBQoSApplyObjectEntry 3 }

unisCBQoSApplyObjectMainSite OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Its value depends on unisCBQoSApplyObjectType.
         It represents VLAN ID when unisCBQoSApplyObjectType
         is vlan, and represents chassis ID when unisCBQoSApplyObjectType
         is controlPlane, otherwise it represents ifIndex."
    ::= { unisCBQoSApplyObjectEntry 4 }

unisCBQoSApplyObjectSubChannel OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Its value depends on unisCBQoSApplyObjectType.
         It represents the value of VPI/VCI, of which high 16-bits
         is VPI and low 16-bits is VCI, when unisCBQoSApplyObjectType
         is atmPvc.
         It represents the value of data link connection identifier
         in FR network, when unisCBQoSApplyObjectType is frDlci.
         It represents slot ID, when unisCBQoSApplyObjectType is controlPlane.
         Otherwise the value is '0xFFFFFFFF'."
    ::= { unisCBQoSApplyObjectEntry 5 }

unisCBQoSApplyObjectSubClass OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The value represents level-1 sub class index when the QoS
         apply object is level-2 or level-3 nesting policy.  Otherwise
         the value is '0xFFFFFFFF'."
    ::= { unisCBQoSApplyObjectEntry 6 }

unisCBQoSApplyObjectSubClassSec OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The value represents level-2 sub class index when the QoS
         apply object is level-3 nesting policy.  Otherwise
         the value is '0xFFFFFFFF'."
    ::= { unisCBQoSApplyObjectEntry 7 }

--
-- IntApplyObjectTable
--
unisCBQoSIntApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSIntApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table used for querying the QoS apply object indexes by
         interface index.  It is suitable for querying QoS apply
         object indexes for policies applied on Ethernet ports, ATM
         ports and FR ports."
    ::= { unisCBQoSApplyPolicyIndexObjects 2 }

unisCBQoSIntApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSIntApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS apply object on interface index querying entry."
    INDEX { unisCBQoSIntApplyObjectIfIndex,
            unisCBQoSApplyObjectDirection }
    ::= { unisCBQoSIntApplyObjectTable 1 }

UnisCBQoSIntApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSIntApplyObjectIfIndex
            Unsigned32,
        unisCBQoSIntApplyObjectIndex
            Unsigned32
    }

unisCBQoSIntApplyObjectIfIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Interface index."
    ::= { unisCBQoSIntApplyObjectEntry 1 }

unisCBQoSIntApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "QoS apply object index."
    ::= { unisCBQoSIntApplyObjectEntry 2 }

--
-- VlanApplyObjectTable
--
unisCBQoSVlanApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSVlanApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table used for querying the QoS apply object indexes by VLAN
         ID and policy direction.  It is suitable for querying QoS
         apply object indexes for policies applied on VLANs.  If the
         value of unisCBQoSVlanApplyObjectVlanID is 0, it means querying
         Qos apply object index for policy applied on global."
    ::= { unisCBQoSApplyPolicyIndexObjects 3 }

unisCBQoSVlanApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSVlanApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "VLAN apply object entry."
    INDEX { unisCBQoSVlanApplyObjectVlanID,
            unisCBQoSApplyObjectDirection }
    ::= { unisCBQoSVlanApplyObjectTable 1 }

UnisCBQoSVlanApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSVlanApplyObjectVlanID
            Unsigned32,
        unisCBQoSVlanApplyObjectIndex
            Unsigned32
    }

unisCBQoSVlanApplyObjectVlanID OBJECT-TYPE
    SYNTAX Unsigned32 (0..4094)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "VLAN ID."
    ::= { unisCBQoSVlanApplyObjectEntry 1 }

unisCBQoSVlanApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "QoS apply object index."
    ::= { unisCBQoSVlanApplyObjectEntry 2 }

--
-- PvcApplyObjectTable
--
unisCBQoSPvcApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSPvcApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table used for querying the QoS apply object indexes by ATM
         PVC or FR DLCI, ifIndex and policy direction.  It is suitable
         for querying QoS apply object indexes for policies applied on
         ATM PVCs or FR DLCIs."
    ::= { unisCBQoSApplyPolicyIndexObjects 4 }

unisCBQoSPvcApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSPvcApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS apply object querying entry for ATM PVC or FR
         DLCI."
    INDEX { unisCBQoSPvcApplyObjectIfIndex,
            unisCBQoSPvcApplyObjectPvcID,
            unisCBQoSApplyObjectDirection }
    ::= { unisCBQoSPvcApplyObjectTable 1 }

UnisCBQoSPvcApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSPvcApplyObjectIfIndex
            Unsigned32,
        unisCBQoSPvcApplyObjectPvcID
            Unsigned32,
        unisCBQoSPvcApplyObjectIndex
            Unsigned32
    }

unisCBQoSPvcApplyObjectIfIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Interface index."
    ::= { unisCBQoSPvcApplyObjectEntry 1 }

unisCBQoSPvcApplyObjectPvcID OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "If the QoS apply object queried is a ATM PVC, its input value
         represents a VPI/VCI.  If the QoS apply object queried is a FR
         DLCI, its input value represents a value of FR DLCI."
    ::= { unisCBQoSPvcApplyObjectEntry 2 }

unisCBQoSPvcApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "QoS apply object index."
    ::= { unisCBQoSPvcApplyObjectEntry 3 }

--
-- unisCBQoSNestPolicyApplyObjectTable
--
unisCBQoSNestPolicyApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSNestPolicyApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table used for querying the nested QoS policy apply object indexes.
         It is suitable for querying nested QoS apply object indexes for policies
         applied on ifIndex, VLAN ID, ATM PVC or FR DLCI."
    ::= { unisCBQoSApplyPolicyIndexObjects 5 }

unisCBQoSNestPolicyApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSNestPolicyApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS apply object on policy querying entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSNestPolicyClassIndex}
    ::= { unisCBQoSNestPolicyApplyObjectTable 1 }

UnisCBQoSNestPolicyApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSNestPolicyClassIndex
            Unsigned32,
        unisCBQoSNestPolicyApplyObjectIndex
            Unsigned32
    }

unisCBQoSNestPolicyClassIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Policyclass index in father policy."
    ::= { unisCBQoSNestPolicyApplyObjectEntry 1 }

unisCBQoSNestPolicyApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "QoS apply object index of the son policy."
    ::= { unisCBQoSNestPolicyApplyObjectEntry 2 }

--
-- unisCBQoSCpApplyObjectTable
--
unisCBQoSCpApplyObjectTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSCpApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table used for querying the QoS policy apply object indexes
         by chassis ID and slot ID.  It is suitable for querying QoS apply
         object indexes for policies applied on control plane."
    ::= { unisCBQoSApplyPolicyIndexObjects 6 }

unisCBQoSCpApplyObjectEntry OBJECT-TYPE
    SYNTAX UnisCBQoSCpApplyObjectEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "QoS policy apply object on control plane querying entry."
    INDEX { unisCBQoSCpApplyObjectChassis,
            unisCBQoSCpApplyObjectSlot,
            unisCBQoSApplyObjectDirection}
    ::= { unisCBQoSCpApplyObjectTable 1 }

UnisCBQoSCpApplyObjectEntry ::=
    SEQUENCE
    {
        unisCBQoSCpApplyObjectChassis
            Unsigned32,
        unisCBQoSCpApplyObjectSlot
            Unsigned32,
        unisCBQoSCpApplyObjectIndex
            Unsigned32
    }

unisCBQoSCpApplyObjectChassis OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Chassis ID."
    ::= { unisCBQoSCpApplyObjectEntry 1 }

unisCBQoSCpApplyObjectSlot OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Slot ID."
    ::= { unisCBQoSCpApplyObjectEntry 2 }

unisCBQoSCpApplyObjectIndex OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "QoS apply object index."
    ::= { unisCBQoSCpApplyObjectEntry 3 }

-- Statistics

unisCBQoSStaticsObjects OBJECT IDENTIFIER
    ::= { unisCBQoSApplyPolicyStaticsObjects 6 }

-- CBQ statistics

unisCBQoSCbqRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSCbqRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of CBQ running statistics.
         When policy using queue behavior is applied on QoS apply
         object, the QoS apply object will use Class Based Queuing."
    ::= { unisCBQoSStaticsObjects 1 }

unisCBQoSCbqRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSCbqRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "CBQ statistics entry of QoS apply object."
    INDEX { unisCBQoSApplyObjectIndex }
    ::= { unisCBQoSCbqRunInfoTable 1 }

UnisCBQoSCbqRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSCbqQueueSize
            Integer32,
        unisCBQoSCbqDiscard
            Counter64,
        unisCBQoSCbqEfQueueSize
            Integer32,
        unisCBQoSCbqAfQueueSize
            Integer32,
        unisCBQoSCbqBeQueueSize
            Integer32,
        unisCBQoSCbqBeActiveQueueNum
            Integer32,
        unisCBQoSCbqBeMaxActiveQueueNum
            Integer32,
        unisCBQoSCbqBeTotalQueueNum
            Integer32,
        unisCBQoSCbqAfAllocatedQueueNum
            Integer32
    }

unisCBQoSCbqQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets in CBQ queue."
    ::= { unisCBQoSCbqRunInfoEntry 1 }

unisCBQoSCbqDiscard OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of discarded packets which couldn't queue."
    ::= { unisCBQoSCbqRunInfoEntry 2 }

unisCBQoSCbqEfQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets in EF queue."
    ::= { unisCBQoSCbqRunInfoEntry 3 }

unisCBQoSCbqAfQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets in AF queue."
    ::= { unisCBQoSCbqRunInfoEntry 4 }

unisCBQoSCbqBeQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets in BE Queue."
    ::= { unisCBQoSCbqRunInfoEntry 5 }

unisCBQoSCbqBeActiveQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of Active BE Queues."
    ::= { unisCBQoSCbqRunInfoEntry 6 }

unisCBQoSCbqBeMaxActiveQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The max number of Active BE Queues."
    ::= { unisCBQoSCbqRunInfoEntry 7 }

unisCBQoSCbqBeTotalQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of total BE Queues."
    ::= { unisCBQoSCbqRunInfoEntry 8 }

unisCBQoSCbqAfAllocatedQueueNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of allocated AF Queues."
    ::= { unisCBQoSCbqRunInfoEntry 9 }

-- Class match statistics

unisCBQoSClassMatchRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSClassMatchRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for matching a classifier on a
         QoS apply object."
    ::= { unisCBQoSStaticsObjects 2 }

unisCBQoSClassMatchRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSClassMatchRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Classifier's matching statistics information entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSClassMatchRunInfoTable 1 }

UnisCBQoSClassMatchRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSClassMatchedPackets
            Counter64,
        unisCBQoSClassMatchedBytes
            Counter64,
        unisCBQoSClassFwdPktpps
            Unsigned32,
        unisCBQoSClassFwdPktbps
            Unsigned32,
        unisCBQoSClassDropPktpps
            Unsigned32,
        unisCBQoSClassDropPktbps
            Unsigned32,
        unisCBQoSClassFlowStatInterval
            Unsigned32,
        unisCBQoSClassBehaviorStatus
            INTEGER
    }

unisCBQoSClassMatchedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets matching a class in a QoS policy."
    ::= { unisCBQoSClassMatchRunInfoEntry 1 }

unisCBQoSClassMatchedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes matching a class in a QoS policy."
    ::= { unisCBQoSClassMatchRunInfoEntry 2 }

unisCBQoSClassFwdPktpps OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of packets macthing the class forwarded
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSClassMatchRunInfoEntry 3 }

unisCBQoSClassFwdPktbps OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average bits of packets matching the class forwarded
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSClassMatchRunInfoEntry 4 }

unisCBQoSClassDropPktpps OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of packets matching the class dropped
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSClassMatchRunInfoEntry 5 }

unisCBQoSClassDropPktbps OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average bits of packets matching the class dropped
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSClassMatchRunInfoEntry 6 }

unisCBQoSClassFlowStatInterval OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Interval of collecting traffic statistics.
         Unit: minute."
    ::= { unisCBQoSClassMatchRunInfoEntry 7 }

unisCBQoSClassBehaviorStatus OBJECT-TYPE
    SYNTAX INTEGER
    {
        success(1),
        failure(2),
        partialSuccess(3)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Classifier-behavior applying status."
    ::= { unisCBQoSClassMatchRunInfoEntry 8 }

-- CAR statistics

unisCBQoSCarRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSCarRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for CAR on a QoS apply object."
    ::= { unisCBQoSStaticsObjects 3 }

unisCBQoSCarRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSCarRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "CAR statistics information entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSCarRunInfoTable 1 }

UnisCBQoSCarRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSCarGreenPackets
            Counter64,
        unisCBQoSCarGreenBytes
            Counter64,
        unisCBQoSCarRedPackets
            Counter64,
        unisCBQoSCarRedBytes
            Counter64,
        unisCBQoSCarYellowPackets
            Counter64,
        unisCBQoSCarYellowBytes
            Counter64,
        unisCBQoSCarClassName
            OCTET STRING,
        unisCBQoSCarGreenpps
            Counter64,
        unisCBQoSCarGreenbps
            Counter64,
        unisCBQoSCarRedpps
            Counter64,
        unisCBQoSCarRedbps
            Counter64,
        unisCBQoSCarYellowpps
            Counter64,
        unisCBQoSCarYellowbps
            Counter64
    }

unisCBQoSCarGreenPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of green packets."
    ::= { unisCBQoSCarRunInfoEntry 1 }

unisCBQoSCarGreenBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of green bytes."
    ::= { unisCBQoSCarRunInfoEntry 2 }

unisCBQoSCarRedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of red packets."
    ::= { unisCBQoSCarRunInfoEntry 3 }

unisCBQoSCarRedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of red bytes."
    ::= { unisCBQoSCarRunInfoEntry 4 }

unisCBQoSCarYellowPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of yellow packets."
    ::= { unisCBQoSCarRunInfoEntry 5 }

unisCBQoSCarYellowBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of yellow bytes."
    ::= { unisCBQoSCarRunInfoEntry 6 }

unisCBQoSCarClassName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..31))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Name of classifier."
    ::= { unisCBQoSCarRunInfoEntry 7 }

unisCBQoSCarGreenpps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of green packets matching a class in a QoS policy
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSCarRunInfoEntry 8 }

unisCBQoSCarGreenbps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
       "Average bits of green packets matching a class in a QoS policy
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSCarRunInfoEntry 9 }

unisCBQoSCarRedpps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of red packets matching a class in a QoS policy
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSCarRunInfoEntry 10 }

unisCBQoSCarRedbps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average bits of red packets matching a class in a QoS policy
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSCarRunInfoEntry 11 }

unisCBQoSCarYellowpps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of yellow packets matching a class in a QoS policy
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSCarRunInfoEntry 12 }

unisCBQoSCarYellowbps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average bits of yellow packets matching a class in a QoS policy
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSCarRunInfoEntry 13 }

-- GTS statistics

unisCBQoSGtsRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSGtsRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for GTS on a QoS apply object."
    ::= { unisCBQoSStaticsObjects 4 }

unisCBQoSGtsRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSGtsRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "GTS statistics entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSGtsRunInfoTable 1 }

UnisCBQoSGtsRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSGtsPassedPackets
            Counter64,
        unisCBQoSGtsPassedBytes
            Counter64,
        unisCBQoSGtsDiscardedPackets
            Counter64,
        unisCBQoSGtsDiscardedBytes
            Counter64,
        unisCBQoSGtsDelayedPackets
            Counter64,
        unisCBQoSGtsDelayedBytes
            Counter64,
        unisCBQoSGtsQueueSize
            Integer32
    }

unisCBQoSGtsPassedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets passed by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 1 }

unisCBQoSGtsPassedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes passed by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 2 }

unisCBQoSGtsDiscardedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets discarded by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 3 }

unisCBQoSGtsDiscardedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes discarded by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 4 }

unisCBQoSGtsDelayedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets delayed by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 5 }

unisCBQoSGtsDelayedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes delayed by GTS."
    ::= { unisCBQoSGtsRunInfoEntry 6 }

unisCBQoSGtsQueueSize OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets in GTS queue."
    ::= { unisCBQoSGtsRunInfoEntry 7 }

-- Remark statistics

unisCBQoSRemarkRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSRemarkRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for remarking on a QoS apply
         object."
    ::= { unisCBQoSStaticsObjects 5 }

unisCBQoSRemarkRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSRemarkRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Remarking statistics entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSRemarkRunInfoTable 1 }

UnisCBQoSRemarkRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSRemarkedPackets
            Counter64
    }

unisCBQoSRemarkedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of remarked packets."
    ::= { unisCBQoSRemarkRunInfoEntry 1 }

-- Queue statistics

unisCBQoSQueueRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSQueueRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for queue on a QoS apply
         object."
    ::= { unisCBQoSStaticsObjects 6 }

unisCBQoSQueueRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSQueueRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Queue statistics entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex }
    ::= { unisCBQoSQueueRunInfoTable 1 }

UnisCBQoSQueueRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSQueueMatchedPackets
            Counter64,
        unisCBQoSQueueMatchedBytes
            Counter64,
        unisCBQoSQueueEnqueuedPackets
            Counter64,
        unisCBQoSQueueEnqueuedBytes
            Counter64,
        unisCBQoSQueueDiscardedPackets
            Counter64,
        unisCBQoSQueueDiscardedBytes
            Counter64
    }

unisCBQoSQueueMatchedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets matched to queue."
    ::= { unisCBQoSQueueRunInfoEntry 1 }

unisCBQoSQueueMatchedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes matched to queue."
    ::= { unisCBQoSQueueRunInfoEntry 2 }

unisCBQoSQueueEnqueuedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets queued."
    ::= { unisCBQoSQueueRunInfoEntry 3 }

unisCBQoSQueueEnqueuedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes queued."
    ::= { unisCBQoSQueueRunInfoEntry 4 }

unisCBQoSQueueDiscardedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets discarded when queued by discard method."
    ::= { unisCBQoSQueueRunInfoEntry 5 }

unisCBQoSQueueDiscardedBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes discarded when queued by discard method."
    ::= { unisCBQoSQueueRunInfoEntry 6 }

-- WRED statistics

unisCBQoSWredRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSWredRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for WRED on a QoS apply object."
    ::= { unisCBQoSStaticsObjects 7 }

unisCBQoSWredRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSWredRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "WRED statistics entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex,
            unisCBQoSWredClassValue }
    ::= { unisCBQoSWredRunInfoTable 1 }

UnisCBQoSWredRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSWredRandomDiscardedPackets
            Counter64,
        unisCBQoSWredTailDiscardedPackets
            Counter64
    }

unisCBQoSWredRandomDiscardedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets random-discarded by WRED."
    ::= { unisCBQoSWredRunInfoEntry 1 }

unisCBQoSWredTailDiscardedPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets tail-discarded by WRED."
    ::= { unisCBQoSWredRunInfoEntry 2 }

--
-- Accounting RunInfo
--
unisCBQoSAccountingRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSAccountingRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for account on a QoS apply
         object."
    ::= { unisCBQoSStaticsObjects 8 }

unisCBQoSAccountingRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSAccountingRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Account statistics entry."
    INDEX { unisCBQoSApplyObjectIndex,
            unisCBQoSPolicyClassIndex
          }
    ::= { unisCBQoSAccountingRunInfoTable 1 }

UnisCBQoSAccountingRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSAccountingPackets
            Counter64,
        unisCBQoSAccountingBytes
            Counter64,
        unisCBQoSAccountingPktpps
            Counter64,
        unisCBQoSAccountingPktbps
            Counter64
    }

unisCBQoSAccountingPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets matching a class in a QoS policy."
    ::= { unisCBQoSAccountingRunInfoEntry 1 }

unisCBQoSAccountingBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes matching a class in a QoS policy."
    ::= { unisCBQoSAccountingRunInfoEntry 2 }

unisCBQoSAccountingPktpps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average number of packets matching a class in a QoS policy
         per second in the last interval.
         Unit: pps."
    ::= { unisCBQoSAccountingRunInfoEntry 3 }

unisCBQoSAccountingPktbps OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Average bits of packets matching a class in a QoS policy
         per second in the last interval.
         Unit: bps."
    ::= { unisCBQoSAccountingRunInfoEntry 4 }

--
-- Policy Accounting RunInfo
--
unisCBQoSPolicyAccRunInfoTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisCBQoSPolicyAccRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "A table of running statistics for account on a QoS apply
         object."
    ::= { unisCBQoSStaticsObjects 9 }

unisCBQoSPolicyAccRunInfoEntry OBJECT-TYPE
    SYNTAX UnisCBQoSPolicyAccRunInfoEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Policy account statistics entry."
    INDEX { unisCBQoSApplyObjectIndex }
    ::= { unisCBQoSPolicyAccRunInfoTable 1 }

UnisCBQoSPolicyAccRunInfoEntry ::=
    SEQUENCE
    {
        unisCBQoSPolicyAccPackets
            Counter64,
        unisCBQoSPolicyAccBytes
            Counter64
    }

unisCBQoSPolicyAccPackets OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of packets matching a QoS policy."
    ::= { unisCBQoSPolicyAccRunInfoEntry 1 }

unisCBQoSPolicyAccBytes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Number of bytes matching a QoS policy."
    ::= { unisCBQoSPolicyAccRunInfoEntry 2 }

-- Policy applying status

unisCBQoSApplyingStatusObjects OBJECT IDENTIFIER ::= { unisCBQoSObjects 6 }

-- System status when applying policy

unisCBQoSApplyingStatus OBJECT-TYPE
    SYNTAX INTEGER
    {
        idle(1),
        busy(2)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "This object shows the status of the system when applying policy.
        It is forbidden to set or read in this MIB module except current
        table when the value is busy."
    ::= { unisCBQoSApplyingStatusObjects 1 }

-- Notifications

unisCBQoSNotifications OBJECT IDENTIFIER ::= { unisCBQoSObjects 7 }

-- All trap definitions should be placed under this object.

unisCBQoSNotificationsPrefix OBJECT IDENTIFIER ::= { unisCBQoSNotifications 0 }

-- All objects used for TRAP only are defined here.

unisCBQoSIfPolicyChanged NOTIFICATION-TYPE
    OBJECTS
        {
            unisCBQoSIfApplyPolicyIfIndex,
            unisCBQoSIfApplyPolicyDirection
        }
    STATUS current
    DESCRIPTION
        "This notification will be sent when the applying status
        of the policy on the interface is changed."
    ::= { unisCBQoSNotificationsPrefix 1 }

unisCBQoSVlanPolicyChanged NOTIFICATION-TYPE
    OBJECTS
        {
            unisCBQoSVlanApplyPolicyVlanid,
            unisCBQoSVlanApplyPolicyDirection
        }
    STATUS current
    DESCRIPTION
        "This notification will be sent when the applying status
        of the policy on the VLAN is changed."
    ::= { unisCBQoSNotificationsPrefix 2 }

END
