-- =================================================================
UNIS-ENTITY-VENDORTYPE-OID-MIB DEFINITIONS ::= BEGIN

IMPORTS
    MODULE-IDENTITY
        FROM SNMPv2-SMI
    unisNetworking
        FROM UNIS-OID-MIB;


unisEntityVendorTypeOID MODULE-IDENTITY

        LAST-UPDATED "200903310000Z"
        ORGANIZATION
            "Unisyue Technologies Co., Ltd."
        CONTACT-INFO
            ""
        DESCRIPTION
            "The private MIB includes the definition of the object
            identifiers on products, which are used by the
            entPhysicalTable of the ENTITY-MIB to uniquely identify the
            type of each physical entry."
        ::= { unisNetworking 3 }

unisEntityVendortypeObjects   OBJECT IDENTIFIER ::= { unisEntityVendorTypeOID 1 }

-- This MIB assigns OIDs for use as the values of entPhysicalVendorType.
-- The subtrees in which the OID values are assigned, are structured
-- into a hierarchy based on the values of RFC 2037's PhysicalClass
-- textual convention.  For reference, the definition of PhysicalClass
-- is as follows:
--
--      PhysicalClass ::= TEXTUAL-CONVENTION
--      STATUS          current
--      DESCRIPTION
--             "An enumerated value which provides an indication of the
--              general hardware type of a particular physical entity."
--      SYNTAX      INTEGER  {
--              other(1),
--              unknown(2),
--              chassis(3),
--              backplane(4),
--              container(5),    e.g. slot or daughter-card holder
--              powerSupply(6),
--              fan(7),
--              sensor(8),
--              module(9),       e.g. plug-in card or daughter-card
--              port(10),
--              stack(11)        e.g., stack of multiple chassis entities
--          }
--

unisevtOther     OBJECT IDENTIFIER ::= { unisEntityVendortypeObjects 1 }

-- May be defined detailed in future.

unisevtOtherUnknownCard  OBJECT IDENTIFIER ::= { unisevtOther 1 }
unisevtCPU               OBJECT IDENTIFIER ::= { unisevtOther 2 }
unisevtDOM               OBJECT IDENTIFIER ::= { unisevtOther 3 }  -- Disk on Module
unisevtCFCard            OBJECT IDENTIFIER ::= { unisevtOther 4 }  -- Compact Flash Card
unisevtHardDisk          OBJECT IDENTIFIER ::= { unisevtOther 5 }  -- Hard Disk
unisevtSDCard            OBJECT IDENTIFIER ::= { unisevtOther 6 }  -- Secure Digital Memory Card
unisevtMEM             OBJECT IDENTIFIER ::= { unisevtOther 7 }  -- Internal Memory

-- unisevtGeneralCPU is a general vendor type of CPU.  It is used only for
-- general purpose.  It is strongly recommended that this object should not
-- be used to present the specific CPU vendor type in most cases.  More
-- accurate and clear vendor types should be defined to present specific CPU.
unisevtGeneralCPU        OBJECT IDENTIFIER ::= { unisevtCPU 1 }


unisevtUnknown   OBJECT IDENTIFIER ::= { unisEntityVendortypeObjects 2 }

unisevtChassis   OBJECT IDENTIFIER ::= { unisEntityVendortypeObjects 3 }

-- chassis OID assignments
-- May be substituted by sysObjectID.  So none is assigned at present.

--
-- backplane
--   The enumeration 'backplane' is applicable if the physical
--   entity class is some sort of device for aggregating and
--   forwarding networking traffic, such as a shared backplane in
--   a modular ethernet switch.  Note that an agent may model a
--   backplane as a single physical entity, which is actually
--   implemented as multiple discrete physical components (within
--   a chassis or stack).
--

