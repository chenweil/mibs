-- *****************************************************************************
-- *  unisDot11ACPortalStatisticCMTable Definition
-- *****************************************************************************
unisDot11ACPortalStatisticCMTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11ACPortalStatisticCMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table describes portal statistics information."
    ::= { unisDot11ACObjectGroup 7 }

unisDot11ACPortalStatisticCMEntry OBJECT-TYPE
    SYNTAX      UnisDot11ACPortalStatisticCMEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the portal statistics information of an SSID."
    INDEX
        {
            unisDot11ACPortalStatisticSSIDCM
        }
    ::= { unisDot11ACPortalStatisticCMTable 1 }

UnisDot11ACPortalStatisticCMEntry ::= SEQUENCE
    {
        unisDot11ACPortalStatisticSSIDCM             OCTET STRING,
        unisDot11ACPortalStatAuthReqCM                  Counter32,
        unisDot11ACPortalStatAuthRespCM                 Counter32
    }

unisDot11ACPortalStatisticSSIDCM OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the service policy name."
    ::= { unisDot11ACPortalStatisticCMEntry 1 }

unisDot11ACPortalStatAuthReqCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of portal authentication requests from
        portal server to AC."
    ::= { unisDot11ACPortalStatisticCMEntry 2 }

unisDot11ACPortalStatAuthRespCM OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the total number of portal authentication responses from
        AC to portal server."
    ::= { unisDot11ACPortalStatisticCMEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11ACPortalStatisticCMTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11LocalACModelTable Definition
-- *****************************************************************************
unisDot11LocalACModelTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11LocalACModelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table defines the capability information for a specific
        kind of local AC."
    ::= { unisDot11ACObjectGroup 8 }

unisDot11LocalACModelEntry OBJECT-TYPE
    SYNTAX      UnisDot11LocalACModelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains capability information for a specific kind
        of local AC."
    INDEX
        {
            unisDot11LocalACModelAlias
        }
    ::= { unisDot11LocalACModelTable 1 }

UnisDot11LocalACModelEntry ::= SEQUENCE
    {
        unisDot11LocalACModelAlias         OCTET STRING,
        unisDot11LocalACModelName          OCTET STRING,
        unisDot11LocalACManufacturer       OCTET STRING,
        unisDot11LocalACCPUType            OCTET STRING,
        unisDot11LocalACCPUClockSpeed      Unsigned32,
        unisDot11LocalACMemoryType         OCTET STRING,
        unisDot11LocalACMemorySize         Unsigned32,
        unisDot11LocalACFlashType          OCTET STRING,
        unisDot11LocalACFlashSize          Unsigned32,
        unisDot11LocalACMemSize            Counter64,
        unisDot11LocalACFlashSizeInBytes   Counter64
    }

unisDot11LocalACModelAlias OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..127))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents alias of local AC model name."
    ::= { unisDot11LocalACModelEntry 1 }

unisDot11LocalACModelName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents local AC model name."
    ::= { unisDot11LocalACModelEntry 2 }

unisDot11LocalACManufacturer OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "'SMI Network Management Private Enterprise Codes'
        assigned by the IANA, which means the vendor of local AC."
    ::= { unisDot11LocalACModelEntry 3 }

unisDot11LocalACCPUType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the CPU type of local AC."
    ::= { unisDot11LocalACModelEntry 4 }

unisDot11LocalACCPUClockSpeed OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "Hz"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the clock speed of CPU."
    ::= { unisDot11LocalACModelEntry 5 }

unisDot11LocalACMemoryType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the memory card type of local AC."
    ::= { unisDot11LocalACModelEntry 6 }

unisDot11LocalACMemorySize OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of local AC memory card."
    ::= { unisDot11LocalACModelEntry 7 }

unisDot11LocalACFlashType OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the flash card type of local AC."
    ::= { unisDot11LocalACModelEntry 8 }

unisDot11LocalACFlashSize OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "kbytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of local AC flash card."
    ::= { unisDot11LocalACModelEntry 9 }

unisDot11LocalACMemSize OBJECT-TYPE
    SYNTAX      Counter64
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the size of local AC memory card."
    ::= { unisDot11LocalACModelEntry 10 }

unisDot11LocalACFlashSizeInBytes OBJECT-TYPE
    SYNTAX      Counter64
    UNITS       "bytes"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This object represents the size of local AC flash card in bytes."
    ::= { unisDot11LocalACModelEntry 11 }

-- *****************************************************************************
-- *  End of unisDot11LocalACModelTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11CAPWAPTunnelTable Definition
-- *****************************************************************************
unisDot11CAPWAPTunnelTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11CAPWAPTunnelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The table will list all the APs which are connecting to the AC
        by the CAPWAP tunnel protocol."
    ::= { unisDot11CAPWAPTunnelGroup 1 }

unisDot11CAPWAPTunnelEntry OBJECT-TYPE
    SYNTAX      UnisDot11CAPWAPTunnelEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains information of data tunnel and control
        tunnel of AP which is connecting to AC."
    INDEX
        {
            unisDot11CurrTunnelAPID
        }
    ::= { unisDot11CAPWAPTunnelTable 1 }

UnisDot11CAPWAPTunnelEntry ::= SEQUENCE
    {
        unisDot11CurrTunnelAPID         UnisDot11ObjectIDType,
        unisDot11CtrlTunnelCurrSec      UnisDot11TunnelSecSchemType,
        unisDot11CtrlTunnelUpTime       Integer32,
        unisDot11DataTunnelCurrSec      UnisDot11TunnelSecSchemType,
        unisDot11DataTunnelUpTime       Integer32,
        unisDot11CtrlTunnelUpTimeTicks  TimeTicks
    }

unisDot11CurrTunnelAPID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "To uniquely identify the CAPWAP tunnel set up between the AP
        identified by APID and a specific AC."
    ::= { unisDot11CAPWAPTunnelEntry 1 }

unisDot11CtrlTunnelCurrSec OBJECT-TYPE
    SYNTAX      UnisDot11TunnelSecSchemType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents what security scheme is in use for
        control tunnel."
    DEFVAL      { cleartxt }
    ::= { unisDot11CAPWAPTunnelEntry 2 }

unisDot11CtrlTunnelUpTime OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "second"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how long for control tunnel up. If the value is zero,
        then tunnel is not set up."
    ::= { unisDot11CAPWAPTunnelEntry 3 }

unisDot11DataTunnelCurrSec OBJECT-TYPE
    SYNTAX      UnisDot11TunnelSecSchemType
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents what security scheme is in use for
        data tunnel."
    DEFVAL      { cleartxt }
    ::= { unisDot11CAPWAPTunnelEntry 4 }

unisDot11DataTunnelUpTime OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "second"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how long for data tunnel up.
        If the value is zero, then tunnel is not set up."
    ::= { unisDot11CAPWAPTunnelEntry 5 }

unisDot11CtrlTunnelUpTimeTicks OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents how long control tunnel is up.
         If the value is zero, then tunnel is not set up."
    ::= { unisDot11CAPWAPTunnelEntry 6 }
-- *****************************************************************************
-- *    End of unisDot11CAPWAPTunnelTable  TABLE
-- *****************************************************************************

-- *****************************************************************************
-- *     Notifications OF unisDot11ACMtNotifyGroup
-- *****************************************************************************
-- AC Management Notification

        unisDot11ACMtTraps OBJECT IDENTIFIER
    ::= { unisDot11ACMtNotifyGroup 0 }

unisDot11ACMtTunnelSetupTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11CurrTunnelAPID,
            unisDot11ACMtTrapTunlUpInfo,
            unisDot11ACMtTrapTnlAPName,
            unisDot11ACMtTrapTnlAPIPAddr,
            unisDot11ACMtTrapAPIPv6Addr,
            unisDot11ACMtFirstTrapTime,
            unisDot11ACMtTrapAPMacAddress
        }
    STATUS      current
    DESCRIPTION
        "This notification is sent by AC when CAPWAP tunnel becomes up.
        By this way, NMS will immediately know tunnel up event.
        It is unnecessary to identify whether it is control or data
        tunnel."
    ::= { unisDot11ACMtTraps 1 }

unisDot11ACMtTunnelDownTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11CurrTunnelAPID,
            unisDot11ACMtTrapTunlDwnInfo,
            unisDot11ACMtTrapTnlAPName,
            unisDot11ACMtTrapTnlAPIPAddr,
            unisDot11ACMtTrapAPIPv6Addr,
            unisDot11ACMtTrapTunlDwnCount,
            unisDot11ACMtTrapTnlAPSysName,
            unisDot11ACMtFirstTrapTime,
            unisDot11ACMtTrapAPMacAddress
        }
    STATUS      current
    DESCRIPTION
        "This notification is sent by AC when CAPWAP tunnel becomes down.
        By this way, NMS will immediately know tunnel down event.
        It is unnecessary to identify whether it is control or data
        tunnel."
    ::= { unisDot11ACMtTraps 2 }

unisDot11ACMtBackupSwtTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11ACMtTrapBackupSwitchInfo,
            unisDot11ACMtFirstTrapTime
        }
    STATUS      current
    DESCRIPTION
        "This trap is sent by AC when AC switches from master to slave
        or from slave to master."
    ::= { unisDot11ACMtTraps 3 }

unisDot11ACLoadBalanceTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11LoadBalanceType,
            unisDot11LoadBalanceThreshold
        }
    STATUS      current
    DESCRIPTION
        "This trap is sent by AC when load-balance is enabled on AC."
    ::= { unisDot11ACMtTraps 4 }

unisDot11ACStaFullTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11ACMaxStaNum
        }
    STATUS current
    DESCRIPTION
        "This notification will be sent when STA is full on AC."
    ::={ unisDot11ACMtTraps 5 }

unisDot11ACStatusSwitchTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11ACStatusSwitchInfo,
            unisDot11SourceACNmsIP
        }
    STATUS current
    DESCRIPTION
        "This notification will be sent when AC switches from standby to active
        or from standby to active."
    ::={ unisDot11ACMtTraps 6}

unisDot11RunAPNumOverload NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11MaxAPNumPermitted,
            unisDot11APConnectCount
        }
    STATUS current
    DESCRIPTION
        "The notification will be sent by AC when run AP number exceeds the threshold."
    ::= { unisDot11ACMtTraps 7}

unisDot11RunAPNumOverloadRecover NOTIFICATION-TYPE
    OBJECTS
        {
            unisDot11MaxAPNumPermitted,
            unisDot11APConnectCount
        }
    STATUS current
    DESCRIPTION
        "The notification will be sent by AC when run AP number
        recover normal from overload state."
    ::= { unisDot11ACMtTraps 8 }


-- AC Management Notification Variable object

        unisDot11ACMtTrapVarObjects OBJECT IDENTIFIER
    ::= { unisDot11ACMtNotifyGroup 1 }

unisDot11ACMtTrapTunlDwnInfo OBJECT-TYPE
    SYNTAX      INTEGER
        {
            tunnelTimeout(1),
            keyUpdateFailure(2),
            apReset(3),
            apCrash(4),
            apDeleted(5),
            apCfgChange(6)
        }
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the reason for tunnel down.
        The following values are supported:
        tunnelTimeout     - When AC detects the tunnel is broken,
        - it will notify NMS.
        keyUpdateFailure  - rekey process is failed, tunnel will be broken.
        apReset           - Administrator reset AP.
        apCrash           - AP reboot for system crash.
        apDeleted         - Delete AP from AC and trigger tunnel down.
        apCfgChange       - The configuration for AP was changed."
    ::= { unisDot11ACMtTrapVarObjects 1 }

unisDot11ACMtTrapTunlUpInfo OBJECT-TYPE
    SYNTAX      INTEGER
        {
            up(1)
        }
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the reason for tunnel up.
        The following values are supported:
        up(1)  - The AP joined AC.
        "
    ::= { unisDot11ACMtTrapVarObjects 2 }

unisDot11ACMtTrapBackupSwitchInfo OBJECT-TYPE
    SYNTAX      INTEGER
        {
            masterToSlave(1),
            slaveToMaster(2)
        }
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents status which the AC switches to.
        The following values are supported:
        masterToSlave  - The AC switches from master to slave.
        slaveToMaster  - The AC switches from slave to master.
        "
    ::= { unisDot11ACMtTrapVarObjects 3 }

unisDot11ACMtTrapTnlAPName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents name of the AP which sets up the tunnel with the AC.
        "
    ::= { unisDot11ACMtTrapVarObjects 4 }

unisDot11ACMtTrapTnlAPIPAddr OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents IP address of the AP which sets up the tunnel with the AC.
        "
    ::= { unisDot11ACMtTrapVarObjects 5 }

unisDot11LoadBalanceType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            traffic(1),
            session(2)
        }
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents which kind load balance is enabled by AC.
         The following values are supported:
         traffic mode load-balancing: traffic snapshot is considered.
         session mode load-balancing: the number of users associated
                                      with the AP/radio is considered.
        "
    ::= { unisDot11ACMtTrapVarObjects 6 }

unisDot11LoadBalanceThreshold OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the value of load balance threshold.
        "
    ::= { unisDot11ACMtTrapVarObjects 7 }

unisDot11ACMtTrapAPIPv6Addr OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents IPv6 address of the AP which sets up the tunnel with
        the AC."
    ::= { unisDot11ACMtTrapVarObjects 8 }

unisDot11ACMtTrapTunlDwnCount OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents how many times that the tunnel between AC and AP has down."
    ::= { unisDot11ACMtTrapVarObjects 9 }

unisDot11ACMaxStaNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the max number of STA on AC."
    ::= { unisDot11ACMtTrapVarObjects 10 }

unisDot11ACMtTrapTnlAPSysName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents system name of the AP which sets up the tunnel with the AC."
    ::= { unisDot11ACMtTrapVarObjects 11 }

unisDot11ACMtFirstTrapTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the first trap time."
    ::= { unisDot11ACMtTrapVarObjects 12 }

unisDot11ACStatusSwitchInfo OBJECT-TYPE
    SYNTAX      INTEGER
        {
            activeToStandby(1),
            standbyToActive(2)
        }
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents status which the AC switches to.
        The following values are supported:
        activeToStandby  - The AC switches from active to standby.
        standbyToActive  - The AC switches from standby to active.
        "
    ::= { unisDot11ACMtTrapVarObjects 13 }

unisDot11SourceACNmsIP OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the NMS IP address of master AC.
        "
    ::= { unisDot11ACMtTrapVarObjects 14 }

unisDot11ACMtTrapAPMacAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
         "Represents the MAC address of an AP."
    ::= { unisDot11ACMtTrapVarObjects 15 }

-- *****************************************************************************
-- *     End OF NotifyGroup
-- *****************************************************************************
END
