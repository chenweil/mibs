unisTunnelGrep2mpStatsTable OBJECT-TYPE
    SYNTAX     SEQUENCE OF UnisTunnelGrep2mpStatsEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "The table contains GRE P2MP tunnel mapping statistics."
    ::= { unisTunnelTables 13 }

unisTunnelGrep2mpStatsEntry OBJECT-TYPE
    SYNTAX     UnisTunnelGrep2mpStatsEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "GRE P2MP tunnel mapping statistics entry."
    INDEX { unisTunnelGrep2mpStatsTunnelNo,
            unisTunnelGrep2mpStatsVrf,
            unisTunnelGrep2mpStatsVPCID,
            unisTunnelGrep2mpStatsBraAddr,
            unisTunnelGrep2mpStatsBraMask,
            unisTunnelGrep2mpStatsAddrType,
            unisTunnelGrep2mpStatsDestAddr}
    ::= { unisTunnelGrep2mpStatsTable 1 }

UnisTunnelGrep2mpStatsEntry ::= SEQUENCE {
        unisTunnelGrep2mpStatsTunnelNo              Integer32,
        unisTunnelGrep2mpStatsVrf                   Integer32,
        unisTunnelGrep2mpStatsVPCID                 Integer32,
        unisTunnelGrep2mpStatsBraAddr               InetAddress,
        unisTunnelGrep2mpStatsBraMask               InetAddress,
        unisTunnelGrep2mpStatsAddrType              InetAddressType,
        unisTunnelGrep2mpStatsDestAddr              InetAddressIPv4,
        unisTunnelGrep2mpStatsInPkts                Counter64,
        unisTunnelGrep2mpStatsInOctets              Counter64,
        unisTunnelGrep2mpStatsInDis                 Counter64,
        unisTunnelGrep2mpStatsOutPkts               Counter64,
        unisTunnelGrep2mpStatsOutOctets             Counter64,
        unisTunnelGrep2mpStatsOutDis                Counter64

    }
unisTunnelGrep2mpStatsTunnelNo OBJECT-TYPE
    SYNTAX     Integer32
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "Tunnel interfacenumber."
    ::= { unisTunnelGrep2mpStatsEntry 1 }


unisTunnelGrep2mpStatsVrf OBJECT-TYPE
    SYNTAX     Integer32
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "VPN instance index."
    ::= { unisTunnelGrep2mpStatsEntry 2 }

unisTunnelGrep2mpStatsVPCID OBJECT-TYPE
    SYNTAX     Integer32
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "VPC ID."
    ::= { unisTunnelGrep2mpStatsEntry 3 }


unisTunnelGrep2mpStatsBraAddr OBJECT-TYPE
    SYNTAX     InetAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "Branch network IP address."
    ::= { unisTunnelGrep2mpStatsEntry 4 }

unisTunnelGrep2mpStatsBraMask OBJECT-TYPE
    SYNTAX     InetAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "Branch network mask."
    ::= { unisTunnelGrep2mpStatsEntry 5 }

unisTunnelGrep2mpStatsAddrType OBJECT-TYPE
    SYNTAX     InetAddressType
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "Type of address in the corresponding
        unisTunnelGrep2mpStatsBraAddr and unisTunnelGrep2mpStatsBraMask
        objects.
        "
    ::= { unisTunnelGrep2mpStatsEntry 6 }

unisTunnelGrep2mpStatsDestAddr OBJECT-TYPE
    SYNTAX     InetAddressIPv4
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
           "Tunnel destination address."
    ::= { unisTunnelGrep2mpStatsEntry 7 }



unisTunnelGrep2mpStatsInPkts OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "Total number of IP datagrams received."
    ::= { unisTunnelGrep2mpStatsEntry 8 }

unisTunnelGrep2mpStatsInOctets OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "Total number of octets received in IP datagrams."
    ::= { unisTunnelGrep2mpStatsEntry 9 }

unisTunnelGrep2mpStatsInDis OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "The number of input IP datagrams for which no problems were
            encountered to prevent their continued processing, but
            were discarded."
    ::= { unisTunnelGrep2mpStatsEntry 10 }

unisTunnelGrep2mpStatsOutPkts OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "Total number IP datagrams sent."
    ::= { unisTunnelGrep2mpStatsEntry 11 }

unisTunnelGrep2mpStatsOutOctets OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "Total number of octets in IP datagrams sent."
    ::= { unisTunnelGrep2mpStatsEntry 12 }

unisTunnelGrep2mpStatsOutDis OBJECT-TYPE
    SYNTAX     Counter64
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
           "The number of output IP datagrams which no problem was
            encountered to prevent their transmission to their
            destination, but were discarded ."
    ::= { unisTunnelGrep2mpStatsEntry 13 }


END
