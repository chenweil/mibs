    ::= { unisTunnelVxlanConfigGroup 2 }

unisTunnelVxlanDropVlanTagPkt OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Whether or not dropping Vxlan packet with inner VLAN tag."
    ::= { unisTunnelVxlanConfigGroup 3 }

unisTunnelAvailableIDGroup OBJECT IDENTIFIER ::= { unisTunnelTables 9 }

unisTunnelAvailableID OBJECT-TYPE
    SYNTAX Integer32 (-1 | 1..2147483647)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The available tunnel ID.  A value of -1 indicates that
         there is no available tunnel ID."
    ::= { unisTunnelAvailableIDGroup 1 }

