    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
       "The (conceptual) table containing information on tunnels.
       "
    ::= { unisTunnelTables 12 }

unisTunnelDestinationEntry OBJECT-TYPE
    SYNTAX     UnisTunnelDestinationEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "An entry (conceptual row) containing the information on a
         particular tunnel.
        "
    INDEX      { unisTunnelDestinationDstAddr,
               unisTunnelDestinationDstType,
         unisTunnelDestinationTunNum}
    ::= { unisTunnelDestinationTable 1 }

UnisTunnelDestinationEntry ::= SEQUENCE {
