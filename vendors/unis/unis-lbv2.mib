    ::= { unisLBv2RSStatsEntry 13 }

unisLBv2SFTables OBJECT IDENTIFIER ::= { unisLBv2 5 }
-- =================================================================
--    LB Server Farm Table
-- =================================================================
unisLBv2SFTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisLBv2SFEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Server farm table for LB."
    ::= { unisLBv2SFTables 1 }

unisLBv2SFEntry OBJECT-TYPE
    SYNTAX      UnisLBv2SFEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry contains the information of the server farm."
    INDEX {
            unisLBv2SFName
          }
    ::= { unisLBv2SFTable 1 }

UnisLBv2SFEntry  ::=
    SEQUENCE{
        unisLBv2SFName                         DisplayString,
        unisLBv2SFRowStatus                    RowStatus
    }

unisLBv2SFName OBJECT-TYPE
    SYNTAX      DisplayString(SIZE(1..63))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Name of the server farm."
    ::= { unisLBv2SFEntry 1 }

unisLBv2SFRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Status of this conceptual row."
    ::= { unisLBv2SFEntry 2 }

