unisLBv2ActionInUseSFChangeTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisLBv2ActionName,
            unisLBv2ActionDefaultSF,
            unisLBv2ActionBackupSF,
            unisLBv2ActionInUseSF
        }
