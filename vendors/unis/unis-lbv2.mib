    SYNTAX SEQUENCE OF UnisLBv2SFStatsEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Server farm statistic for LB."
    ::= { unisLBv2SFTables 2 }

unisLBv2SFStatsEntry OBJECT-TYPE
    SYNTAX      UnisLBv2SFStatsEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "An entry contains the statistic information of the server farm."
