            unisLBv2SFName,
            unisLBv2SFStatChassis,
            unisLBv2SFStatSlot,
            unisLBv2SFStatCpuid
          }
    ::= { unisLBv2SFStatsTable 1 }

UnisLBv2SFStatsEntry  ::=
    SEQUENCE{
        unisLBv2SFStatChassis                  Unsigned32,
        unisLBv2SFStatSlot                     Unsigned32,
        unisLBv2SFStatCpuid                    Unsigned32,
        unisLBv2SFStatTotalConnections         Counter64,
        unisLBv2SFStatActiveConnections        Unsigned32,
        unisLBv2SFStatServerSidePKTsIn         Counter64,
        unisLBv2SFStatServerSidePKTsOut        Counter64,
        unisLBv2SFStatDroppedPackets           Counter64,
        unisLBv2SFStatServerSideBytesIn        Counter64,
        unisLBv2SFStatServerSideBytesOut       Counter64,
        unisLBv2SFStatReceivedRequests         Counter64,
        unisLBv2SFStatSentResponses            Counter64
    }

unisLBv2SFStatChassis OBJECT-TYPE
    SYNTAX      Unsigned32(0..255)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "ID of the device that holds the card."
    ::= { unisLBv2SFStatsEntry 1 }

unisLBv2SFStatSlot OBJECT-TYPE
    SYNTAX      Unsigned32(0..255)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Member ID of the card on device."
    ::= { unisLBv2SFStatsEntry 2 }

unisLBv2SFStatCpuid OBJECT-TYPE
    SYNTAX      Unsigned32(0..255)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "ID of the CPU on the card."
    ::= { unisLBv2SFStatsEntry 3 }

unisLBv2SFStatTotalConnections OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Total number of connections that the server farm received."
    ::= { unisLBv2SFStatsEntry 4 }

unisLBv2SFStatActiveConnections OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Active connections that the server farm received."
    ::= { unisLBv2SFStatsEntry 5 }

unisLBv2SFStatServerSidePKTsIn OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of packets that the server farm received from device."
    ::= { unisLBv2SFStatsEntry 6 }

unisLBv2SFStatServerSidePKTsOut OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of packets that the server farm sent."
    ::= { unisLBv2SFStatsEntry 7 }

unisLBv2SFStatDroppedPackets OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of packets that the server farm dropped."
    ::= { unisLBv2SFStatsEntry 8 }

unisLBv2SFStatServerSideBytesIn OBJECT-TYPE
    SYNTAX      Counter64
    UNITS       "byte"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of bytes that the server farm received."
    ::= { unisLBv2SFStatsEntry 9 }

unisLBv2SFStatServerSideBytesOut OBJECT-TYPE
    SYNTAX      Counter64
    UNITS       "byte"
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of bytes that the server farm sent."
    ::= { unisLBv2SFStatsEntry 10 }

unisLBv2SFStatReceivedRequests OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of requests that all real servers in the server farm
         received from device."
    ::= { unisLBv2SFStatsEntry 11 }

unisLBv2SFStatSentResponses OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Number of responses that the server farm sent to device."
    ::= { unisLBv2SFStatsEntry 12 }

-- =================================================================
--    LB NOTIFICATION
-- =================================================================
unisLBv2Trap OBJECT IDENTIFIER ::= { unisLBv2 6 }

unisLBv2TrapPrefix OBJECT IDENTIFIER ::= { unisLBv2Trap 0 }
-- =================================================================
--    Virtual Server Connections Overload Notification
-- =================================================================
unisLBv2VSConnOverloadTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisLBv2VSName,
            unisLBv2VSConnectionsLimit,
            unisLBv2VSStatChassis,
            unisLBv2VSStatSlot,
            unisLBv2VSStatCpuid,
            unisLBv2VSStatActiveConnections
        }
    STATUS      current
    DESCRIPTION
        "A unisLBv2VSConnOverloadTrap notification is sent when
         the number of active connections of the virtual server
         has reached the upper limit. "
    ::= { unisLBv2TrapPrefix 1 }

-- =================================================================
--    Virtual Server Connections Overload Recovery Notification
-- =================================================================
unisLBv2VSConnRecoveryTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisLBv2VSName,
            unisLBv2VSConnectionsLimit,
            unisLBv2VSStatChassis,
            unisLBv2VSStatSlot,
            unisLBv2VSStatCpuid,
            unisLBv2VSStatActiveConnections
        }
    STATUS      current
    DESCRIPTION
        "A unisLBv2VSConnRecoveryTrap notification is sent when
         the number of active connections of the virtual server
         is less than the upper limit."
    ::= { unisLBv2TrapPrefix 2 }
-- =================================================================
--    Virtual Server Connections Rate Overload Notification
-- =================================================================
unisLBv2VSConnsRateOverloadTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisLBv2VSName,
            unisLBv2VSConnectionsRateLimit,
            unisLBv2VSStatChassis,
            unisLBv2VSStatSlot,
            unisLBv2VSStatCpuid,
            unisLBv2VSStatConnectionsRate
        }
    STATUS      current
    DESCRIPTION
        "A unisLBv2VSConnsRateOverloadTrap notification is sent
         when the connection rate of the virtual server has
         reached the upper limit."
    ::= { unisLBv2TrapPrefix 3 }

-- =================================================================
--    Virtual Server Connections Rate Overload Recovery Notification
-- =================================================================
unisLBv2VSConnsRateRecoveryTrap NOTIFICATION-TYPE
    OBJECTS
        {
            unisLBv2VSName,
            unisLBv2VSConnectionsRateLimit,
            unisLBv2VSStatChassis,
            unisLBv2VSStatSlot,
            unisLBv2VSStatCpuid,
            unisLBv2VSStatConnectionsRate
        }
    STATUS      current
    DESCRIPTION
        "A unisLBv2VSConnsRateRecoveryTrap notification is sent
         when the connection rate of the virtual server is smaller than
         the upper limit."
    ::= { unisLBv2TrapPrefix 4 }

