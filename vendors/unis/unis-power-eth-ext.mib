               }

unisPOEACSwitchStateIndex OBJECT-TYPE
      SYNTAX Integer32 (1..2147483647)
      MAX-ACCESS accessible-for-notify
      STATUS current
      DESCRIPTION
             "The index of the AC switch state on this POE power.
             The range of this node is from 1 to unisPOEACSwitchStateModuleNum."
      ::= { unisPOEACSwitchStateEntry 1 }

unisPOEACSwitchState OBJECT-TYPE
      SYNTAX SwitchState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The AC switch state on this POE power.
             The value of this node will be one of the following values:
                                 on             (1),
                                 off            (2),
                                 highVoltInput  (3),
                                 lowVoltInput   (4)"
      ::= { unisPOEACSwitchStateEntry 2 }

unisPOEInCurStateObjects OBJECT IDENTIFIER ::= { unisPOEPowerObjects 6 }

unisPOEInCurStateModuleNum OBJECT-TYPE
      SYNTAX Integer32
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The DC input current state of the module on this POE power.
             It is the maximum of the unisPOESwitchStateVolExIndex."
      ::= { unisPOEInCurStateObjects 1 }

unisPOEInCurAState OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The current A state in the DC input on this POE power.
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOEInCurStateObjects 2 }

unisPOEInCurBState OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The current B state in the DC input on this POE power.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOEInCurStateObjects 3 }

unisPOEInCurCState OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The current C state in the DC input on this POE power.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOEInCurStateObjects 4 }

unisPOESwitchStateVolExTable OBJECT-TYPE
      SYNTAX SEQUENCE OF UnisPOESwitchStateVolExEntry
      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "All alarm status of the VOL status.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOEInCurStateObjects 5 }

unisPOESwitchStateVolExEntry OBJECT-TYPE
      SYNTAX UnisPOESwitchStateVolExEntry
      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "The unisPOESwitchStateVolExIndex will match the number of the VOL status."
      INDEX { unisPOESwitchStateVolExIndex }
      ::= { unisPOESwitchStateVolExTable 1 }

UnisPOESwitchStateVolExEntry ::=
      SEQUENCE {
               unisPOESwitchStateVolExIndex
                       Integer32,
               unisPOESwitchStateInVolAB
                       ACAlarmState,
               unisPOESwitchStateInVolBC
                       ACAlarmState,
               unisPOESwitchStateInVolCA
                       ACAlarmState
               }

unisPOESwitchStateVolExIndex OBJECT-TYPE
      SYNTAX Integer32 (1..2147483647)
      MAX-ACCESS accessible-for-notify
      STATUS current
      DESCRIPTION
             "The object species the index of the VOL status.
             The range of this node is from 1 to unisPOEInCurStateModuleNum."
      ::= { unisPOESwitchStateVolExEntry 1 }

unisPOESwitchStateInVolAB OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The object specifies the VOL AB alarm in each VOL status.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOESwitchStateVolExEntry 2 }

unisPOESwitchStateInVolBC OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The object specifies the VOL BC alarm in each VOL status.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOESwitchStateVolExEntry 3 }

unisPOESwitchStateInVolCA OBJECT-TYPE
      SYNTAX ACAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The object specifies the VOL CA alarm in each VOL status.
             The value of this node will be one of the following values:
                                 normal     (1),
                                 underLimit (2),
                                 aboveLimit (3),
                                 lackPhrase (4),
                                 fuseBroken (5),
                                 switchOff  (6),
                                 otherError (7)."
      ::= { unisPOESwitchStateVolExEntry 4 }

unisPOEAlarmStateObjects OBJECT IDENTIFIER ::= { unisPOEPowerObjects 7 }

unisPOEAlarmStateModuleNum OBJECT-TYPE
      SYNTAX Integer32
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The object specifies the number of the power modules in alarm state."
      ::= { unisPOEAlarmStateObjects 1 }

unisPOEAlarmStateInfoTable OBJECT-TYPE
      SYNTAX SEQUENCE OF UnisPOEAlarmStateInfoEntry
      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "All alarm states in the POE power modules."
      ::= { unisPOEAlarmStateObjects 2 }

unisPOEAlarmStateInfoEntry OBJECT-TYPE
      SYNTAX UnisPOEAlarmStateInfoEntry
      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "The unisPOEAlarmModuleInfoIndex will match the number
             of the power module."
INDEX { unisPOEAlarmModuleInfoIndex }
      ::= { unisPOEAlarmStateInfoTable 1 }

UnisPOEAlarmStateInfoEntry ::=
      SEQUENCE {
               unisPOEAlarmModuleInfoIndex
                       Integer32,
               unisPOEModuleDisconnect
                       ModuleAlarmState,
               unisPOEModuleInputError
                       ModuleAlarmState,
               unisPOEModuleOutputError
                       ModuleAlarmState,
               unisPOEModuleOverVoltage
                       ModuleAlarmState,
               unisPOEModuleOverTemp
                       ModuleAlarmState,
               unisPOEModuleFanError
                       ModuleAlarmState,
               unisPOEModuleShutdown
                       ModuleAlarmState,
               unisPOEModuleCurRestricted
                       ModuleAlarmState
               }

unisPOEAlarmModuleInfoIndex OBJECT-TYPE
      SYNTAX Integer32 (1..2147483647)
      MAX-ACCESS accessible-for-notify
      STATUS current
      DESCRIPTION
             "The index specifies the index of the UnisPOEAlarmStateInfoEntry table.
             The range of this node is from 1 to unisPOEAlarmStateModuleNum."
      ::= { unisPOEAlarmStateInfoEntry 1 }

unisPOEModuleDisconnect OBJECT-TYPE
      SYNTAX ModuleAlarmState
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The node specifies the alarm state:
             The module does not link.
             The value of this node is one of the following values:
                              normal (1),
                              alarm  (2)."
