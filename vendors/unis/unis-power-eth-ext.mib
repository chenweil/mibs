unisPOEACSwitchStateModuleObjs OBJECT IDENTIFIER ::= { unisPOEPowerObjects 5 }

unisPOEACSwitchStateModuleNum OBJECT-TYPE
      SYNTAX Integer32
      MAX-ACCESS read-only
      STATUS current
      DESCRIPTION
             "The number of the AC swtich state module on this POE power.
             It is the maximum of unisPOEACSwitchStateIndex."
      ::= { unisPOEACSwitchStateModuleObjs 1 }

unisPOEACSwitchStateTable OBJECT-TYPE
      SYNTAX SEQUENCE OF UnisPOEACSwitchStateEntry
      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "The table of the AC switch state on this POE power."
