      MAX-ACCESS not-accessible
      STATUS current
      DESCRIPTION
             "The entry of the AC switch state on this POE power."
      INDEX { unisPOEACSwitchStateIndex }
      ::= { unisPOEACSwitchStateTable 1 }

UnisPOEACSwitchStateEntry ::=
