        unisIfMonInputErrorAlarmStatistics    Counter64,
        unisIfMonOutputErrorAlarmStatistics   Counter64,
        unisIfMonSdhErrorStatistics           Counter64,
        unisIfMonSdhB1ErrorStatistics         Counter64,
        unisIfMonSdhB2ErrorStatistics         Counter64,
