-- =================================================================
unisIfMonControl  OBJECT IDENTIFIER ::= { unisIfMonGroup 2 }

unisIfMonThresholdTable  OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisIfMonThresholdEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table is about the upper threshold, lower threshold, CRC type, and inspection interval.
         The upper threshold and lower threshold must be bound together.  If the CRC type is configured,
         node unisIfMonCRCErrType must be carried.  If there is no current configuration for a type, all
         attributes of this type must be carried.  After modification, the table unisIfMonAlarmDownEnableTable
         will be changed.If there is configuration for the current type, setting all attributes of this type to
         invalid values indicates that the configuration of this type is deleted, and the table unisIfMonAlarmDownEnableTable
         will be changed.  Take CRC as an example.  If there is no CRC configuration, nodes unisIfMonCRCErrorLowThres,
         unisIfMonCRCErrorLowThres, unisIfMonCRCErrorLowThres, and unisIfMonCRCErrorLowThres must be carried.
         After modification, the node unisIfMonCRCErrorEnableDown becomes false.  If there is CRC configuration,
         settings the nodes unisIfMonCRCErrorLowThres, unisIfMonCRCErrorHighThres, unisIfMonCRCErrorInterval,
         and unisIfMonCRCErrorInterval to invalid values indicates the CRC configuration is deleted, and the
         node unisIfMonCRCErrorEnableDown becomes invalid."

    ::= { unisIfMonControl 1 }

unisIfMonThresholdEntry OBJECT-TYPE
    SYNTAX      UnisIfMonThresholdEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Entry items."
    INDEX
        {
            ifIndex
        }
    ::= { unisIfMonThresholdTable 1}

UnisIfMonThresholdEntry ::= SEQUENCE
    {
        unisIfMonInputUsageLowThres               Unsigned32,
        unisIfMonInputUsageHighThres              Unsigned32,
        unisIfMonOutputUsageLowThres              Unsigned32,
        unisIfMonOutputUsageHighThres             Unsigned32,
        unisIfMonInputErrorAlarmLowThres          Unsigned32,
        unisIfMonInputErrorAlarmHighThres         Unsigned32,
        unisIfMonInputErrorAlarmInterval          Unsigned32,
        unisIfMonOutputErrorAlarmLowThres         Unsigned32,
        unisIfMonOutputErrorAlarmHighThres        Unsigned32,
        unisIfMonOutputErrorAlarmInterval         Unsigned32,
        unisIfMonSdhErrorLowThres                 Unsigned32,
        unisIfMonSdhErrorHighThres                Unsigned32,
        unisIfMonSdhErrorInterval                 Unsigned32,
        unisIfMonSdhB1ErrorLowThres               Unsigned32,
        unisIfMonSdhB1ErrorHighThres              Unsigned32,
        unisIfMonSdhB1ErrorInterval               Unsigned32,
        unisIfMonSdhB2ErrorLowThres               Unsigned32,
        unisIfMonSdhB2ErrorHighThres              Unsigned32,
        unisIfMonSdhB2ErrorInterval               Unsigned32,
        unisIfMonCRCErrorLowThres                 Unsigned32,
        unisIfMonCRCErrorHighThres                Unsigned32,
        unisIfMonCRCErrorInterval                 Unsigned32,
        unisIfMonCRCErrType                       INTEGER,
        unisIfMonRxPauseFrameLowThres             Unsigned32,
        unisIfMonRxPauseFrameHighThres            Unsigned32,
        unisIfMonRxPauseFrameInterval             Unsigned32,
        unisIfMonTxPauseFrameLowThres             Unsigned32,
        unisIfMonTxPauseFrameHighThres            Unsigned32,
        unisIfMonTxPauseFrameInterval             Unsigned32,
        unisIfMonGiantLowThres                    Unsigned32,
        unisIfMonGiantHighThres                   Unsigned32,
        unisIfMonGiantInterval                    Unsigned32,
        unisIfMonRuntLowThres                     Unsigned32,
        unisIfMonRuntHighThres                    Unsigned32,
        unisIfMonRuntInterval                     Unsigned32
    }

