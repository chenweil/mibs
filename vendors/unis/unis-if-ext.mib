unisIfMonAlarmDownEnableTable   OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisIfMonAlarmDownEnableEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table can set or get whether to enable the interface down function."
    ::= { unisIfMonControl 2 }

unisIfMonAlarmDownEnableEntry OBJECT-TYPE
    SYNTAX      UnisIfMonAlarmDownEnableEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Entry items"
    INDEX
        {
            ifIndex
        }
    ::= { unisIfMonAlarmDownEnableTable 1}

UnisIfMonAlarmDownEnableEntry ::= SEQUENCE
    {
        unisIfMonInputErrorAlarmEnableDown        TruthValue,
        unisIfMonOutputErrorAlarmEnableDown       TruthValue,
        unisIfMonSdhErrorEnableDown               TruthValue,
        unisIfMonSdhB1ErrorEnableDown             TruthValue,
        unisIfMonSdhB2ErrorEnableDown             TruthValue,
        unisIfMonCRCErrorEnableDown               TruthValue,
        unisIfMonGiantEnableDown                  TruthValue,
        unisIfMonRuntEnableDown                   TruthValue
    }

unisIfMonInputErrorAlarmEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of inbound error packets exceeds the upper threshold,
         the physical interface goes down. "
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 1 }

unisIfMonOutputErrorAlarmEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of outbound error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 2 }

unisIfMonSdhErrorEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of SDH error packets exceeds the upper threshold,
         the physical interface goes down. "
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 3 }

unisIfMonSdhB1ErrorEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of SDH B1 error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 4 }

unisIfMonSdhB2ErrorEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of SDH B2 error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 5 }

unisIfMonCRCErrorEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of CRC error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 6 }

unisIfMonGiantEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of Giant error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 7 }

unisIfMonRuntEnableDown OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "When the number of Runt error packets exceeds the upper threshold,
         the physical interface goes down."
    DEFVAL { false }
    ::= { unisIfMonAlarmDownEnableEntry 8 }


-- =================================================================
-- Traps are defined below.

unisIfMonTrap OBJECT IDENTIFIER ::= { unisIfExt 6 }
unisIfMonTrapPrex OBJECT IDENTIFIER ::= { unisIfMonTrap 0 }
-- All trap definitions should be placed under this object.

unisIfMonInputUsageRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonInputUsageLowThres,
            unisIfMonInputUsageHighThres,
            unisIfMonInputUsageStatistics
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the inbound bandwidth usage exceeds the
         upper threshold."
    ::= { unisIfMonTrapPrex 1 }

unisIfMonInputUsageResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonInputUsageLowThres,
            unisIfMonInputUsageHighThres,
            unisIfMonInputUsageStatistics
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the inbound bandwidth usage drops from
         above the upper threshold to below the lower threshold."
    ::= { unisIfMonTrapPrex 2 }

unisIfMonOutputUsageRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonOutputUsageLowThres,
            unisIfMonOutputUsageHighThres,
            unisIfMonOutputUsageStatistics
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the outbound bandwidth usage exceeds the
         upper threshold."
    ::= { unisIfMonTrapPrex 3 }

unisIfMonOutputUsageResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonOutputUsageLowThres,
            unisIfMonOutputUsageHighThres,
            unisIfMonOutputUsageStatistics
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the outbound bandwidth usage drops from
         above the upper threshold to below the lower threshold."
    ::= { unisIfMonTrapPrex 4 }

unisIfMonInputErrorAlarmRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonInputErrorAlarmHighThres,
            unisIfMonInputErrorAlarmLowThres,
            unisIfMonInputErrorAlarmStatistics,
            unisIfMonInputErrorAlarmInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of inbound error packets exceeds the
         upper threshold within the default interval."
    ::= { unisIfMonTrapPrex 5 }

unisIfMonInputErrorAlarmResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonInputErrorAlarmHighThres,
            unisIfMonInputErrorAlarmLowThres,
            unisIfMonInputErrorAlarmStatistics,
            unisIfMonInputErrorAlarmInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of inbound error packets drops from
         above the upper threshold to below the lower threshold within the default interval."
    ::= { unisIfMonTrapPrex 6 }

unisIfMonOutputErrorAlarmRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonOutputErrorAlarmHighThres,
            unisIfMonOutputErrorAlarmLowThres,
            unisIfMonOutputErrorAlarmStatistics,
            unisIfMonOutputErrorAlarmInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of outbound error packets exceeds the
         upper threshold within the default interval."
    ::= { unisIfMonTrapPrex 7 }

unisIfMonOutputErrorAlarmResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonOutputErrorAlarmHighThres,
            unisIfMonOutputErrorAlarmLowThres,
            unisIfMonOutputErrorAlarmStatistics,
            unisIfMonOutputErrorAlarmInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of outbound error packets drops from
         above the upper threshold to below the lower threshold within the default interval."
    ::= { unisIfMonTrapPrex 8 }

unisIfMonSdhErrorRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonSdhErrorLowThres,
            unisIfMonSdhErrorHighThres,
            unisIfMonSdhErrorStatistics,
            unisIfMonSdhErrorInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of SDH error packets exceeds
         the upper threshold within the default interval."
    ::= { unisIfMonTrapPrex 9 }

unisIfMonSdhErrorResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonSdhErrorLowThres,
            unisIfMonSdhErrorHighThres,
            unisIfMonSdhErrorStatistics,
            unisIfMonSdhErrorInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of SDH error packets drops from
         above the upper threshold to below the lower threshold within the default interval."
    ::= { unisIfMonTrapPrex 10 }

unisIfMonSdhB1ErrorRising NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonSdhB1ErrorLowThres,
            unisIfMonSdhB1ErrorHighThres,
            unisIfMonSdhB1ErrorStatistics,
            unisIfMonSdhB1ErrorInterval
        }
    STATUS current
    DESCRIPTION
        "The notification is generated when the number of SDH B1 error packets exceeds
         the upper threshold within the default interval."
    ::= { unisIfMonTrapPrex 11 }

unisIfMonSdhB1ErrorResume NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisIfMonSdhB1ErrorLowThres,
            unisIfMonSdhB1ErrorHighThres,
            unisIfMonSdhB1ErrorStatistics,
            unisIfMonSdhB1ErrorInterval
        }
    STATUS current
