    unisDomainOnlineIPv6User   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of online IPv6 users in the domain."
    ::= { unisDomainStatEntry 14 }

    unisDomainOnlineDualStackUser   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of online dual stack users in the domain."
    ::= { unisDomainStatEntry 15 }

    -- ----------------------------------------------------------------------
    -- Domain IP Pool Statistics Table
    -- ----------------------------------------------------------------------
    unisDomainIPPoolStatTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF UnisDomainIPPoolStatEntry
        MAX-ACCESS  not-accessible
        STATUS  current
        DESCRIPTION
        "The (conceptual) table listing IP pool statistics."
    ::= { unisDomainTables 5 }

    unisDomainIPPoolStatEntry OBJECT-TYPE
        SYNTAX  UnisDomainIPPoolStatEntry
        MAX-ACCESS  not-accessible
        STATUS  current
        DESCRIPTION
        "An entry (conceptual row) representing statistics of an IP pool."
        INDEX { unisDomainName }
    ::= { unisDomainIPPoolStatTable 1 }

    UnisDomainIPPoolStatEntry ::= SEQUENCE {
        unisDomainIPTotalNum                Unsigned32,
        unisDomainIPUsedNum                 Unsigned32,
        unisDomainIPConflictNum             Unsigned32,
        unisDomainIPExcludeNum              Unsigned32,
        unisDomainIPIdleNum                 Unsigned32,
        unisDomainIPUsedPercent             OCTET STRING,
        unisDomainIPv6AddressTotalNum       Unsigned32,
        unisDomainIPv6AddressUsedNum        Unsigned32,
        unisDomainIPv6AddressFreeNum        Unsigned32,
        unisDomainIPv6AddressConflictNum    Unsigned32,
        unisDomainIPv6AddressExcludeNum     Unsigned32,
        unisDomainIPv6AddressUsedPercent    OCTET STRING,
        unisDomainNDRAPrefixTotalNum        Unsigned32,
        unisDomainNDRAPrefixUsedNum         Unsigned32,
        unisDomainNDRAPrefixFreeNum         Unsigned32,
        unisDomainNDRAPrefixConflictNum     Unsigned32,
        unisDomainNDRAPrefixExcludeNum      Unsigned32,
        unisDomainNDRAPrefixUsedPercent     OCTET STRING,
        unisDomainPDPrefixTotalNum          Unsigned32,
        unisDomainPDPrefixUsedNum           Unsigned32,
        unisDomainPDPrefixFreeNum           Unsigned32,
        unisDomainPDPrefixConflictNum       Unsigned32,
        unisDomainPDPrefixExcludeNum        Unsigned32,
        unisDomainPDPrefixUsedPercent       OCTET STRING }


    unisDomainIPTotalNum   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS  current
        DESCRIPTION
        "Total number of addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 1 }


    unisDomainIPUsedNum    OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS  current
        DESCRIPTION
        "Number of addresses already used in the IP pool."
    ::= { unisDomainIPPoolStatEntry 2 }


    unisDomainIPConflictNum   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS  current
        DESCRIPTION
        "Number of conflicting addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 3 }


    unisDomainIPExcludeNum   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of addresses excluded from the IP pool."
    ::= { unisDomainIPPoolStatEntry 4 }

   unisDomainIPIdleNum   OBJECT-TYPE
        SYNTAX   Unsigned32
        MAX-ACCESS  read-only
        STATUS  current
        DESCRIPTION
        "Number of idle addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 5 }

    unisDomainIPUsedPercent   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (0..32))
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Address occupancy rate in the IP pool."
    ::= { unisDomainIPPoolStatEntry 6 }

    unisDomainIPv6AddressTotalNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Total number of IPv6 addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 7 }

    unisDomainIPv6AddressUsedNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of IPv6 addresses already used in the IP pool."
    ::= { unisDomainIPPoolStatEntry 8 }

    unisDomainIPv6AddressFreeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of idle IPv6 addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 9 }

    unisDomainIPv6AddressConflictNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of conflicting IPv6 addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 10 }

    unisDomainIPv6AddressExcludeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of IPv6 addresses excluded from the IP pool."
    ::= { unisDomainIPPoolStatEntry 11 }

    unisDomainIPv6AddressUsedPercent   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (1..64))
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "IPv6 Address occupancy rate in the IP pool.
        The value is in percentage.
        For example: 0.79 means the IPv6 Address occupancy rate in the IP pool is 0.79%."
    ::= { unisDomainIPPoolStatEntry 12 }

    unisDomainNDRAPrefixTotalNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Total number of NDRA prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 13 }

    unisDomainNDRAPrefixUsedNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of NDRA prefix addresses already used in the IP pool."
    ::= { unisDomainIPPoolStatEntry 14 }

    unisDomainNDRAPrefixFreeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of idle NDRA prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 15 }

    unisDomainNDRAPrefixConflictNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of conflicting NDRA prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 16 }

    unisDomainNDRAPrefixExcludeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of NDRA prefix addresses excluded from the IP pool."
    ::= { unisDomainIPPoolStatEntry 17 }

    unisDomainNDRAPrefixUsedPercent   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (1..64))
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "NDRA prefix occupancy rate in the IP pool.
        The value is in percentage.
        For example: 0.79 means the NDRA prefix occupancy rate in the IP pool is 0.79%."
    ::= { unisDomainIPPoolStatEntry 18 }

    unisDomainPDPrefixTotalNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Total number of PD prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 19 }

    unisDomainPDPrefixUsedNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of PD prefix addresses already used in the IP pool."
    ::= { unisDomainIPPoolStatEntry 20 }

    unisDomainPDPrefixFreeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of idle PD prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 21 }

    unisDomainPDPrefixConflictNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of conflicting PD prefix addresses in the IP pool."
    ::= { unisDomainIPPoolStatEntry 22 }

    unisDomainPDPrefixExcludeNum   OBJECT-TYPE
        SYNTAX Unsigned32
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "Number of PD prefix addresses excluded from the IP pool."
    ::= { unisDomainIPPoolStatEntry 23 }

    unisDomainPDPrefixUsedPercent   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (1..64))
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "PD prefix occupancy rate in the IP pool.
        The value is in percentage.
        For example: 0.79 means the PD prefix occupancy rate in the IP pool is 0.79%."
    ::= { unisDomainIPPoolStatEntry 24 }

    -- ----------------------------------------------------------------------
    -- Domain NAT binding Table
    -- ----------------------------------------------------------------------
    unisDomainNatBindingTable OBJECT-TYPE
        SYNTAX  SEQUENCE OF UnisDomainNatBindingEntry
        MAX-ACCESS  not-accessible
        STATUS  current
        DESCRIPTION
        "The (conceptual) table lists user group-to-NAT instance bindings of
        all domains.  The device assigns an authenticated user to a load-sharing
        user group and uses the NAT instance associated with that user group
        to process the NAT service of the user."
    ::= { unisDomainTables 6 }

    unisDomainNatBindingEntry OBJECT-TYPE
        SYNTAX  UnisDomainNatBindingEntry
        MAX-ACCESS  not-accessible
        STATUS  current
        DESCRIPTION
        "An entry (conceptual row) lists user group-to-NAT instance bindings of a domain."
        INDEX { unisDomainName, unisDomainNatBindingUserGroupName }
    ::= { unisDomainNatBindingTable 1 }

    UnisDomainNatBindingEntry ::= SEQUENCE {
        unisDomainNatBindingUserGroupName  OCTET STRING,
        unisDomainNatBindingNatInstance    OCTET STRING,
        unisDomainNatBindingRowStatus      RowStatus
        }

    unisDomainNatBindingUserGroupName   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (1..32))
        MAX-ACCESS  read-only
        STATUS   current
        DESCRIPTION
        "The user group name."
    ::= { unisDomainNatBindingEntry 1 }

    unisDomainNatBindingNatInstance   OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE (1..31))
        MAX-ACCESS  read-create
        STATUS   current
        DESCRIPTION
        "The bound NAT instance."
    ::= { unisDomainNatBindingEntry 2 }

    unisDomainNatBindingRowStatus   OBJECT-TYPE
        SYNTAX   RowStatus
        MAX-ACCESS  read-create
        STATUS   current
        DESCRIPTION
        "This object is responsible for managing the creation, deletion and
         modification of rows. The object supports the active state and the
         CreateAndGo and Destroy operations."
    ::= { unisDomainNatBindingEntry 3 }

