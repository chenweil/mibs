    ::= { unisNqaGroupStatsJitterEntry 34 }

-- Reaction Table
unisNqaReactionTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisNqaReactionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table of NQA test monitoring notification and
        reaction configuration definitions.

        An entry is removed from this table when its
        corresponding pingCtlEntry is deleted.

         When PingCtlType of the test is unisNqaTwampLight,
         it does not support the table."
  ::= { unisNqaObjects 13 }

unisNqaReactionEntry OBJECT-TYPE
    SYNTAX      UnisNqaReactionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Defines an entry in the unisNqaReactionTable. The first two index
        elements identify the pingCtlEntry that a unisNqaReactItemIndex
        belongs to. The third index element selects a single reaction."
    INDEX
        {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex
        }
    ::= { unisNqaReactionTable 1 }

UnisNqaReactionEntry ::=
    SEQUENCE
        {
            unisNqaReactOwnerIndex                   SnmpAdminString,
            unisNqaReactTestName                     SnmpAdminString,
            unisNqaReactItemIndex                    Unsigned32,
            unisNqaReactCheckedElement               INTEGER,
            unisNqaReactThresholdUpperLimit          Unsigned32,
            unisNqaReactThresholdLowerLimit          Unsigned32,
            unisNqaReactThresholdType                INTEGER,
            unisNqaReactThresholdConsecNum           Unsigned32,
            unisNqaReactThresholdAccumNum            Unsigned32,
            unisNqaReactActionType                   INTEGER,
            unisNqaReactCurrentStatus                INTEGER,
            unisNqaReactRowStatus                    RowStatus,
            unisNqaReactCheckedNum                   Unsigned32,
            unisNqaReactThresholdNum                 Unsigned32
        }

unisNqaReactOwnerIndex OBJECT-TYPE
    SYNTAX      SnmpAdminString (SIZE(0..32))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "The first index of unisNqaReactionTable, it is the same as
        pingCtlOwnerIndex in pingCtlTable. unisNqaReactOwnerIndex and
        unisNqaReactTestName identify an existed test."
    ::= { unisNqaReactionEntry 1 }

unisNqaReactTestName OBJECT-TYPE
    SYNTAX      SnmpAdminString (SIZE(0..32))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "The second index of unisNqaReactionTable, it is the same as
        pingCtlTestName in pingCtlTable. unisNqaReactOwnerIndex and
        unisNqaReactTestName identify an existed test."
    ::= { unisNqaReactionEntry 2 }

unisNqaReactItemIndex OBJECT-TYPE
    SYNTAX      Unsigned32 (1..10)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "The third index of unisNqaReactionTable, it definitely
        identifies one of the reaction configurations for a test."
    ::= { unisNqaReactionEntry 3 }

unisNqaReactCheckedElement OBJECT-TYPE
    SYNTAX      INTEGER {
                          probetime(1),
                          probefailure(2),
                          jitterrtt(3),
                          jitterpacketloss(4),
                          jittersd(5),
                          jitterds(6),
                          icpif(7),
                          mos(8),
                          jitterOwdSD(9),
                          jitterOwdDS(10)
                        }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "A list of reaction condition type.
        'probetime' and 'probefailure' are valid when pingCtlType of
        the test is not unisNqajitter.

        'jitterOwdSD': one way time from source to destination in
                       jitter test.
        'jitterOwdDS': one way time from destination to source in
                       jitter test.

        'jitterrtt', 'jitterpacketloss', 'jittersd', 'jitterds',
        'jitterOwdSD' and 'jitterOwdDS' are valid when pingCtlType
        of the test is unisNqajitter.

        'icpif' and 'mos' are valid when pingCtlType of the test is
        unisNqajitter and unisNqaCtlCodecType is 'g711Alaw' or 'g711Ulaw'
        or 'g729A'."
     ::= { unisNqaReactionEntry 4 }

unisNqaReactThresholdUpperLimit OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object defines an administrative upper-threshold value for
        unisNqaReactCheckedElement.

        The value of this object is zero if unisNqaReactCheckedElement is
        specified as 'jitterpacketloss' and 'probefailure'."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 5 }

unisNqaReactThresholdLowerLimit OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object defines an administrative lower-threshold value for
        unisNqaReactCheckedElement.

        The value of unisNqaReactThresholdLowerLimit should be equal or less
        than the value of unisNqaReactThresholdUpperLimit.

        The value of this object is zero if unisNqaReactCheckedElement is
        specified as 'jitterpacketloss' and 'probefailure'."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 6 }

unisNqaReactThresholdType OBJECT-TYPE
    SYNTAX      INTEGER {
                           invalid(0),
                           average(1),
                           consecutive(2),
                           accumulative(3)
                       }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object defines the reaction threshold types.

        invalid(0):     Invalid value.

        average(1):     If reaction threshold type is average and the average
                        value of watched operation exceeds threshold limit,
                        an action specified in unisNqaReactActionType is
                        generated when unisNqaReactCurrentStatus changes.

        consecutive(2): If reaction threshold type is consecutive and
                        the times of watched operation consecutively exceeds
                        the limit specified by unisNqaReactThresholdConsecNum,
                        an action specified in unisNqaReactActionType is
                        generated when unisNqaReactCurrentStatus changes.

        accumulative(3): If reaction threshold type is accumulative and
                        the times of watched operation accumulatively exceeds
                        the limit specified by unisNqaReactThresholdAccumNum,
                        an action specified in unisNqaReactActionType is
                        generated when unisNqaReactCurrentStatus changes.

        If reaction threshold type is not configured, the value of this
        object is 'invalid'."
    ::= { unisNqaReactionEntry 7 }

unisNqaReactThresholdConsecNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object defines a consecutive threshold limit.

        The value is zero when unisNqaReactThresholdType
        is not 'consecutive'."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 8 }

unisNqaReactThresholdAccumNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object defines an accumulative threshold limit.

        The value is zero when the unisNqaReactThresholdType
        is not 'accumulative'."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 9 }

unisNqaReactActionType OBJECT-TYPE
    SYNTAX      INTEGER {
                           none(0),
                           trapOnly(1),
                           triggerOnly(2),
                           trapAndTrigger(3)
                        }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Specifies the type of reaction to generate if the specified
        violation type occurs for the monitored element:

        none               - No reaction is generated
        trapOnly           - A trap is generated
        triggerOnly        - All trigger actions defined for this
                             entry are generated
        trapAndTrigger     - Both a trap and all trigger actions
                             are generated "
    DEFVAL { none }
    ::= { unisNqaReactionEntry 10 }

unisNqaReactCurrentStatus OBJECT-TYPE
    SYNTAX      INTEGER {
                            invalid(1),
                            overThreshold(2),
                            belowThreshold(3),
                            overUpperThreshold(4),
                            belowLowerThreshold(5)
                        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Specifies the current status of this reaction entry:

        invalid  - The status of the reaction entry is unknown.

        overThreshold       - The status of the reaction entry is overThreshold
                              when the monitored result exceeds the threshold
                              value for the unisNqaReactThresholdType.

        belowThreshold      - The status of the reaction entry is belowThreshold
                              when the monitored result is under the threshold
                              value for the unisNqaReactThresholdType.

        overUpperThreshold  - The status of the reaction entry is overThreshold
                              when the monitored result is exceeds the
                              upper-threshold value for the
                              unisNqaReactThresholdType.

        belowLowerThreshold - The status of the reaction entry is belowThreshold
                              when the monitored result is under the
                              lower-threshold value for
                              unisNqaReactThresholdType."

    ::= { unisNqaReactionEntry 11 }

unisNqaReactRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object allows entries to be created and deleted
        in the unisNqaReactionTable.

        Creation of an entry in this table results in a new set of reaction
        configurations which take effect immediately.

        Deletion of an entry in this table results in corresponding reaction
        configurations are being deleted and stop taking effect."
    REFERENCE
        "See definition of RowStatus in RFC 2579, 'Textual
        Conventions for SMIv2.'"
    ::= { unisNqaReactionEntry 12 }

unisNqaReactCheckedNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The number of checked element samples that are monitored."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 13 }

unisNqaReactThresholdNum OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The number of checked element samples that are over threshold."
    DEFVAL { 0 }
    ::= { unisNqaReactionEntry 14 }

-- Statistics Reaction Table
unisNqaStatisticsReactionTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisNqaStatisticsReactionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table of NQA test monitoring notification and
        reaction configuration definitions.

        An entry is removed from this table when its
        corresponding pingCtlEntry is deleted."
  ::= { unisNqaObjects 14 }

unisNqaStatisticsReactionEntry OBJECT-TYPE
    SYNTAX      UnisNqaStatisticsReactionEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Defines an entry in the unisNqaStatisticsReactionTable. The
        first two index elements identify the pingCtlEntry that a
        unisNqaReactItemIndex belongs to. The third index element
        identifies an entry in the unisNqaStatisticsResultsTable.
        The forth index element selects a single reaction."
    INDEX
        {
            unisNqaStatReactOwnerIndex,
            unisNqaStatReactTestName,
            unisNqaStatReactIndex,
            unisNqaStatReactItemIndex
        }
    ::= { unisNqaStatisticsReactionTable 1 }

UnisNqaStatisticsReactionEntry ::=
    SEQUENCE
        {
            unisNqaStatReactOwnerIndex               SnmpAdminString,
            unisNqaStatReactTestName                 SnmpAdminString,
            unisNqaStatReactIndex                    Unsigned32,
            unisNqaStatReactItemIndex                Unsigned32,
            unisNqaStatReactCheckedNum               Counter32,
            unisNqaStatReactThresholdNum             Counter32
        }

unisNqaStatReactOwnerIndex OBJECT-TYPE
    SYNTAX      SnmpAdminString (SIZE(0..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The first index of unisNqaStatisticsReactionTable, it is the same
        as pingCtlOwnerIndex in pingCtlTable."
    ::= { unisNqaStatisticsReactionEntry 1 }

unisNqaStatReactTestName OBJECT-TYPE
    SYNTAX      SnmpAdminString (SIZE(0..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The second index of unisNqaStatisticsReactionTable, it is the same
        as pingCtlTestName in pingCtlTable."
    ::= { unisNqaStatisticsReactionEntry 2 }

unisNqaStatReactIndex OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The third index of unisNqaStatisticsReactionTable. An entry in
        this table is created when the statistics result of a NQA probe
        is determined.

        An implementation MUST start assigning unisNqaStatResIndex values
        at 1 and wrap after exceeding the maximum possible value as
        defined by the limit of this object ('ffffffff'h)."
    DEFVAL { 0 }
    ::= { unisNqaStatisticsReactionEntry 3 }

unisNqaStatReactItemIndex OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "The forth index of unisNqaStatisticsReactionTable, it definitely
        identifies one of the reaction configurations for a test"
    DEFVAL { 0 }
    ::= { unisNqaStatisticsReactionEntry 4 }

unisNqaStatReactCheckedNum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The number of checked element samples that are monitored."
    DEFVAL { 0 }
    ::= { unisNqaStatisticsReactionEntry 5 }

unisNqaStatReactThresholdNum OBJECT-TYPE
    SYNTAX      Counter32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The number of checked element samples that are over threshold."
    DEFVAL { 0 }
    ::= { unisNqaStatisticsReactionEntry 6 }

-- =================================================================
--   NQA server configuration extended information
-- =================================================================

unisNqaTcpServerExtendTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisNqaTcpServerExtendEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table which contains the status of extended NQA TCP server
        configuration information."
    ::= { unisNqaObjects 15 }

unisNqaTcpServerExtendEntry OBJECT-TYPE
    SYNTAX      UnisNqaTcpServerExtendEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table which contains the status of extended NQA TCP server
        configuration information.
        This entry includes the TCP server IP address, port,
        VPN name and DSField."
    INDEX {
            unisNqaTcpServerExtIpAddress,
            unisNqaTcpServerExtPort,
            unisNqaTcpServerExtVPNType,
            unisNqaTcpServerExtVPNInstance
          }
    ::= { unisNqaTcpServerExtendTable 1 }

UnisNqaTcpServerExtendEntry  ::= SEQUENCE
{
    unisNqaTcpServerExtIpAddress                InetAddress,
    unisNqaTcpServerExtPort                     Integer32,
    unisNqaTcpServerExtVPNType                  VpnInstanceType,
    unisNqaTcpServerExtVPNInstance              OCTET STRING,
    unisNqaTcpServerExtDSField                  Unsigned32,
    unisNqaTcpServerExtRowStatus                RowStatus
}

unisNqaTcpServerExtIpAddress          OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "TCP server's IP address."
    ::= { unisNqaTcpServerExtendEntry 1 }

unisNqaTcpServerExtPort          OBJECT-TYPE
    SYNTAX      Integer32 (0..65536)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "TCP server's port number."
    ::= { unisNqaTcpServerExtendEntry 2 }

unisNqaTcpServerExtVPNType OBJECT-TYPE
    SYNTAX      VpnInstanceType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "TCP server's VPN instance type."
    ::= { unisNqaTcpServerExtendEntry 3 }

unisNqaTcpServerExtVPNInstance OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..31))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "TCP server's VPN name.If the NQA server listens on the public network,
        the value of unisNqaTcpServerExtVPNType must be public(1) and the value
        of this object can be set to any non-printable character string.If the
        NQA server listens on the private network, the value of unisNqaTcpServerExtVPNType
        must be vpn(2) and the value of this object can be set to any non-printable
        character string."
    ::= { unisNqaTcpServerExtendEntry 4 }

unisNqaTcpServerExtDSField OBJECT-TYPE
    SYNTAX      Unsigned32 (0..256)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Specifies the value to store in the Differentiated
        Services (DS) Field in the IP packet used to
        encapsulate the probe.  The DS Field is defined
        as the Type of Service (TOS) octet in a IPv4 header
        or as the Traffic Class octet in a IPv6 header.

        The value of this object must be a decimal integer
        in the range of 0 to 255.  Not all values are legal or
        meaningful.  A value of 0 means that the function
        represented by this option is not supported.  The value
        of 256 indicates that TOS is not configured, and this
        value is not supported by IP implementations.  DS Field
        usage is often not supported by IP implementations and
        not all values are supported.  Refer to RFC 2474 for
        guidance on usage of this field."
    REFERENCE
        "Refer to RFC 2474 for the definition of the
        Differentiated Services Field and to RFC 1812
        Section 5.3.2 for Type of Service (TOS)."
    ::= { unisNqaTcpServerExtendEntry 5 }

unisNqaTcpServerExtRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "unisNqaTcpServerIpAddress, unisNqaTcpServerPort, unisNqaTcpServerExtVPNType
        and unisNqaTcpServerVPNInstance must be set during a creation operation."
    REFERENCE
        "RFC 2579"
    ::= { unisNqaTcpServerExtendEntry 6 }

unisNqaUdpServerExtendTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisNqaUdpServerExtendEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Status of extended NQA UDP server configuration information."
    ::= { unisNqaObjects 16 }

unisNqaUdpServerExtendEntry OBJECT-TYPE
    SYNTAX      UnisNqaUdpServerExtendEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "A table which contains the status of extended NQA UDP server
        configuration information.
        This entry includes the UDP server IP address, port,
        VPN name and DSField."
    INDEX {
            unisNqaUdpServerExtIpAddress,
            unisNqaUdpServerExtPort,
            unisNqaUdpServerExtVPNType,
            unisNqaUdpServerExtVPNInstance
          }
    ::= { unisNqaUdpServerExtendTable 1 }

UnisNqaUdpServerExtendEntry  ::= SEQUENCE
{
    unisNqaUdpServerExtIpAddress                InetAddress,
    unisNqaUdpServerExtPort                     Integer32,
    unisNqaUdpServerExtVPNType                  VpnInstanceType,
    unisNqaUdpServerExtVPNInstance              OCTET STRING,
    unisNqaUdpServerExtDSField                  Unsigned32,
    unisNqaUdpServerExtRowStatus                RowStatus
}

unisNqaUdpServerExtIpAddress          OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "UDP server's IP address."
    ::= { unisNqaUdpServerExtendEntry 1 }

unisNqaUdpServerExtPort          OBJECT-TYPE
    SYNTAX      Integer32 (0..65536)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "UDP server's port number."
    ::= { unisNqaUdpServerExtendEntry 2 }

unisNqaUdpServerExtVPNType OBJECT-TYPE
    SYNTAX      VpnInstanceType
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "UDP server's VPN instance type."
    ::= { unisNqaUdpServerExtendEntry 3 }

unisNqaUdpServerExtVPNInstance OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..31))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "UDP server's VPN name.If the NQA server listens on the public network,
        the value of unisNqaUdpServerExtVPNType must be public(1) and the value
        of this object can be set to any non-printable character string.If the
        NQA server listens on the private network, the value of unisNqaUdpServerExtVPNType
        must be vpn(2) and the value of this object can be set to any non-printable
        character string."
    ::= { unisNqaUdpServerExtendEntry 4 }

unisNqaUdpServerExtDSField OBJECT-TYPE
    SYNTAX      Unsigned32 (0..256)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Specifies the value to store in the Differentiated
        Services (DS) Field in the IP packet used to
        encapsulate the probe.  The DS Field is defined
        as the Type of Service (TOS) octet in a IPv4 header
        or as the Traffic Class octet in a IPv6 header.

        The value of this object must be a decimal integer
        in the range of 0 to 255.  Not all values are legal or
        meaningful.  A value of 0 means that the function
        represented by this option is not supported.  The value
        of 256 indicates that TOS is not configured, and this
        value is not supported by IP implementations.  DS Field
        usage is often not supported by IP implementations and
        not all values are supported.  Refer to RFC 2474 for
        guidance on usage of this field."
    REFERENCE
        "Refer to RFC 2474 for the definition of the
        Differentiated Services Field and to RFC 1812
        Section 5.3.2 for Type of Service (TOS)."
    ::= { unisNqaUdpServerExtendEntry 5 }

unisNqaUdpServerExtRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "unisNqaUdpServerIpAddress, unisNqaUdpServerPort, unisNqaUdpServerExtVPNType
        and unisNqaUdpServerVPNInstance must be set during a creation operation."
    REFERENCE
        "RFC 2579"
    ::= { unisNqaUdpServerExtendEntry 6 }

-- Notification Definition section
unisNqaNotifications  OBJECT IDENTIFIER ::= { unisNqa 3 }
unisNqaProbeTimeOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. Probe time(equals to RTT for some type of tests) is not in
             the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit.
          2. The probe time is accumulatively not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdAccumNum.
          3. The probe time is consecutively in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdConsecNum.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 1 }

unisNqaJitterRTTOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. The average NQA round-trip-time (RTT) of jitter packets
             is not in the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit.
          2. The RTT of jitter packets is accumulatively not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times specified
             in unisNqaReactThresholdAccumNum in one test.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is unisNqajitter or unisNqaTwampLight."
    ::= { unisNqaNotifications 2 }

unisNqaProbeFailure NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. When the probe test accumulatively failed for a
             number of times specified in unisNqaReactThresholdAccumNum in one
             test while the value of unisNqaReactThresholdType is 'accumulative'.
          2. When the probe test consecutively failed for
             a number of times specified in unisNqaReactThresholdConsecNum in one
             test while the value of unisNqaReactThresholdType is 'consecutive'.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 3 }

unisNqaJitterPacketLoss NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. When the jitter packets accumulatively lost for a
             number of times specified in unisNqaReactThresholdAccumNum in one
             test while the value of unisNqaReactThresholdType is 'accumulative'.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is unisNqajitter or unisNqaTwampLight."
    ::= { unisNqaNotifications 4 }

unisNqaJitterSDOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "The SD means the jitter values from source to destination.

        It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. The average of SD in one jitter test is not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit and the
             unisNqaReactThresholdType is specified as 'average' type.
          2. The average of SD in one jitter test is accumulatively
             not in the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times specified
             in unisNqaReactThresholdAccumNum and the
             unisNqaReactThresholdType is specified as 'accumulative' type.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is unisNqajitter."
    ::= { unisNqaNotifications 5 }

unisNqaJitterDSOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "The DS means the jitter values from destination to source.

        It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. The average of DS in one jitter test is not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit and the
             unisNqaReactThresholdType is specified as 'average' type.
          2. The average of DS in one jitter test is accumulatively not
             in the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times specified
             in unisNqaReactThresholdAccumNum and the
             unisNqaReactThresholdType is specified as 'accumulative' type.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is unisNqajitter."
    ::= { unisNqaNotifications 6 }

unisNqaICPIFOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. When the ICPIF value in one jitter test is not in
             the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger', pingCtlType of the test
        is unisNqajitter and unisNqaCtlCodecType is 'g711Alaw' or 'g711Ulaw'
        or 'g729A'."
    ::= { unisNqaNotifications 7 }

unisNqaMOSOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is over threshold
        or below threshold.

        The over threshold situations is specified as below.
          1. When the MOS value in one jitter test is not in
             the range unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger', pingCtlType of the test
        is unisNqajitter and unisNqaCtlCodecType is 'g711Alaw' or 'g711Ulaw'
        or 'g729A'."
    ::= { unisNqaNotifications 8 }

unisNqaJitterOverThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType,
            unisNqaReactCurrentStatus
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes.
        The change may occur when the watched condition is above threshold
        or below threshold.

          1. The average jitter value is not in the range of
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit and the
             unisNqaReactThresholdType is specified as 'average' type.
          2. The total number of times that the average jitter value is not
             in the range of unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit reaches or exceeds
             the value specified in unisNqaReactThresholdAccumNum and the
             unisNqaReactThresholdType is specified as 'accumulative' type.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is unisNqajitter or unisNqaTwampLight."
    ::= { unisNqaNotifications 9 }

unisNqaProbeTimeAboveThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes to 'overThreshold', 'invalid' or 'overUpperThreshold'.
        The change may occur when the monitored condition exceeds the
        threshold (or upper threshold) or When NQA operation is stopped.

        The above threshold situations are specified as below.
          1. Probe time is not in the range unisNqaReactThresholdLowerLimit
             through unisNqaReactThresholdUpperLimit.
          2. The probe time is accumulatively not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdAccumNum.
          3. The probe time is consecutively not in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdConsecNum.
          4. When NQA operation is stopped.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 10 }

unisNqaProbeTimeBelowThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes to 'belowThreshold' or 'belowLowerThreshold' from a
        threshold-crossing state.

        The below threshold situations are specified as below.
          1. Probe time is in the range unisNqaReactThresholdLowerLimit
             through unisNqaReactThresholdUpperLimit.
          2. The probe time is accumulatively in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdAccumNum.
          3. The probe time is consecutively in the range
             unisNqaReactThresholdLowerLimit through
             unisNqaReactThresholdUpperLimit for a number of times
             specified in unisNqaReactThresholdConsecNum.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 11 }

unisNqaProbeFailAboveThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes to 'overThreshold', 'invalid' or 'overUpperThreshold'.
        The change may occur when the monitored condition exceeds the
        threshold (or upper threshold) or When NQA operation is stopped.

        The threshold-crossing situations are specified as below.
          1. When the number of accumulative failed probes reaches the specified
             value in unisNqaReactThresholdAccumNum in one test while the value
             of unisNqaReactThresholdType is 'accumulative'.
          2. When the number of consecutive failed probes reaches the specified
             value in unisNqaReactThresholdConsecNum in one test while the value
             of unisNqaReactThresholdType is 'consecutive'.
          3. When NQA operation is stopped.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 12 }

unisNqaProbeFailBelowThreshold NOTIFICATION-TYPE
    OBJECTS {
            unisNqaReactOwnerIndex,
            unisNqaReactTestName,
            unisNqaReactItemIndex,
            pingCtlTargetAddressType,
            pingCtlTargetAddress,
            pingCtlType,
            pingCtlDescr,
            unisNqaReactThresholdType
        }
    STATUS  current
    DESCRIPTION
        "It is generated when the value of unisNqaReactCurrentStatus
        changes to 'belowThreshold' or 'belowLowerThreshold' from a
        threshold-crossing state.

        The below threshold situations are specified as below.
          1. When the number of accumulative successful probes reaches the specified
             value in unisNqaReactThresholdAccumNum in one test while the value
             of unisNqaReactThresholdType is 'accumulative'.
          2. When the number of consecutive successful probes reaches the specified
             value in unisNqaReactThresholdConsecNum in one test while the value
             of unisNqaReactThresholdType is 'consecutive'.

        This notification is valid only when unisNqaReactActionType
        is 'trapOnly' or 'trapAndTrigger' and pingCtlType of the test
        is not unisNqajitter."
    ::= { unisNqaNotifications 13 }

END
