    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "The table of MirrorGroup."
    ::= { unisLswQosMibObject 26 }

  unisMirroringGroupEntry OBJECT-TYPE
    SYNTAX      UnisMirroringGroupEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "Configuration information of MirrorGroup."
    INDEX  {
    	       unisMirroringGroupID
    	   }
    ::= { unisMirroringGroupTable 1 }

  UnisMirroringGroupEntry ::=
    SEQUENCE
    {
      unisMirroringGroupID    INTEGER,
      unisMirroringGroupType    INTEGER,
      unisMirroringGroupStatus    INTEGER,
      unisMirroringGroupRowStatus    RowStatus
    }

   unisMirroringGroupID  OBJECT-TYPE
    SYNTAX      INTEGER(1..20)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "GroupID."
    ::= { unisMirroringGroupEntry 1 }

    unisMirroringGroupType  OBJECT-TYPE
    SYNTAX      INTEGER{local(1),remote-source(2),remote-destination(3)}
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "GroupType."
    ::= { unisMirroringGroupEntry 2 }

    unisMirroringGroupStatus  OBJECT-TYPE
    SYNTAX      INTEGER{active(1),inactive(2)}
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
      "MirroringGroup status."
    ::= { unisMirroringGroupEntry 3 }

    unisMirroringGroupRowStatus  OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "RowStatus, Now support three status: createAndGo, active, destroy."
    ::= { unisMirroringGroupEntry 4 }

  -- TABLE: unisMirroringGroupMirrorTable ---------
  unisMirroringGroupMirrorTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisMirroringGroupMirrorEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "MirroringGroup mirroring-port information."
    ::= { unisLswQosMibObject 27 }

  unisMirroringGroupMirrorEntry OBJECT-TYPE
    SYNTAX      UnisMirroringGroupMirrorEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "MirroringGroup mirroring-port information."
    INDEX {
              unisMirroringGroupID
          }
    ::= { unisMirroringGroupMirrorTable 1 }

  UnisMirroringGroupMirrorEntry ::=
    SEQUENCE
    {
      unisMirroringGroupMirrorInboundIfIndexList    OCTET STRING,
      unisMirroringGroupMirrorOutboundIfIndexList    OCTET STRING,
      unisMirroringGroupMirrorRowStatus    RowStatus,
      unisMirroringGroupMirrorInTypeList         OCTET STRING,
      unisMirroringGroupMirrorOutTypeList         OCTET STRING
    }

    unisMirroringGroupMirrorInboundIfIndexList  OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Inbound-Mirror ifIndex(for port) and slot number(for board) list.

      Example A describes the relation between values of
      unisMirroringGroupMirrorInboundIfIndexList and unisMirroringGroupMirrorInTypeList.

      Example A:
      unisMirroringGroupMirrorInboundIfIndexList: '00000002 0C000022 00000007'
      unisMirroringGroupMirrorInTypeList:         '00000002 00000001 00000002'

      Every four octets represent an integer value.
      The first four octets of them should be same. Here the value '00000002'
      indicates there are two inbound mirror sources.
      The following every four octets of unisMirroringGroupMirrorInboundIfIndexList
      indicate an ifIndex or a slot number of mirror source. For '0C000022' and
      '00000007' in the value of unisMirroringGroupMirrorInboundIfIndexList above,
      the corresponding value of unisMirroringGroupMirrorInTypeList is '00000001'
      and '00000002'(00000001 means the mirror source is port, 00000002 means the 
      mirror source is board, the meaning reference the object UnisMirrorOrMonitorType), 
      then '0C000022' indicates an ifIndex value 201326626(decimal), and '00000007' 
      indicates a slot with number 7(decimal).

      Values with different types(port/board) should be set in separate set operations.
      If one value with port type and one value with board type are set with same
      unisMirroringGroupID separately, the result of get operation for that entry
      will be like the example A above.
      
      If unisMirroringGroupMirrorInTypeList is not supported, the first four octets
      of unisMirroringGroupMirrorInboundIfIndexList also indicates the number of mirror
      source, but the following octets are values for ifIndex(port type).

      unisMirroringGroupMirrorOutboundIfIndexList and unisMirroringGroupMirrorOutTypeList
      are a pair and have the same relations like unisMirroringGroupMirrorInboundIfIndexList
      and unisMirroringGroupMirrorInTypeList pair.
      "
    ::= { unisMirroringGroupMirrorEntry 1 }

    unisMirroringGroupMirrorOutboundIfIndexList  OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Outbound-Mirror ifIndex and slot number list.
      Please refer to the description of unisMirroringGroupMirrorInboundIfIndexList."
    ::= { unisMirroringGroupMirrorEntry 2 }

    unisMirroringGroupMirrorRowStatus  OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "RowStatus, now support three status: createAndGo, active, destroy."
    ::= { unisMirroringGroupMirrorEntry 3 }
    
    unisMirroringGroupMirrorInTypeList  OBJECT-TYPE
    SYNTAX      OCTET STRING 
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Inbound-Mirror type list.
      Please refer to the description of unisMirroringGroupMirrorInboundIfIndexList."
      
    ::= { unisMirroringGroupMirrorEntry 4 }
    
    unisMirroringGroupMirrorOutTypeList  OBJECT-TYPE
    SYNTAX      OCTET STRING    
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Outbound-Mirror type list.
      Please refer to the description of unisMirroringGroupMirrorInboundIfIndexList."
    ::= { unisMirroringGroupMirrorEntry 5 }

  -- TABLE: unisMirroringGroupMonitorTable ---------
  unisMirroringGroupMonitorTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisMirroringGroupMonitorEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "MirroringGroup monitor-port information."
    ::= { unisLswQosMibObject 28 }

  unisMirroringGroupMonitorEntry OBJECT-TYPE
    SYNTAX      UnisMirroringGroupMonitorEntry
    MAX-ACCESS  not-accessible
