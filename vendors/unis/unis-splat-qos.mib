--     V1.0 2002-11-18 created by qizhenglin
--     V1.1 2004-05-09 add and modify unisPortWredTable by tangshun
--     V1.2 2004-08-05 modify unisQueueScheduleMode(add hq_wrr(9)) by qizhenglin
--     v1.3 2004-08-12 add unisFlowtempVlanId,unisFlowtempCos to unisFlowtempTable
--     v1.4 2004-09-17 change value range of unisRateLimitTargetRateKbps from 200..100000
--          to 64..1000000 by zhuangyu
--     v1.5 2004-10-12 updated by gaolong
--          Import Counter64.
--          Remove some adjacent hyphens
--          Rewrite value of unisQueueScheduleMode and unisRateLimitConformActionType.
--          Change all underscore('_') characters to hyphen characters('-') because
--          underscore character is not allowed in MIB module.
--     v1.51 2004-10-27 changed by zhuangyu
--          1 Add an enumeration in unisRateLimitConformActionType
--          2 Add unisRateLimitConformCos and unisRateLimitConformDscp in unisRateLimitTable
--          3 Import IpAddress
--     v1.52 2004-12-13 updated by jinyi
--          Fix syntax bugs and adjust format of the whole file.
--     v1.53 2004-12-13 updated by zhuangyu
--          Modify description of unisRateLimitExceedDscp,unisRateLimitConformDscp and unisPriorityDscp.
--     v1.6 2004-12-1 changed by yangjianjun
--          Add  unisMirroringGroupTable
--               unisMirroringGroupMirrorTable
--               unisMirroringGroupMonitorTable
--               unisMirroringGroupReflectorTable
--               unisMirroringGroupRprobeVlanTable
--     v1.7 2005-4-6 changed by fanghailin
--          Add unisRedirectToSlotNo unisRedirectRemarkedDSCP unisRedirectRemarkedPri unisRedirectRemarkedTos
--          unisRedirectToNextHop3 unisRedirectTargetVlan unisRedirectMode
--          in unisRedirectTable Notice:All the nodes are used only for L3plus funtion and speciality.
--     v1.8 2005-5-18 updated by zhangyinxi
--          Add  unisRedirectToNestedVlanID and unisRedirectToModifiedVlanID
--     v1.9 2005-6-27
--          1. Add unisMirroringGroupMirrorMacTable, unisMirroringGroupMirrorVlanTable,
--             unisPortTrustTable, unisRemarkVlanIDTable, unisCosToDscpMapTable, unisDscpToLocalPreMapTable,
--             unisDscpToDropPreMapTable, unisDscpToCosMapTable, unisDscpToDscpMapTable,
--             unisRateLimitMeterStatByteCount, unisRateLimitMeterStatByteXCount,
--             unisRateLimitMeterStatState by liyan and wangyingxia
--          2. Modify the range of unisRateLimitTargetRateKbps by liyan and wangyingxia
--          3. Add unisMirrorToGroup in unisMirrorTable by yubin
--     v2.0 2005-10-25 updated by houli
--          1. Remove value range of unisLineRateValue
--          2. Remove value range of unisRateLimitTargetRateMbps
--     V2.1 2005-11-07 update by wangyingxia
--          1. Add UnisMirrorOrMonitorType and unisMirroringGroupMonitorType
--          2. Modify the description of unisMirroringGroupMonitorIfIndex
--          3. Change the value range of unisRedirectTargetVlan by lihaijun
--     V2.2 2005-12-19 update by wangyingxia
--          1. Add unisMirroringGroupMirrorInTypeList, unisMirroringGroupMirrorOutTypeList
--             by wangyingxia
--          2. change the description of unisMirroringGroupMirrorInboundIfIndexList  
--             add unisMirroringGroupMirrorOutboundIfIndexList by wangyingxia
--     v2.3 2006-01-16 updated by houli
--          1. Remove value range of unisTrafficShapeMaxRate
--          2. Remove value range of unisTrafficShapeBurstSize
-- ------------------------------------------------------------------
-- ------------------------------------------------------------------
--
-- Import and definition
--
-- ------------------------------------------------------------------
UNIS-LswQos-MIB DEFINITIONS ::= BEGIN

IMPORTS

    Integer32, MODULE-IDENTITY,OBJECT-TYPE,Counter32, Counter64,IpAddress
        FROM SNMPv2-SMI
    TruthValue, MacAddress, RowStatus, TEXTUAL-CONVENTION
        FROM SNMPv2-TC
    unislswCommon
        FROM UNIS-OID-MIB;


---------- Following is for NodeŁşunisLswQosMib --------
  unisLswQosAclMib MODULE-IDENTITY
    LAST-UPDATED "200211190000Z"
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
      "Module node for qos and acl."
    REVISION "200211190000Z"
    DESCRIPTION
      "Table of qos and acl."
    ::= { unislswCommon  16 }

  UnisMirrorOrMonitorType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
    "
     Specify the mirror source or destination type.
     port(1):
        the mirror source or destination is port.
     board(2):
        the mirror source or destination is board.
    "
    SYNTAX INTEGER
    {
       port(1),
       board(2)
    }

---------- Following is for NodeŁşunisLswQosMibObject --------
  unisLswQosMibObject OBJECT IDENTIFIER ::= {  unisLswQosAclMib 2  }

  unisPriorityTrustMode OBJECT-TYPE
    SYNTAX      INTEGER
            {
                default(0),
                dscp(1),
                ipprecedence(2),
                cos(3),
                localprecedence(4)
            }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "Priority type of inbound queue."
    DEFVAL      { 0}
    ::= { unisLswQosMibObject 1 }

  unisPortMonitorBothIfIndex OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "The ifIndex of in/out monitor port."
    DEFVAL      { 0}
    ::= { unisLswQosMibObject 2 }


 --TABLE: unisQueueTable

  unisQueueTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisQueueEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "Queue table which contains queue entry."
    ::= { unisLswQosMibObject 3 }

  unisQueueEntry OBJECT-TYPE
    SYNTAX      UnisQueueEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "The configuration information of queue."
    INDEX {
              unisQueueIfIndex
          }
    ::= { unisQueueTable 1 }

  UnisQueueEntry ::=
    SEQUENCE
    {
      unisQueueIfIndex    INTEGER,
      unisQueueScheduleMode    INTEGER,
      unisQueueWeight1    INTEGER,
      unisQueueWeight2    INTEGER,
      unisQueueWeight3    INTEGER,
      unisQueueWeight4    INTEGER,
      unisQueueMaxDelay    INTEGER,
      unisQueueWeight5    INTEGER,
      unisQueueWeight6    INTEGER,
      unisQueueWeight7    INTEGER,
      unisQueueWeight8    INTEGER
    }


  unisQueueIfIndex OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
      "ifIndex of port."
    ::= { unisQueueEntry 1 }

  unisQueueScheduleMode OBJECT-TYPE
    SYNTAX      INTEGER{
                        sp(1),
                        wrr(2),
                        wrr-max-delay(3),
                        sc-0(4),
                        sc-1(5),
                        sc-2(6),
                        rr(7),
                        wfq(8),
                        hq-wrr(9)
                       }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "The mode of the queue schedule."
    DEFVAL      { sp }
    ::= { unisQueueEntry 2 }

  unisQueueWeight1 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight1 represent the bandwidth of queue 1.
      If queue mode is wrr, then unisQueueWeight1 represent the weight of queue 1."
    ::= { unisQueueEntry 3 }

  unisQueueWeight2 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight2 represent the bandwidth of queue 2.
      If queue mode is wrr, then unisQueueWeight2 represent the weight of queue 2."
    ::= { unisQueueEntry 4 }

  unisQueueWeight3 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight3 represent the bandwidth of queue 3.
      If queue mode is wrr, then unisQueueWeight3 represent the weight of queue 3."
    ::= { unisQueueEntry 5 }

  unisQueueWeight4 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight4 represent the bandwidth of queue 4.
      If queue mode is wrr, then unisQueueWeight4 represent the weight of queue 4."
    ::= { unisQueueEntry 6 }

  unisQueueMaxDelay OBJECT-TYPE
    SYNTAX      INTEGER(0..255)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      " "
    ::= { unisQueueEntry 7 }

  unisQueueWeight5 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight5 represent the bandwidth of queue 5.
      If queue mode is wrr, then unisQueueWeight5 represent the weight of queue 5."
    ::= { unisQueueEntry 8 }

  unisQueueWeight6 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight6 represent the bandwidth of queue 6.
      If queue mode is wrr, then unisQueueWeight6 represent the weight of queue 6."
    ::= { unisQueueEntry 9 }

  unisQueueWeight7 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight7 represent the bandwidth of queue 7.
      If queue mode is wrr, then unisQueueWeight7 represent the weight of queue 7."
    ::= { unisQueueEntry 10 }

  unisQueueWeight8 OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
      "If queue mode is wfq, then unisQueueWeight8 represent the bandwidth of queue 8.
      If queue mode is wrr, then unisQueueWeight8 represent the weight of queue 8."
    ::= { unisQueueEntry 11 }


  -- TABLE: unisRateLimitTable ------
  unisRateLimitTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisRateLimitEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "Rate limit table which contains limit entry. "
    ::= { unisLswQosMibObject 4 }

  unisRateLimitEntry OBJECT-TYPE
    SYNTAX      UnisRateLimitEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "The configuration information of the rate-limited port."
    INDEX {
              unisRateLimitAclIndex,
              unisRateLimitIfIndex,
              unisRateLimitVlanID,
              unisRateLimitDirection
          }
    ::= { unisRateLimitTable 1 }

  UnisRateLimitEntry ::=
    SEQUENCE
    {
      unisRateLimitAclIndex    INTEGER,
      unisRateLimitIfIndex    INTEGER,
      unisRateLimitVlanID    INTEGER,
      unisRateLimitDirection    INTEGER,
      unisRateLimitUserAclNum    INTEGER,
      unisRateLimitUserAclRule    INTEGER,
      unisRateLimitIpAclNum    INTEGER,
      unisRateLimitIpAclRule    INTEGER,
      unisRateLimitLinkAclNum    INTEGER,
      unisRateLimitLinkAclRule    INTEGER,
      unisRateLimitTargetRateMbps    INTEGER,
      unisRateLimitTargetRateKbps    INTEGER,
      unisRateLimitPeakRate    INTEGER,
      unisRateLimitCIR    INTEGER,
      unisRateLimitCBS    INTEGER,
      unisRateLimitEBS    INTEGER,
      unisRateLimitPIR    INTEGER,
      unisRateLimitConformLocalPre    INTEGER,
      unisRateLimitConformActionType    INTEGER,
      unisRateLimitExceedActionType    INTEGER,
      unisRateLimitExceedDscp    INTEGER,
      unisRateLimitRuntime    TruthValue,
      unisRateLimitRowStatus    RowStatus,
      unisRateLimitExceedCos INTEGER,
      unisRateLimitConformCos INTEGER,
      unisRateLimitConformDscp INTEGER,
      unisRateLimitMeterStatByteCount Counter64,
      unisRateLimitMeterStatByteXCount Counter64,
      unisRateLimitMeterStatState INTEGER
    }

  unisRateLimitAclIndex OBJECT-TYPE
    SYNTAX      INTEGER(0..2999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Index of acl rule."
    ::= { unisRateLimitEntry 1 }

  unisRateLimitIfIndex OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "ifIndex of the rate-limited port."
    ::= { unisRateLimitEntry 2 }

  unisRateLimitVlanID OBJECT-TYPE
    SYNTAX      INTEGER(0..4094)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Vlan ID."
    ::= { unisRateLimitEntry 3 }

  unisRateLimitDirection OBJECT-TYPE
    SYNTAX      INTEGER{invalid(0), input(1), output(2)}
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Direction of the rate-limited port."
    ::= { unisRateLimitEntry 4 }

  unisRateLimitUserAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|5000..5999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of user acl."
    ::= { unisRateLimitEntry 5 }

  unisRateLimitUserAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of user acl-rule."
    ::= { unisRateLimitEntry 6 }

  unisRateLimitIpAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|2000..3999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of Ip acl."
    ::= { unisRateLimitEntry 7 }

  unisRateLimitIpAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of Ip acl-rule."
    ::= { unisRateLimitEntry 8 }

  unisRateLimitLinkAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|4000..4999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of link acl."
    ::= { unisRateLimitEntry 9 }

  unisRateLimitLinkAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of link acl-rule."
    ::= { unisRateLimitEntry 10 }

  unisRateLimitTargetRateMbps OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Target rate: Mbps."
    ::= { unisRateLimitEntry 11 }

  unisRateLimitTargetRateKbps OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Target rate: Kbps."
    ::= { unisRateLimitEntry 12 }

  unisRateLimitPeakRate OBJECT-TYPE
    SYNTAX      INTEGER(0|64..8388608)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Peak rate of the rate-limited port."
    ::= { unisRateLimitEntry 13 }

  unisRateLimitCIR OBJECT-TYPE
    SYNTAX      INTEGER(0..34120000)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "CIR of the rate-limited port."
    ::= { unisRateLimitEntry 14 }

  unisRateLimitCBS OBJECT-TYPE
    SYNTAX      INTEGER(0..1048575)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Burst traffic of the rate-limited port."
    ::= { unisRateLimitEntry 15 }

  unisRateLimitEBS OBJECT-TYPE
    SYNTAX      INTEGER(0..268435455)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Excess burst traffic of the rate-limited port."
    ::= { unisRateLimitEntry 16 }

  unisRateLimitPIR OBJECT-TYPE
    SYNTAX      INTEGER(0..34120000)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "PIR of the rate-limited port."
    ::= { unisRateLimitEntry 17 }

  unisRateLimitConformLocalPre OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Conform local pre."
    DEFVAL      { 1 }
    ::= { unisRateLimitEntry 18 }

  unisRateLimitConformActionType OBJECT-TYPE
    SYNTAX      INTEGER{
                       invalid(0),
                       remark-cos(1),
                       remark-drop-priority(2),
                       remark-cos-drop-priority(3),
                       remark-policed-service(4),
                       remark-dscp(5)
                       }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Conform action type."
    DEFVAL      { 1 }
    ::= { unisRateLimitEntry 19 }

  unisRateLimitExceedActionType OBJECT-TYPE
    SYNTAX      INTEGER{invalid(0), forward(1), drop(2), remarkdscp(3), exceed-cos(4)}
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Exceed action type."
    DEFVAL      { 1 }
    ::= { unisRateLimitEntry 20 }

  unisRateLimitExceedDscp OBJECT-TYPE
    SYNTAX      INTEGER(0..63|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Exceed DSCP.
      <0-63>  Value of DSCP
      af11    Specify Assured Forwarding 11 service(10)
      af12    Specify Assured Forwarding 12 service(12)
      af13    Specify Assured Forwarding 13 service(14)
      af21    Specify Assured Forwarding 21 service(18)
      af22    Specify Assured Forwarding 22 service(20)
      af23    Specify Assured Forwarding 23 service(22)
      af31    Specify Assured Forwarding 31 service(26)
      af32    Specify Assured Forwarding 32 service(28)
      af33    Specify Assured Forwarding 33 service(30)
      af41    Specify Assured Forwarding 41 service(34)
      af42    Specify Assured Forwarding 42 service(36)
      af43    Specify Assured Forwarding 43 service(38)
      be      Specify Best Effort service(0)
      cs1     Specify Class Selector 1 service(8)
      cs2     Specify Class Selector 2 service(16)
      cs3     Specify Class Selector 3 service(24)
      cs4     Specify Class Selector 4 service(32)
      cs5     Specify Class Selector 5 service(40)
      cs6     Specify Class Selector 6 service(48)
      cs7     Specify Class Selector 7 service(56)
      ef      Specify Expedited Forwarding service(46)"
    DEFVAL      { 255 }
    ::= { unisRateLimitEntry 21 }

  unisRateLimitRuntime OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
      "Runtime."
    ::= { unisRateLimitEntry 22 }

  unisRateLimitRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "RowStatus, now support three status: createAndGo, active, destroy."
    ::= { unisRateLimitEntry 23 }

  unisRateLimitExceedCos OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Exceeding COS of rate-limited port."
    DEFVAL      { 255 }
    ::= { unisRateLimitEntry 24 }

  unisRateLimitConformCos OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "If the user choose remark-cos value of the unisRateLimitConformActionType,
      This object can be used to set the conform COS value.  There are a few
      enumerations as follows:
      background          Specify background priority(1)
      best-effort         Specify best-effort priority(0)
      controlled-load     Specify controlled-load priority(4)
      excellent-effort    Specify excellent-effort priority(3)
      network-management  Specify network-management priority(7)
      spare               Specify spare priority(2)
      video               Specify video priority(5)
      voice               Specify voice priority(6)"
    DEFVAL      { 255 }
    ::= { unisRateLimitEntry 25 }

  unisRateLimitConformDscp OBJECT-TYPE
    SYNTAX      INTEGER(0..63|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "If the user choose remark-dscp value of the unisRateLimitConformActionType,
      This object can be used to set the conform dscp value.  There are a few
      enumerations as follows:
      <0-63>  Value of DSCP
      af11    Specify Assured Forwarding 11 service(10)
      af12    Specify Assured Forwarding 12 service(12)
      af13    Specify Assured Forwarding 13 service(14)
      af21    Specify Assured Forwarding 21 service(18)
      af22    Specify Assured Forwarding 22 service(20)
      af23    Specify Assured Forwarding 23 service(22)
      af31    Specify Assured Forwarding 31 service(26)
      af32    Specify Assured Forwarding 32 service(28)
      af33    Specify Assured Forwarding 33 service(30)
      af41    Specify Assured Forwarding 41 service(34)
      af42    Specify Assured Forwarding 42 service(36)
      af43    Specify Assured Forwarding 43 service(38)
      be      Specify Best Effort service(0)
      cs1     Specify Class Selector 1 service(8)
      cs2     Specify Class Selector 2 service(16)
      cs3     Specify Class Selector 3 service(24)
      cs4     Specify Class Selector 4 service(32)
      cs5     Specify Class Selector 5 service(40)
      cs6     Specify Class Selector 6 service(48)
      cs7     Specify Class Selector 7 service(56)
      ef      Specify Expedited Forwarding service(46)"
    DEFVAL      { 255 }
    ::= { unisRateLimitEntry 26 }

  unisRateLimitMeterStatByteCount  OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
               "The counter of conform byte."
    ::= { unisRateLimitEntry 27 }

  unisRateLimitMeterStatByteXCount  OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
               "The counter of exceed byte."
    ::= { unisRateLimitEntry 28 }

  unisRateLimitMeterStatState  OBJECT-TYPE
    SYNTAX      INTEGER
                       {
                       set(1), --enable meter statistic
                       unDo(2), --undo meter statistic
                       reset(3), --reset meter statistic
                       running(4), --status of meter statistic running
                       notRunning(5) --status of meter statistic not running
                       }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
               "The status of meter statistic."
    ::= { unisRateLimitEntry 29 }

  -- TABLE: unisPriorityTable ------
  unisPriorityTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPriorityEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "The priority table which contains priority entry."
    ::= { unisLswQosMibObject 5 }

  unisPriorityEntry OBJECT-TYPE
    SYNTAX      UnisPriorityEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
      "The configuration information of priority."
    INDEX {
              unisPriorityAclIndex,
              unisPriorityIfIndex,
              unisPriorityVlanID,
              unisPriorityDirection
          }
    ::= { unisPriorityTable 1 }

  UnisPriorityEntry ::=
    SEQUENCE
    {
      unisPriorityAclIndex    INTEGER,
      unisPriorityIfIndex    INTEGER,
      unisPriorityVlanID    INTEGER,
      unisPriorityDirection    INTEGER,
      unisPriorityUserAclNum    INTEGER,
      unisPriorityUserAclRule    INTEGER,
      unisPriorityIpAclNum    INTEGER,
      unisPriorityIpAclRule    INTEGER,
      unisPriorityLinkAclNum    INTEGER,
      unisPriorityLinkAclRule    INTEGER,
      unisPriorityDscp    INTEGER,
      unisPriorityIpPre    INTEGER,
      unisPriorityIpPreFromCos    TruthValue,
      unisPriorityCos    INTEGER,
      unisPriorityCosFromIpPre    TruthValue,
      unisPriorityLocalPre    INTEGER,
      unisPriorityPolicedServiceType    INTEGER,
      unisPriorityPolicedServiceDscp    INTEGER,
      unisPriorityPolicedServiceExp    INTEGER,
      unisPriorityPolicedServiceCos    INTEGER,
      unisPriorityPolicedServiceLoaclPre    INTEGER,
      unisPriorityPolicedServiceDropPriority    INTEGER,
      unisPriorityRuntime    TruthValue,
      unisPriorityRowStatus    RowStatus
    }

  unisPriorityAclIndex OBJECT-TYPE
    SYNTAX      INTEGER(0..2999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Index of acl rule."
    ::= { unisPriorityEntry 1 }

  unisPriorityIfIndex OBJECT-TYPE
    SYNTAX      INTEGER
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "ifIndex of the port."
    ::= { unisPriorityEntry 2 }

  unisPriorityVlanID OBJECT-TYPE
    SYNTAX      INTEGER(0..4094)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Vlan ID."
    ::= { unisPriorityEntry 3 }

  unisPriorityDirection OBJECT-TYPE
    SYNTAX      INTEGER{invalid(0), input(1), output(2)}
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Direction of data stream."
    ::= { unisPriorityEntry 4 }

  unisPriorityUserAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|5000..5999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of user acl."
    ::= { unisPriorityEntry 5 }

  unisPriorityUserAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The subitem of the user acl."
    ::= { unisPriorityEntry 6 }

  unisPriorityIpAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|2000..3999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of Ip acl."
    ::= { unisPriorityEntry 7 }

  unisPriorityIpAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The subitem of the IP acl."
    ::= { unisPriorityEntry 8 }

  unisPriorityLinkAclNum OBJECT-TYPE
    SYNTAX      INTEGER(0|4000..4999|10000..12999)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The number of Link acl."
    ::= { unisPriorityEntry 9 }

  unisPriorityLinkAclRule OBJECT-TYPE
    SYNTAX      INTEGER(0..65535)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The subitem of the link acl."
    ::= { unisPriorityEntry 10 }

  unisPriorityDscp OBJECT-TYPE
    SYNTAX      INTEGER(0..63|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set DSCP Value.
      <0-63>  Value of DSCP
      af11    Specify Assured Forwarding 11 service(10)
      af12    Specify Assured Forwarding 12 service(12)
      af13    Specify Assured Forwarding 13 service(14)
      af21    Specify Assured Forwarding 21 service(18)
      af22    Specify Assured Forwarding 22 service(20)
      af23    Specify Assured Forwarding 23 service(22)
      af31    Specify Assured Forwarding 31 service(26)
      af32    Specify Assured Forwarding 32 service(28)
      af33    Specify Assured Forwarding 33 service(30)
      af41    Specify Assured Forwarding 41 service(34)
      af42    Specify Assured Forwarding 42 service(36)
      af43    Specify Assured Forwarding 43 service(38)
      be      Specify Best Effort service(0)
      cs1     Specify Class Selector 1 service(8)
      cs2     Specify Class Selector 2 service(16)
      cs3     Specify Class Selector 3 service(24)
      cs4     Specify Class Selector 4 service(32)
      cs5     Specify Class Selector 5 service(40)
      cs6     Specify Class Selector 6 service(48)
      cs7     Specify Class Selector 7 service(56)
      ef      Specify Expedited Forwarding service(46)"
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 11 }

  unisPriorityIpPre OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set Ip precedence."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 12 }

  unisPriorityIpPreFromCos OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set Ip precedence according to vlan priority."
    DEFVAL      { 2 }
    ::= { unisPriorityEntry 13 }

  unisPriorityCos OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set vlan priority."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 14 }

  unisPriorityCosFromIpPre OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set vlan priority according to IP precedence."
    DEFVAL      { 2 }
    ::= { unisPriorityEntry 15 }

  unisPriorityLocalPre OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "Set local precedence."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 16 }

  unisPriorityPolicedServiceType OBJECT-TYPE
    SYNTAX      INTEGER{invalid(0), auto(1), trust-dscp(2), new-dscp(3), untrusted(4)}
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The service type of proliced Priority."
    ::= { unisPriorityEntry 17 }

  unisPriorityPolicedServiceDscp OBJECT-TYPE
    SYNTAX      INTEGER(0..63|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The service Dscp of proliced Priority."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 18 }

  unisPriorityPolicedServiceExp OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The service Exp of proliced Priority."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 19 }

  unisPriorityPolicedServiceCos OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
      "The service COS of proliced Priority."
    DEFVAL      { 255 }
    ::= { unisPriorityEntry 20 }

  unisPriorityPolicedServiceLoaclPre OBJECT-TYPE
    SYNTAX      INTEGER(0..7|255)
    MAX-ACCESS  read-create
    STATUS      current
