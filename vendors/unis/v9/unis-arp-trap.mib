-- unisARPTrapGatewayCheck
unisARPTrapGatewayCheck OBJECT IDENTIFIER ::= { unisARPTrapPkt 7 }

unisARPTrapsGatewayCheck OBJECT IDENTIFIER  ::= { unisARPTrapGatewayCheck 0 }
unisARPTrapGatewayCheckAlarm NOTIFICATION-TYPE
    OBJECTS
        {
            unisARPTrapGatewayCheckIf,
            unisARPTrapGatewayCheckSlot,
            unisARPTrapGatewayCheckIp
        }
    STATUS      current
    DESCRIPTION
        "If the ARP gateway protection feature intercepts an ARP attack
        packet, a trap message is generated and sent to
        the remote monitoring device."
    ::= { unisARPTrapsGatewayCheck 1 }

unisARPTrapGatewayCheckResume NOTIFICATION-TYPE
    OBJECTS
        {
            unisARPTrapGatewayCheckIf,
            unisARPTrapGatewayCheckSlot,
            unisARPTrapGatewayCheckIp
        }
    STATUS      current
    DESCRIPTION
        "If the device is no longer attacked for a period of
        time, a trap message is generated and sent to
        the remote monitoring device."
    ::= { unisARPTrapsGatewayCheck 2 }

unisARPTrapGatewayCheckObjs OBJECT IDENTIFIER  ::= { unisARPTrapGatewayCheck 1 }

unisARPTrapGatewayCheckIf OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(1..47))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Name of the interface that received the ARP packet."
    ::= { unisARPTrapGatewayCheckObjs 1 }

unisARPTrapGatewayCheckSlot OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Slot of interface board."
    ::= { unisARPTrapGatewayCheckObjs 2 }

unisARPTrapGatewayCheckIp OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        " IP address of the ARP packet."
    ::= { unisARPTrapGatewayCheckObjs 3 }

