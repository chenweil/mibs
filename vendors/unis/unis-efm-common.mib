        REFERENCE   "[802.3ah], 30.3.6.1.26."
        ::= { unisDot3OamStatsEntry 7 }

      unisDot3OamLoopbackControlRx OBJECT-TYPE
        SYNTAX      Counter32
        MAX-ACCESS  read-only
