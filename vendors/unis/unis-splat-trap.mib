      STATUS  current
      DESCRIPTION
              "Power module is incompatible with the device"
      ::= { unissLswTRAPMibObject 28 }

      unisCpuUsageSevereNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCpuRatio,
            unisLswCpuUsageMinorThreshold,
            unisLswCpuUsageSevereThreshold,
            unisLswCpuUsageRecoverThreshold,
            unissLswTrapCpuCoreInfo,
            unissLswTrapProcessCpuInfo
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the CPU usage increased to or above
             the unisLswCpuUsageSevereThreshold."
      ::= { unissLswTRAPMibObject 29 }

      unisCpuUsageSevereRecoverNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCpuRatio,
            unisLswCpuUsageMinorThreshold,
            unisLswCpuUsageSevereThreshold,
            unisLswCpuUsageRecoverThreshold,
            unissLswTrapCpuCoreInfo,
            unissLswTrapProcessCpuInfo
            }
      STATUS current
      DESCRIPTION
            "
            When the product does not support unisLswCpuUsageRecoverThreshold,
            the trap indicates that the CPU usage decreased to or below
            the unisLswCpuUsageSevereThreshold.
            When the product supports unisLswCpuUsageRecoverThreshold,
            the trap indicates that the CPU usage decreased to or below
            the unisLswCpuUsageMinorThreshold.
            "
      ::= { unissLswTRAPMibObject 30 }

      unisCpuUsageMinorNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
