    unisNetworkHealthMonitorFailure OBJECT IDENTIFIER ::= { unissLswTRAPMibObject 98 }
    unisNetworkHealthMonitorNormal OBJECT IDENTIFIER ::= { unissLswTRAPMibObject 99 }

-- For compatibility reasons, DO NOT add notification nodes under unissLswTRAPMibObject.
-- Please use unissLswTRAPMibObjectV2Prefix instead.

-- ==================================================================
--
-- lsw trap info
--
-- ==================================================================
   unissLswTRAPMibInfor OBJECT IDENTIFIER ::= { unisLswTrapMib 2 }

   unissLswTrapCpuCoreInfo OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "unisLswCpuCoreIndex,unisLswCpuCoreUsage,unisLswCpuCoreUsr,
             unisLswCpuCoreSys,unisLswCpuCoreIrq,unisLswCpuCoreIdle.

            Each line contains the following comma-separated values:

            unisLswCpuCoreIndex(Integer32):CPU core index.
            unisLswCpuCoreUsage(Unsigned32): Percentage of CPU core usage ,0~100
            unisLswCpuCoreUsr(Unsigned32): Percentage of CPU core user usage ,0~100
            unisLswCpuCoreSys(Unsigned32): Percentage of CPU core system usage ,0~100
            unisLswCpuCoreIrq(Unsigned32): Percentage of CPU core interrupt usage ,0~100
            unisLswCpuCoreIdle(Unsigned32): Percentage of CPU core idle usage ,0~100
            "
        ::= { unissLswTRAPMibInfor 1}

   unissLswTrapProcessCpuInfo OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "unisLswProcessJobId,unisLswProcessPid,unisLswProcessName,
            unisLswProcessState,unisLswProcessPriority,unisLswProcessFDs,
            unisLswProcessRunTime,unisLswProcessCpuRatio5Secs,unisLswProcessCpuRatio1Min,
            unisLswProcessCpuRatio5Mins.

            Each line contains the following comma-separated values:

            unisLswProcessName: Process name
            unisLswProcessJobId:Job ID
            unisLswProcessPid: Process ID
            unisLswProcessPriority: Process priority
            unisLswProcessState: Process state
                {
                R(1):running,
                S(2):sleeping,
                T(3):tracedorStopped,
                D(4):uninterruptibleSleep,
                Z(5):zombie
                }
            unisLswProcessFDs: Process FDs
            unisLswProcessRunTime: Process run time
            unisLswProcessCpuRatio: CPU ratio for the process.
            "
        ::= { unissLswTRAPMibInfor 2 }

   unissLswTrapProcessMemoryInfo OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "unisLswProcessJobId,unisLswProcessName,unisLswProcessMemoryUsed.

            Each line contains the following comma-separated values:

            unisLswProcessJobId: Job ID
            unisLswProcessName: Process name
            unisLswProcessMemoryUsed:
            Memory be used by the process(text + data + stack + dynamic)in KB.
            "
        ::= { unissLswTRAPMibInfor 3 }

   unissLswTrapSlubInfo OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "unisLswSlubInfoUsed + unisLswSlubInfoName.

            Each line contains the following comma-separated values:

            unisLswSlubInfoName: Name of slubinfo
            unisLswSlubInfoUsed: Memory be used by the slub(num*size)
            "
        ::= { unissLswTRAPMibInfor 4 }

    unisLswTrapCpuUsage OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "Cpu usage in 5sec 1min 5min."
        ::= { unissLswTRAPMibInfor 5 }

    unisLswTrapCoreProcessInfo OBJECT-TYPE
        SYNTAX      SnmpAdminString (SIZE (0..255))
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "
            Each line contains the following values:
            JID PID PPID CPU State Memory 5Sec 1Min 5Min Name.
            "
        ::= { unissLswTRAPMibInfor 6 }

    unisLswCoreTrapUsage   OBJECT-TYPE
        SYNTAX     Unsigned32
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "Core usage in last 30 minutes."
        ::= {unissLswTRAPMibInfor 7}

    unisBoardAvailablePower OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "Available power of power supply."
        ::= { unissLswTRAPMibInfor 8 }

    unisBoardRequiredPower OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "Power required for a single board."
        ::= { unissLswTRAPMibInfor 9 }

    unisLswAlarmInPortInNum OBJECT-TYPE
        SYNTAX      Unsigned32
        MAX-ACCESS  accessible-for-notify
        STATUS      current
        DESCRIPTION
            "Alarm-in port-in num."
        ::= { unissLswTRAPMibInfor 10 }

    unisDMAMemoryTotal   OBJECT-TYPE
        SYNTAX     CounterBasedGauge64
        UNITS "byte"
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The total DMA-memory space on the node."
        ::= { unissLswTRAPMibInfor 11 }

    unisDMAMemoryUsed   OBJECT-TYPE
        SYNTAX     CounterBasedGauge64
        UNITS "byte"
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The used DMA-memory space on the node."
        ::= { unissLswTRAPMibInfor 12 }

    unisDMAMemoryFree   OBJECT-TYPE
        SYNTAX     CounterBasedGauge64
        UNITS "byte"
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The free memory space on the node."
        ::= { unissLswTRAPMibInfor 13 }

    unisDMAMemoryFreeRatio   OBJECT-TYPE
        SYNTAX     Unsigned32 (0..100)
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The percentage of free DMA-memory space on the node."
        ::= { unissLswTRAPMibInfor 14 }

    unisDMAMemoryCriticalThreshold   OBJECT-TYPE
        SYNTAX     Unsigned32
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The critical alarm threshold for free DMA-memory,
             MB or percentage."
        ::= { unissLswTRAPMibInfor 15 }

    unisDMAMemoryRecoverThreshold   OBJECT-TYPE
        SYNTAX     Unsigned32
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "The normal state threshold for free DMA-memory,
             MB or percentage.

             When the free DMA-memory space exceeds this threshold, a recovery notification will be sent.
             The normal state threshold cannot be smaller than the critical alarm threshold."
        ::= { unissLswTRAPMibInfor 16 }

    unisDMAMemoryCurrentState   OBJECT-TYPE
        SYNTAX          INTEGER
        {
            normal (1),
            critical (2)
        }
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "Current status of free DMA-memory.

             Normal
             Critical"
        ::= { unissLswTRAPMibInfor 17 }

    unisFrameRemainingPower   OBJECT-TYPE
        SYNTAX     Unsigned32
        UNITS "W"
        MAX-ACCESS     accessible-for-notify
        STATUS     current
        DESCRIPTION
            "Remaining power of the frame."
        ::= {unissLswTRAPMibInfor 18}

    unissLswTRAPMibObjectV2 OBJECT IDENTIFIER ::= { unisLswTrapMib 3 }
    unissLswTRAPMibObjectV2Prefix OBJECT IDENTIFIER ::= { unissLswTRAPMibObjectV2 0 }

    unisCoreUsageNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCoreIndex,
            unisLswCoreTrapUsage,
            unisLswCoreThreshold,
            unisLswTrapCpuUsage,
            unisLswTrapCoreProcessInfo,
            unisLswCoreMinorThreshold,
            unisLswCoreRecoveryThreshold
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the amount of core usage increased to or above
             the unisLswCoreThreshold."
      ::= { unissLswTRAPMibObjectV2Prefix 1 }

    unisBoardPowerNotEnough NOTIFICATION-TYPE
      OBJECTS { unisLswFrameIndex, unisLswSlotIndex, unisBoardAvailablePower, unisBoardRequiredPower}
      STATUS  current
      DESCRIPTION
              "Not enough power for the board."
      ::= { unissLswTRAPMibObjectV2Prefix 2 }

    unisAlarmInPortIn NOTIFICATION-TYPE
        OBJECTS { unisLswFrameIndex, unisLswSlotIndex, unisLswAlarmInPortInNum }
        STATUS current
        DESCRIPTION
            "Alarm reported on the alarm-in port."
        ::= { unissLswTRAPMibObjectV2Prefix 3 }

    unisAlarmInPortRecover NOTIFICATION-TYPE
        OBJECTS { unisLswFrameIndex, unisLswSlotIndex, unisLswAlarmInPortInNum }
        STATUS current
        DESCRIPTION
            "Alarm removed on the alarm-in port."
        ::= { unissLswTRAPMibObjectV2Prefix 4 }

    unisCoreUsageSevereRecoveryNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCoreIndex,
            unisLswCoreTrapUsage,
            unisLswCoreThreshold,
            unisLswTrapCpuUsage,
            unisLswTrapCoreProcessInfo,
            unisLswCoreMinorThreshold,
            unisLswCoreRecoveryThreshold
            }
      STATUS current
      DESCRIPTION
            "
            When the product does not support unisLswCoreRecoveryThreshold,
            the trap indicates that the core usage decreased to or below
            the unisLswCoreThreshold.
            When the product supports unisLswCoreRecoveryThreshold,
            the trap indicates that the core usage decreased to or below
            the unisLswCoreMinorThreshold.
            "
      ::= { unissLswTRAPMibObjectV2Prefix 10 }

    unisCoreUsageMinorNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCoreIndex,
            unisLswCoreTrapUsage,
            unisLswCoreThreshold,
            unisLswTrapCpuUsage,
            unisLswTrapCoreProcessInfo,
            unisLswCoreMinorThreshold,
            unisLswCoreRecoveryThreshold
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the core usage increased to or above
             the unisLswCoreMinorThreshold."
      ::= { unissLswTRAPMibObjectV2Prefix 11 }

    unisCoreUsageMinorRecoveryNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisLswCoreIndex,
            unisLswCoreTrapUsage,
            unisLswCoreThreshold,
            unisLswTrapCpuUsage,
            unisLswTrapCoreProcessInfo,
            unisLswCoreMinorThreshold,
            unisLswCoreRecoveryThreshold
            }
      STATUS current
      DESCRIPTION
            "
            When the product does not support unisLswCoreRecoveryThreshold,
            the trap indicates that the core usage decreased to or below
            the unisLswCoreMinorThreshold.
            When the product supports unisLswCoreRecoveryThreshold,
            the trap indicates that the core usage decreased to or below
            the unisLswCoreRecoveryThreshold.
            "
      ::= { unissLswTRAPMibObjectV2Prefix 12 }

      unisDMAMemoryUsageCriticalNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisDMAMemoryTotal,
            unisDMAMemoryUsed,
            unisDMAMemoryFree,
            unisDMAMemoryCurrentState,
            unisDMAMemoryFreeRatio,
            unisDMAMemoryCriticalThreshold
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the free DMA-memory space decreased to or below
             the critical alarm threshold."
      ::= { unissLswTRAPMibObjectV2Prefix 41 }

      unisDMAMemoryUsageRecoverNotification NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisLswSlotIndex,
            unisLswCpuIndex,
            unisDMAMemoryTotal,
            unisDMAMemoryUsed,
            unisDMAMemoryFree,
            unisDMAMemoryCurrentState,
            unisDMAMemoryFreeRatio,
            unisDMAMemoryRecoverThreshold
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the of free DMA-memory space increased to or above
             the normal state threshold."
      ::= { unissLswTRAPMibObjectV2Prefix 42 }

      unisRemainingPowerNotEnough NOTIFICATION-TYPE
      OBJECTS {
            unisLswFrameIndex,
            unisFrameRemainingPower
            }
      STATUS current
      DESCRIPTION
            "The trap indicates that the remaining power of the chassis is not enouth."
      ::= { unissLswTRAPMibObjectV2Prefix 43 }
END
