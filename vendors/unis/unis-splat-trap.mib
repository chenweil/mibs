            unisLswCpuMemoryFreeRatio,
            unisLswCpuMemoryHighTotal,
            unisLswCpuMemoryHighFree,
            unisLswCpuMemoryLowTotal,
            unisLswCpuMemoryLowFree,
            unisLswCpuMemorySecureThreshold,
