-- ==================================================================
--
-- Variables and types be imported
--
-- ==================================================================
UNIS-LswTRAP-MIB DEFINITIONS ::= BEGIN
IMPORTS
    MODULE-IDENTITY, NOTIFICATION-TYPE, OBJECT-TYPE, Unsigned32, Integer32
        FROM SNMPv2-SMI
    unislswCommon
        FROM UNIS-OID-MIB
    CounterBasedGauge64
        FROM HCNUM-TC
    SnmpAdminString
        FROM SNMP-FRAMEWORK-MIB
    unisDevMPowerNum, unisDevMFanNum, unisDevMFirstTrapTime
        FROM UNIS-LswDEVM-MIB
    unisLswFrameIndex, unisLswSlotIndex, unisLswSubslotIndex, unisLswCpuIndex, unisLswCoreIndex, unisLswCoreThreshold,
    unisLswCoreMinorThreshold, unisLswCoreRecoveryThreshold,unisLswCpuRatio,unisLswCpuUsageMinorThreshold,unisLswCpuUsageSevereThreshold,
    unisLswCpuUsageRecoverThreshold,unisLswCpuMemory,unisLswCpuMemoryFree,unisLswCpuMemoryFreeRatio,unisLswCpuMemoryHighTotal,unisLswCpuMemoryHighFree,
    unisLswCpuMemoryLowTotal,unisLswCpuMemoryLowFree,unisLswCpuMemorySecureThreshold,unisLswCpuMemoryEarlyWarningThreshold,unisLswCpuMemoryNormalThreshold,
    unisLswCpuMemoryMinorThreshold,unisLswCpuMemorySevereThreshold,unisLswCpuMemoryCriticalThreshold,unisLswCpuMemoryCurrentState
        FROM UNIS-LSW-DEV-ADM-MIB;

-- ==================================================================
--
-- ======================= definition begin =========================
--
-- ==================================================================

    unisLswTrapMib MODULE-IDENTITY
            LAST-UPDATED "202010150000Z"
            ORGANIZATION
                "Unisyue Technologies Co., Ltd."
            CONTACT-INFO
                ""
            DESCRIPTION
            ""
            REVISION "202010150000Z"
            DESCRIPTION
            "Add unisRemainingPowerNotEnough
             unisFrameRemainingPower."
            REVISION "201911220000Z"
            DESCRIPTION
            "Add unisDMAMemoryUsageCriticalNotification
             unisDMAMemoryUsageRecoverNotification."
            REVISION "201901110000Z"
            DESCRIPTION
            "Added unisCoreUsageSevereRecoveryNotification
            unisCoreUsageMinorNotification
            unisCoreUsageMinorRecoveryNotificationm."
            REVISION "201804130000Z"
            DESCRIPTION
            "Added unisLswAlarmInPortInNum."
            REVISION "201712050000Z"
            DESCRIPTION
            "Added unisAlarmInPortIn,  unisAlarmInPortRecover."
            REVISION "201707170000Z"
            DESCRIPTION
            "Added unisBoardPowerNotEnough, unisAvailablePower and unisRequiredPower."
            REVISION "201706240000Z"
            DESCRIPTION
            "unisCoreUsageNotification.
             Add unissLswTRAPMibObjectV2Prefix for bindings of notification."
            REVISION "201701120000Z"
            DESCRIPTION
            "Add unisCpuUsageSevereNotification
             unisCpuUsageSevereRecoverNotification
             unisCpuUsageMinorNotification
             unisCpuUsageMinorRecoverNotification.
             unisMemoryUsageEarlyWarningNotification
             unisMemoryUsageEarlyWarningRecoverNotification
             unisMemoryUsageMinorNotification
             unisMemoryUsageMinorRecoverNotification
             unisMemoryUsageSevereNotification
             unisMemoryUsageSevereRecoverNotification
             unisMemoryUsageCriticalNotification
             unisMemoryUsageCriticalRecoverNotification.
             Add unissLswTRAPMibInfor for bindings of notification."
            REVISION "201111260000Z"
            DESCRIPTION
            "Initial revision"
            ::= { unislswCommon 12 }

-- ==================================================================
--
-- lsw trap object
--
-- ==================================================================
    unissLswTRAPMibObject OBJECT IDENTIFIER ::= { unisLswTrapMib 1 }

    unispowerfailure NOTIFICATION-TYPE
      OBJECTS { unisDevMPowerNum, unisDevMFirstTrapTime }
      STATUS  current
      DESCRIPTION
              "Power supply failure"
      ::= { unissLswTRAPMibObject 1 }

    unisPowerNormal NOTIFICATION-TYPE
      OBJECTS { unisDevMPowerNum, unisDevMFirstTrapTime }
      STATUS  current
      DESCRIPTION
              "Power supply normal"
      ::= { unissLswTRAPMibObject 2 }

    unisMasterPowerNormal NOTIFICATION-TYPE
      OBJECTS { unisDevMPowerNum }
      STATUS  current
      DESCRIPTION
              "Master power supply normal"
      ::= { unissLswTRAPMibObject 3 }

    unisSlavePowerNormal NOTIFICATION-TYPE
      OBJECTS { unisDevMPowerNum }
      STATUS  current
      DESCRIPTION
              "Slave power supply normal"
      ::= { unissLswTRAPMibObject 4 }

    unisPowerRemoved NOTIFICATION-TYPE
      OBJECTS { unisDevMPowerNum }
      STATUS  current
      DESCRIPTION
              "Power removed"
      ::= { unissLswTRAPMibObject 5 }

    unisfanfailure NOTIFICATION-TYPE
      OBJECTS { unisDevMFanNum }
      STATUS  current
      DESCRIPTION
              "Fan failure"
      ::= { unissLswTRAPMibObject 6 }

    unisFanNormal NOTIFICATION-TYPE
      OBJECTS { unisDevMFanNum }
      STATUS  current
      DESCRIPTION
              "Fan normal"
      ::= { unissLswTRAPMibObject 7 }

    unisBoardRemoved NOTIFICATION-TYPE
      OBJECTS { unisLswFrameIndex, unisLswSlotIndex }
