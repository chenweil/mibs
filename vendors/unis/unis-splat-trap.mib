            unisLswCpuMemoryHighTotal,
            unisLswCpuMemoryHighFree,
            unisLswCpuMemoryLowTotal,
            unisLswCpuMemoryLowFree,
            unisLswCpuMemorySecureThreshold,
            unisLswCpuMemoryEarlyWarningThreshold,
            unisLswCpuMemoryNormalThreshold,
            unisLswCpuMemoryMinorThreshold,
            unisLswCpuMemorySevereThreshold,
            unisLswCpuMemoryCriticalThreshold,
