unisDot11WlanBssIfTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WlanBssIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table is used to configure WLAN BSS interface."
    ::= { unisDot11InterfaceConfigGroup 2 }

unisDot11WlanBssIfEntry OBJECT-TYPE
    SYNTAX      UnisDot11WlanBssIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the WLAN BSS interface configuration."
    INDEX
        {
            unisDot11WlanBssIfNumber
        }
    ::= { unisDot11WlanBssIfTable 1 }

UnisDot11WlanBssIfEntry ::= SEQUENCE
    {
        unisDot11WlanBssIfNumber     Integer32,
        unisDot11WlanBssIfIndex      Integer32,
        unisDot11WlanBssRowStatus    RowStatus
    }

unisDot11WlanBssIfNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This node represents the WLAN BSS interface number."
    ::= { unisDot11WlanBssIfEntry 1 }

unisDot11WlanBssIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This node represents the ifIndex of WLAN-BSS interface."
    ::= { unisDot11WlanBssIfEntry 2 }

unisDot11WlanBssRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This node represents the WLAN BSS interface row status."
    ::= { unisDot11WlanBssIfEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11WlanBssIfTable Definition
-- *****************************************************************************
-- *****************************************************************************
-- *  unisDot11WLANEthernetIfTable Definition
-- *************************************************************************

unisDot11WLANEthernetIfTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WLANEthernetIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table is used to configure WLAN Ethernet interface."
    ::= { unisDot11InterfaceConfigGroup 3 }

unisDot11WLANEthernetIfEntry OBJECT-TYPE
    SYNTAX      UnisDot11WLANEthernetIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the WLAN Ethernet interface configuration."
    INDEX
        {
            unisDot11WlanEthernetIfNumber
        }
    ::= { unisDot11WLANEthernetIfTable 1 }

UnisDot11WLANEthernetIfEntry ::= SEQUENCE
    {
        unisDot11WlanEthernetIfNumber     Integer32,
        unisDot11WLANEthernetIfIndex      Integer32,
        unisDot11WlanEthernetRowStatus    RowStatus
    }

unisDot11WlanEthernetIfNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This node represents the WLAN Ethernet interface number."
    ::= { unisDot11WLANEthernetIfEntry 1 }

unisDot11WLANEthernetIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This node represents the ifIndex of WLAN-Ethernet interface."
    ::= { unisDot11WLANEthernetIfEntry 2 }

unisDot11WlanEthernetRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This node represents the Wlan Ethernet interface row status."
    ::= { unisDot11WLANEthernetIfEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11DataRateConfigTable Definition
-- *****************************************************************************
-- *****************************************************************************
-- *  unisDot11PortSecurityTable Definition
-- *****************************************************************************
unisDot11PortSecurityTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11PortSecurityEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table defines the WLAN security status for ESS, BSS, mesh and
        WLAN-Ethernet interface which binding the crypto service-template.
        Otherwise, when binding the clear service-template,
        unisPortSecurityTables should be used to configure port security."
    ::= { unisDot11InterfaceConfigGroup 4 }

unisDot11PortSecurityEntry OBJECT-TYPE
    SYNTAX      UnisDot11PortSecurityEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for each ESS, BSS and WLAN-Ethernet
        interface.It is indexed using the object ifIndex in RFC1213-MIB."
    INDEX
        {
            ifIndex
        }
    ::= { unisDot11PortSecurityTable 1 }

UnisDot11PortSecurityEntry ::= SEQUENCE
    {
        unisDot11PortSecurityMode                 INTEGER,
        unisDot11SecurityUserLoginTxKeyType       INTEGER,
        unisDot11SecurityPskKeyMode               INTEGER,
        unisDot11SecurityPskKeyString             DisplayString
    }

unisDot11PortSecurityMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            noRestrictions(1),
            userLoginSecureExt(2),
            psk(3),
            macAddressAndPsk(4),
            userLoginSecureExtOrPsk(5),
            ext(6)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Determines the security modes of the WLAN port.

        noRestrictions  - The default value,no any security mode is set.

        userLoginSecureExt  - Access to the port is denied until the port
        client is authorized (by 802.1X).

        psk  - Access to the port is denied until the port client is
        authorized (by 802.1X key negotiation).

        macAddressAndPsk  - The MAC address is first authenticated and only if
        this succeeds does the psk then attempt user authentication.

        userLoginSecureExtOrPsk  - This selects both the userLoginSecureExt and
        psk modes together such that either is allowed to authorized access.
        Which mode works for client depends on the client's choice.

        ext  - Access to the port is denied until the port client is
        authenticated (by ext).
        "
    ::= { unisDot11PortSecurityEntry 1 }

unisDot11SecurityUserLoginTxKeyType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            userLoginTxKeyTypeNone(1),
            userLoginTxKeyTypeDot11Key(2),
            userLoginTxKeyTypeRsaRC4Key(3)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This indicates the key type in the 802.1X EAPOL_Key packet.

        userLoginTxKeyTypeNone  - This means the key type is not set yet.

        userLoginTxKeyTypeDot11Key  - This selects the 802.11 key type.

        userLoginTxKeyTypeRsaRC4Key  - This selects the RC4 key for RSA RC4
        session encryption."
    ::= { unisDot11PortSecurityEntry 2 }

unisDot11SecurityPskKeyMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            pskKeyModeNone(1),
            pskKeyModePassPhrase(2),
            pskKeyModeRawKey(3)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This is the password input mode.  When input as pskKeyModePassPhrase,
        unisDot11SecurePskKeyString must be 8 to 63 characters; when input as
        pskKeyModeRawKey, unisDot11SecurePskKeyString must be 64 characters and
        each character must be '0'-'9', 'a'-'f' and 'A'-'F'."
    ::= { unisDot11PortSecurityEntry 3 }

unisDot11SecurityPskKeyString OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This is the password string used for psk authentication."
    ::= { unisDot11PortSecurityEntry 4 }

-- *****************************************************************************
-- *  End of unisDot11PortSecurityTable Definition
-- *****************************************************************************
-- *****************************************************************************
-- *  unisDot11WlanMeshIfTable Definition
-- *************************************************************************

unisDot11WlanMeshIfTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11WlanMeshIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table is used to configure WLAN mesh interface."
    ::= { unisDot11InterfaceConfigGroup 5 }

unisDot11WlanMeshIfEntry OBJECT-TYPE
    SYNTAX      UnisDot11WlanMeshIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the WLAN mesh interface configuration."
    INDEX
        {
            unisDot11WlanMeshIfNumber
        }
    ::= { unisDot11WlanMeshIfTable 1 }

UnisDot11WlanMeshIfEntry ::= SEQUENCE
    {
        unisDot11WlanMeshIfNumber    Integer32,
        unisDot11WlanMeshIfIndex     Integer32,
        unisDot11WlanMeshRowStatus   RowStatus
    }

unisDot11WlanMeshIfNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This node represents the WLAN mesh interface number."
    ::= { unisDot11WlanMeshIfEntry 1 }

unisDot11WlanMeshIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "This node represents the index of WLAN mesh interface."
    ::= { unisDot11WlanMeshIfEntry 2 }

unisDot11WlanMeshRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This node represents the WLAN mesh interface row status."
    ::= { unisDot11WlanMeshIfEntry 3 }

-- *****************************************************************************
-- *  End of unisDot11WlanMeshIfTable Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11ACBackupGroup Definition
-- *****************************************************************************
unisDot11BackupACAdrssIP OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object represents the backup AC IP address.
        If the backup AC IP address is not configured,
        the object value is 0.0.0.0."
    ::= { unisDot11ACBackupGroup 1 }

unisDot11BackupACAdrssIPv6 OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "This object represents the backup AC IPv6 address.
         If the backup AC IPv6 address is not configured,
         the object value is 0::0."
    ::= { unisDot11ACBackupGroup 2 }

-- *****************************************************************************
-- *  End of unisDot11ACBackupGroup Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11RadioElementConfigGroup Definition
-- *****************************************************************************

unisDot11nRadioCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11nRadioCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "This table is used to configure dot11n on the radio."
    ::= { unisDot11RadioElementConfigGroup 1 }

unisDot11nRadioCfgEntry OBJECT-TYPE
    SYNTAX UnisDot11nRadioCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "This entry contains the dot11n configuration on the radio."
    INDEX { unisDot11nRadioCfgIndex }
    ::= { unisDot11nRadioCfgTable 1 }

UnisDot11nRadioCfgEntry ::= SEQUENCE
    {
        unisDot11nRadioCfgIndex       UnisDot11RadioElementIndex,
        unisDot11nAMpduEnable         TruthValue,
        unisDot11nAMsduEnable         TruthValue,
        unisDot11nClientDot11nOnly    TruthValue,
        unisDot11nChanelBand          INTEGER,
        unisDot11nShortGiEnable       TruthValue,
        unisDot11nClientDot11acOnly   TruthValue,
        unisDot11nSupportMaxMcs       Integer32,
        unisDot11nMandatoryMaxMcs     Integer32
    }

unisDot11nRadioCfgIndex OBJECT-TYPE
    SYNTAX UnisDot11RadioElementIndex
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents index of the radio."
    ::= { unisDot11nRadioCfgEntry 1 }

unisDot11nAMpduEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of A-MPDU."
        DEFVAL { true }
    ::= { unisDot11nRadioCfgEntry 2 }

unisDot11nAMsduEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of A-MSDU."
    DEFVAL { true }
    ::= { unisDot11nRadioCfgEntry 3 }

unisDot11nClientDot11nOnly OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "If radio type is 802.11an or 802.11gn, only permit clients of 11n mode.
         If radio type is 802.11ac, permit clients of 11n and 11ac mode."
    DEFVAL { false }
    ::= { unisDot11nRadioCfgEntry 4 }

unisDot11nChanelBand OBJECT-TYPE
    SYNTAX INTEGER
        {
        mode20(1),
        mode40(2),
        mode80(3),
        mode160(4),
        mode80and80(5)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the bandwidth mode."
    DEFVAL { mode40 }
    ::= { unisDot11nRadioCfgEntry 5 }

unisDot11nShortGiEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "The function of Short GI."
    DEFVAL { true }
    ::= { unisDot11nRadioCfgEntry 6 }

unisDot11nClientDot11acOnly OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Only permit clients of 11ac mode."
    DEFVAL { false }
    ::= { unisDot11nRadioCfgEntry 7 }

unisDot11nSupportMaxMcs OBJECT-TYPE
    SYNTAX Integer32 (0..76)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the maximum Modulation and Coding Scheme (MCS) index for
        802.11n supported rates.
        The specified maximum MCS index for 802.11n supported rates must be no
        less than the specified maximum MCS index for 802.11n mandatory rates."
    DEFVAL { 76 }
    ::= { unisDot11nRadioCfgEntry 8 }

unisDot11nMandatoryMaxMcs OBJECT-TYPE
    SYNTAX Integer32 (0..76 | 255)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the maximum modulation and coding scheme (MCS) index for
        802.11n mandatory rates.
        The value 255 indicates that no maximum MCS index
        is specified.  No maximum MCS index is specified for 802.11n
        mandatory rates by default.
        Besides 255, the specified maximum MCS index for 802.11n supported
        rates must be no less than the specified maximum MCS index for 802.11n
        mandatory rates."
    DEFVAL { 255 }
    ::= { unisDot11nRadioCfgEntry 9 }

-- *****************************************************************************
-- *  End of unisDot11RadioElementConfigGroup Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11RadioWDSTable Definition
-- *****************************************************************************

unisDot11RadioWDSTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11RadioWDSEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table is used to configure WDS on the radio."
    ::= { unisDot11RadioElementConfigGroup 2 }

unisDot11RadioWDSEntry OBJECT-TYPE
    SYNTAX      UnisDot11RadioWDSEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains the WDS configuration on the radio."
    INDEX
        {
            unisDot11RadioWDSIndex
        }
    ::= { unisDot11RadioWDSTable 1 }

UnisDot11RadioWDSEntry ::= SEQUENCE
    {
        unisDot11RadioWDSIndex            UnisDot11RadioElementIndex,
        unisDot11RadioWDSMode             INTEGER,
        unisDot11RadioWDSNetWorkID        OCTET STRING,
        unisDot11WDSSecPskKeyMode         INTEGER,
        unisDot11WDSSecPskKeyString       DisplayString
    }

unisDot11RadioWDSIndex OBJECT-TYPE
    SYNTAX      UnisDot11RadioElementIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the element index of radio."
    ::= { unisDot11RadioWDSEntry 1 }

unisDot11RadioWDSMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            nowds(1),
            wds(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents enable the WDS mode or not.
        nowds: The WDS mode is disabled.
        wds  : The WDS mode is enabled"
    DEFVAL      { nowds }
    ::= { unisDot11RadioWDSEntry 2 }

unisDot11RadioWDSNetWorkID OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..32))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the mesh ID of WDS."
    DEFVAL      { "" }
    ::= { unisDot11RadioWDSEntry 3 }

unisDot11WDSSecPskKeyMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
          pskKeyModeNone(1),
          pskKeyModePassPhrase(2),
          pskKeyModeRawKey(3)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the PSK mode of WDS."
    DEFVAL      { pskKeyModeNone }
    ::= { unisDot11RadioWDSEntry 4 }

unisDot11WDSSecPskKeyString OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Represents the PSK value of WDS."
    DEFVAL      { "" }
    ::= { unisDot11RadioWDSEntry 5 }

-- *****************************************************************************
-- *  End of unisDot11RadioWDSTable  Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11nRadioCfg2Table Definition
-- *****************************************************************************

unisDot11nRadioCfg2Table OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11nRadioCfg2Entry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "This table is used to configure dot11n on the radio."
    ::= { unisDot11RadioElementConfigGroup 3 }

unisDot11nRadioCfg2Entry OBJECT-TYPE
    SYNTAX UnisDot11nRadioCfg2Entry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "This entry contains the dot11n configuration on the radio."
    INDEX {
              unisDot11nRadioCfg2APIDIndex,
              unisDot11nRadioCfg2RadioIDIndex
          }
    ::= { unisDot11nRadioCfg2Table 1 }

UnisDot11nRadioCfg2Entry ::= SEQUENCE
    {
        unisDot11nRadioCfg2APIDIndex           UnisDot11ObjectIDType,
        unisDot11nRadioCfg2RadioIDIndex        UnisDot11RadioScopeType,
        unisDot11nRadioCfg2AMpduEnable         TruthValue,
        unisDot11nRadioCfg2AMsduEnable         TruthValue,
        unisDot11nRadioCfg2ClientDot11nOnly    TruthValue,
        unisDot11nRadioCfg2ChannelBand          INTEGER,
        unisDot11nRadioCfg2ShortGiEnable       TruthValue,
        unisDot11nRadioCfg2AMpduEnableCM        INTEGER,
        unisDot11nRadioCfg2ChannelBandCM        INTEGER,
        unisDot11nRadioCfg2ShortGiEnableCM      INTEGER,
        unisDot11nRadioCfg2ClientDot11acOnly   TruthValue,
        unisDot11nRadioCfg2ClientDot11nOnlyCM   UnisDot11TruthValueCM,
        unisDot11nRadioCfg2SupportMaxMcs       Integer32,
        unisDot11nRadioCfg2MandatoryMaxMcs     Integer32
    }

unisDot11nRadioCfg2APIDIndex OBJECT-TYPE
    SYNTAX UnisDot11ObjectIDType
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents index of the AP."
    ::= { unisDot11nRadioCfg2Entry 1 }

unisDot11nRadioCfg2RadioIDIndex OBJECT-TYPE
    SYNTAX UnisDot11RadioScopeType
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents index of the radio."
    ::= { unisDot11nRadioCfg2Entry 2 }

unisDot11nRadioCfg2AMpduEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of A-MPDU."
        DEFVAL { true }
    ::= { unisDot11nRadioCfg2Entry 3 }

unisDot11nRadioCfg2AMsduEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of A-MSDU."
    DEFVAL { true }
    ::= { unisDot11nRadioCfg2Entry 4 }

unisDot11nRadioCfg2ClientDot11nOnly OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "If radio type is 802.11an or 802.11gn, only permit clients of 11n mode.
         If radio type is 802.11ac, permit clients of 11n and 11ac mode."
    DEFVAL { false }
    ::= { unisDot11nRadioCfg2Entry 5 }

unisDot11nRadioCfg2ChannelBand OBJECT-TYPE
    SYNTAX INTEGER
        {
            mode20(1),
            mode40(2),
            mode80(3),
            mode160(4),
            mode80and80(5)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the bandwidth mode."
    ::= { unisDot11nRadioCfg2Entry 6 }

unisDot11nRadioCfg2ShortGiEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of Short GI."
    DEFVAL { true }
    ::= { unisDot11nRadioCfg2Entry 7 }

unisDot11nRadioCfg2AMpduEnableCM OBJECT-TYPE
    SYNTAX   INTEGER
        {
            off(0),
            on(1)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of A-MPDU."
        DEFVAL { on }
    ::= { unisDot11nRadioCfg2Entry 8 }

unisDot11nRadioCfg2ChannelBandCM OBJECT-TYPE
    SYNTAX      INTEGER
        {
            mode40(1),
            mode20(2),
            mode80(3),
            mode160(4),
            mode80and80(5)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the bandwidth mode."
    ::= { unisDot11nRadioCfg2Entry 9 }

unisDot11nRadioCfg2ShortGiEnableCM OBJECT-TYPE
    SYNTAX    INTEGER
        {
            off(0),
            on(1)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Enable the function of Short GI."
    DEFVAL { on }
    ::= { unisDot11nRadioCfg2Entry 10 }

unisDot11nRadioCfg2ClientDot11acOnly OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Only permit clients of 11ac mode."
    DEFVAL { false }
    ::= { unisDot11nRadioCfg2Entry 11 }

unisDot11nRadioCfg2ClientDot11nOnlyCM OBJECT-TYPE
    SYNTAX UnisDot11TruthValueCM
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "If radio type is 802.11an or 802.11gn, permit only clients of 11n mode.
        If radio type is 802.11ac, permit clients of both 11n and 11ac mode."
    DEFVAL { dot11false }
    ::= { unisDot11nRadioCfg2Entry 12 }

unisDot11nRadioCfg2SupportMaxMcs OBJECT-TYPE
    SYNTAX Integer32 (0..76)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the maximum Modulation and Coding Scheme (MCS) index for
        802.11n supported rates.
        The specified maximum MCS index for 802.11n supported rates must be no
        less than the specified maximum MCS index for 802.11n mandatory rates."
    DEFVAL { 76 }
    ::= { unisDot11nRadioCfg2Entry 13 }

unisDot11nRadioCfg2MandatoryMaxMcs OBJECT-TYPE
    SYNTAX Integer32 (0..76 | 255)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Specify the maximum modulation and coding scheme (MCS) index for
        802.11n mandatory rates.
        The value 255 indicates that no maximum MCS index
        is specified.  No maximum MCS index is specified for 802.11n
        mandatory rates by default.
        Besides 255, the specified maximum MCS index for 802.11n supported
        rates must be no less than the specified maximum MCS index for 802.11n
        mandatory rates."
    DEFVAL { 255 }
    ::= { unisDot11nRadioCfg2Entry 14 }

-- *****************************************************************************
-- *  End of unisDot11nRadioCfg2Table Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11CfgNotifyGroup Definition
-- *****************************************************************************
unisDot11CfgNotifications OBJECT IDENTIFIER ::= { unisDot11CfgNotifyGroup 0 }

unisDot11CfgCipherChange NOTIFICATION-TYPE
    OBJECTS
    {
        unisDot11SSIDName,
        unisDot11SecurityCiphers
    }
    STATUS      current
    DESCRIPTION
        "This notification is sent when cipher type of corresponding service
        template is changed."
    ::= { unisDot11CfgNotifications 1 }

unisDot11CfgPSKChange NOTIFICATION-TYPE
    OBJECTS
    {
        unisDot11SSIDName
    }
    STATUS      current
    DESCRIPTION
        "This notification is sent when pre-shared key of corresponding
        service template is changed."
    ::= { unisDot11CfgNotifications 2 }

unisDot11SSIDWepIDConflictTrap NOTIFICATION-TYPE
    OBJECTS
    {
        unisDot11PreConflictTemplateNum,
        unisDot11CurrConflictTemplateNum,
        unisDot11ConflictCipherIdx,
        unisDot11ConfigureAPID,
        unisDot11ConfigureRadioID,
        unisDot11ConfigureAPMacAddress,
        unisDot11PreConflictTemplateSSID,
        unisDot11CurrConflictTemplateSSID
    }
    STATUS      current
    DESCRIPTION
        "This notification will be sent when the same wep ID is configured
         on two service policies."
    ::= { unisDot11CfgNotifications 3 }

-- CFG Notification variable object

unisDot11CfgTrapVarObjects OBJECT IDENTIFIER
    ::= { unisDot11CfgNotifyGroup 1 }

unisDot11PreConflictTemplateNum OBJECT-TYPE
    SYNTAX      Integer32 (1..1024)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents previous service policy ID when radio bind service policy
         and current service policy conflict with previous service policy
         in cipher configuration."
    ::= { unisDot11CfgTrapVarObjects 1 }

unisDot11CurrConflictTemplateNum OBJECT-TYPE
    SYNTAX      Integer32 (1..1024)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents current service policy ID when radio bind service policy
         and current service policy conflict with previous service policy
         in cipher configuration."
    ::= { unisDot11CfgTrapVarObjects 2 }

unisDot11ConflictCipherIdx OBJECT-TYPE
    SYNTAX      Integer32 (1..4)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents wep ID that conflicted with."
    ::= { unisDot11CfgTrapVarObjects 3 }

unisDot11ConfigureAPID OBJECT-TYPE
    SYNTAX      UnisDot11ObjectIDType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents which AP is configured."
    ::= { unisDot11CfgTrapVarObjects 4 }

unisDot11ConfigureRadioID OBJECT-TYPE
    SYNTAX      UnisDot11RadioScopeType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents which radio in AP is configured."
    ::= { unisDot11CfgTrapVarObjects 5 }

unisDot11ConfigureAPMacAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents MAC Address of AP."
    ::= { unisDot11CfgTrapVarObjects 6 }

unisDot11PreConflictTemplateSSID OBJECT-TYPE
    SYNTAX      UnisDot11SSIDStringType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the previous SSID of the AP."
    ::= { unisDot11CfgTrapVarObjects 7 }

unisDot11CurrConflictTemplateSSID OBJECT-TYPE
    SYNTAX      UnisDot11SSIDStringType
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the current SSID of the AP."
    ::= { unisDot11CfgTrapVarObjects 8 }

-- *****************************************************************************
-- *  End of unisDot11CfgNotifyGroup Definition
-- *****************************************************************************

-- *****************************************************************************
-- *  unisDot11LocalACTemplateTable Definition
-- *****************************************************************************
unisDot11LocalACTemplateTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisDot11LocalACTemplateEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "By local AC template CLI, administrator will configure the parameters of LocalAC
        by convenience.
        Before local AC boot up and connect to AC by CAPWAP tunnel, administrator
        will create local AC template for each local AC. When local AC connect to AC,
        AC will assign configuration to local AC by unisDot11LocalACSerialID
        information in local AC template."
    ::= { unisDot11LocalACConfigGroup 1 }

unisDot11LocalACTemplateEntry OBJECT-TYPE
    SYNTAX      UnisDot11LocalACTemplateEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Each entry contains configuration information for each LocalAC."
    INDEX
        {
            unisDot11LocalACTemplateName
        }
    ::= { unisDot11LocalACTemplateTable 1 }

UnisDot11LocalACTemplateEntry ::= SEQUENCE
    {
        unisDot11LocalACTemplateName             OCTET STRING,
        unisDot11LocalACName                     OCTET STRING,
        unisDot11LocalACSerialID                 OCTET STRING,
        unisDot11TemLocalACModelAlias            OCTET STRING,
        unisDot11LocalACTempRowStatus            RowStatus,
        unisDot11LocalACStatus                   INTEGER,
        unisDot11LocalACIPAddress                IpAddress,
        unisDot11LocalACIPv6Address              OCTET STRING,
        unisDot11EchoInterval                    Integer32,
        unisDot11RetransInterval                 Integer32,
        unisDot11RetransCount                    Integer32,
        unisDot11FirmwareUpgrade                 INTEGER
    }

unisDot11LocalACTemplateName OBJECT-TYPE
    SYNTAX      OCTET STRING(SIZE(0..127))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "Represents the name of LocalAC template."
    ::= { unisDot11LocalACTemplateEntry 1 }

unisDot11LocalACName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Represents the LocalAC name."
    ::= { unisDot11LocalACTemplateEntry 2 }

unisDot11LocalACSerialID OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Represents LocalAC serial id."
    ::= { unisDot11LocalACTemplateEntry 3 }

unisDot11TemLocalACModelAlias OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "Represents the alias of LocalAC model name."
    ::= { unisDot11LocalACTemplateEntry 4 }

unisDot11LocalACTempRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11LocalACTemplateEntry 5 }

unisDot11LocalACStatus OBJECT-TYPE
    SYNTAX      INTEGER
        {
            join(1),
            joinConfirm(2),
            download(3),
            config(4),
            run(5),
            idle(6)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the capwap status of local AC.
        The following values are supported:
        join         - local AC is joining to cnetral AC.
        joinConfirm  - cnetral AC confirm whether permit local AC to
        - join.
        download     - local AC is downloading software from cnetral
        - AC.
        config       - local AC and cnetral AC exchange configuration
        - before local AC provide WLAN service.
        run          - The local AC is run.
        idle         - The local AC is idle."
    ::= { unisDot11LocalACTemplateEntry 6 }

unisDot11LocalACIPAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "Represents the IP address of an LocalAC."
    ::= { unisDot11LocalACTemplateEntry 7 }

unisDot11LocalACIPv6Address OBJECT-TYPE
