-- =================================================================
UNIS-PORTAL-MIB DEFINITIONS ::= BEGIN
IMPORTS
    unisCommon
        FROM UNIS-OID-MIB
    OBJECT-TYPE, NOTIFICATION-TYPE, MODULE-IDENTITY, Integer32, Counter64, Unsigned32,
    TimeTicks
        FROM SNMPv2-SMI
    RowStatus, MacAddress, TEXTUAL-CONVENTION
        FROM SNMPv2-TC
    ifIndex, InterfaceIndex
        FROM IF-MIB
    InetAddressPrefixLength, InetAddressType, InetAddress, InetAddressIPv4
        FROM INET-ADDRESS-MIB;

unisPortal MODULE-IDENTITY
    LAST-UPDATED "201607141020Z"        -- Jul 14, 2016 at 10:20 GMT
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
        "The MIB module is used for managing portal."
    REVISION "201607141020Z"        -- Jul 14, 2016 at 10:20 GMT
    DESCRIPTION
        "Modified to add new node in table unisPortalForbiddenRuleTable."
    REVISION "201510081020Z"        -- Oct 8, 2015 at 10:20 GMT
    DESCRIPTION
        "Modified to add new table."
    ::= { unisCommon 99 }

UnisPortalAuthMethod ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION
    "Specify the portal authentication method."
    SYNTAX      INTEGER
    {
        invalid(1),
        direct(2),
        layer3(3),
        redhcp(4)
    }

unisPortalConfig OBJECT IDENTIFIER ::= { unisPortal 1 }

--
-- PORTAL MAX USER NUMBER
--

unisPortalMaxUserNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Specify the maximum number of online users,
        the value to be set should meet the following two conditions:
        1. Less than or equal to unisPortalUserNumberUpperLimit.
        2. Greater than or equal to one.

        The default value is equal to unisPortalUserNumberUpperLimit."
    ::= { unisPortalConfig 1 }

--
-- PORTAL CURRENT USER NUMBER
--

unisPortalCurrentUserNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The current number of users connecting to the portal."
    ::= { unisPortalConfig 2 }

--
-- PORTAL STATUS
--

unisPortalStatus OBJECT-TYPE
    SYNTAX      INTEGER
    {
         enabled(1),
         disabled(2)
    }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It indicates the portal status.
         enabled:
            Portal is enabled on one or more interfaces.
         disabled:
            Portal is not enabled on any interface."
    ::= { unisPortalConfig 3 }

--
-- PORTAL USER NUMBER_UPPER_LIMIT
--

unisPortalUserNumberUpperLimit OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The upper limit of unisPortalMaxUserNumber."
    ::= { unisPortalConfig 4 }

--
-- PORTAL NAS-ID Config
--
unisPortalNasId OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The nas id of this device."
    ::= { unisPortalConfig 5 }

--
-- PORTAL TABLES
--

unisPortalTables OBJECT IDENTIFIER ::= { unisPortal 2 }


--
-- PORTAL server table
--
unisPortalServerTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalServerEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table defines the name and URL of portal server.
        It can not be created and destroyed by MIB."
    ::= { unisPortalTables 1 }

unisPortalServerEntry OBJECT-TYPE
    SYNTAX      UnisPortalServerEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for each name and URL of portal server.
        It is indexed using the object unisPortalServerName."
    INDEX
        {
            unisPortalServerName
        }
    ::= { unisPortalServerTable 1 }


UnisPortalServerEntry ::= SEQUENCE
    {
        unisPortalServerName               OCTET STRING,
        unisPortalServerUrl                OCTET STRING,
        unisPortalServerPort               Integer32
    }

unisPortalServerName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..32))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalServerTable, it shows
        the name of the portal server."
    ::= { unisPortalServerEntry 1 }

unisPortalServerUrl OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..127))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows the uniform resource locator to the portal server.
        Users which have not logon to portal will be redirected to the
        portal server according to unisPortalServerUrl.

        The value is consisted of protocol, IP address and relative path.
        For example: HTTP://10.1.1.1/portal

        It is not configurable when the portal server has been enabled."
    ::= { unisPortalServerEntry 2 }

unisPortalServerPort OBJECT-TYPE
    SYNTAX      Integer32 (1..65534)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows the UDP port of the portal server.

        The port will be used when client sends packets to portal server.
        Default value is 50100.

        It is not configurable when the portal server has been enabled."
    ::= { unisPortalServerEntry 3 }

--
-- PORTAL If Info Table
--
unisPortalIfInfoTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalIfInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the portal information on some interface."
    ::= { unisPortalTables 2 }

unisPortalIfInfoEntry OBJECT-TYPE
    SYNTAX      UnisPortalIfInfoEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for a interface on which
        portal has been enabled.
        It is indexed using the object ifIndex."
    INDEX
        {
            ifIndex
        }
    ::= { unisPortalIfInfoTable 1 }


UnisPortalIfInfoEntry ::= SEQUENCE
    {
        unisPortalAuthReqNumber            Integer32,
        unisPortalAuthSuccNumber           Integer32,
        unisPortalAuthFailNumber           Integer32
    }

unisPortalAuthReqNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication request messages
        which are sent by portal module to AAA module."
    ::= { unisPortalIfInfoEntry 1 }


unisPortalAuthSuccNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication success response messages
        which are sent by AAA module to portal module."
    ::= { unisPortalIfInfoEntry 2 }

unisPortalAuthFailNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication failure response messages
        which are sent by AAA module to portal module."
    ::= { unisPortalIfInfoEntry 3 }

--
-- PORTAL If Config Table
--
unisPortalIfServerTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalIfServerEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the portal information on some interface."
    ::= { unisPortalTables 3 }

unisPortalIfServerEntry OBJECT-TYPE
    SYNTAX      UnisPortalIfServerEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for a interface on which
        portal has been enabled.
        It is indexed using the object ifIndex."
    INDEX
        {
            unisPortalIfServerIndex
        }
    ::= { unisPortalIfServerTable 1 }

UnisPortalIfServerEntry ::= SEQUENCE
    {
        unisPortalIfServerIndex                   Integer32,
        unisPortalIfServerUrl                     OCTET STRING,
        unisPortalIfServerRowStatus               RowStatus
    }

unisPortalIfServerIndex  OBJECT-TYPE
    SYNTAX      Integer32 (0..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisIfPtServerTable, it shows
        the index of the portal server."
    ::={ unisPortalIfServerEntry 1 }

unisPortalIfServerUrl OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the uniform resource locator to the portal server.
        Users which have not logon to portal will be redirected to the
        portal server according to unisPortalServerIfUrl.
        The value is consisted of protocol, IP address and relative path.
        For example: HTTP://10.1.1.1/portal
        It is not configurable when the portal server has been enabled."
    ::= { unisPortalIfServerEntry 2 }

unisPortalIfServerRowStatus OBJECT-TYPE
    SYNTAX   RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo,
        Destroy operation.  To create a new row, portal server must be specified.
        To destroy an existent row, the portal server MUST NOT be referred by
        interface."
    ::= { unisPortalIfServerEntry 3 }

-- PORTAL Vlan Not binding NAS ID Table
unisPortalIfVlanNasIDTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalIfVlanNasIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the interface on which portal has been enabled,
        the Vlan that the interface belongs to and the NAS ID to which the Vlan
        is bound."
    ::= { unisPortalTables 4 }

unisPortalIfVlanNasIDEntry OBJECT-TYPE
    SYNTAX      UnisPortalIfVlanNasIDEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for a interface on which portal has been
        enabled, the Vlan that the interface belongs to and the NAS ID to which
        the Vlan is bound.
        It is indexed using the object ifIndex and Vlan that the interface
        belongs to."
    INDEX
        {
            unisPortalIfVlanNasIDIfIndex,
            unisPortalIfVlanNasIDVlanID
        }
    ::= { unisPortalIfVlanNasIDTable 1 }

UnisPortalIfVlanNasIDEntry ::= SEQUENCE
    {
        unisPortalIfVlanNasIDIfIndex         InterfaceIndex,
        unisPortalIfVlanNasIDVlanID          Integer32,
        unisPortalIfVlanNasIDNasID           OCTET STRING
    }

unisPortalIfVlanNasIDIfIndex  OBJECT-TYPE
    SYNTAX      InterfaceIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalIfVlanNasIDTable, it shows
        the interface on which portal has been enabled."
    ::={ unisPortalIfVlanNasIDEntry 1 }

unisPortalIfVlanNasIDVlanID OBJECT-TYPE
    SYNTAX      Integer32 (1..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalIfVlanNasIDTable, it shows
        the Vlan that the interface belongs to."
    ::= { unisPortalIfVlanNasIDEntry 2 }

unisPortalIfVlanNasIDNasID OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE(0..64))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It is the NAS ID to which the Vlan is bound to."
    ::= { unisPortalIfVlanNasIDEntry 3 }

--
-- PORTAL SSID Free-rule Config Table
--

unisPortalSSIDFreeRuleTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalSSIDFreeRuleEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes SSID portal-free rule(s) allows specified users
        to access specified external websites without portal authentication."
    ::= { unisPortalTables 5 }

unisPortalSSIDFreeRuleEntry OBJECT-TYPE
    SYNTAX      UnisPortalSSIDFreeRuleEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for SSID portal-free rule.
        It is indexed using the object Index."
    INDEX
        {
            unisPortalSSIDFreeRuleIndex
        }
    ::= { unisPortalSSIDFreeRuleTable 1 }

UnisPortalSSIDFreeRuleEntry ::= SEQUENCE
    {
        unisPortalSSIDFreeRuleIndex                   Integer32,
        unisPortalSSIDFreeRuleSrcSSID                 OCTET STRING,
        unisPortalSSIDFreeRuleRowStatus               RowStatus,
        unisPortalSSIDFreeRuleSrcSpot                 OCTET STRING
    }

unisPortalSSIDFreeRuleIndex  OBJECT-TYPE
    SYNTAX      Integer32 (0..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalSSIDFreeRuleTable, it shows
        the index of the SSID portal-free rule."
    ::={ unisPortalSSIDFreeRuleEntry 1 }

unisPortalSSIDFreeRuleSrcSSID  OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE(1..128))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The SSID match against the packet's source SSID."
    ::={ unisPortalSSIDFreeRuleEntry 2 }

unisPortalSSIDFreeRuleRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo,
        Destroy operation."
    ::= { unisPortalSSIDFreeRuleEntry 3 }

unisPortalSSIDFreeRuleSrcSpot  OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE(0..63))
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The spot match against the packet's source spot."
    ::={ unisPortalSSIDFreeRuleEntry 4 }

--
-- PORTAL MAC Trigger Server
--

unisPortalMacTriggerSrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalMacTriggerSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the configration of MAC Trigger Portal server."
    ::= { unisPortalTables 6 }

unisPortalMacTriggerSrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalMacTriggerSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in the table for MAC Trigger Portal server.
        It is indexed using the object Index."
    INDEX
        {
            unisPortalMacTriggerSrvIndex
        }
    ::= { unisPortalMacTriggerSrvTable 1 }

UnisPortalMacTriggerSrvEntry ::= SEQUENCE
    {
        unisPortalMacTriggerSrvIndex              Integer32,
        unisPortalMacTriggerSrvIPAddrType         InetAddressType,
        unisPortalMacTriggerSrvIP                 InetAddress,
        unisPortalMacTriggerSrvPort               Integer32,
        unisPortalMacTriggerSrvRowStatus          RowStatus
    }

unisPortalMacTriggerSrvIndex  OBJECT-TYPE
    SYNTAX      Integer32 (0..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalMacTriggerSrvTable, it shows
        the index of the MAC Trigger Portal server."
    ::={ unisPortalMacTriggerSrvEntry 1 }

unisPortalMacTriggerSrvIPAddrType  OBJECT-TYPE
    SYNTAX      InetAddressType
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The type of MAC Trigger Portal server IP address.  While
       other types of addresses are defined in the InetAddressType
       textual convention, and DNS names, a classifier can only look at
       packets on the wire."
    ::={ unisPortalMacTriggerSrvEntry 2 }

unisPortalMacTriggerSrvIP OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the IP address of MAC Trigger Portal server."
    ::= { unisPortalMacTriggerSrvEntry 3 }

unisPortalMacTriggerSrvPort OBJECT-TYPE
    SYNTAX      Integer32 (1..65534)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the UDP port of MAC Trigger Portal server.
        The port will be used when client sends packets to MAC Trigger Portal server.
        Default value is 50100."
    ::= { unisPortalMacTriggerSrvEntry 4 }

unisPortalMacTriggerSrvRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo,
        Destroy operation."
    ::= { unisPortalMacTriggerSrvEntry 5 }

--
-- PORTAL Eanble MAC Trigger on interface
--

unisPortalMacTriggerOnIfTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalMacTriggerOnIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the configration of Portal MAC Trigger on
        interface."
    ::= { unisPortalTables 7 }

unisPortalMacTriggerOnIfEntry OBJECT-TYPE
    SYNTAX      UnisPortalMacTriggerOnIfEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in the table for Portal MAC Trigger configuration on
        interface.  It is indexed using the object Index."
    INDEX
        {
            unisPortalMacTriggerOnIfIfIndex
        }
    ::= { unisPortalMacTriggerOnIfTable 1 }

UnisPortalMacTriggerOnIfEntry ::= SEQUENCE
    {
        unisPortalMacTriggerOnIfIfIndex               InterfaceIndex,
        unisPortalMacTriggerOnIfDetctFlowPeriod       Integer32,
        unisPortalMacTriggerOnIfThresholdFlow         Unsigned32,
        unisPortalMacTriggerOnIfRowStatus             RowStatus
    }

unisPortalMacTriggerOnIfIfIndex  OBJECT-TYPE
    SYNTAX      InterfaceIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the interface index and the index of
        unisPortalMacTriggerOnIfTable."
    ::={ unisPortalMacTriggerOnIfEntry 1 }

unisPortalMacTriggerOnIfDetctFlowPeriod  OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "seconds"
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the user flow detection interval (in seconds) when
        MAC Trigger and Portal are enabled.
        Default value is 300."
    DEFVAL { 300 }
    ::={ unisPortalMacTriggerOnIfEntry 2 }

unisPortalMacTriggerOnIfThresholdFlow  OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "bytes"
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the user traffic threshold (in bytes) that triggers authentication
        when MAC Trigger and Portal are enabled.
        Default value is 0."
    DEFVAL { 0 }
    ::={ unisPortalMacTriggerOnIfEntry 3 }

unisPortalMacTriggerOnIfRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo,
        Destroy operation."
    ::= { unisPortalMacTriggerOnIfEntry 4 }

--
-- PORTAL Free-rule Config Table
--

unisPortalFreeRuleTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalFreeRuleEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes portal-free rule(s) allows specified users to
         access specified external websites without portal authentication."
    ::= { unisPortalTables 8 }

unisPortalFreeRuleEntry OBJECT-TYPE
    SYNTAX      UnisPortalFreeRuleEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for portal-free rule.
        It is indexed using the object Index."
    INDEX
        {
            unisPortalFreeRuleIndex
        }
    ::= { unisPortalFreeRuleTable 1 }

UnisPortalFreeRuleEntry ::= SEQUENCE
    {
        unisPortalFreeRuleIndex                   Integer32,
        unisPortalFreeRuleSrcIfIndex              InterfaceIndex,
        unisPortalFreeRuleSrcVlanID               Integer32,
        unisPortalFreeRuleSrcMac                  MacAddress,
        unisPortalFreeRuleAddrType                InetAddressType,
        unisPortalFreeRuleSrcAddr                 InetAddress,
        unisPortalFreeRuleSrcPrefix               InetAddressPrefixLength,
        unisPortalFreeRuleDstAddr                 InetAddress,
        unisPortalFreeRuleDstPrefix               InetAddressPrefixLength,
        unisPortalFreeRuleProtocol                INTEGER,
        unisPortalFreeRuleSrcPort                 Integer32,
        unisPortalFreeRuleDstPort                 Integer32,
        unisPortalFreeRuleRowStatus               RowStatus
    }

unisPortalFreeRuleIndex  OBJECT-TYPE
    SYNTAX      Integer32 (0..2147483647)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table of unisPortalFreeRuleTable, it shows
        the index of the portal-free rule."
    ::={ unisPortalFreeRuleEntry 1 }

unisPortalFreeRuleSrcIfIndex  OBJECT-TYPE
    SYNTAX      InterfaceIndex
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The index of source interface."
    ::={ unisPortalFreeRuleEntry 2 }

unisPortalFreeRuleSrcVlanID  OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The identification of source vlan."
    ::={ unisPortalFreeRuleEntry 3 }

unisPortalFreeRuleSrcMac  OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The MAC address to match against the packet's source MAC address."
    ::={ unisPortalFreeRuleEntry 4 }

unisPortalFreeRuleAddrType  OBJECT-TYPE
    SYNTAX      InetAddressType
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The type of IP address used by this classifier entry.  While
       other types of addresses are defined in the InetAddressType
       textual convention, and DNS names, a classifier can only look at
       packets on the wire."
    ::={ unisPortalFreeRuleEntry 5 }

unisPortalFreeRuleSrcAddr  OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The IP address to match against the packet's source IP
       address.  This may be a DNS name or an IPv4 or IPv6
       prefix.  unisPortalFreeRuleSrcPrefix indicates the
       number of bits that are relevant."
    ::={ unisPortalFreeRuleEntry 6 }

unisPortalFreeRuleSrcPrefix  OBJECT-TYPE
    SYNTAX      InetAddressPrefixLength
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The length of the CIDR Prefix carried in
       unisPortalFreeRuleSrcAddr.  In IPv4 addresses, a length of 0
       indicates a match of any address; a length of 32 indicates a
       match of a single host address, and a length between 0 and 32
       indicates the use of a CIDR Prefix.  IPv6 is similar, except that
       prefix lengths range from 0..128."
    ::={ unisPortalFreeRuleEntry 7 }

unisPortalFreeRuleDstAddr  OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The IP address to match against the packet's destination IP
       address.  This may be a DNS name or an IPv4 or IPv6
       prefix.  unisPortalFreeRuleDstPrefix indicates the
       number of bits that are relevant."
    ::={ unisPortalFreeRuleEntry 8 }

unisPortalFreeRuleDstPrefix  OBJECT-TYPE
    SYNTAX      InetAddressPrefixLength
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The length of the CIDR Prefix carried in
       unisPortalFreeRuleDstAddr.  In IPv4 addresses, a length of 0
       indicates a match of any address; a length of 32 indicates a
       match of a single host address, and a length between 0 and 32
       indicates the use of a CIDR Prefix.  IPv6 is similar, except that
       prefix lengths range from 0..128."
    ::={ unisPortalFreeRuleEntry 9 }

unisPortalFreeRuleProtocol  OBJECT-TYPE
    SYNTAX      INTEGER
    {
        invalid(0),
        tcp(6),
        udp(17)
    }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The protocol-type of port."
    ::={ unisPortalFreeRuleEntry 10 }

unisPortalFreeRuleSrcPort  OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The source port allows users to access."
    ::={ unisPortalFreeRuleEntry 11 }

unisPortalFreeRuleDstPort  OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The destination port allows users to access."
    ::={ unisPortalFreeRuleEntry 12 }

unisPortalFreeRuleRowStatus OBJECT-TYPE
    SYNTAX   RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo,
        Destroy operation."
    ::= { unisPortalFreeRuleEntry 13 }

