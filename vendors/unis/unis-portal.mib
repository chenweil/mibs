--
-- Define the portal Traps.
--

unisPortalTraps OBJECT IDENTIFIER ::= { unisPortal 3 }

unisPortalTrapPrefix OBJECT IDENTIFIER ::= { unisPortalTraps 0 }

unisPortalServerLost NOTIFICATION-TYPE
    OBJECTS
        {
            unisPortalServerName,
            unisPortalFirstTrapTime,
            unisPortalServerIP,
            unisPortalServerPort
        }
    STATUS      current
    DESCRIPTION
        "This trap is generated when the device finds that the portal server
        is unreachable, the portal server's name is unisPortalServerName, and
        the portal server's IP is unisPortalServerIP, and the portal server's
        port is unisPortalServerPort, and the portal server has been enabled."
    ::= { unisPortalTrapPrefix 1 }

unisPortalServerGet NOTIFICATION-TYPE
    OBJECTS
        {
            unisPortalServerName,
            unisPortalFirstTrapTime,
            unisPortalServerIP,
            unisPortalServerPort
        }
    STATUS      current
    DESCRIPTION
        "This trap is generated when the device finds that the state of portal
        server changes from unreachable state to reachable,
        the portal server's name is unisPortalServerName, and the portal server's
        IP is unisPortalServerIP, and the portal server's port is unisPortalServerPort,
        and the portal server has been enabled."
    ::= { unisPortalTrapPrefix 2 }

unisPortalTrapVarObjects OBJECT IDENTIFIER ::= { unisPortalTraps 1 }

unisPortalFirstTrapTime OBJECT-TYPE
    SYNTAX      TimeTicks
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Represents the first trap time."
    ::= { unisPortalTrapVarObjects 1 }

unisPortalServerIP OBJECT-TYPE
    SYNTAX      InetAddressIPv4
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "The portal server's IP."
    ::= { unisPortalTrapVarObjects 2 }

-- PORTAL STATISTIC

unisPortalStatistic OBJECT IDENTIFIER ::= { unisPortal 4 }

-- PORTAL AUTH REQ STATISTIC

unisPortalStatAuthReq OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of portal authentication requests from the
        portal server."
    ::= { unisPortalStatistic 1 }

-- PORTAL ACK LOGOUT STATISTIC

unisPortalStatAckLogout OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of logout requests from the portal server."
    ::= { unisPortalStatistic 2 }

-- PORTAL NOTIFY LOGOUT STATISTIC

unisPortalStatNotifyLogout OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of logout requests from the access device."
    ::= { unisPortalStatistic 3 }

-- PORTAL CHALLENGE TIMEOUT STATISTIC

unisPortalStatChallengeTimeout OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of challenge from the portal server without
        response."
    ::= { unisPortalStatistic 4 }

-- PORTAL CHALLENGE BUSY STATISTIC

unisPortalStatChallengeBusy OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of device-busy responses for challenges from
        the portal server."
    ::= { unisPortalStatistic 5 }

-- PORTAL CHALLENGE FAIL STATISTIC

unisPortalStatChallengeFail OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of challenges from the portal server with
        failure response."
    ::= { unisPortalStatistic 6 }

-- PORTAL authenticate TIMEOUT STATISTIC

unisPortalStatAuthTimeout OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication requests from the portal
        server without responses."
    ::= { unisPortalStatistic 7 }

-- PORTAL authenticate FAIL STATISTIC

unisPortalStatAuthFail OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication requests from the portal
        server with failure responses."
    ::= { unisPortalStatistic 8 }

-- PORTAL PASSWORD ERROR STATISTIC

unisPortalStatPwdError OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of password errors."
    ::= { unisPortalStatistic 9 }

-- PORTAL authenticate BUSY STATISTIC

unisPortalStatAuthBusy OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of device-busy responses to authentication
        requests from the portal server."
    ::= { unisPortalStatistic 10 }

-- PORTAL authenticate DISORDER STATISTIC

unisPortalStatAuthDisordered OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of disordered authentication packets from
        the portal server."
    ::= { unisPortalStatistic 11 }

-- PORTAL authenticate UNKNOWN ERROR STATISTIC

unisPortalStatAuthUnknownError OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of unknown errors."
    ::= { unisPortalStatistic 12 }
-- PORTAL authenticate response STATISTIC

unisPortalStatAuthResp OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of authentication response messages
        which are sent by device to portal server."
    ::= { unisPortalStatistic 13 }

-- PORTAL authenticate challenge request STATISTIC

unisPortalStatChallengeReq OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of challenge request messages
        which are sent by portal server to device."
    ::= { unisPortalStatistic 14 }

-- PORTAL authenticate challenge response STATISTIC

unisPortalStatChallengeResp OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of challenge response messages
        which are sent by device to portal server."
    ::= { unisPortalStatistic 15 }

-- PORTAL http request statistic

unisPortalStatHttpReq OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of http request messages
        which are sent by portal user to device."
    ::= { unisPortalStatistic 16 }

-- PORTAL http response statistic

unisPortalStatHttpResp OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of http response messages
        which are sent by  device to portal user."
    ::= { unisPortalStatistic 17 }

-- PORTAL HTTPS  request statistic

unisPortalStatHttpsReq OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of HTTPS request messages
        sent from portal users to the device."
    ::= { unisPortalStatistic 18 }

-- PORTAL HTTPS response statistic

unisPortalStatHttpsResp OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the number of HTTPS response messages
         sent from the device to portal users."
    ::= { unisPortalStatistic 19 }


-- PORTAL PACKET STATISTIC BY ERROR CODE

unisPortalPktStatistic OBJECT IDENTIFIER ::= { unisPortal 5 }

-- PORTAL REQ AUTH STATISTIC

unisPortalPktStaReqAuthNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of portal authentication requests from the
        portal server."
    ::= { unisPortalPktStatistic 1 }

unisPortalPktStaAckAuthSuccess OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to REQ-AUTH packet of
        portal server including error code 0 in the packet, that is
        authentication success."
    ::= { unisPortalPktStatistic 2 }

unisPortalPktStaAckAuthReject OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to REQ-AUTH packet of
        portal server including error code 1 in the packet, that is rejected
        by server."
    ::= { unisPortalPktStatistic 3 }

unisPortalPktStaAckAuthEstablish OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to REQ-AUTH packet of
        portal server including error code 2 in the packet, that is the link
        is already established."
    ::= { unisPortalPktStatistic 4 }

unisPortalPktStaAckAuthBusy OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to REQ-AUTH packet of
        portal server including error code 3 in the packet, that is the
        system is busy."
    ::= { unisPortalPktStatistic 5 }

unisPortalPktStaAckAuthAuthFail OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to REQ-AUTH packet of
        portal server including error code 4 in the packet, that is
        authentication fail."
    ::= { unisPortalPktStatistic 6 }

unisPortalPktStaReqChallengeNum OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of portal challenge requests from the
        portal server."
    ::= { unisPortalPktStatistic 7 }

unisPortalPktStaAckChallengeSuccess OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to challenge packet of
        portal server including error code 0 in the packet, that is
        challenge is success."
    ::= { unisPortalPktStatistic 8 }

unisPortalPktStaAckChallengeReject OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to challenge packet of
        portal server including error code 1 in the packet, that is
        challenge is rejected by server."
    ::= { unisPortalPktStatistic 9 }

unisPortalPktStaAckChallengeEstablish OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to challenge packet of
        portal server including error code 2 in the packet, that is the
        link is alreadys established."
    ::= { unisPortalPktStatistic 10 }

unisPortalPktStaAckChallengeBusy OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to challenge packet of
        portal server including error code 3 in the packet, that is the
        system is busy."
    ::= { unisPortalPktStatistic 11 }

unisPortalPktStaAckChallengeAuthFail OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It shows the total number of the response to challenge packet of
        portal server including error code 4 in the packet, that is
        authentication fail."
    ::= { unisPortalPktStatistic 12 }

unisPortalExtConfig OBJECT IDENTIFIER ::= { unisPortal 6 }

--
-- PORTAL MAX USER NUMBER
--

unisPortalExtMaxUserNumber OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Specify the maximum number of online users."
    ::= { unisPortalExtConfig 1 }

--
-- PORTAL CURRENT USER NUMBER
--

unisPortalExtCurrentUserNumber OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "The current number of online portal users."
    ::= { unisPortalExtConfig 2 }

--
-- PORTAL STATUS
--

unisPortalExtStatus OBJECT-TYPE
    SYNTAX      INTEGER
    {
         enabled(1),
         disabled(2)
    }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "It indicates the portal status.
         enabled:
            Portal is enabled on one or more interfaces.
         disabled:
            Portal is not enabled on any interface."
    ::= { unisPortalExtConfig 3 }

unisPortalExtTables OBJECT IDENTIFIER ::= { unisPortal 7 }

--
-- PORTAL server table
--
unisPortalExtSrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalExtSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table defines the name of the portal server.  It can be created
        and destroyed by MIB."
    ::= { unisPortalExtTables 1 }

unisPortalExtSrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalExtSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for each name and URL of the portal server.
        It is indexed by using the object unisPortalExtSrvName."
    INDEX
        {
            unisPortalExtSrvName
        }
    ::= { unisPortalExtSrvTable 1 }


UnisPortalExtSrvEntry ::= SEQUENCE
    {
        unisPortalExtSrvName          OCTET STRING,
        unisPortalExtSrvIPAddrType    InetAddressType,
        unisPortalExtSrvIP            InetAddress,
        unisPortalExtSrvPort          Integer32,
        unisPortalExtSrvRowStatus     RowStatus
    }

unisPortalExtSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table unisPortalExtSrvTable.  It shows
        the name of the portal server."
    ::= { unisPortalExtSrvEntry 1 }

unisPortalExtSrvIPAddrType OBJECT-TYPE
    SYNTAX      InetAddressType
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The type of the portal server IP address."
    ::={ unisPortalExtSrvEntry 2 }

unisPortalExtSrvIP OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the IP address of the portal server."
    ::= { unisPortalExtSrvEntry 3 }

unisPortalExtSrvPort OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows the UDP port of the portal server.
        The port will be used when clients send packets to the portal server.
        Default value is 50100.
        It is not configurable when the portal server has been enabled."
    ::= { unisPortalExtSrvEntry 4 }

unisPortalExtSrvRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo and
        Destroy operations.  To create a new row, the portal server must be
        specified.
        To destroy an existing row, the portal server MUST NOT be referenced by
        an interface."
    ::= { unisPortalExtSrvEntry 5 }

--
-- PORTAL web server table
--
unisPortalExtWebSrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalExtWebSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table defines the name of the portal Web server.  It can be created
         and destroyed by MIB."
    ::= { unisPortalExtTables 2 }

unisPortalExtWebSrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalExtWebSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for each name and portal Web server.
        It is indexed by using the object unisPortalExtWebSrvName."
    INDEX
        {
            unisPortalExtWebSrvName
        }
    ::= { unisPortalExtWebSrvTable 1 }


UnisPortalExtWebSrvEntry ::= SEQUENCE
    {
        unisPortalExtWebSrvName         OCTET STRING,
        unisPortalExtWebSrvUrl          OCTET STRING,
        unisPortalExtWebSrvRowStatus    RowStatus
    }

unisPortalExtWebSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table unisPortalExtWebSrvTable.  It shows
        the name of the portal Web server."
    ::= { unisPortalExtWebSrvEntry 1 }

unisPortalExtWebSrvUrl OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the URL to the portal Web server.
        Users which have not logged on to portal will be redirected to the
        portal server according to unisPortalServerIfUrl.
        The value is consisted of protocol, IP address and relative path.
        For example: http://10.1.1.1/portal."
    ::= { unisPortalExtWebSrvEntry 2 }

unisPortalExtWebSrvRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo and
        Destroy operations.  To create a new row, the portal server must be specified.
        To destroy an existing row, the portal Web server MUST NOT be referenced by an
        interface."
    ::= { unisPortalExtWebSrvEntry 3 }

unisPortalExtMTSrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalExtMTSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the configuration of the MAC Trigger server."
    ::= { unisPortalExtTables 3 }

unisPortalExtMTSrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalExtMTSrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in the table for the MAC Trigger server.  It is indexed by using the object Index."
    INDEX
        {
            unisPortalExtMTSrvName
        }
    ::= { unisPortalExtMTSrvTable 1 }

UnisPortalExtMTSrvEntry ::= SEQUENCE
    {
        unisPortalExtMTSrvName          OCTET STRING,
        unisPortalExtMTSrvIPAddrType    InetAddressType,
        unisPortalExtMTSrvIP            InetAddress,
        unisPortalExtMTSrvPort          Integer32,
        unisPortalExtMTDetctFlowPeriod  Integer32,
        unisPortalExtMTThresholdFlow    Unsigned32,
        unisPortalExtMTSrvRowStatus     RowStatus
    }

unisPortalExtMTSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..32))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table unisPortalExtMTSrvTable.  It shows
         the name of the MAC Trigger server."
    ::= { unisPortalExtMTSrvEntry 1 }

unisPortalExtMTSrvIPAddrType OBJECT-TYPE
    SYNTAX      InetAddressType
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "The type of the MAC Trigger server IP address."
    ::={ unisPortalExtMTSrvEntry 2 }

unisPortalExtMTSrvIP OBJECT-TYPE
    SYNTAX      InetAddress
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the IP address of the MAC Trigger server."
    ::= { unisPortalExtMTSrvEntry 3 }

unisPortalExtMTSrvPort OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the UDP port of the MAC Trigger server.
        The port will be used when clients send packets to the MAC Trigger server.
        Default value is 50100."
    DEFVAL { 50100 }
    ::= { unisPortalExtMTSrvEntry 4 }

unisPortalExtMTDetctFlowPeriod  OBJECT-TYPE
    SYNTAX      Integer32
    UNITS       "seconds"
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the user flow detection interval (in seconds) when
        MAC Trigger and Portal are enabled.
        Default value is 300."
    DEFVAL { 300 }
    ::= { unisPortalExtMTSrvEntry 5 }

unisPortalExtMTThresholdFlow  OBJECT-TYPE
    SYNTAX      Unsigned32
    UNITS       "bytes"
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "It shows the user traffic threshold (in bytes) that triggers authentication
        when MAC Trigger and Portal are enabled.
        Default value is 0."
    DEFVAL { 0 }
    ::= { unisPortalExtMTSrvEntry 6 }

unisPortalExtMTSrvRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "This object is responsible for managing the creation, deletion and
        modification of rows, which support active status and CreateAndGo and
        Destroy operations."
    ::= { unisPortalExtMTSrvEntry 7 }
--
-- PORTAL extend if table
--
unisPortalExtIfConfigTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalExtIfConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes portal information on interfaces."
    ::= { unisPortalExtTables 4 }

unisPortalExtIfConfigEntry OBJECT-TYPE
    SYNTAX      UnisPortalExtIfConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for an interface on which
        portal has been enabled.
        It is indexed by using the object ifIndex."
    INDEX
        {
            unisPortalExtIfIndex
        }
    ::= { unisPortalExtIfConfigTable 1 }

UnisPortalExtIfConfigEntry ::= SEQUENCE
    {
        unisPortalExtIfIndex            InterfaceIndex,
        unisPortalExtIfWebSrvName       OCTET STRING,
        unisPortalExtIfDomainName       OCTET STRING,
        unisPortalExtIfAuthMethod       UnisPortalAuthMethod,
        unisPortalExtIfMTSrvName        OCTET STRING,
        unisPortalExtIfMaxUser          Unsigned32
    }

unisPortalExtIfIndex OBJECT-TYPE
    SYNTAX      InterfaceIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the interface index and the index of unisPortalExtIfConfigTable."
    ::= { unisPortalExtIfConfigEntry 1 }

unisPortalExtIfWebSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The Portal Web server name must exist.  It references
        unisPortalExtWebSrvName."
    ::= { unisPortalExtIfConfigEntry 2 }

unisPortalExtIfDomainName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Authentication domain."
    ::= { unisPortalExtIfConfigEntry 3 }

unisPortalExtIfAuthMethod OBJECT-TYPE
    SYNTAX      UnisPortalAuthMethod
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Specify the portal authentication method."
    ::= { unisPortalExtIfConfigEntry 4 }

unisPortalExtIfMTSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The MAC trigger server name must exist.  It references unisPortalExtMTSrvName."
    ::= { unisPortalExtIfConfigEntry 5 }

unisPortalExtIfMaxUser OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Maximum number of portal users."
    ::= { unisPortalExtIfConfigEntry 6 }

unisPortalExtIfIpv6ConfigTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalExtIfIpv6ConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes IPv6 portal information on interfaces."
    ::= { unisPortalExtTables 5 }

unisPortalExtIfIpv6ConfigEntry OBJECT-TYPE
    SYNTAX      UnisPortalExtIfIpv6ConfigEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for an interface on which
        IPv6 portal has been enabled.
        It is indexed by using the object ifIndex."
    INDEX
        {
            unisPortalExtIfIpv6Index
        }
    ::= { unisPortalExtIfIpv6ConfigTable 1 }

UnisPortalExtIfIpv6ConfigEntry ::= SEQUENCE
    {
        unisPortalExtIfIpv6Index            InterfaceIndex,
        unisPortalExtIfIpv6WebSrvName       OCTET STRING,
        unisPortalExtIfIpv6DomainName       OCTET STRING,
        unisPortalExtIfIpv6AuthMethod       UnisPortalAuthMethod,
        unisPortalExtIfIpv6MaxUser          Unsigned32
    }

unisPortalExtIfIpv6Index OBJECT-TYPE
    SYNTAX      InterfaceIndex
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the interface index and the index of unisPortalExtIfIpv6ConfigTable."
    ::= { unisPortalExtIfIpv6ConfigEntry 1 }

unisPortalExtIfIpv6WebSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The Portal Web server name must exist.  It references unisPortalExtWebSrvName."
    ::= { unisPortalExtIfIpv6ConfigEntry 2 }

unisPortalExtIfIpv6DomainName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Authentication domain."
    ::= { unisPortalExtIfIpv6ConfigEntry 3 }

unisPortalExtIfIpv6AuthMethod  OBJECT-TYPE
    SYNTAX      UnisPortalAuthMethod
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Specify the portal authentication method."
    ::= { unisPortalExtIfIpv6ConfigEntry 4 }


unisPortalExtIfIpv6MaxUser OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Maximum number of IPv6 portal users."
    ::= { unisPortalExtIfIpv6ConfigEntry 5 }
--
-- PORTAL dot11 configuration table
--
unisPortalDot11SrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalDot11SrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes the portal information on service templates."
    ::= { unisPortalExtTables 6 }

unisPortalDot11SrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalDot11SrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for a service template on which
        portal has been enabled.
        It is indexed by using the object wlan service-template name."
    INDEX
        {
            unisPortalDot11SrvTemName
        }
    ::= { unisPortalDot11SrvTable 1 }

UnisPortalDot11SrvEntry ::= SEQUENCE
    {
        unisPortalDot11SrvTemName     OCTET STRING,
        unisPortalDot11WebSrvName     OCTET STRING,
        unisPortalDot11DomainName     OCTET STRING,
        unisPortalDot11AuthMethod     UnisPortalAuthMethod,
        unisPortalDot11MTSrvName      OCTET STRING,
        unisPortalDot11MaxUser        Unsigned32
    }

unisPortalDot11SrvTemName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..63))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table unisPortalDot11SrvTable, it shows
        the name of the wlan service-template."
    ::= { unisPortalDot11SrvEntry 1 }

unisPortalDot11WebSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows portal web-server name."
    ::= { unisPortalDot11SrvEntry 2 }

unisPortalDot11DomainName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows portal authentication domain name."
    ::= { unisPortalDot11SrvEntry 3 }

unisPortalDot11AuthMethod  OBJECT-TYPE
    SYNTAX      UnisPortalAuthMethod
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
     "Specify the portal authentication method on service templates."
    ::= { unisPortalDot11SrvEntry 4 }

unisPortalDot11MTSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "The MAC trigger server name must exist.  It references unisPortalExtMTSrvName."
    ::= { unisPortalDot11SrvEntry 5 }

unisPortalDot11MaxUser OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Maximum number of portal users."
    ::= { unisPortalDot11SrvEntry 6 }

unisPortalDot11Ipv6SrvTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisPortalDot11Ipv6SrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "This table describes IPv6 portal information on service templates."
    ::= { unisPortalExtTables 7 }

unisPortalDot11Ipv6SrvEntry OBJECT-TYPE
    SYNTAX      UnisPortalDot11Ipv6SrvEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "There is a row in this table for a service template on which
        IPv6 portal has been enabled.
        It is indexed by using the object wlan service-template name."
    INDEX
        {
            unisPortalDot11Ipv6SrvTemName
        }
    ::= { unisPortalDot11Ipv6SrvTable 1 }

UnisPortalDot11Ipv6SrvEntry ::= SEQUENCE
    {
        unisPortalDot11Ipv6SrvTemName     OCTET STRING,
        unisPortalDot11Ipv6WebSrvName     OCTET STRING,
        unisPortalDot11Ipv6DomainName     OCTET STRING,
        unisPortalDot11Ipv6AuthMethod     UnisPortalAuthMethod,
        unisPortalDot11Ipv6MaxUser        Unsigned32
    }

unisPortalDot11Ipv6SrvTemName OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (1..63))
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "It is the index of the table unisPortalDot11Ipv6SrvTable.  It shows
        the name of the IPv6 portal server."
    ::= { unisPortalDot11Ipv6SrvEntry 1 }

unisPortalDot11Ipv6WebSrvName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "It shows the IPv6 portal Web server name."
    ::= { unisPortalDot11Ipv6SrvEntry 2 }

unisPortalDot11Ipv6DomainName OBJECT-TYPE
    SYNTAX      OCTET STRING
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "IPv6 portal authentication domain name."
    ::= { unisPortalDot11Ipv6SrvEntry 3 }

unisPortalDot11Ipv6AuthMethod  OBJECT-TYPE
    SYNTAX      UnisPortalAuthMethod
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
     "Specify the IPv6 portal authentication method on service templates."
    ::= { unisPortalDot11Ipv6SrvEntry 4 }

unisPortalDot11Ipv6MaxUser OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "Maximum number of IPv6 portal users."
    ::= { unisPortalDot11Ipv6SrvEntry 5 }

END

