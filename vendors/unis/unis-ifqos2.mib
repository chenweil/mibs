            INDEX { unisIfQoSWredGroupIndex }
            ::= { unisIfQoSWredGroupTable 1 }

        UnisIfQoSWredGroupEntry ::=
            SEQUENCE
            {
                unisIfQoSWredGroupIndex
                    Integer32,
                unisIfQoSWredGroupName
                    OCTET STRING,
                unisIfQoSWredGroupType
                    INTEGER,
                unisIfQoSWredGroupWeightingConstant
                    Integer32,
                unisIfQoSWredGroupRowStatus
                    RowStatus
            }

        unisIfQoSWredGroupIndex OBJECT-TYPE
            SYNTAX Integer32 (0..256)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "WRED group index."
            ::= { unisIfQoSWredGroupEntry 1 }

        unisIfQoSWredGroupName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(1..32))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "WRED group name."
            ::= { unisIfQoSWredGroupEntry 2 }

        unisIfQoSWredGroupType OBJECT-TYPE
            SYNTAX INTEGER
            {
                userdefined(0),
                dot1p(1),
                ippre(2),
                dscp(3),
                localpre(4),
                atmclp(5),
                frde(6),
                exp(7),
                queue(8),
                dropLevel(9)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Type of WRED group."
            ::= { unisIfQoSWredGroupEntry 3 }

        unisIfQoSWredGroupWeightingConstant OBJECT-TYPE
            SYNTAX Integer32 (1..15)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Exponent for WRED calculates the average length of queue.
                 If 'unisIfQoSWredGroupType' is 'queue', the object is ineffective.
                 So, it must use the object, which is 'unisIfQoSWredGroupExponent' of
                 unisIfQoSWredGroupContentTable, to indicate the exponent of
                 each queue of the queue WRED group."
            DEFVAL { 9 }
            ::= { unisIfQoSWredGroupEntry 4 }

        unisIfQoSWredGroupRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisIfQoSWredGroupEntry 6 }

--
-- nodes of unisIfQoSWredGroupContentTable
--
        unisIfQoSWredGroupContentTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSWredGroupContentEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of priority WRED information."
            ::= { unisIfQoSWredGroupGroup 3 }

        unisIfQoSWredGroupContentEntry OBJECT-TYPE
            SYNTAX UnisIfQoSWredGroupContentEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Priority WRED information entry."
            INDEX { unisIfQoSWredGroupIndex,
                    unisIfQoSWredGroupContentIndex,
                    unisIfQoSWredGroupContentSubIndex  }
            ::= { unisIfQoSWredGroupContentTable 1 }

        UnisIfQoSWredGroupContentEntry ::=
            SEQUENCE
            {
                unisIfQoSWredGroupContentIndex
                    Integer32,
                unisIfQoSWredGroupContentSubIndex
                    Integer32,
                unisIfQoSWredLowLimit
                    Integer32,
                unisIfQoSWredHighLimit
                    Integer32,
                unisIfQoSWredDiscardProb
                    Integer32,
                unisIfQoSWredGroupExponent
                    Integer32,
                unisIfQoSWredRowStatus
                    RowStatus
            }

        unisIfQoSWredGroupContentIndex OBJECT-TYPE
            SYNTAX Integer32 (0..63)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The priority of a packet.
                 Different type of packet has different priority.
                 Type of priority    Range of priority
                 dot1p              0..7
                 ippre              0..7
                 dscp               0..63
                 atmclp             0..1
                 frde               0..1
                 exp                0..7
                 queue              0..7 ( defined by product )
                 dropLevel          0..2
                 "
            ::= { unisIfQoSWredGroupContentEntry 1 }

        unisIfQoSWredGroupContentSubIndex OBJECT-TYPE
            SYNTAX Integer32 (0..63)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The sub index.
                 Different type of packet has different value.
                 Type of priority    Range of value
                 queue              0..2
                 other types : 0
                 "
            ::= { unisIfQoSWredGroupContentEntry 2 }

        unisIfQoSWredLowLimit OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Discard low limit."
            ::= { unisIfQoSWredGroupContentEntry 3 }

        unisIfQoSWredHighLimit OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Discard high limit."
            ::= { unisIfQoSWredGroupContentEntry 4 }

        unisIfQoSWredDiscardProb OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Discard probability."
            ::= { unisIfQoSWredGroupContentEntry 5 }

        unisIfQoSWredGroupExponent OBJECT-TYPE
            SYNTAX Integer32 (0..15)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Exponent for WRED calculates the average length of queue.
                 Only 'unisIfQoSWredGroupType' is 'queue', the object is effective.
                 This object is designed to indicate the exponent of
                 each queue of the queue WRED group.
                "
            DEFVAL { 9 }
            ::= { unisIfQoSWredGroupContentEntry 6 }

        unisIfQoSWredRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisIfQoSWredGroupContentEntry 7 }
