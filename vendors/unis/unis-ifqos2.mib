--
-- nodes of car group
--
        unisIfQoSCARObjects OBJECT IDENTIFIER ::= { unisIfQos2 4 }
--
-- nodes of unisIfQoSAggregativeCarGroup
--
        unisIfQoSAggregativeCarGroup OBJECT IDENTIFIER ::= { unisIfQoSCARObjects 1 }
--
-- nodes of unisIfQoSAggregativeCarConfigTable
--
        unisIfQoSAggregativeCarNextIndex OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "This object contains an appropriate value to be used for unisIfQoSAggregativeCarIndex
                 when creating rows in the unisIfQoSAggregativeCarConfigTable.
                 Begin with 1.
                "
            ::= { unisIfQoSAggregativeCarGroup 1 }

        unisIfQoSAggregativeCarConfigTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSAggregativeCarConfigEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of aggregative car information."
            ::= { unisIfQoSAggregativeCarGroup 2 }

        unisIfQoSAggregativeCarConfigEntry OBJECT-TYPE
            SYNTAX UnisIfQoSAggregativeCarConfigEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Aggregative car information."
            INDEX { unisIfQoSAggregativeCarIndex }
            ::= { unisIfQoSAggregativeCarConfigTable 1 }

        UnisIfQoSAggregativeCarConfigEntry     ::=
            SEQUENCE
            {
                unisIfQoSAggregativeCarIndex
                    Integer32,
                unisIfQoSAggregativeCarName
                    OCTET STRING,
                unisIfQoSAggregativeCarCir
                    Unsigned32,
                unisIfQoSAggregativeCarCbs
                    Unsigned32,
                unisIfQoSAggregativeCarEbs
                    Unsigned32,
                unisIfQoSAggregativeCarPir
                    Unsigned32,
                unisIfQoSAggregativeCarGreenActionType
                    UnisIfCarAction,
                unisIfQoSAggregativeCarGreenActionValue
                    Integer32,
                unisIfQoSAggregativeCarYellowActionType
                    UnisIfCarAction,
                unisIfQoSAggregativeCarYellowActionValue
                    Integer32,
                unisIfQoSAggregativeCarRedActionType
                    UnisIfCarAction,
                unisIfQoSAggregativeCarRedActionValue
                    Integer32,
                unisIfQoSAggregativeCarType
                    INTEGER,
                unisIfQoSAggregativeCarRowStatus
                    RowStatus
            }

        unisIfQoSAggregativeCarIndex OBJECT-TYPE
            SYNTAX Integer32 (1..65534)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The index of aggregative car."
            ::= { unisIfQoSAggregativeCarConfigEntry 1 }

        unisIfQoSAggregativeCarName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(1..31))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The name of aggregative car."
            ::= { unisIfQoSAggregativeCarConfigEntry 2 }

        unisIfQoSAggregativeCarCir OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Committed-information-rate.  Unit : kbps"
            ::= { unisIfQoSAggregativeCarConfigEntry 3 }

        unisIfQoSAggregativeCarCbs OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Committed-burst-size.  Unit : byte"
            ::= { unisIfQoSAggregativeCarConfigEntry 4 }

        unisIfQoSAggregativeCarEbs OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Excess-burst-size.  Unit : byte"
            ::= { unisIfQoSAggregativeCarConfigEntry 5 }

        unisIfQoSAggregativeCarPir OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Peak-information-rate.  Unit : kbps"
            DEFVAL { 4294967295 }
            ::= { unisIfQoSAggregativeCarConfigEntry 6 }

        unisIfQoSAggregativeCarGreenActionType OBJECT-TYPE
            SYNTAX UnisIfCarAction
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Supported green action:
                 invalid(0),
                 pass(1),
                 discard(3),
                 remark(4),
                 remark-ip-pass(6),
                 remark-mplsexp-pass(8),
                 remark-dscp-pass(10),
                 remark-dot1p-pass(12),
                 remark-atm-clp-pass(14),
                 remark-fr-de-pass(16),
                 remarkLocalPrePass(18),
                 remarkDropPrePass(20).
                 Hardware QoS : pass, discard, remark.
                 Software QoS : pass, discard, remark-ip-pass(6),
                 remark-mplsexp-pass(8), remark-dscp-pass(10).
                 'invalid' is returned when getting value from software QoS.
                 "
            DEFVAL { pass }
            ::= { unisIfQoSAggregativeCarConfigEntry 7 }

        unisIfQoSAggregativeCarGreenActionValue OBJECT-TYPE
            SYNTAX Integer32 (0..63|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value is to remark When green action is remarking.
                 For remark-dscp-pass, the range is 0 to 63;
                 For remark-ip-pass, remark-mplsexp-pass, remark-dot1p-pass and
                 remarkLocalPrePass, the range is 0 to 7;
                 For remark-fr-de-pass and remark-atm-clp-pass, the range is 0 to 1;
                 For remarkDropPrePass, the range is 0 to 2.
                 Only software QoS support this node.
                 255 is returned only when getting value from hardware QoS or
                 when action being pass, discard of software QoS.
                 255 can't be set.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 8 }

        unisIfQoSAggregativeCarYellowActionType OBJECT-TYPE
            SYNTAX UnisIfCarAction
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Supported yellow action:
                 invalid(0),
                 pass(1),
                 discard(3),
                 remark(4),
                 remark-ip-pass(6),
                 remark-mplsexp-pass(8),
                 remark-dscp-pass(10),
                 remark-dot1p-pass(12),
                 remark-atm-clp-pass(14),
                 remark-fr-de-pass(16),
                 remarkLocalPrePass(18),
                 remarkDropPrePass(20).
                 Hardware QoS : pass, discard, remark.
                 Software QoS : pass, discard, remark-ip-pass(6),
                 remark-mplsexp-pass(8), remark-dscp-pass(10).
                 'invalid' is returned when getting value from software QoS.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 9 }

        unisIfQoSAggregativeCarYellowActionValue OBJECT-TYPE
            SYNTAX Integer32 (0..63|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value is to remark When yellow action is remarking.
                 For remark-dscp-pass, the range is 0 to 63;
                 For remark-ip-pass, remark-mplsexp-pass, remark-dot1p-pass and
                 remarkLocalPrePass, the range is 0 to 7;
                 For remark-fr-de-pass and remark-atm-clp-pass, the range is 0 to 1;
                 For remarkDropPrePass, the range is 0 to 2.
                 Only software QoS support this node.
                 255 is returned only when getting value from hardware QoS or
                 when action being pass, discard of software QoS.
                 255 can't be set.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 10 }

        unisIfQoSAggregativeCarRedActionType OBJECT-TYPE
            SYNTAX UnisIfCarAction
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Supported red action:
                 invalid(0),
                 pass(1),
                 discard(3),
                 remark(4),
                 remark-ip-pass(6),
                 remark-mplsexp-pass(8),
                 remark-dscp-pass(10),
                 remark-dot1p-pass(12),
                 remark-atm-clp-pass(14),
                 remark-fr-de-pass(16),
                 remarkLocalPrePass(18),
                 remarkDropPrePass(20).
                 Hardware QoS : pass, discard, remark.
                 Software QoS : pass, discard, remark-ip-pass(6),
                 remark-mplsexp-pass(8), remark-dscp-pass(10).
                 'invalid' is returned when getting value from software QoS.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 11 }

        unisIfQoSAggregativeCarRedActionValue OBJECT-TYPE
            SYNTAX Integer32 (0..63|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The value is to remark When red action is remarking.
                 For remark-dscp-pass, the range is 0 to 63;
                 For remark-ip-pass, remark-mplsexp-pass, remark-dot1p-pass and
                 remarkLocalPrePass, the range is 0 to 7;
                 For remark-fr-de-pass and remark-atm-clp-pass, the range is 0 to 1;
                 For remarkDropPrePass, the range is 0 to 2.
                 Only software QoS support this node.
                 255 is returned only when getting value from hardware QoS or
                 when action being pass, discard of software QoS.
                 255 can't be set.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 12 }

        unisIfQoSAggregativeCarType OBJECT-TYPE
            SYNTAX INTEGER
            {
                aggregative(1),
                notAggregative(2),
                hierarchy(3)
            }
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "The type of aggregative CAR.
                 The enumeration 'aggregative' indicates that the ports
                 with a same aggregative CAR use one token bulk.

                 The enumeration 'notAggregative' indicates that each port
                 uses one token bulk.

                 The enumeration 'hierarchy' indicates that each object uses one
                 token bulk after processed first by some other token bulk.
                "
            ::= { unisIfQoSAggregativeCarConfigEntry 13 }

        unisIfQoSAggregativeCarRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "RowStatus."
            ::= { unisIfQoSAggregativeCarConfigEntry 14 }
