--  Modify property of unisIfQoSPortWredPreID to "not-accessible".
--  Add the  enumeration ipall to unisIfQoSPQClassRuleType in unisIfQoSPQClassRuleTable.
--  Modify some text errors in this file.
-- V1.2 2006/03/29 modified by xialei
--  Modify the ipv4acl value in description of unisIfQoSPQClassRuleValue and unisIfQoSCQClassRuleValue
--  Add the enumeration mpls to unisIfQoSPQClassRuleType in unisIfQoSPQClassRuleTable.
--  Add the enumeration ipall, mpls to unisIfQoSCQClassRuleType in unisIfQoSCQClassRuleTable.
-- V1.3 2006/05/24 add by cuichuanjin
--  Add unisIfQoSCarlTable
-- V1.4 2007/11/12 modified by mouxuanli
--  Modify the description of the object unisIfQoSPassPackets.
--  Add 18 objects in unisIfQoSHardwareQueueRunInfoTable.
--  Add unisIfQoSHQueueTcpRunInfoTable.
-- V1.5 2008/9/25 modified by yueting
--  Add unisQoSIfTraStaConfigInfoTable.
--  Add unisQoSIfTraStaRunInfoTable.
-- V1.6 2011/12/14 modified by mouxuanli
--  Add the enumeration byteCountWrr, byteCountWfq to unisIfQoSQSMode in unisIfQoSQSModeTable.
--  Add unisIfQoSQSMinBandwidth in unisIfQoSQSWeightTable.
--  Add unisIfQoSLRPir in unisIfQoSLRConfigTable.
-- V1.7 2012/04/28 modified by mouxuanli
--  Add the enumeration ipPrecedence, dot11e, auto to unisIfQoSPortPriorityTrustTrustType.
--  Add the enumeration overcast to unisIfQoSPortPriorityTrustOvercastType.
--  Add unisIfQoSPrePriMapTable.
-- V1.8 2013/10/25 modified by mouxuanli
--  Add the enumeration gmb to unisIfQoSQSMode.
--  Add unisIfQoSQSMinBandwidthPercent in unisIfQoSQSWeightTable.
--  Add unisIfQoSLRUnit in unisIfQoSLRConfigTable.
--  Add unisQoSGlobalPriorityObject.
-- V1.9 2014/11/25 modified by zhaixiaoxiang & xunzhi
--  Modify the name of CarAction to UnisIfCarAction.
--  Add the enumeration remarkLocalPreContinue, remarkLocalPrePass, remarkDropPreContinue
--  and remarkDropPrePass to UnisIfCarAction and modify the related descriptions.
--  Add the enumeration hierarchy to unisIfQoSAggregativeCarType.
--  Add unisIfQoSTricolorCarUnitType in unisIfQoSTricolorCarConfigTable.
--  Add unisIfQoSGTSPir and unisIfQoSGTSUnitType in unisIfQoSGTSConfigTable.
--  Add unisIfQoSProcessingStatus node.
-- V1.10 2016/10/25 modified by gaomengfei
--  Add the enumeration group3 and group4 to unisIfQoSQueueGroupType
--  2017/05/20 modified by gaomengfei
--  Add the unisIfQoSQueueName in unisIfQoSHardwareQueueRunInfoEntry
--  Add unisIfQoSHardwareQueueTotalRunInfoTable
--  2018/02/28 modified by hulifang
--  Add unisIfQoSCoppFlowStatTable
-- V1.11 2018/12/12 modified by meixixue
--  2018/12/12 modified by meixixue
--  Add the unisIfQoSDropPPS and unisIfQoSDropBPS in unisIfQoSHardwareQueueRunInfoEntry
-- V1.12 2019/06/20 modified by wangqian
--  2019/06/20 modified by wangqian
--  Add the unisIfQoSPeakPassPPS and unisIfQoSPeakPassBPS in unisIfQoSHardwareQueueRunInfoEntry
-- ============================================================================
UNIS-IFQOS2-MIB DEFINITIONS ::= BEGIN

        IMPORTS
            unisCommon
                FROM UNIS-OID-MIB
            OBJECT-TYPE, MODULE-IDENTITY, Integer32, Counter64, Unsigned32, IpAddress
                FROM SNMPv2-SMI
            ifIndex
                FROM IF-MIB
            InetAddressIPv6, InetAddressPrefixLength
                FROM INET-ADDRESS-MIB
            RowStatus, TruthValue, TEXTUAL-CONVENTION
                FROM SNMPv2-TC;
--
-- Nodes definitions
--

        unisIfQos2 MODULE-IDENTITY
            LAST-UPDATED "201906200000Z"
            ORGANIZATION
                "Unisyue Technologies Co., Ltd."
            CONTACT-INFO
                ""
            DESCRIPTION
                "Add the unisIfQoSPeakPassPPS and unisIfQoSPeakPassBPS in unisIfQoSHardwareQueueRunInfoEntry."
            REVISION "201906200000Z"        --June 20, 2019 at 00:00 GMT
            DESCRIPTION
                "Add the unisIfQoSDropPPS and unisIfQoSDropBPS in unisIfQoSHardwareQueueRunInfoEntry."
            REVISION "201812120000Z"        --December 12, 2018 at 00:00 GMT
            DESCRIPTION
                "Interface QoS management information base."
            REVISION "201802280000Z"        --February 28, 2018 at 00:00 GMT
            DESCRIPTION
                "Add unisIfQoSCoppFlowStatTable."
            REVISION "201705200000Z"        --May 20, 2017 at 00:00 GMT
            DESCRIPTION
                "Add the unisIfQoSQueueName in unisIfQoSHardwareQueueRunInfoEntry and
                add unisIfQoSHardwareQueueTotalRunInfoTable."
            REVISION "201610250000Z"        --October 25, 2016 at 00:00 GMT
            DESCRIPTION
                "Add the enumeration group3 and group4 to unisIfQoSQueueGroupType."
            REVISION "201411250000Z"        --November 25, 2014 at 00:00 GMT
            DESCRIPTION
                "Add the unit type node in unisIfQoSTricolorCarConfigTable and
                unisIfQoSGTSConfigTable, and add object unisIfQoSProcessingStatus."
            REVISION "201311280000Z"        --November 28, 2013 at 00:00 GMT
            DESCRIPTION
                "Interface QoS management information base."
            ::= { unisQos2 1 }

        unisQos2     OBJECT IDENTIFIER ::= { unisCommon 65 }

-- IfCar Action
        UnisIfCarAction ::= TEXTUAL-CONVENTION
            STATUS current
            DESCRIPTION
                "The actions taken when packets conforming or exceeding the configured CIR."
            SYNTAX  INTEGER
            {
                invalid(0),
                pass(1),
                continue(2),
                discard(3),
                remark(4),
                remark-ip-continue(5),
                remark-ip-pass(6),
                remark-mplsexp-continue(7),
                remark-mplsexp-pass(8),
                remark-dscp-continue(9),
                remark-dscp-pass(10),
                remark-dot1p-continue(11),
                remark-dot1p-pass(12),
                remark-atm-clp-continue(13),
                remark-atm-clp-pass(14),
                remark-fr-de-continue(15),
                remark-fr-de-pass(16),
                remarkLocalPreContinue(17),
                remarkLocalPrePass(18),
                remarkDropPreContinue(19),
                remarkDropPrePass(20)
            }

--
-- priority queue
--
        PriorityQueue ::= TEXTUAL-CONVENTION
            STATUS current
            DESCRIPTION
                "The type of priority queue."
            SYNTAX INTEGER
            {
                top(1),
                middle(2),
                normal(3),
                bottom(4)
            }
--
-- direction
--
        Direction ::= TEXTUAL-CONVENTION
            STATUS current
            DESCRIPTION
                "Inbound or outbound."
            SYNTAX INTEGER
            {
                inbound(1),
                outbound(2)
            }
--
-- node of unisIfQoSHardwareQueueObjects
--
        unisIfQoSHardwareQueueObjects OBJECT IDENTIFIER ::= { unisIfQos2 1 }
--
-- nodes of unisIfQoSHardwareQueueConfigGroup
--
        unisIfQoSHardwareQueueConfigGroup OBJECT IDENTIFIER ::= { unisIfQoSHardwareQueueObjects 1 }

        unisIfQoSQSModeTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSQSModeEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of queue schedule mode information."
            ::= { unisIfQoSHardwareQueueConfigGroup 1 }

        unisIfQoSQSModeEntry OBJECT-TYPE
            SYNTAX UnisIfQoSQSModeEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Queue schedule mode information entry."
            INDEX { ifIndex }
            ::= { unisIfQoSQSModeTable 1 }

        UnisIfQoSQSModeEntry ::=
            SEQUENCE
            {
                unisIfQoSQSMode
                    INTEGER
            }

        unisIfQoSQSMode OBJECT-TYPE
            SYNTAX INTEGER
            {
                sp(1),
                sp0(2),
                sp1(3),
                sp2(4),
                wrr(5),
                unisfq(6),
                wrr-sp(7),
                byteCountWrr(8),
                byteCountWfq(9),
                gmb(10)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "The mode of schedule."
            ::= { unisIfQoSQSModeEntry 1 }

--
-- notes of unisIfQoSQSWeightTable
--
        unisIfQoSQSWeightTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSQSWeightEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of queue schedule weight configuration information."
            ::= { unisIfQoSHardwareQueueConfigGroup 2 }

        unisIfQoSQSWeightEntry OBJECT-TYPE
            SYNTAX UnisIfQoSQSWeightEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Queue schedule weight configuration information entry."
            INDEX { ifIndex, unisIfQoSQueueID }
            ::= { unisIfQoSQSWeightTable 1 }

        UnisIfQoSQSWeightEntry ::=
            SEQUENCE
            {
                unisIfQoSQueueID
                    Integer32,
                unisIfQoSQueueGroupType
                    INTEGER,
                unisIfQoSQSType
                    INTEGER,
                unisIfQoSQSValue
                    Integer32,
                unisIfQoSQSMaxDelay
                    Integer32,
                unisIfQoSQSMinBandwidth
                    Integer32,
                unisIfQoSQSMinBandwidthPercent
                    Unsigned32
            }

        unisIfQoSQueueID OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Queue ID"
            ::= { unisIfQoSQSWeightEntry 1 }

        unisIfQoSQueueGroupType OBJECT-TYPE
            SYNTAX INTEGER
            {
                group0(1),
                group1(2),
                group2(3),
                group3(4),
                group4(5)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Group type of WRR and WFQ."
            ::= { unisIfQoSQSWeightEntry 2 }

        unisIfQoSQSType OBJECT-TYPE
            SYNTAX INTEGER
            {
                weight(1),
                byte-count(2)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Schedule type."
            ::= { unisIfQoSQSWeightEntry 3 }

        unisIfQoSQSValue OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Schedule value."
            ::= { unisIfQoSQSWeightEntry 4 }

        unisIfQoSQSMaxDelay OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Max delay."
            DEFVAL { 9 }
            ::= { unisIfQoSQSWeightEntry 5 }

        unisIfQoSQSMinBandwidth OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Min bandwidth.  Unit: kbps."
            ::= { unisIfQoSQSWeightEntry 6 }

        unisIfQoSQSMinBandwidthPercent OBJECT-TYPE
            SYNTAX Unsigned32  (0..100 | 255)
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Percent of min bandwidth.  Unit: %.
                 The value is 255 when the schedule mode of the queue is strict queuing.
                "
            ::= { unisIfQoSQSWeightEntry 7 }

--
-- nodes of unisIfQoSHardwareQueueRunInfoGroup
--
        unisIfQoSHardwareQueueRunInfoGroup OBJECT IDENTIFIER ::= { unisIfQoSHardwareQueueObjects 2 }

        unisIfQoSHardwareQueueRunInfoTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSHardwareQueueRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of queue statistic information."
            ::= { unisIfQoSHardwareQueueRunInfoGroup 1 }

        unisIfQoSHardwareQueueRunInfoEntry OBJECT-TYPE
            SYNTAX UnisIfQoSHardwareQueueRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Queue statistic information entry."
            INDEX { ifIndex, unisIfQoSQueueID }
            ::= { unisIfQoSHardwareQueueRunInfoTable 1 }

        UnisIfQoSHardwareQueueRunInfoEntry ::=
            SEQUENCE
            {
                unisIfQoSPassPackets
                    Counter64,
                unisIfQoSDropPackets
                    Counter64,
                unisIfQoSPassBytes
                    Counter64,
                unisIfQoSPassPPS
                    Unsigned32,
                unisIfQoSPassBPS
                    Unsigned32,
                unisIfQoSDropBytes
                    Counter64,
                unisIfQoSQueueLengthInPkts
                    Unsigned32,
                unisIfQoSQueueLengthInBytes
                    Unsigned32,
                unisIfQoSCurQueuePkts
                    Unsigned32,
                unisIfQoSCurQueueBytes
                    Unsigned32,
                unisIfQoSCurQueuePPS
                    Unsigned32,
                unisIfQoSCurQueueBPS
                    Unsigned32,
                unisIfQoSTailDropPkts
                    Counter64,
                unisIfQoSTailDropBytes
                    Counter64,
                unisIfQoSTailDropPPS
                    Unsigned32,
                unisIfQoSTailDropBPS
                    Unsigned32,
                unisIfQoSWredDropPkts
                    Counter64,
                unisIfQoSWredDropBytes
                    Counter64,
                unisIfQoSWredDropPPS
                    Unsigned32,
                unisIfQoSWredDropBPS
                    Unsigned32,
                unisIfQoSQueueName
                    OCTET STRING,
                unisIfQoSDropPPS
                    Unsigned32,
                unisIfQoSDropBPS
                    Unsigned32,
                unisIfQoSPeakPassPPS
                    Unsigned32,
                unisIfQoSPeakPassBPS
                    Unsigned32
            }

        unisIfQoSPassPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of forwarded packets."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 1 }

        unisIfQoSDropPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of dropped packets."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 2 }

        unisIfQoSPassBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of forwarded packets."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 3 }

        unisIfQoSPassPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of forwarded packets.  PPS: packets per second."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 4 }

        unisIfQoSPassBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of forwarded packets.  BPS: bytes per second."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 5 }

        unisIfQoSDropBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of dropped packets."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 6 }

        unisIfQoSQueueLengthInPkts OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The max number of packets which the queue can hold."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 7 }

        unisIfQoSQueueLengthInBytes OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The max bytes of packets which the queue can hold."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 8 }

        unisIfQoSCurQueuePkts OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of packets in the current queue."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 9 }

        unisIfQoSCurQueueBytes OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of packets in the current queue."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 10 }

        unisIfQoSCurQueuePPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of packets in the current queue."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 11 }

        unisIfQoSCurQueueBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of packets in the current queue."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 12 }

        unisIfQoSTailDropPkts OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of packets dropped by tail dropping."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 13 }

        unisIfQoSTailDropBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of packets dropped by tail dropping."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 14 }

        unisIfQoSTailDropPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of packets dropped by tail dropping."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 15 }

        unisIfQoSTailDropBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of packets dropped by tail dropping."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 16 }

        unisIfQoSWredDropPkts OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of packets dropped by WRED."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 17 }

        unisIfQoSWredDropBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of packets dropped by WRED."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 18 }

        unisIfQoSWredDropPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of packets dropped by WRED."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 19 }

        unisIfQoSWredDropBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of packets dropped by WRED."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 20 }

        unisIfQoSQueueName OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE(2..3))
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The Name of Queue."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 21 }

        unisIfQoSDropPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of dropped packets.  PPS: packets per second."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 22 }

        unisIfQoSDropBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of dropped packets.  BPS: bytes per second."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 23 }

        unisIfQoSPeakPassPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The max rate of forwarded packets in bytes per second (pps)
                 during the period from the time when the reset command was executed
                 to the current time."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 24 }

        unisIfQoSPeakPassBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The max rate of forwarded packets in bytes per second (Bps)
                 during the period from the time when the reset command was executed
                 to the current time."
            ::= { unisIfQoSHardwareQueueRunInfoEntry 25 }

--
-- nodes of unisIfQoSHQueueTcpRunInfoTable
--

        unisIfQoSHQueueTcpRunInfoTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSHQueueTcpRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of queue statistic information
                 about TCP and non-TCP packets."
            ::= { unisIfQoSHardwareQueueRunInfoGroup 2 }

        unisIfQoSHQueueTcpRunInfoEntry OBJECT-TYPE
            SYNTAX UnisIfQoSHQueueTcpRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Queue statistic information entry
                 about TCP and non-TCP packets."
            INDEX { ifIndex, unisIfQoSQueueID }
            ::= { unisIfQoSHQueueTcpRunInfoTable 1 }

        UnisIfQoSHQueueTcpRunInfoEntry ::=
            SEQUENCE
            {
                unisIfQoSWredDropLPreNTcpPkts
                    Counter64,
                unisIfQoSWredDropLPreNTcpBytes
                    Counter64,
                unisIfQoSWredDropLPreNTcpPPS
                    Unsigned32,
                unisIfQoSWredDropLPreNTcpBPS
                    Unsigned32,
                unisIfQoSWredDropLPreTcpPkts
                    Counter64,
                unisIfQoSWredDropLPreTcpBytes
                    Counter64,
                unisIfQoSWredDropLPreTcpPPS
                    Unsigned32,
                unisIfQoSWredDropLPreTcpBPS
                    Unsigned32,
                unisIfQoSWredDropHPreNTcpPkts
                    Counter64,
                unisIfQoSWredDropHPreNTcpBytes
                    Counter64,
                unisIfQoSWredDropHPreNTcpPPS
                    Unsigned32,
                unisIfQoSWredDropHPreNTcpBPS
                    Unsigned32,
                unisIfQoSWredDropHPreTcpPkts
                    Counter64,
                unisIfQoSWredDropHPreTcpBytes
                    Counter64,
                unisIfQoSWredDropHPreTcpPPS
                    Unsigned32,
                unisIfQoSWredDropHPreTcpBPS
                    Unsigned32
            }

        unisIfQoSWredDropLPreNTcpPkts OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of low-precedence non-TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 1 }

        unisIfQoSWredDropLPreNTcpBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of low-precedence non-TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 2 }

        unisIfQoSWredDropLPreNTcpPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of low-precedence non-TCP packets dropped by WRED.
                 PPS: packets per second."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 3 }

        unisIfQoSWredDropLPreNTcpBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of low-precedence non-TCP packets dropped by WRED.
                 BPS: bytes per second."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 4 }

        unisIfQoSWredDropLPreTcpPkts OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of low-precedence TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 5 }

        unisIfQoSWredDropLPreTcpBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of low-precedence TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 6 }

        unisIfQoSWredDropLPreTcpPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The PPS of low-precedence TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 7 }

        unisIfQoSWredDropLPreTcpBPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The BPS of low-precedence TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 8 }

        unisIfQoSWredDropHPreNTcpPkts OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of high-precedence non-TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 9 }

        unisIfQoSWredDropHPreNTcpBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The bytes of high-precedence non-TCP packets dropped by WRED."
            ::= { unisIfQoSHQueueTcpRunInfoEntry 10 }

        unisIfQoSWredDropHPreNTcpPPS OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS read-only
