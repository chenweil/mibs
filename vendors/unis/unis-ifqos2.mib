--
-- node of unisQoSTraStaObjects
--
        unisQoSTraStaObjects OBJECT IDENTIFIER ::= { unisIfQos2 11 }
--
-- nodes of unisQoSTraStaConfigGroup
--
        unisQoSTraStaConfigGroup OBJECT IDENTIFIER ::= { unisQoSTraStaObjects 1 }

        unisQoSIfTraStaConfigInfoTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisQoSIfTraStaConfigInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of traffic statistics configuration information."
            ::= { unisQoSTraStaConfigGroup 1 }

        unisQoSIfTraStaConfigInfoEntry OBJECT-TYPE
            SYNTAX UnisQoSIfTraStaConfigInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "An entry of interface traffic statistics configuration information."
            INDEX { ifIndex, unisQoSIfTraStaConfigDirection }
            ::= { unisQoSIfTraStaConfigInfoTable 1 }

        UnisQoSIfTraStaConfigInfoEntry ::=
            SEQUENCE
            {
                unisQoSIfTraStaConfigDirection
                    Direction,
                unisQoSIfTraStaConfigQueue
                    OCTET STRING,
                unisQoSIfTraStaConfigDot1p
                    OCTET STRING,
                unisQoSIfTraStaConfigDscp
                    OCTET STRING,
                unisQoSIfTraStaConfigVlan
                    OCTET STRING,
                unisQoSIfTraStaConfigStatus
                    RowStatus
            }

        unisQoSIfTraStaConfigDirection OBJECT-TYPE
            SYNTAX Direction
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION "The direction of the traffic statistics."
            ::= { unisQoSIfTraStaConfigInfoEntry 1 }

        unisQoSIfTraStaConfigQueue OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (1))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION "The bitmap of Queue ID.
                        The octet specifies queues 0 through 7.  If a bit has
                        a value of '1', the corresponding queue is configured
                        in the set of Queues; if a bit has a value of '0',
                        the corresponding queue is not configured."
            ::= { unisQoSIfTraStaConfigInfoEntry 2 }

        unisQoSIfTraStaConfigDot1p OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (1))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION "The bitmap of Dot1p value.
                        The octet specifies Dot1p values 0 through 7.  If a bit
                        has a value of '1', the corresponding Dot1p value is
                        configured in the set of Dot1p values; if a bit has a
                        value of '0', the corresponding Dot1p value is not
                        configured."
            ::= { unisQoSIfTraStaConfigInfoEntry 3 }

        unisQoSIfTraStaConfigDscp OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (8))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION "The bitmap of Dscp value.
                        Each octet within this value specifies a set of
                        eight Dscp values, with the first octet specifying
                        Dscp values 0 through 7, the second octet specifying
                        Dscp values 8 through 15, etc.  If a bit has a value
                        of '1', the corresponding Dscp value is configured
                        in the set of Dscp values; if a bit has a value of
                        '0', the corresponding Dscp value is not configured."
            ::= { unisQoSIfTraStaConfigInfoEntry 4 }

        unisQoSIfTraStaConfigVlan OBJECT-TYPE
            SYNTAX OCTET STRING (SIZE (512))
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION "The bitmap of VLAN ID.
                        Each octet within this value specifies a set of
                        eight VLANs, with the first octet specifying
                        VLANs 0 through 7, the second octet specifying VLANs
                        8 through 15, etc.  If a bit has a value of '1', the
                        corresponding VLAN is configured in the set of VLANs;
                        if a bit has a value of '0', the corresponding VLAN
                        is not configured."
            ::= { unisQoSIfTraStaConfigInfoEntry 5 }

        unisQoSIfTraStaConfigStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION "The row status of this table entry."
            ::= { unisQoSIfTraStaConfigInfoEntry 6 }


--
-- nodes of unisQoSTraStaRunGroup
--
        unisQoSTraStaRunGroup OBJECT IDENTIFIER ::= { unisQoSTraStaObjects 2 }

        unisQoSIfTraStaRunInfoTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisQoSIfTraStaRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of traffic statistics running information."
            ::= { unisQoSTraStaRunGroup 1 }

        unisQoSIfTraStaRunInfoEntry OBJECT-TYPE
            SYNTAX UnisQoSIfTraStaRunInfoEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "An entry of interface traffic statistics running information."
            INDEX { ifIndex,
                    unisQoSIfTraStaRunObjectType,
                    unisQoSIfTraStaRunObjectValue,
                    unisQoSIfTraStaRunDirection }
            ::= { unisQoSIfTraStaRunInfoTable 1 }

        UnisQoSIfTraStaRunInfoEntry ::=
            SEQUENCE
            {
                unisQoSIfTraStaRunObjectType
                    INTEGER,
                unisQoSIfTraStaRunObjectValue
                    Integer32,
                unisQoSIfTraStaRunDirection
                    Direction,
                unisQoSIfTraStaRunPassPackets
                    Counter64,
                unisQoSIfTraStaRunDropPackets
                    Counter64,
                unisQoSIfTraStaRunPassBytes
                    Counter64,
                unisQoSIfTraStaRunDropBytes
                    Counter64,
                unisQoSIfTraStaRunPassPPS
                    Counter64,
                unisQoSIfTraStaRunPassBPS
                    Counter64
            }

        unisQoSIfTraStaRunObjectType OBJECT-TYPE
            SYNTAX INTEGER
            {
                queue(1),
                dot1p(2),
                dscp(3),
                vlanID(4)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Type of statistics object."
            ::= { unisQoSIfTraStaRunInfoEntry 1 }

        unisQoSIfTraStaRunObjectValue OBJECT-TYPE
            SYNTAX Integer32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Value range for the object type:
                 for Queue: 0~7
                 for Dot1p: 0~7
                 for Dscp: 0~63
                 for VlanID: 1~4094
                 "
            ::= { unisQoSIfTraStaRunInfoEntry 2 }

        unisQoSIfTraStaRunDirection OBJECT-TYPE
            SYNTAX Direction
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The direction of the traffic statistics."
            ::= { unisQoSIfTraStaRunInfoEntry 3 }

        unisQoSIfTraStaRunPassPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Number of passed packets."
            ::= { unisQoSIfTraStaRunInfoEntry 4 }

        unisQoSIfTraStaRunDropPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Number of dropped packets."
            ::= { unisQoSIfTraStaRunInfoEntry 5 }

        unisQoSIfTraStaRunPassBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Number of passed bytes."
            ::= { unisQoSIfTraStaRunInfoEntry 6 }

        unisQoSIfTraStaRunDropBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "Number of dropped bytes."
            ::= { unisQoSIfTraStaRunInfoEntry 7 }

        unisQoSIfTraStaRunPassPPS OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "PPS (packets per second) of passed packets."
            ::= { unisQoSIfTraStaRunInfoEntry 8 }

        unisQoSIfTraStaRunPassBPS OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "BPS (bytes per second) of passed packets."
            ::= { unisQoSIfTraStaRunInfoEntry 9 }

