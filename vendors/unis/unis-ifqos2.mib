--
        unisIfQoSWredGroupTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSWredGroupEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of WRED group information."
            ::= { unisIfQoSWredGroupGroup 2 }

        unisIfQoSWredGroupEntry OBJECT-TYPE
            SYNTAX UnisIfQoSWredGroupEntry
