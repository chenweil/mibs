                 protocol will be remarked to the configured value.
                "
            ::= { unisQoSGlobalPriorityObject 5 }

        unisQoSRemarkProtocolPriEntry OBJECT-TYPE
            SYNTAX UnisQoSRemarkProtocolPriEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Remarking layer 3 protocol priority information entry."
            INDEX { unisQoSRemarkProtocolValue }
            ::= { unisQoSRemarkProtocolPriTable 1 }

        UnisQoSRemarkProtocolPriEntry ::=
            SEQUENCE
            {
                unisQoSRemarkProtocolValue
                    INTEGER,
                unisQoSRemarkProtocolDot1p
                    Unsigned32,
                unisQoSRemarkProtocolRowStatus
                    RowStatus
            }

        unisQoSRemarkProtocolValue OBJECT-TYPE
            SYNTAX INTEGER
            {
                ip(1),
                ipx(2),
                arp(3),
                appletalk(4),
                sna(5),
                netbeui(6)
            }
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Layer 3 protocol type."
            ::= { unisQoSRemarkProtocolPriEntry 1 }

        unisQoSRemarkProtocolDot1p OBJECT-TYPE
            SYNTAX Unsigned32 (0..7|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Dot1p value."
            ::= { unisQoSRemarkProtocolPriEntry 2 }

        unisQoSRemarkProtocolRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Row status."
            ::= { unisQoSRemarkProtocolPriEntry 3 }

--unisQoSRemarkVlanPriTable

        unisQoSRemarkVlanPriTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisQoSRemarkVlanPriEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of remarking VLAN priority information.
                 The priority field of all packets of the specified
                 VLAN will be remarked to the configured value.
                "
            ::= { unisQoSGlobalPriorityObject 6 }

        unisQoSRemarkVlanPriEntry OBJECT-TYPE
            SYNTAX UnisQoSRemarkVlanPriEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Remarking VLAN priority information entry."
            INDEX { unisQoSRemarkVlanStart }
            ::= { unisQoSRemarkVlanPriTable 1 }

        UnisQoSRemarkVlanPriEntry ::=
            SEQUENCE
            {
                unisQoSRemarkVlanStart
                    Integer32,
                unisQoSRemarkVlanEnd
                    Integer32,
                unisQoSRemarkVlanDot1p
                    Unsigned32,
                unisQoSRemarkVlanDscp
                    Unsigned32,
                unisQoSRemarkVlanRowStatus
                    RowStatus
            }

        unisQoSRemarkVlanStart OBJECT-TYPE
            SYNTAX Integer32 (1..4094)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Start VLAN ID."
            ::= { unisQoSRemarkVlanPriEntry 1 }

        unisQoSRemarkVlanEnd OBJECT-TYPE
            SYNTAX Integer32 (1..4094)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "End VLAN ID.  It cannot be less than start value."
            ::= { unisQoSRemarkVlanPriEntry 2 }

        unisQoSRemarkVlanDot1p OBJECT-TYPE
            SYNTAX Unsigned32 (0..7|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Dot1p value."
            ::= { unisQoSRemarkVlanPriEntry 3 }

        unisQoSRemarkVlanDscp OBJECT-TYPE
            SYNTAX Unsigned32 (0..63|255)
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "DSCP value."
            ::= { unisQoSRemarkVlanPriEntry 4 }

        unisQoSRemarkVlanRowStatus OBJECT-TYPE
            SYNTAX RowStatus
            MAX-ACCESS read-create
            STATUS current
            DESCRIPTION
                "Row status."
            ::= { unisQoSRemarkVlanPriEntry 5 }

--Type of service node
        unisQoSTypeOfServiceObjects OBJECT IDENTIFIER
            ::= { unisQoSGlobalPriorityObject 7 }

        unisQoSTypeOfServiceMode OBJECT-TYPE
            SYNTAX INTEGER
            {
                disabled(1),
                ipPrecedence(2),
                dscp(3)
            }
            MAX-ACCESS read-write
            STATUS current
            DESCRIPTION
                "Global type of service.
                 The type of service is disabled by default.
                 When in ip-precedence mode, device uses ip-precedence value to
                 determine the 802.1p priority of the packet and its outbound queue.
                 When in DSCP mode, device uses DSCP value to determine
                 the 802.1p priority of the packet and its outbound queue.
                "
            DEFVAL { disabled }
            ::= { unisQoSTypeOfServiceObjects 1 }

--
-- nodes of unisIfQoSProcessingStatusObjects
--
        unisIfQoSProcessingStatusObjects OBJECT IDENTIFIER ::= { unisIfQos2 13 }

-- System status when processing

        unisIfQoSProcessingStatus OBJECT-TYPE
            SYNTAX INTEGER
            {
                idle(1),
                busy(2)
            }
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "This object shows the current running status of the IFQoS module.
                'busy' means a task is being executed in the IFQoS module.  It is
                highly recommended not setting or reading IFQoS MIB objects in this state.
                otherwise, an operation failure might occur.
                'idle' means no task is being executed in the IFQoS module.  In this
                state, operations on IFQoS MIB objects will be accepted and executed
                immediately."

            ::= { unisIfQoSProcessingStatusObjects 1 }

--
-- nodes of unisIfQoSCoppObjects
--
        unisIfQoSCoppObjects OBJECT IDENTIFIER ::= { unisIfQos2 14 }

        unisIfQoSCoppFlowStatTable OBJECT-TYPE
            SYNTAX SEQUENCE OF UnisIfQoSCoppFlowStatEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "A table of display the copp flow stat."
            ::= { unisIfQoSCoppObjects 1 }

        unisIfQoSCoppFlowStatEntry OBJECT-TYPE
            SYNTAX UnisIfQoSCoppFlowStatEntry
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "Display the copp flow stat entry."
            INDEX { unisIfQoSCoppFlowStatChassis, unisIfQoSCoppFlowStatSlot, unisIfQoSCoppFlowStatProType}
            ::= { unisIfQoSCoppFlowStatTable 1 }

    UnisIfQoSCoppFlowStatEntry ::=
            SEQUENCE
            {
                unisIfQoSCoppFlowStatChassis
                    Unsigned32,
                unisIfQoSCoppFlowStatSlot
                    Unsigned32,
                unisIfQoSCoppFlowStatProType
                    Unsigned32,
                unisIfQoSCoppFlowPassPackets
                    Counter64,
                unisIfQoSCoppFlowPassBytes
                    Counter64,
                unisIfQoSCoppFlowDropPackets
                    Counter64,
                unisIfQoSCoppFlowDropBytes
                    Counter64
            }

    unisIfQoSCoppFlowStatChassis OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The Chassis number."
            ::= { unisIfQoSCoppFlowStatEntry 1 }

    unisIfQoSCoppFlowStatSlot OBJECT-TYPE
            SYNTAX Unsigned32
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The slot number."
            ::= { unisIfQoSCoppFlowStatEntry 2 }

    unisIfQoSCoppFlowStatProType OBJECT-TYPE
            SYNTAX Unsigned32 (1..65)
            MAX-ACCESS not-accessible
            STATUS current
            DESCRIPTION
                "The protocol type."
            ::= { unisIfQoSCoppFlowStatEntry 3 }

    unisIfQoSCoppFlowPassPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of passed packets."
            ::= { unisIfQoSCoppFlowStatEntry 4 }

    unisIfQoSCoppFlowPassBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of passed bytes."
            ::= { unisIfQoSCoppFlowStatEntry 5 }

    unisIfQoSCoppFlowDropPackets OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of dropped packets."
            ::= { unisIfQoSCoppFlowStatEntry 6 }

    unisIfQoSCoppFlowDropBytes OBJECT-TYPE
            SYNTAX Counter64
            MAX-ACCESS read-only
            STATUS current
            DESCRIPTION
                "The number of dropped bytes."
            ::= { unisIfQoSCoppFlowStatEntry 7 }

END
