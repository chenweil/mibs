    unisIPsecGlobalStatsV2 OBJECT IDENTIFIER ::= { unisIPsecObjectsV2 6 }

    unisIPsecGlobalActiveTunnelsV2 OBJECT-TYPE
        SYNTAX Gauge32
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of currently active IPsec Phase-2 Tunnels."
