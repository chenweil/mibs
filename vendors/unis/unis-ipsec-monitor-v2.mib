-- ===============================================
-- Begin the table of unisIPsecSaV2Table.
-- ===============================================

    unisIPsecSaV2Table OBJECT-TYPE
        SYNTAX SEQUENCE OF UnisIPsecSaV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "The IPsec Phase-2 Security Protection Index Table.  This table
             contains an entry for each active and expiring security association."
        ::= { unisIPsecObjectsV2 4 }

    unisIPsecSaV2Entry OBJECT-TYPE
        SYNTAX UnisIPsecSaV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "Information about unisIPsecSaV2Table."
        INDEX { unisIPsecTunIndexV2,unisIPsecSaIndexV2 }
        ::= { unisIPsecSaV2Table 1 }

    UnisIPsecSaV2Entry ::=
        SEQUENCE {
            unisIPsecSaIndexV2
                Integer32,
            unisIPsecSaDirectionV2
                INTEGER,
            unisIPsecSaSpiValueV2
                Unsigned32,
            unisIPsecSaSecProtocolV2
                UnisIPsecSaProtocolV2,
            unisIPsecSaEncryptAlgoV2
                UnisIPsecEncryptAlgoV2,
            unisIPsecSaAuthAlgoV2
                UnisIPsecAuthAlgoV2,
            unisIPsecSaStatusV2
                INTEGER
        }

    unisIPsecSaIndexV2 OBJECT-TYPE
        SYNTAX Integer32 (1..2147483647)
        MAX-ACCESS accessible-for-notify
        STATUS current
        DESCRIPTION
            "The number of the Sa associated with the Phase-2 Tunnel
             Table.  The value of this index is a number which begins
             at one and is incremented with each Sa associated with
             an IPsec Phase-2 Tunnel.  The value of this object will
             wrap at 2,147,483,647."
        ::= { unisIPsecSaV2Entry 1 }

    unisIPsecSaDirectionV2 OBJECT-TYPE
        SYNTAX INTEGER {
            in(1),
            out(2)
        }
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The direction of the SA."
        ::= { unisIPsecSaV2Entry 2 }

    unisIPsecSaSpiValueV2 OBJECT-TYPE
        SYNTAX Unsigned32 (1..4294967295)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The value of the SPI."
        ::= { unisIPsecSaV2Entry 3 }

    unisIPsecSaSecProtocolV2 OBJECT-TYPE
        SYNTAX UnisIPsecSaProtocolV2
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The security protocol of the SA."
        ::= { unisIPsecSaV2Entry 4 }

    unisIPsecSaEncryptAlgoV2 OBJECT-TYPE
        SYNTAX UnisIPsecEncryptAlgoV2
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The encryption algorithm used by the security association
             of the IPsec Phase-2 Tunnel."
        ::= { unisIPsecSaV2Entry 5 }

    unisIPsecSaAuthAlgoV2 OBJECT-TYPE
        SYNTAX UnisIPsecAuthAlgoV2
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The authentication algorithm used by the SA."
        ::= { unisIPsecSaV2Entry 6 }

    unisIPsecSaStatusV2 OBJECT-TYPE
        SYNTAX INTEGER {
            active(1),
            expiring(2)
        }
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The status of the SA."
        ::= { unisIPsecSaV2Entry 7 }

-- ===============================================
-- Begin the table of unisIPsecTrafficV2Table.
-- ===============================================

    unisIPsecTrafficV2Table OBJECT-TYPE
        SYNTAX SEQUENCE OF UnisIPsecTrafficV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "The IPsec Phase-2 Tunnel Traffic Table."
        ::= { unisIPsecObjectsV2 5 }

    unisIPsecTrafficV2Entry OBJECT-TYPE
        SYNTAX UnisIPsecTrafficV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "Information about unisIPsecTrafficV2Table."
        INDEX { unisIPsecTunIndexV2 }
        ::= { unisIPsecTrafficV2Table 1 }

    UnisIPsecTrafficV2Entry ::=
        SEQUENCE {
            unisIPsecTrafficLocalTypeV2
                UnisIPsecTrafficTypeV2,
            unisIPsecTrafficLocalAddr1TypeV2
                InetAddressType,
            unisIPsecTrafficLocalAddr1V2
                InetAddress,
            unisIPsecTrafficLocalAddr2TypeV2
                InetAddressType,
            unisIPsecTrafficLocalAddr2V2
                InetAddress,
            unisIPsecTrafficLocalProtocol1V2
                Integer32,
            unisIPsecTrafficLocalProtocol2V2
                Integer32,
            unisIPsecTrafficLocalPort1V2
                Integer32,
            unisIPsecTrafficLocalPort2V2
                Integer32,
            unisIPsecTrafficRemoteTypeV2
                UnisIPsecTrafficTypeV2,
            unisIPsecTrafficRemAddr1TypeV2
                InetAddressType,
            unisIPsecTrafficRemAddr1V2
                InetAddress,
            unisIPsecTrafficRemAddr2TypeV2
                InetAddressType,
            unisIPsecTrafficRemAddr2V2
                InetAddress,
            unisIPsecTrafficRemoPro1V2
                Integer32,
            unisIPsecTrafficRemoPro2V2
                Integer32,
            unisIPsecTrafficRemPort1V2
                Integer32,
            unisIPsecTrafficRemPort2V2
                Integer32
    }

    unisIPsecTrafficLocalTypeV2 OBJECT-TYPE
        SYNTAX UnisIPsecTrafficTypeV2
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the local peer's traffic.  Possible values are:
            1) A single IP address
            2) An IP address range
            3) An IP subnet"
        ::= { unisIPsecTrafficV2Entry 1 }

    unisIPsecTrafficLocalAddr1TypeV2 OBJECT-TYPE
        SYNTAX InetAddressType
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the first IP address specification for the local peer's
             traffic."
        ::= { unisIPsecTrafficV2Entry 2 }

    unisIPsecTrafficLocalAddr1V2 OBJECT-TYPE
        SYNTAX InetAddress
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first IP address specification of the local peer's traffic.

            If the local peer's traffic type is single IP address, this is the
            IP address.

            If the local peer's traffic type is IP subnet, this is the subnet address.

            If the local peer's traffic type is IP address range, this is the
            beginning IP address of the range."
        ::= { unisIPsecTrafficV2Entry 3 }

    unisIPsecTrafficLocalAddr2TypeV2 OBJECT-TYPE
        SYNTAX InetAddressType
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the second IP address specification for the local peer's
             traffic."
        ::= { unisIPsecTrafficV2Entry 4 }

    unisIPsecTrafficLocalAddr2V2 OBJECT-TYPE
        SYNTAX InetAddress
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The second IP address specification of the local peer's traffic.

            If the local peer's traffic type is single IP address, this is the
            IP address.

            If the local peer's traffic type is IP subnet, this is the subnet mask.

            If the local peer's traffic type is IP address range, this is the
            ending IP address of the range."
        ::= { unisIPsecTrafficV2Entry 5 }

    unisIPsecTrafficLocalProtocol1V2 OBJECT-TYPE
        SYNTAX Integer32 (0..255)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first protocol number specification of the local peer's traffic.

            If the protocol type of the local peer's traffic is single protocol,
            this is the protocol number.

            If the protocol type of the local peer's traffic is protocol range,
            this is the beginning protocol number of the range."
        ::= { unisIPsecTrafficV2Entry 6 }

    unisIPsecTrafficLocalProtocol2V2 OBJECT-TYPE
        SYNTAX Integer32 (0..255)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The second protocol number specification of the local peer's traffic.

            If the protocol type of the local peer's traffic is single protocol,
            this is the protocol number.

            If the protocol type of the local peer's traffic is protocol range,
            this is the ending protocol number of the range."
        ::= { unisIPsecTrafficV2Entry 7 }

    unisIPsecTrafficLocalPort1V2 OBJECT-TYPE
        SYNTAX Integer32 (0..65535)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first port number specification of the local peer's traffic.

            If the port type of the local peer's traffic is single port, this is
            the port number.

            If the port type of the local peer's traffic is port range, this is
            the beginning port number of the range."
        ::= { unisIPsecTrafficV2Entry 8 }

    unisIPsecTrafficLocalPort2V2 OBJECT-TYPE
        SYNTAX Integer32 (0..65535)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The second port number specification of the local peer's traffic.

            If the port type of the local peer's traffic is single port, this is
            the port number.

            If the port type of the local peer's traffic is port range, this is
            the ending port number of the range."
        ::= { unisIPsecTrafficV2Entry 9 }

    unisIPsecTrafficRemoteTypeV2 OBJECT-TYPE
        SYNTAX UnisIPsecTrafficTypeV2
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the remote peer's traffic.  Possible values are:
            1) A single IP address
            2) An IP address range
            3) An IP subnet"
        ::= { unisIPsecTrafficV2Entry 10 }

    unisIPsecTrafficRemAddr1TypeV2 OBJECT-TYPE
        SYNTAX InetAddressType
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the first IP address specification for the remote peer's
             traffic."
        ::= { unisIPsecTrafficV2Entry 11 }

    unisIPsecTrafficRemAddr1V2 OBJECT-TYPE
        SYNTAX InetAddress
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first IP address specification of the remote peer's traffic.

            If the remote traffic type is single IP address, this is the IP address.

            If the remote traffic type is IP subnet, this is the subnet address.

            If the remote traffic type is IP address range, this is the beginning
            IP address of the range."
        ::= { unisIPsecTrafficV2Entry 12 }

    unisIPsecTrafficRemAddr2TypeV2 OBJECT-TYPE
        SYNTAX InetAddressType
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The type of the second IP address specification for the remote peer's
             traffic."
        ::= { unisIPsecTrafficV2Entry 13 }

    unisIPsecTrafficRemAddr2V2 OBJECT-TYPE
        SYNTAX InetAddress
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The second IP address specification of the remote peer's traffic.

            If the remote traffic type is single IP address, this is the IP address.

            If the remote traffic type is IP subnet, this is the subnet mask.

            If the remote traffic type is IP address range, this is the ending IP
            address of the range."
        ::= { unisIPsecTrafficV2Entry 14 }

    unisIPsecTrafficRemoPro1V2 OBJECT-TYPE
        SYNTAX Integer32 (0..255)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first protocol number specification of the remote peer's traffic.

            If the protocol type of the remote peer's traffic is single protocol,
            this is the protocol number.

            If the protocol type of the remote peer's traffic is protocol range,
            this is the beginning protocol number of the range."
        ::= { unisIPsecTrafficV2Entry 15 }

    unisIPsecTrafficRemoPro2V2 OBJECT-TYPE
        SYNTAX Integer32 (0..255)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The second protocol number specification of the remote peer's traffic.

            If the protocol type of the remote peer's traffic is single protocol,
            this is the protocol number.

            If the protocol type of the remote peer's traffic is protocol range,
            this is the ending protocol number of the range."
        ::= { unisIPsecTrafficV2Entry 16 }

    unisIPsecTrafficRemPort1V2 OBJECT-TYPE
        SYNTAX Integer32 (0..65535)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The first port number specification of the remote peer's traffic.

            If the port type of the remote peer's traffic is single port,
            this is the port number.

            If the port type of the remote peer's traffic is port range,
            this is the beginning port number of the range."
        ::= { unisIPsecTrafficV2Entry 17 }

    unisIPsecTrafficRemPort2V2 OBJECT-TYPE
        SYNTAX Integer32 (0..65535)
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
