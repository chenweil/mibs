            "Indicates whether unisIPsecAuthFailFailureV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 5 }

    unisIPsecEncryFailureTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecEncryFailFailureV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 6 }

    unisIPsecDecryFailureTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecDecryFailFailureV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 7 }

    unisIPsecInvalidSaTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecInvalidSaFailureV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 8 }

    unisIPsecPolicyAddTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecPolicyAddV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 9 }

    unisIPsecPolicyDelTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecPolicyDelV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 10 }

    unisIPsecPolicyAttachTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecPolicyAttachV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 11 }

    unisIPsecPolicyDetachTrapCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecPolicyDetachV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 12 }

    unisIPsecConnectionStartCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecConnectionStartV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 13 }

    unisIPsecConnectionStopCntlV2 OBJECT-TYPE
        SYNTAX TruthValue
        MAX-ACCESS read-write
        STATUS current
        DESCRIPTION
            "Indicates whether unisIPsecConnectionStopV2 traps should be generated."
        ::= { unisIPsecTrapCntlV2 14 }

-- ===============================================
-- definition of traps.
-- ===============================================

    unisIPsecTrapV2 OBJECT IDENTIFIER ::= { unisIPsecObjectsV2 9 }

    unisIPsecNotificationsV2 OBJECT IDENTIFIER ::= { unisIPsecTrapV2 0 }

    unisIPsecTunnelStartV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2,
                    unisIPsecTunLifeTimeV2,
                    unisIPsecTunLifeSizeV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec Phase-2
             Tunnel is created."
        ::= { unisIPsecNotificationsV2 1 }

    unisIPsecTunnelStopV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2,
                    unisIPsecTunActiveTimeV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec Phase-2
             Tunnel is deleted."
        ::= { unisIPsecNotificationsV2 2 }

    unisIPsecNoSaFailureV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec Phase-2
             non-existent SA error occurs."
        ::= { unisIPsecNotificationsV2 3 }

    unisIPsecAuthFailFailureV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2
                  }
        STATUS     current
        DESCRIPTION
            "This notification is generated when the IPsec phase-2
             authentication failure occurs."
        ::= { unisIPsecNotificationsV2 4 }

    unisIPsecEncryFailFailureV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when the IPsec phase-2
             tunnel has an encrypting failure."
        ::= { unisIPsecNotificationsV2 5 }

    unisIPsecDecryFailFailureV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when the IPsec phase-2
             tunnel has a decrypting failure."
        ::= { unisIPsecNotificationsV2 6 }

    unisIPsecInvalidSaFailureV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecTunIndexV2,
                    unisIPsecSaIndexV2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2,
                    unisIPsecSaSpiValueV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when the IPsec phase-2
             invalid SA failure occurs."
        ::= { unisIPsecNotificationsV2 7 }

    unisIPsecPolicyAddV2 NOTIFICATION-TYPE
        OBJECTS { unisIPsecPolicyNameV2,
                  unisIPsecPolicySeqNumV2,
                  unisIPsecPolicySizeV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec policy is added."
        ::= { unisIPsecNotificationsV2 8 }

    unisIPsecPolicyDelV2 NOTIFICATION-TYPE
        OBJECTS { unisIPsecPolicyNameV2,
                  unisIPsecPolicySeqNumV2,
                  unisIPsecPolicySizeV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec policy is deleted."
        ::= { unisIPsecNotificationsV2 9 }

    unisIPsecPolicyAttachV2 NOTIFICATION-TYPE
        OBJECTS { unisIPsecPolicyNameV2,
                  unisIPsecPolicySizeV2,
                  ifIndex
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec policy is attached
             with one interface."
        ::= { unisIPsecNotificationsV2 10 }

    unisIPsecPolicyDetachV2 NOTIFICATION-TYPE
        OBJECTS { unisIPsecPolicyNameV2,
                  unisIPsecPolicySizeV2,
                  ifIndex
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec policy is detached
             with one interface."
        ::= { unisIPsecNotificationsV2 11 }

    unisIPsecConnectionStartV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecPolicyDescripV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec connection
             is created."
        ::= { unisIPsecNotificationsV2 12 }

    unisIPsecConnectionStopV2 NOTIFICATION-TYPE
        OBJECTS {
                    unisIPsecPolicyDescripV2
                }
        STATUS     current
        DESCRIPTION
            "This notification is generated when an IPsec connection
             is terminated."
        ::= { unisIPsecNotificationsV2 13 }

-- ===============================================
-- Begin the table of unisIPsecTunnelStatByDescripV2Table.
-- ===============================================

    unisIPsecTunnelStatByDescripV2Table OBJECT-TYPE
        SYNTAX SEQUENCE OF UnisIPsecTunnelStatByDescripV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "This table contains IPsec phase-2 tunnel statistics by description."
        ::= { unisIPsecObjectsV2 10 }

    unisIPsecTunnelStatByDescripV2Entry OBJECT-TYPE
        SYNTAX UnisIPsecTunnelStatByDescripV2Entry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "An entry of IPsec phase-2 tunnels statistics by description table."
        INDEX { unisIPsecPolicyDescripV2 }
        ::= { unisIPsecTunnelStatByDescripV2Table 1 }

    UnisIPsecTunnelStatByDescripV2Entry ::=
        SEQUENCE {
            unisIPsecPolicyDescripV2
                OCTET STRING,
            unisIPsecTunInOctetsByDescripV2
                Counter64,
            unisIPsecTunInDecompOctetsByDescripV2
                Counter64,
            unisIPsecTunInPktsByDescripV2
                Counter64,
            unisIPsecTunInDropPktsByDescripV2
                Counter64,
            unisIPsecTunInReplayDropPktsByDescripV2
                Counter64,
            unisIPsecTunInAuthFailsByDescripV2
                Counter64,
            unisIPsecTunInDecryptFailsByDescripV2
                Counter64,
            unisIPsecTunOutOctetsByDescripV2
                Counter64,
            unisIPsecTunOutUncompOctetsByDescripV2
                Counter64,
            unisIPsecTunOutPktsByDescripV2
                Counter64,
            unisIPsecTunOutDropPktsByDescripV2
                Counter64,
            unisIPsecTunOutEncryptFailsByDescripV2
                Counter64,
            unisIPsecTunNoMemoryDropPktsByDescripV2
                Counter64,
            unisIPsecTunQueueFullDropPktsByDescripV2
                Counter64,
            unisIPsecTunInvalidLenDropPktsByDescripV2
                Counter64,
            unisIPsecTunTooLongDropPktsByDescripV2
                Counter64,
            unisIPsecTunInvalidSaDropPktsByDescripV2
                Counter64
        }

    unisIPsecPolicyDescripV2 OBJECT-TYPE
        SYNTAX OCTET STRING (SIZE(1..80))
        MAX-ACCESS accessible-for-notify
        STATUS current
        DESCRIPTION
            "The IPsec policy's description."
        ::= { unisIPsecTunnelStatByDescripV2Entry 1 }

    unisIPsecTunInOctetsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of octets received by IPsec phase-2 tunnels.
             This value is accumulated BEFORE determining whether or not the
             packet should be decompressed."
        ::= { unisIPsecTunnelStatByDescripV2Entry 2 }

    unisIPsecTunInDecompOctetsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of decompressed octets received by IPsec
             phase-2 tunnels.  This value is accumulated AFTER the packet
             is decompressed."
        ::= { unisIPsecTunnelStatByDescripV2Entry 3 }

    unisIPsecTunInPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets received by IPsec phase-2 tunnels."
        ::= { unisIPsecTunnelStatByDescripV2Entry 4 }

    unisIPsecTunInDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels during receiving process."
        ::= { unisIPsecTunnelStatByDescripV2Entry 5 }

    unisIPsecTunInReplayDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of receive  packets dropped by IPsec phase-2 tunnels
            due to Anti-Replay processing."
        ::= { unisIPsecTunnelStatByDescripV2Entry 6 }

    unisIPsecTunInAuthFailsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of inbound authentication
             failures on IPsec phase-2 tunnels."
        ::= { unisIPsecTunnelStatByDescripV2Entry 7 }

    unisIPsecTunInDecryptFailsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of inbound decryption
             failures on IPsec phase-2 tunnels."
        ::= { unisIPsecTunnelStatByDescripV2Entry 8 }

    unisIPsecTunOutOctetsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of octets sent by IPsec phase-2 tunnels.
             This value is accumulated AFTER determining whether or not
             the packet should be compressed."
        ::= { unisIPsecTunnelStatByDescripV2Entry 9 }

    unisIPsecTunOutUncompOctetsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of uncompressed octets sent by IPsec phase-2
             tunnels.  This value is accumulated BEFORE the packet is compressed."
        ::= { unisIPsecTunnelStatByDescripV2Entry 10 }

    unisIPsecTunOutPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets sent by IPsec phase-2 tunnels."
        ::= { unisIPsecTunnelStatByDescripV2Entry 11 }

    unisIPsecTunOutDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels during sending process."
        ::= { unisIPsecTunnelStatByDescripV2Entry 12 }

    unisIPsecTunOutEncryptFailsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of outbound encryption failures
             on IPsec Phase-2 Tunnels."
        ::= { unisIPsecTunnelStatByDescripV2Entry 13 }

    unisIPsecTunNoMemoryDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels due to no enough memory."
        ::= { unisIPsecTunnelStatByDescripV2Entry 14 }

    unisIPsecTunQueueFullDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by
             IPsec phase-2 tunnels due to queue full."
        ::= { unisIPsecTunnelStatByDescripV2Entry 15 }

    unisIPsecTunInvalidLenDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels due to invalid length packet."
        ::= { unisIPsecTunnelStatByDescripV2Entry 16 }

    unisIPsecTunTooLongDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels due to packet."
        ::= { unisIPsecTunnelStatByDescripV2Entry 17 }

    unisIPsecTunInvalidSaDropPktsByDescripV2 OBJECT-TYPE
        SYNTAX Counter64
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "The total number of packets dropped by IPsec phase-2 tunnels due to invalid SA."
        ::= { unisIPsecTunnelStatByDescripV2Entry 18 }

-- ===============================================
-- Conformance Information
-- ===============================================
    unisIPsecConformanceV2   OBJECT IDENTIFIER
        ::= { unisIPsecMonitorV2 2 }
    unisIPsecCompliancesV2   OBJECT IDENTIFIER
        ::= { unisIPsecConformanceV2 1 }
    unisIPsecGroupsV2        OBJECT IDENTIFIER
        ::= { unisIPsecConformanceV2 2 }

-- ===============================================
-- Compliance Statements
-- ===============================================
    unisIPsecComplianceV2 MODULE-COMPLIANCE
        STATUS current
        DESCRIPTION
            " "
        MODULE -- this module
        MANDATORY-GROUPS
            {
                unisIPsecScalarObjectsGroupV2,
                unisIPsecTunnelTableGroupV2,
                unisIPsecTunnelStatGroupV2,
                unisIPsecSaGroupV2,
                unisIPsecTrafficTableGroupV2,
                unisIPsecGlobalStatsGroupV2,
                unisIPsecTrapObjectGroupV2,
                unisIPsecTrapCntlGroupV2,
                unisIPsecTrapGroupV2
            }
        ::= { unisIPsecCompliancesV2 1 }

    unisIPsecScalarObjectsGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecMIBVersion
                }
        STATUS current
        DESCRIPTION
            "The group contains all of scalar objects of the MIB."
        ::= { unisIPsecGroupsV2 1 }

    unisIPsecTunnelTableGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecTunIfIndexV2,
                    unisIPsecTunIKETunnelIndexV2,
                    unisIPsecTunIKETunLocalIDTypeV2,
                    unisIPsecTunIKETunLocalIDVal1V2,
                    unisIPsecTunIKETunLocalIDVal2V2,
                    unisIPsecTunIKETunRemoteIDTypeV2,
                    unisIPsecTunIKETunRemoteIDVal1V2,
                    unisIPsecTunIKETunRemoteIDVal2V2,
                    unisIPsecTunLocalAddrTypeV2,
                    unisIPsecTunLocalAddrV2,
                    unisIPsecTunRemoteAddrTypeV2,
                    unisIPsecTunRemoteAddrV2,
                    unisIPsecTunKeyTypeV2,
                    unisIPsecTunEncapModeV2,
                    unisIPsecTunInitiatorV2,
                    unisIPsecTunLifeSizeV2,
                    unisIPsecTunLifeTimeV2,
                    unisIPsecTunRemainTimeV2,
                    unisIPsecTunActiveTimeV2,
                    unisIPsecTunRemainSizeV2,
                    unisIPsecTunTotalRefreshesV2,
                    unisIPsecTunCurrentSaInstancesV2,
                    unisIPsecTunInSaEncryptAlgoV2,
                    unisIPsecTunInSaAhAuthAlgoV2,
                    unisIPsecTunInSaEspAuthAlgoV2,
                    unisIPsecTunDiffHellmanGrpV2,
                    unisIPsecTunOutSaEncryptAlgoV2,
                    unisIPsecTunOutSaAhAuthAlgoV2,
                    unisIPsecTunOutSaEspAuthAlgoV2,
                    unisIPsecTunPolicyNameV2,
                    unisIPsecTunPolicyNumV2,
                    unisIPsecTunStatusV2,
                    unisIPsecTunPolicyDescriptionV2
                }
        STATUS current
        DESCRIPTION
            "The group contains the IPsec tunnel's property information."
        ::= { unisIPsecGroupsV2 2 }

    unisIPsecTunnelStatGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecTunInOctetsV2,
                    unisIPsecTunInDecompOctetsV2,
                    unisIPsecTunInPktsV2,
                    unisIPsecTunInDropPktsV2,
                    unisIPsecTunInReplayDropPktsV2,
                    unisIPsecTunInAuthFailsV2,
                    unisIPsecTunInDecryptFailsV2,
                    unisIPsecTunOutOctetsV2,
                    unisIPsecTunOutUncompOctetsV2,
                    unisIPsecTunOutPktsV2,
                    unisIPsecTunOutDropPktsV2,
                    unisIPsecTunOutEncryptFailsV2,
                    unisIPsecTunNoMemoryDropPktsV2,
                    unisIPsecTunQueueFullDropPktsV2,
                    unisIPsecTunInvalidLenDropPktsV2,
                    unisIPsecTunTooLongDropPktsV2,
                    unisIPsecTunInvalidSaDropPktsV2
                }
        STATUS current
        DESCRIPTION
            "The group contains the IPsec tunnel's statistic information."
        ::= { unisIPsecGroupsV2 3 }

    unisIPsecSaGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecSaDirectionV2,
                    unisIPsecSaSpiValueV2,
                    unisIPsecSaSecProtocolV2,
                    unisIPsecSaEncryptAlgoV2,
                    unisIPsecSaAuthAlgoV2,
                    unisIPsecSaStatusV2
                }
        STATUS current
        DESCRIPTION
            "The group contains the SA's property information."
        ::= { unisIPsecGroupsV2 4 }

    unisIPsecTrafficTableGroupV2 OBJECT-GROUP
        OBJECTS {
            unisIPsecTrafficLocalTypeV2,
            unisIPsecTrafficLocalAddr1TypeV2,
            unisIPsecTrafficLocalAddr1V2,
            unisIPsecTrafficLocalAddr2TypeV2,
            unisIPsecTrafficLocalAddr2V2,
            unisIPsecTrafficLocalProtocol1V2,
            unisIPsecTrafficLocalProtocol2V2,
            unisIPsecTrafficLocalPort1V2,
            unisIPsecTrafficLocalPort2V2,
            unisIPsecTrafficRemoteTypeV2,
            unisIPsecTrafficRemAddr1TypeV2,
            unisIPsecTrafficRemAddr1V2,
            unisIPsecTrafficRemAddr2TypeV2,
            unisIPsecTrafficRemAddr2V2,
            unisIPsecTrafficRemoPro1V2,
            unisIPsecTrafficRemoPro2V2,
            unisIPsecTrafficRemPort1V2,
            unisIPsecTrafficRemPort2V2
        }
        STATUS current
        DESCRIPTION
            "The group contains the property information of the
             data flow protected by IPsec tunnel."
        ::= { unisIPsecGroupsV2 5 }

    unisIPsecGlobalStatsGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecGlobalActiveTunnelsV2,
                    unisIPsecGlobalActiveSasV2,
                    unisIPsecGlobalInOctetsV2,
                    unisIPsecGlobalInDecompOctetsV2,
                    unisIPsecGlobalInPktsV2,
                    unisIPsecGlobalInDropsV2,
                    unisIPsecGlobalInReplayDropsV2,
                    unisIPsecGlobalInAuthFailsV2,
                    unisIPsecGlobalInDecryptFailsV2,
                    unisIPsecGlobalOutOctetsV2,
                    unisIPsecGlobalOutUncompOctetsV2,
                    unisIPsecGlobalOutPktsV2,
                    unisIPsecGlobalOutDropsV2,
                    unisIPsecGlobalOutEncryptFailsV2,
                    unisIPsecGlobalNoMemoryDropsV2,
                    unisIPsecGlobalNoFindSaDropsV2,
                    unisIPsecGlobalQueueFullDropsV2,
                    unisIPsecGlobalInvalidLenDropsV2,
                    unisIPsecGlobalTooLongDropsV2,
                    unisIPsecGlobalInvalidSaDropsV2
                }
        STATUS current
        DESCRIPTION
            "The group contains all of the IPsec tunnel's statistic
             information."
        ::= { unisIPsecGroupsV2 6 }

    unisIPsecTrapObjectGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecPolicyNameV2,
                    unisIPsecPolicySeqNumV2,
                    unisIPsecPolicySizeV2
                }
        STATUS current
        DESCRIPTION
            "The group contains all of trap objects of IPsec tunnels."
        ::= { unisIPsecGroupsV2 7 }

    unisIPsecTrapCntlGroupV2 OBJECT-GROUP
        OBJECTS {
                    unisIPsecTrapGlobalCntlV2,
                    unisIPsecTunnelStartTrapCntlV2,
                    unisIPsecTunnelStopTrapCntlV2,
                    unisIPsecNoSaTrapCntlV2,
                    unisIPsecAuthFailureTrapCntlV2,
                    unisIPsecEncryFailureTrapCntlV2,
                    unisIPsecDecryFailureTrapCntlV2,
                    unisIPsecInvalidSaTrapCntlV2,
                    unisIPsecPolicyAddTrapCntlV2,
                    unisIPsecPolicyDelTrapCntlV2,
                    unisIPsecPolicyAttachTrapCntlV2,
                    unisIPsecPolicyDetachTrapCntlV2
                }
        STATUS current
        DESCRIPTION
            "The group contains all of trap switches of IPsec tunnels."
        ::= { unisIPsecGroupsV2 8 }

    unisIPsecTrapGroupV2 NOTIFICATION-GROUP
        NOTIFICATIONS {
                          unisIPsecTunnelStartV2,
                          unisIPsecTunnelStopV2,
                          unisIPsecNoSaFailureV2,
                          unisIPsecAuthFailFailureV2,
                          unisIPsecEncryFailFailureV2,
                          unisIPsecDecryFailFailureV2,
                          unisIPsecInvalidSaFailureV2,
                          unisIPsecPolicyAddV2,
                          unisIPsecPolicyDelV2,
                          unisIPsecPolicyAttachV2,
                          unisIPsecPolicyDetachV2,
                          unisIPsecConnectionStartV2,
                          unisIPsecConnectionStopV2
                      }
        STATUS current
        DESCRIPTION
            "The group contains all of trap of IPsec tunnels."
        ::= { unisIPsecGroupsV2 9 }


END

