        unisWIPSSigRule2PolicyRowStatus
            RowStatus,
        unisWIPSSigRule2PolicyPrecedence
            Unsigned32
     }

unisWIPSSigRule2PolicySigRuleIDCfg OBJECT-TYPE
    SYNTAX Unsigned32 (1..64)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the ID of signature rule attached to signature policy."
    ::= { unisWIPSSigRule2PolicyEntry 1 }

unisWIPSSigRule2PolicyRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSSigRule2PolicyEntry 2 }

unisWIPSSigRule2PolicyPrecedence OBJECT-TYPE
    SYNTAX Unsigned32 (1..64)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of signature rule attached to signature policy."
    DEFVAL { 1 }
    ::= { unisWIPSSigRule2PolicyEntry 3 }

unisWIPSSigRuleTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSSigRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the signature rules.
        "
    ::= { unisWIPSSigConfigGroup 3 }

unisWIPSSigRuleEntry OBJECT-TYPE
    SYNTAX UnisWIPSSigRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each signature rules."
    INDEX { unisWIPSSigRuleName }
    ::= { unisWIPSSigRuleTable 1 }

UnisWIPSSigRuleEntry ::=
    SEQUENCE {
        unisWIPSSigRuleName
            OCTET STRING,
        unisWIPSSigRuleID
            Integer32,
        unisWIPSSigRuleRowStatus
            RowStatus,
        unisWIPSSigSubRuleMatchAll
            TruthValue,
        unisWIPSSigRuleDctPeriod
            Unsigned32,
        unisWIPSSigRuleTrackMethod
            INTEGER,
        unisWIPSSigRuleDctThresholdPerMAC
            Unsigned32,
        unisWIPSSigRuleDctThresholdPerSig
            Unsigned32,
        unisWIPSSigRuleActionEvtLevel
            Unsigned32,
        unisWIPSSigRuleQuietTime
            Unsigned32,
        unisWIPSSigSubRuleFrameType
            INTEGER,
        unisWIPSSigSubRuleFrameSubType
            INTEGER,
        unisWIPSSigSubRuleMac
            OCTET STRING,
        unisWIPSSigSubRuleMacType
            INTEGER,
        unisWIPSSigSubRuleSeqNumMin
            Unsigned32,
        unisWIPSSigSubRuleSeqNumMax
            Unsigned32,
        unisWIPSSigSubRuleSSIDLenMin
            Unsigned32,
        unisWIPSSigSubRuleSSIDLenMax
            Unsigned32,
        unisWIPSSigSubRuleSSID
            OCTET STRING,
        unisWIPSSigSubRuleSSIDOpe
            INTEGER,
        unisWIPSSigSubRuleSSIDCase
            TruthValue
     }

unisWIPSSigRuleName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of signature rule."
    ::= { unisWIPSSigRuleEntry 1 }

unisWIPSSigRuleID OBJECT-TYPE
    SYNTAX Integer32 (1..64)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the ID of signature rule.
        The values from 1 to 32 are for built-in rules, which can not
        be assigned to user-define rules.
        When a user-define signature rule is being created, if ID is not specified,
        the ID of the rule will be automatically assigned, which values from 33 to 64.
        Once the rule is created, the ID is fixed and can not be changed again."
    ::= { unisWIPSSigRuleEntry 2 }

unisWIPSSigRuleRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSSigRuleEntry 3 }

unisWIPSSigSubRuleMatchAll OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents whether match all the sub rules
        which have been configured in the signature rule.
        The default value for user-define rule is false,
        and for built-in rule is true."
    ::= { unisWIPSSigRuleEntry 4 }

unisWIPSSigRuleDctPeriod OBJECT-TYPE
    SYNTAX Unsigned32
    UNITS "second"
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the detect period of signature rule.
         Available value limits from 1 to 3600.
         The default value depends on the certain rule.
         For user-define rules it is 60.
         The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 5 }

unisWIPSSigRuleTrackMethod OBJECT-TYPE
    SYNTAX INTEGER
        {
        perSig(1),
        perMAC(2),
        both(3)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the track-method for the signature rule.
         The default value depends on the certain rule.
         For user-define rules it is 'both(3)'."
    ::= { unisWIPSSigRuleEntry 6 }

unisWIPSSigRuleDctThresholdPerMAC OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the detect threshold for per-MAC track-method.
         Available value limits from 1 to 32000.
         The default value depends on the certain rule.
         For user-define rules it is 1000.
         The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 7 }

unisWIPSSigRuleDctThresholdPerSig OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the detect threshold for per-Signature track-method.
         Available value limits from 1 to 32000.
         The default value depends on the certain rule.
         For user-define rules it is 1000.
         The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 8 }

unisWIPSSigRuleActionEvtLevel OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the level of event sended for the action of reporting event alarm.
         Available value limits from 0 to 7.
         The default value depends on the certain rule.
         For user-define rules it is 0xffffffff."
    ::= { unisWIPSSigRuleEntry 9 }

unisWIPSSigRuleQuietTime OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting event alarm.
         Available value limits from 60 to 32000.
         The default value depends on the certain rule.
         For user-define rules it is 900.
         The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 10 }

unisWIPSSigSubRuleFrameType OBJECT-TYPE
    SYNTAX INTEGER
        {
        manage(0),
        control(1),
        data(2),
        undo(3)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the type of frame to match.
        0x0 management type
        0x1 control type
        0x2 data type
        The default value depends on the certain rule.
        For user-define rules it is 'undo(3)'."
    ::= { unisWIPSSigRuleEntry 11 }

unisWIPSSigSubRuleFrameSubType OBJECT-TYPE
    SYNTAX INTEGER
        {
        none(0),
        assocReq(1),
        assocRes(2),
        probeReq(3),
        beacon(4),
        disasso(5),
        auth(6),
        deauth(7)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the sub-type of frame to match.
        1 association request
        2 association response
        3 probe request
        4 beacon
        5 disassoc
        6 authentication
        7 de-authentication
        The default value depends on the certain rule.
        For user-define rules it is 'none(0)'."
    ::= { unisWIPSSigRuleEntry 12 }

unisWIPSSigSubRuleMac OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..12))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the MAC address or BSSID to match."
    ::= { unisWIPSSigRuleEntry 13 }

unisWIPSSigSubRuleMacType OBJECT-TYPE
    SYNTAX INTEGER
        {
        source(0),
        dest(1),
        bssid(2)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the type of MAC address or BSSID to match.
         0 Source MAC address in the 802.11 frame header
         1 Destination MAC address in the 802.11 frame header
         2 BSSID field in the 802.11 frame header"
    ::= { unisWIPSSigRuleEntry 14 }

unisWIPSSigSubRuleSeqNumMin OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the minimun value of sequence number of packet to match.
         Available value limits from 0 to 4094.
         The default value depends on the certain rule.
         For user-define rules it is 0xffffffff.
         The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 15 }

unisWIPSSigSubRuleSeqNumMax OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the maximum value of sequence number of packet to match.
        Available value limits from 1 to 4095.
        The default value depends on the certain rule.
        For user-define rules it is 0xffffffff.
        The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 16 }

unisWIPSSigSubRuleSSIDLenMin OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the minimun value of SSID of packet to match.
        Available value limits from 0 to 31.
        The default value depends on the certain rule.
        For user-define rules it is 0xffffffff.
        The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 17 }

unisWIPSSigSubRuleSSIDLenMax OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the maximum value of SSID of packet to match.
        Available value limits from 1 to 32.
        The default value depends on the certain rule.
        For user-define rules it is 0xffffffff.
        The value 0xffffffff represents restoring default value operation."
    ::= { unisWIPSSigRuleEntry 18 }

unisWIPSSigSubRuleSSID OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the string of SSID of packet to match."
    ::= { unisWIPSSigRuleEntry 19 }

unisWIPSSigSubRuleSSIDOpe OBJECT-TYPE
    SYNTAX INTEGER
        {
        include(1),
        notinclude(2),
        equal(3),
        notequal(4)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the compare way of the SSID in the sub rule,
        including include/not include/equal/not equal."
    ::= { unisWIPSSigRuleEntry 20 }

unisWIPSSigSubRuleSSIDCase OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the case sensitive or not for the SSID match.
        'true': Case insensitive.
        'false': Case sensitive."
    DEFVAL { false }
    ::= { unisWIPSSigRuleEntry 21 }

unisWIPSSigSubRulePatternTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSSigSubRulePatternEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the signature sub rules
        which define the user-define match way through pattern of packet.
        "
    ::= { unisWIPSSigConfigGroup 4 }

unisWIPSSigSubRulePatternEntry OBJECT-TYPE
    SYNTAX UnisWIPSSigSubRulePatternEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each pattern signature sub rules."
    INDEX { unisWIPSSigRuleName, unisWIPSSigSubRulePatternID }
    ::= { unisWIPSSigSubRulePatternTable 1 }

UnisWIPSSigSubRulePatternEntry ::=
    SEQUENCE {
        unisWIPSSigSubRulePatternID
            Unsigned32,
        unisWIPSSigSubRuleRowStatus
            RowStatus,
        unisWIPSSigSubRulePatternName
            OCTET STRING,
        unisWIPSSigSubRulePatternOffset
            Integer32,
        unisWIPSSigSubRulePatternMask
            Integer32,
        unisWIPSSigSubRulePatternValueMin
            Unsigned32,
        unisWIPSSigSubRulePatternValueMax
            Unsigned32,
        unisWIPSSigSubRulePatternFromPayload
            TruthValue
     }

unisWIPSSigSubRulePatternID OBJECT-TYPE
    SYNTAX Unsigned32 (1..27)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the ID of the pattern sub rule."
    ::= { unisWIPSSigSubRulePatternEntry 1 }

unisWIPSSigSubRuleRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSSigSubRulePatternEntry 2 }

unisWIPSSigSubRulePatternName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE(0..32))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the name of the pattern sub rule."
    ::= { unisWIPSSigSubRulePatternEntry 3 }

unisWIPSSigSubRulePatternOffset OBJECT-TYPE
    SYNTAX Integer32 (0..2346)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the offset value of packet match."
    ::= { unisWIPSSigSubRulePatternEntry 4 }

unisWIPSSigSubRulePatternMask OBJECT-TYPE
    SYNTAX Integer32 (0..65535)
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the mask value of packet match."
    ::= { unisWIPSSigSubRulePatternEntry 5 }

unisWIPSSigSubRulePatternValueMin OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the minimun value of match byte.
         Available value limits from 0 to 65534."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSSigSubRulePatternEntry 6 }

unisWIPSSigSubRulePatternValueMax OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the maximun value of match byte.
         Available value limits from 1 to 65535."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSSigSubRulePatternEntry 7 }

unisWIPSSigSubRulePatternFromPayload OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether match start from the payload of the data frame."
    DEFVAL { false }
    ::= { unisWIPSSigSubRulePatternEntry 8 }

unisWIPSCtmConfigGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 11 }

unisWIPSCtmPolicyCfgSupportSet OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (16))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the bit string of supported countermeasure policy.
        The specific countermeasure policy is supported if its corresponding
        bit is set to 1; otherwise its corresponding bit is set to 0.
        bit3:  misconfigured AP
        bit4:  rogue AP
        bit5:  unauthorized station
        bit6:  external AP
        bit9:  misassociation station
        bit10: potential authorized AP
        bit11: potential rogue AP
        bit12: potential external AP
        bit13: uncategorized AP
        bit14: uncategorized station
        "
    ::= { unisWIPSCtmConfigGroup 1 }

unisWIPSCtmPolicyTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSCtmPolicyEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the parameters for WIPS countermeasure policy.
        One policy could be assigned to different VSDs.
        "
    ::= { unisWIPSCtmConfigGroup 2 }

unisWIPSCtmPolicyEntry OBJECT-TYPE
    SYNTAX UnisWIPSCtmPolicyEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each countermeasure policy."
    INDEX { unisWIPSCtmPolicyName }
    ::= { unisWIPSCtmPolicyTable 1 }

UnisWIPSCtmPolicyEntry ::=
    SEQUENCE {
        unisWIPSCtmPolicyName
            OCTET STRING,
        unisWIPSCtmPolicyCfgRowStatus
            RowStatus,
        unisWIPSCtmPolicyBitString
            OCTET STRING,
        unisWIPSCtmPolicyFixedChl
            TruthValue,
        unisWIPSCtmPolicyRogueAPPre
            Unsigned32,
        unisWIPSCtmPolicyPtRogueAPPre
            Unsigned32,
        unisWIPSCtmPolicyMisconfAPPre
            Unsigned32,
        unisWIPSCtmPolicyExternalAPPre
            Unsigned32,
        unisWIPSCtmPolicyPtExternalAPPre
            Unsigned32,
        unisWIPSCtmPolicyUncateAPPre
            Unsigned32,
        unisWIPSCtmPolicyPtAuthAPPre
            Unsigned32,
        unisWIPSCtmPolicyMisassoStaPre
            Unsigned32,
        unisWIPSCtmPolicyUncateStaPre
            Unsigned32,
        unisWIPSCtmPolicyUnauthStaPre
            Unsigned32
     }

unisWIPSCtmPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of countermeasure policy."
    ::= { unisWIPSCtmPolicyEntry 1 }

unisWIPSCtmPolicyCfgRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSCtmPolicyEntry 2 }

unisWIPSCtmPolicyBitString OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (16))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the bit string of countermeasure policy configuration.
        The specific countermeasure of device is enabled if its corresponding
        bit is set to 1; disabled if its corresponding bit is set to 0.
        bit3:  misconfigured AP
        bit4:  rogue AP
        bit5:  unauthorized station
        bit6:  external AP
        bit9:  misassociation station
        bit10: potential authorized AP
        bit11: potential rogue AP
        bit12: potential external AP
        bit13: uncategorized AP
        bit14: uncategorized station"
    ::= { unisWIPSCtmPolicyEntry 3 }

unisWIPSCtmPolicyFixedChl OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents whether enable fixed channel scan function."
    DEFVAL { false }
    ::= { unisWIPSCtmPolicyEntry 4 }

unisWIPSCtmPolicyRogueAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure for rogue AP.
         Available value limits from 0 to 9.
         Value 0xffffffff represents undo operation."
    DEFVAL { 9 }
    ::= { unisWIPSCtmPolicyEntry 5 }

unisWIPSCtmPolicyPtRogueAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for potential rogue AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 7 }
    ::= { unisWIPSCtmPolicyEntry 6 }

unisWIPSCtmPolicyMisconfAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for misconfigured AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 3 }
    ::= { unisWIPSCtmPolicyEntry 7 }

unisWIPSCtmPolicyExternalAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for external AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 1 }
    ::= { unisWIPSCtmPolicyEntry 8 }

unisWIPSCtmPolicyPtExternalAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for potential external AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 2 }
    ::= { unisWIPSCtmPolicyEntry 9 }

unisWIPSCtmPolicyUncateAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for uncategorized AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 5 }
    ::= { unisWIPSCtmPolicyEntry 10 }

unisWIPSCtmPolicyPtAuthAPPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for potential authorized AP.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 0 }
    ::= { unisWIPSCtmPolicyEntry 11 }

unisWIPSCtmPolicyMisassoStaPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for misassociated station.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 6 }
    ::= { unisWIPSCtmPolicyEntry 12 }

unisWIPSCtmPolicyUncateStaPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for uncategorized station.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 4 }
    ::= { unisWIPSCtmPolicyEntry 13 }

unisWIPSCtmPolicyUnauthStaPre OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of countermeasure
        for unauthorized station.
        Available value limits from 0 to 9.
        Value 0xffffffff represents undo operation."
    DEFVAL { 8 }
    ::= { unisWIPSCtmPolicyEntry 14 }

unisWIPSCtmPolicyDevListTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSCtmPolicyDevListEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the MAC address list of countermeasure device
        in WIPS countermeasure policy. "
    ::= { unisWIPSCtmConfigGroup 3 }

unisWIPSCtmPolicyDevListEntry OBJECT-TYPE
    SYNTAX UnisWIPSCtmPolicyDevListEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each MAC address of device."
    INDEX { unisWIPSCtmPolicyName,  unisWIPSCtmPolicyDevMAC }
    ::= { unisWIPSCtmPolicyDevListTable 1 }

UnisWIPSCtmPolicyDevListEntry ::=
    SEQUENCE {
        unisWIPSCtmPolicyDevMAC
            MacAddress,
        unisWIPSCtmPolicyDevRowStatus
            RowStatus
     }

unisWIPSCtmPolicyDevMAC OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address of countermeasure device."
    ::= { unisWIPSCtmPolicyDevListEntry 1 }

unisWIPSCtmPolicyDevRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSCtmPolicyDevListEntry 2 }

unisWIPSMalPktDctConfigGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 12 }

unisWIPSMalPktDctCfgLogSupportSet OBJECT-TYPE
    SYNTAX OCTET STRING  (SIZE (32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the bit string of supported malformed packet detect policy
        controlling the log function.
        The specific malformed packet detect policy is supported if its corresponding
        bit is set to 1; otherwise its corresponding bit is set to 0.
        bit0:  invalid IE length
        bit1:  duplicated IE
        bit2:  redundant IE
        bit3:  invalid packet length
        bit4:  illegal IBSS and ESS
        bit5:  invalid source address
        bit6:  overflow EAPOL key length
        bit7:  malformed authetication
        bit8:  malformed association request
        bit9:  malformed HT-IE
        bit10: large duration
        bit11: null probe response
        bit12: invalid deauthentication reason code
        bit13: invalid disassociation reason code
        bit14: overflow SSID length
        bit15: fata-jack
        bit17: invalid-channel"
    ::= { unisWIPSMalPktDctConfigGroup 1 }

unisWIPSMalPktDctCfgTrapSupportSet OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the bit string of supported malformed packet detect policy
        controlling the trap function.
        The specific malformed packet detect policy is supported if its corresponding
        bit is set to 1; otherwise its corresponding bit is set to 0.
        bit0:  invalid IE length
        bit1:  duplicated IE
        bit2:  redundant IE
        bit3:  invalid packet length
        bit4:  illegal IBSS and ESS
        bit5:  invalid source address
        bit6:  overflow EAPOL key length
        bit7:  malformed authetication
        bit8:  malformed association request
        bit9:  malformed HT-IE
        bit10: large duration
        bit11: null probe response
        bit12: invalid deauthentication reason code
        bit13: invalid disassociation reason code
        bit14: overflow SSID length
        bit15: fata-jack
        bit17: invalid-channel"
    ::= { unisWIPSMalPktDctConfigGroup 2 }

unisWIPSMalPktDctPolicyTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSMalPktDctPolicyEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents."
    ::= { unisWIPSMalPktDctConfigGroup 3 }

unisWIPSMalPktDctPolicyEntry OBJECT-TYPE
    SYNTAX UnisWIPSMalPktDctPolicyEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents."
    INDEX { unisWIPSMalPktDctPolicyName }
    ::= { unisWIPSMalPktDctPolicyTable 1 }

UnisWIPSMalPktDctPolicyEntry ::=
    SEQUENCE {
        unisWIPSMalPktDctPolicyName
            OCTET STRING,
        unisWIPSMalPktDctPolicyCfgRowStatus
            RowStatus,
        unisWIPSMalPktDctPolicyLogBitString
            OCTET STRING,
        unisWIPSMalPktDctPolicyTrapBitString
            OCTET STRING,
        unisWIPSMalPktDctPolicyDurationThreshold
            Integer32,
        unisWIPSMalPktDctPolicyQuietTime
            Integer32
     }

unisWIPSMalPktDctPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of malformed packet detect policy."
    ::= { unisWIPSMalPktDctPolicyEntry 1 }

unisWIPSMalPktDctPolicyCfgRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSMalPktDctPolicyEntry 2 }

unisWIPSMalPktDctPolicyLogBitString OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the bit string of malformed packet detect policy
        controlling the log function configuration.
        The specific malformed packet detect is enbled if its corresponding
        bit is set to 1; disabled its corresponding bit is set to 0.
        bit0:  invalid IE length
        bit1:  duplicated IE
        bit2:  redundant IE
        bit3:  invalid packet length
        bit4:  illegal IBSS and ESS
        bit5:  invalid source address
        bit6:  overflow EAPOL key length
        bit7:  malformed authetication
        bit8:  malformed association request
        bit9:  malformed HT-IE
        bit10: large duration
        bit11: null probe response
        bit12: invalid deauthentication reason code
        bit13: invalid disassociation reason code
        bit14: overflow SSID length
        bit15: fata-jack
        bit17: invalid-channel"
    ::= { unisWIPSMalPktDctPolicyEntry 3 }

unisWIPSMalPktDctPolicyTrapBitString OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the bit string of malformed packet detect policy
        controlling the trap function configuration.
        The specific malformed packet detect is enbled if its corresponding
        bit is set to 1; disabled its corresponding bit is set to 0.
        bit0:  invalid IE length
        bit1:  duplicated IE
        bit2:  redundant IE
        bit3:  invalid packet length
        bit4:  illegal IBSS and ESS
        bit5:  invalid source address
        bit6:  overflow EAPOL key length
        bit7:  malformed authetication
        bit8:  malformed association request
        bit9:  malformed HT-IE
        bit10: large duration
        bit11: null probe response
        bit12: invalid deauthentication reason code
        bit13: invalid disassociation reason code
        bit14: overflow SSID length
        bit15: fata-jack
        bit17: invalid-channel"
    ::= { unisWIPSMalPktDctPolicyEntry 4 }

unisWIPSMalPktDctPolicyDurationThreshold OBJECT-TYPE
    SYNTAX Integer32 (1..32767)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the threshold of duration
        for large duration malformed packet detection."
    DEFVAL {5000}
    ::= { unisWIPSMalPktDctPolicyEntry 5 }

unisWIPSMalPktDctPolicyQuietTime OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSMalPktDctPolicyEntry 6 }

unisWIPSStaticTrustOUIListCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSStaticTrustOUIListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the OUI list
        of devices in the static trust list.
        WIPS will take the devices in the list as authorized devices."
    ::= { unisWIPSConfigGroup 13 }

unisWIPSStaticTrustOUIListCfgEntry OBJECT-TYPE
    SYNTAX UnisWIPSStaticTrustOUIListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each OUI
        in the static trust list.
        "
    INDEX { unisWIPSStaticTrustOUIListOUI }
    ::= { unisWIPSStaticTrustOUIListCfgTable 1 }

UnisWIPSStaticTrustOUIListCfgEntry ::=
    SEQUENCE {
        unisWIPSStaticTrustOUIListOUI
            OCTET STRING,
        unisWIPSStaticTrustOUIListRowStatus
            RowStatus
     }

unisWIPSStaticTrustOUIListOUI OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (3))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the OUI in static trust list."
    ::= { unisWIPSStaticTrustOUIListCfgEntry 1 }

unisWIPSStaticTrustOUIListRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSStaticTrustOUIListCfgEntry 2 }

unisWIPSStaticTrustVendorListCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSStaticTrustVendorListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the vendor list
        of devices in the static trust list.
        WIPS will take the devices in the list as authorized devices."
    ::= { unisWIPSConfigGroup 14 }

unisWIPSStaticTrustVendorListCfgEntry OBJECT-TYPE
    SYNTAX UnisWIPSStaticTrustVendorListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each vendor
        in the static trust list.
        "
    INDEX { unisWIPSStaticTrustVendorListVendor }
    ::= { unisWIPSStaticTrustVendorListCfgTable 1 }

UnisWIPSStaticTrustVendorListCfgEntry ::=
    SEQUENCE {
        unisWIPSStaticTrustVendorListVendor
            OCTET STRING,
        unisWIPSStaticTrustVendorListRowStatus
            RowStatus
     }

unisWIPSStaticTrustVendorListVendor OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the vendor in static trust list."
    ::= { unisWIPSStaticTrustVendorListCfgEntry 1 }

unisWIPSStaticTrustVendorListRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSStaticTrustVendorListCfgEntry 2 }

unisWIPSDetectGroup OBJECT IDENTIFIER ::= { unisWIPS 2 }

unisWIPSDctAPTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctAPEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of possible BSS information for
        APs detected by the WIPS."
    ::= { unisWIPSDetectGroup 1 }

unisWIPSDctAPEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctAPEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible BSS information of each AP detected
        by WIPS."
    INDEX { unisWIPSDctAPVSD, unisWIPSDctAPBSSID }
    ::= { unisWIPSDctAPTable 1 }

UnisWIPSDctAPEntry ::=
    SEQUENCE {
        unisWIPSDctAPVSD
            OCTET STRING,
        unisWIPSDctAPBSSID
            MacAddress,
        unisWIPSDctAPRunningTime
            TimeTicks,
        unisWIPSDctAPRunTmLastUpdateTm
            TimeTicks,
        unisWIPSDctAPIsCountered
            TruthValue,
        unisWIPSDctAPWorkChannel
            UnisWIPSChannel,
        unisWIPSDctAPRadioType
            UnisWIPSRadioType,
        unisWIPSDctAPAuthMethod
            UnisWIPSAuthMethod,
        unisWIPSDctAPEncryptMethod
            UnisWIPSEncryptMethod,
        unisWIPSDctAPSecurity
            UnisWIPSAPSecurityType,
        unisWIPSDctAPSeverityLevel
            Unsigned32,
        unisWIPSDctAPLastDctTm
            TimeTicks,
        unisWIPSDctAPFirstDctTm
            TimeTicks,
        unisWIPSDctAPAdd2BlackList
            TruthValue,
        unisWIPSDctAPAdd2WhiteList
            TruthValue,
        unisWIPSDctAPAdd2IgnoreList
            TruthValue,
        unisWIPSDctAPAdd2CtmList
            TruthValue,
        unisWIPSDctAPCategory
            UnisWIPSAPCategoryType,
        unisWIPSDctAPCategoryWay
            UnisWIPSDevCategoryWay,
        unisWIPSDctAPStatus
            UnisWIPSDevStatus,
        unisWIPSDctAPSSID
            OCTET STRING,
        unisWIPSDctAPAttachStaNum
            Integer32,
        unisWIPSDctAPRptSensorNum
            Integer32,
        unisWIPSDctAPVendor
            OCTET STRING
     }

unisWIPSDctAPVSD OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the virtual security domain where the BSS was detected."
    ::= { unisWIPSDctAPEntry 1 }

unisWIPSDctAPBSSID OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the Basic Service Set."
    ::= { unisWIPSDctAPEntry 2 }

unisWIPSDctAPRunningTime OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time since AP started to work, which is got from
        beacon/probe response frame."
    ::= { unisWIPSDctAPEntry 3 }

unisWIPSDctAPRunTmLastUpdateTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time update unisWIPSDctAPRunningTime since
        system is up."
    ::= { unisWIPSDctAPEntry 4 }

unisWIPSDctAPIsCountered OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents whether the detected AP is countered by WIPS."
    ::= { unisWIPSDctAPEntry 5 }

unisWIPSDctAPWorkChannel OBJECT-TYPE
    SYNTAX UnisWIPSChannel
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the radio channel which the detected AP work on."
    ::= { unisWIPSDctAPEntry 6 }

unisWIPSDctAPRadioType OBJECT-TYPE
    SYNTAX UnisWIPSRadioType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the radio type used by the detected AP."
    ::= { unisWIPSDctAPEntry 7 }

unisWIPSDctAPAuthMethod OBJECT-TYPE
    SYNTAX UnisWIPSAuthMethod
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the authentication method used by the detected AP.
        none(1)            - No key management mode configured,
        psk(2)             - pre-shared key authentication,
        dot1x(3)           - 802.1x authentication,
        other(4)           - other authentication,
        psk/dot1x(5)       - psk and dot1x authentication,
        psk/other(6)       - psk and other authentication,
        dot1x/other(7)     - dot1x and other authentication,
        psk/dot1x/other(8) - psk, dot1x and other authentication."

    ::= { unisWIPSDctAPEntry 8 }

unisWIPSDctAPEncryptMethod OBJECT-TYPE
    SYNTAX UnisWIPSEncryptMethod
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the encrypt method used by the detected AP.
        none(1)     - clear text or no cipher method is configure,
        wep(2)      - WEP key,
        tkip(4)     - WPA Temporal Key encryption,
        ccmp(8)     - WPA AES CCMP encryption"
    ::= { unisWIPSDctAPEntry 9 }

unisWIPSDctAPSecurity OBJECT-TYPE
    SYNTAX UnisWIPSAPSecurityType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the security suites of the detected AP.
        clear  0x01
        wpa2   0x02
        wpa    0x04
        wep    0x08"
    ::= { unisWIPSDctAPEntry 10 }

unisWIPSDctAPSeverityLevel OBJECT-TYPE
    SYNTAX Unsigned32 (0..100)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the severity level of the detected AP."
    ::= { unisWIPSDctAPEntry 11 }

unisWIPSDctAPLastDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that AP was detected for the last time since system
        is up."
    ::= { unisWIPSDctAPEntry 12 }

unisWIPSDctAPFirstDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that AP was detected for the first time
        since system is up."
    ::= { unisWIPSDctAPEntry 13 }

unisWIPSDctAPAdd2BlackList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the AP will be taken as a rogue AP.
        If the value is true, the MAC address will be automatically added
        into unisWIPSBlockListTable and the category of the AP will be
        taken as rogue.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSBlockListTable."
    DEFVAL { false }
    ::= { unisWIPSDctAPEntry 14 }

unisWIPSDctAPAdd2WhiteList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the AP will be taken as an authorized AP.
        If the value is true, the MAC address will be automatically added
        into unisWIPSTrustListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSTrustListTable"
    DEFVAL { false }
    ::= { unisWIPSDctAPEntry 15 }

unisWIPSDctAPAdd2IgnoreList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the AP will be taken as an ignored AP.
        If the value is true, the MAC address will be automatically added
        into unisWIPSIgnoreListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSIgnoreListTable"
    DEFVAL { false }
    ::= { unisWIPSDctAPEntry 16 }

unisWIPSDctAPAdd2CtmList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the AP will be taken as a countered AP.
        If the value is true, the MAC address will be automatically added
        into unisWIPSCountermeasureListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSCountermeasureListTable."
    DEFVAL { false }
    ::= { unisWIPSDctAPEntry 17 }

unisWIPSDctAPCategory OBJECT-TYPE
    SYNTAX UnisWIPSAPCategoryType
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the categorized result of the AP.
        For set operation, only the following values are valid:
        authorized(2),rogue(3),misconfigured(4),external(5)"
    ::= { unisWIPSDctAPEntry 18 }

unisWIPSDctAPCategoryWay OBJECT-TYPE
    SYNTAX UnisWIPSDevCategoryWay
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents by which way the AP is categorized.
        manual(1)    -categorized by user
        autoByNMS(2) -categorized by NMS(Network Management System)
        autoByDev(3) -categorized by WIPS"
    DEFVAL { autoByDev }
    ::= { unisWIPSDctAPEntry 19 }

unisWIPSDctAPStatus OBJECT-TYPE
    SYNTAX UnisWIPSDevStatus
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the status of the AP detected by WIPS."
    ::= { unisWIPSDctAPEntry 20 }

unisWIPSDctAPSSID OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the SSID broadcasted by AP."
    ::= { unisWIPSDctAPEntry 21 }

unisWIPSDctAPAttachStaNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of clients associated with the detected AP."
    ::= { unisWIPSDctAPEntry 22 }

unisWIPSDctAPRptSensorNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of sensors detecting the AP."
    ::= { unisWIPSDctAPEntry 23 }


unisWIPSDctAPVendor OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..64))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the vendor of this AP detected by WIPS."
    ::= { unisWIPSDctAPEntry 24 }

unisWIPSDctAPAttachStaTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctAPAttachStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of station associated with APs
        detected by the WIPS."
    ::= { unisWIPSDetectGroup 2 }

unisWIPSDctAPAttachStaEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctAPAttachStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible station information detected
        by WIPS."
    INDEX { unisWIPSDctAPVSD, unisWIPSDctAPBSSID, unisWIPSDctAPAttachStaMac }
    ::= { unisWIPSDctAPAttachStaTable 1 }

UnisWIPSDctAPAttachStaEntry ::=
    SEQUENCE {
        unisWIPSDctAPAttachStaMac
            MacAddress,
        unisWIPSDctAPAttachStaRowStatus
            RowStatus
     }

unisWIPSDctAPAttachStaMac OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address of station associated with AP."
    ::= { unisWIPSDctAPAttachStaEntry 1 }

unisWIPSDctAPAttachStaRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "The status of this table entry.  It is read-only and
        will return 'Not writable' for set operation."
    ::= { unisWIPSDctAPAttachStaEntry 2 }

unisWIPSDctAPRptSensorTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctAPRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of sensors."
    ::= { unisWIPSDetectGroup 3 }

unisWIPSDctAPRptSensorEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctAPRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible sensor information of WIPS."
    INDEX { unisWIPSDctAPVSD, unisWIPSDctAPBSSID, unisWIPSDctAPRptSensorName }
    ::= { unisWIPSDctAPRptSensorTable 1 }

UnisWIPSDctAPRptSensorEntry ::=
    SEQUENCE {
        unisWIPSDctAPRptSensorName
            OCTET STRING,
        unisWIPSDctAPRptSensorRadioId
            Integer32,
        unisWIPSDctAPRptRSSI
            Integer32,
        unisWIPSDctAPLastRptTm
            TimeTicks
     }

unisWIPSDctAPRptSensorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of sensor."
    ::= { unisWIPSDctAPRptSensorEntry 1 }

unisWIPSDctAPRptSensorRadioId OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents on which radio the sensor AP detected the AP."
    ::= { unisWIPSDctAPRptSensorEntry 2 }

unisWIPSDctAPRptRSSI OBJECT-TYPE
    SYNTAX Integer32 (0..90)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the current value of signal strength that WIPS sensor
        AP received from the AP."
    ::= { unisWIPSDctAPRptSensorEntry 3 }

unisWIPSDctAPLastRptTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that AP was detected by this sensor
        for the last time since system is up."
    ::= { unisWIPSDctAPRptSensorEntry 4 }

unisWIPSDctStaTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of possible information for
        stations detected by the WIPS."
    ::= { unisWIPSDetectGroup 4 }

unisWIPSDctStaEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible station information of each station
        detected by WIPS."
    INDEX { unisWIPSDctStaVSD, unisWIPSDctStaMac }
    ::= { unisWIPSDctStaTable 1 }

UnisWIPSDctStaEntry ::=
    SEQUENCE {
        unisWIPSDctStaVSD
            OCTET STRING,
        unisWIPSDctStaMac
            MacAddress,
        unisWIPSDctStaAssocBSSID
            MacAddress,
        unisWIPSDctStaStatus
            UnisWIPSDevStatus,
        unisWIPSDctStaCategory
            UnisWIPSClientCategoryType,
        unisWIPSDctStaRadioType
            UnisWIPSRadioType,
        unisWIPSDctStaWorkChannel
            UnisWIPSChannel,
        unisWIPSDctStaIsCountered
            TruthValue,
        unisWIPSDctStaAdd2BlackList
            TruthValue,
        unisWIPSDctStaAdd2WhiteList
            TruthValue,
        unisWIPSDctStaAdd2IgnoreList
            TruthValue,
        unisWIPSDctStaAdd2CtmList
            TruthValue,
        unisWIPSDctStaFirstDctTm
            TimeTicks,
        unisWIPSDctStaLastDctTm
            TimeTicks,
        unisWIPSDctStaRptSensorNum
            Integer32,
        unisWIPSDctStaState
            INTEGER,
        unisWIPSDctStaVendor
            OCTET STRING
     }

unisWIPSDctStaVSD OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the virtual security domain in which the station was detected."
    ::= { unisWIPSDctStaEntry 1 }

unisWIPSDctStaMac OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address of station."
    ::= { unisWIPSDctStaEntry 2 }

unisWIPSDctStaAssocBSSID OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the BSSID which station associates with."
    ::= { unisWIPSDctStaEntry 3 }

unisWIPSDctStaStatus OBJECT-TYPE
    SYNTAX UnisWIPSDevStatus
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the status of this station detected by WIPS."
    ::= { unisWIPSDctStaEntry 4 }

unisWIPSDctStaCategory OBJECT-TYPE
    SYNTAX UnisWIPSClientCategoryType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the categorized result of the station."
    ::= { unisWIPSDctStaEntry 5 }

unisWIPSDctStaRadioType OBJECT-TYPE
    SYNTAX UnisWIPSRadioType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the radio type used by the detected station."
    ::= { unisWIPSDctStaEntry 6 }

unisWIPSDctStaWorkChannel OBJECT-TYPE
    SYNTAX UnisWIPSChannel
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents on which radio channel that WIPS sensor AP detected
        the station."
    ::= { unisWIPSDctStaEntry 7 }

unisWIPSDctStaIsCountered OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents whether the detected station is countered by WIPS."
    ::= { unisWIPSDctStaEntry 8 }

unisWIPSDctStaAdd2BlackList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as a rogue station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSBlockListTable and the category of the station will be
        taken as rogue.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSBlockListTable."
    DEFVAL { false }
    ::= { unisWIPSDctStaEntry 9 }

unisWIPSDctStaAdd2WhiteList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as an authorized station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSTrustListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSTrustListTable."
    DEFVAL { false }
    ::= { unisWIPSDctStaEntry 10 }

unisWIPSDctStaAdd2IgnoreList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as an ignored station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSIgnoreListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSIgnoreListTable."
    DEFVAL { false }
    ::= { unisWIPSDctStaEntry 11 }

unisWIPSDctStaAdd2CtmList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as a countered station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSCountermeasureListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSCountermeasureListTable."
    DEFVAL { false }
    ::= { unisWIPSDctStaEntry 12 }

unisWIPSDctStaFirstDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that station was detected for the first time
        since system is up."
    ::= { unisWIPSDctStaEntry 13 }

unisWIPSDctStaLastDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that station was detected for the last time
        since system is up."
    ::= { unisWIPSDctStaEntry 14 }

unisWIPSDctStaRptSensorNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of sensors detecting the station."
    ::= { unisWIPSDctStaEntry 15 }

unisWIPSDctStaState OBJECT-TYPE
    SYNTAX INTEGER
    {
        authentication(1),
        association(2),
        eapSuccess(3),
        eapLogoff(4),
        disassociation(5),
        deauthentication(6),
        unassociation(7)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the authentication state of station with AP."
    ::= { unisWIPSDctStaEntry 16 }

unisWIPSDctStaVendor OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..64))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the vendor of this station detected by WIPS."
    ::= { unisWIPSDctStaEntry 17 }

unisWIPSDctStaRptSensorTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctStaRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of sensors detecting the station."
    ::= { unisWIPSDetectGroup 5 }

unisWIPSDctStaRptSensorEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctStaRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible sensor information of WIPS."
    INDEX { unisWIPSDctStaVSD, unisWIPSDctStaMac, unisWIPSDctStaRtpSensorName }
    ::= { unisWIPSDctStaRptSensorTable 1 }

UnisWIPSDctStaRptSensorEntry ::=
    SEQUENCE {
        unisWIPSDctStaRtpSensorName
            OCTET STRING,
        unisWIPSDctStaRptSensorRadioId
            Integer32,
        unisWIPSDctStaRptRSSI
            Integer32,
        unisWIPSDctStaLastRptTm
            TimeTicks
     }

unisWIPSDctStaRtpSensorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of sensor."
    ::= { unisWIPSDctStaRptSensorEntry 1 }

unisWIPSDctStaRptSensorRadioId OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents on which radio the sensor AP detected the station."
    ::= { unisWIPSDctStaRptSensorEntry 2 }

unisWIPSDctStaRptRSSI OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the current value of signal strength that WIPS sensor
        AP received from the station."
    ::= { unisWIPSDctStaRptSensorEntry 3 }

unisWIPSDctStaLastRptTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that station was detected by this sensor
        for the last time since system is up."
    ::= { unisWIPSDctStaRptSensorEntry 4 }

unisWIPSDctSSIDTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctSSIDEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of possible ESS information for
        networks detected by WIPS."
    ::= { unisWIPSDetectGroup 6 }

unisWIPSDctSSIDEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctSSIDEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible ESS information of each ESS detected
        by WIPS."
    INDEX { unisWIPSDctNetworkVSD, unisWIPSDctNetworkSSID,
            unisWIPSDctNetworkCfg }
    ::= { unisWIPSDctSSIDTable 1 }

UnisWIPSDctSSIDEntry ::=
    SEQUENCE {
        unisWIPSDctNetworkVSD
            OCTET STRING,
        unisWIPSDctNetworkSSID
            OCTET STRING,
        unisWIPSDctNetworkCfg
            Unsigned32,
        unisWIPSDctNetworkFirstRptTm
            TimeTicks,
        unisWIPSDctNetworkLastRptTm
            TimeTicks,
        unisWIPSDctNetworkStatus
            UnisWIPSDevStatus,
        unisWIPSDctNetworkSSIDHide
            TruthValue,
        unisWIPSDctNetworkBSSNum
            Integer32
     }

unisWIPSDctNetworkVSD OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the virtual security domain in which the ESS was detected."
    ::= { unisWIPSDctSSIDEntry 1 }

unisWIPSDctNetworkSSID OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the service set identifier for the ESS.
         Using the ASCII value '1' represents that the SSID is not advertised
         in the beacon frames."
    ::= { unisWIPSDctSSIDEntry 2 }

unisWIPSDctNetworkCfg OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the encrypt method, security suite and authentication method
        which are used by the detected ESS.
        The lowest 8 bits mean encrypt method.  The higher 8 bits mean security suite.
        The third 8 bits stand for authentication method.  The higerest 8 bits
        are reserved.  The meaning is shown as follows:
        31              23              15              7             0
        + + + + + + + + + + + + + + + + + + + + + + + + + + + + + + + +
        |  reserved     |  auth method  | security suite|encryptmethod|
        + + + + + + + + + + + + + + + + + + + + + + + + + + + + + + + +
        For encrypt method, the following values are supported:
        1: none     - clear text or no cipher method is configure,
        2: wep      - WEP key,
        4: tkip     - WPA Temporal Key encryption,
        8: ccmp     - WPA AES CCMP encryption
        For security suite, the following values are supported:
        0x01: clear
        0x02: wpa2
        0x04: wpa
        0x08: wep
        For authentication method, the following values are supported:
        1:  none            - No key management mode configured,
        2:  psk             - pre-shared key authentication,
        3:  dot1x           - 802.1x authentication,
        4:  other           - other authentication,
        5:  psk/dot1x       - psk and dot1x authentication,
        6:  psk/other       - psk and other authentication,
        7:  dot1x/other     - dot1x and other authentication,
        8:  psk/dot1x/other - psk, dot1x and other authentication."
    ::= { unisWIPSDctSSIDEntry 3 }

unisWIPSDctNetworkFirstRptTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that ESS was detected for the first time
        since system is up."
    ::= { unisWIPSDctSSIDEntry 4 }

unisWIPSDctNetworkLastRptTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that ESS was detected for the last time
        since system is up."
    ::= { unisWIPSDctSSIDEntry 5 }

unisWIPSDctNetworkStatus OBJECT-TYPE
    SYNTAX UnisWIPSDevStatus
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the status of this ESS detected by WIPS."
    ::= { unisWIPSDctSSIDEntry 6 }

unisWIPSDctNetworkSSIDHide OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents whether the ESS broadcasted its SSID."
    DEFVAL { false }
    ::= { unisWIPSDctSSIDEntry 7 }

unisWIPSDctNetworkBSSNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of APs using the same SSID in the ESS."
    ::= { unisWIPSDctSSIDEntry 8 }

unisWIPSDctSSIDBSSTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctSSIDBSSEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of APs using the same SSID in the ESS."
    ::= { unisWIPSDetectGroup 7 }

unisWIPSDctSSIDBSSEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctSSIDBSSEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible BSS information of each AP detected
        by WIPS."
    INDEX { unisWIPSDctNetworkVSD, unisWIPSDctNetworkSSID,
            unisWIPSDctNetworkCfg, unisWIPSDctNetworkBSSID }
    ::= { unisWIPSDctSSIDBSSTable 1 }

UnisWIPSDctSSIDBSSEntry ::=
    SEQUENCE {
        unisWIPSDctNetworkBSSID
            MacAddress,
        unisWIPSDctNetworkBSSWorkChl
            UnisWIPSChannel,
        unisWIPSDctNetworkBSSStaNum
            Integer32
     }

unisWIPSDctNetworkBSSID OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the Basic Service Set."
    ::= { unisWIPSDctSSIDBSSEntry 1 }

unisWIPSDctNetworkBSSWorkChl OBJECT-TYPE
    SYNTAX UnisWIPSChannel
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents on which radio channel that WIPS sensor AP detected
        the BSS."
    ::= { unisWIPSDctSSIDBSSEntry 2 }

unisWIPSDctNetworkBSSStaNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of clients associated with the detected BSS."
    ::= { unisWIPSDctSSIDBSSEntry 3 }

