        unisWIPSSigPolicyNameCfg
            OCTET STRING,
        unisWIPSSigPolicyRowStatus
            RowStatus
     }

unisWIPSSigPolicyNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of signature policy."
    ::= { unisWIPSSigPolicyEntry 1 }

unisWIPSSigPolicyRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSSigPolicyEntry 2 }

unisWIPSSigRule2PolicyTable OBJECT-TYPE
