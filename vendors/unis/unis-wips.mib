            RowStatus
     }

unisWIPSIgnoreListMAC OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address in ignore list."
    ::= { unisWIPSIgnoreListCfgEntry 1 }

unisWIPSIgnoreListRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSIgnoreListCfgEntry 2 }

unisWIPSDctModeTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctModeEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of AP scanning mode configuration
        on radio."
    ::= { unisWIPSConfigGroup 9 }

unisWIPSDctModeEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctModeEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of WIPS scanning mode on radio."
    INDEX { unisWIPSDctModeAPName, unisWIPSDctModeRadio }
    ::= { unisWIPSDctModeTable 1 }

UnisWIPSDctModeEntry ::=
    SEQUENCE {
        unisWIPSDctModeAPName
            OCTET STRING,
        unisWIPSDctModeRadio
            Integer32,
        unisWIPSDctModeScanMode
            INTEGER,
        unisWIPSDctModeRowStatus
            RowStatus
     }

unisWIPSDctModeAPName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of AP."
    ::= { unisWIPSDctModeEntry 1 }

unisWIPSDctModeRadio OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the radio of AP."
    ::= { unisWIPSDctModeEntry 2 }

unisWIPSDctModeScanMode OBJECT-TYPE
    SYNTAX INTEGER
        {
        accessFirst(1),
        detectFirst(2),
        middle(3),
        detectOnly(4)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the scanning mode.
        The radio enable-disable status must be disabled before
        WIPS scanning mode is configured on this radio.
        The mesh feature must be disabled before any WIPS scanning mode
        is set on radio.
        This radio can not apply any service template before
        the detectOnly scanning mode is set on the radio. "
    ::= { unisWIPSDctModeEntry 3 }

unisWIPSDctModeRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSDctModeEntry 4 }

unisWIPSSigConfigGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 10 }

unisWIPSSigPolicyTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSSigPolicyEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the parameters for WIPS signature policy.
        One policy could be assigned to different VSDs.
        "
