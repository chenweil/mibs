    ::= { unisWIPSStaticBlockListCfgTable 1 }

UnisWIPSStaticBlockListCfgEntry ::=
    SEQUENCE {
        unisWIPSStaticBlockListMAC
            MacAddress,
        unisWIPSStaticBlockListRowStatus
            RowStatus
     }

unisWIPSStaticBlockListMAC OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address in static block list."
    ::= { unisWIPSStaticBlockListCfgEntry 1 }

unisWIPSStaticBlockListRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSStaticBlockListCfgEntry 2 }

unisWIPSStaticTrustListCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSStaticTrustListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the MAC address list
        of devices in the static trust list.
        WIPS will take the devices in the list as authorized devices."
    ::= { unisWIPSConfigGroup 7 }

unisWIPSStaticTrustListCfgEntry OBJECT-TYPE
    SYNTAX UnisWIPSStaticTrustListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each MAC address
        in the static trust list.
        "
    INDEX { unisWIPSStaticTrustListMAC }
    ::= { unisWIPSStaticTrustListCfgTable 1 }

UnisWIPSStaticTrustListCfgEntry ::=
    SEQUENCE {
        unisWIPSStaticTrustListMAC
            MacAddress,
        unisWIPSStaticTrustListRowStatus
            RowStatus
     }

unisWIPSStaticTrustListMAC OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address in static trust list."
    ::= { unisWIPSStaticTrustListCfgEntry 1 }

unisWIPSStaticTrustListRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSStaticTrustListCfgEntry 2 }

unisWIPSIgnoreListCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSIgnoreListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the MAC address list of devices in the ignore list.
