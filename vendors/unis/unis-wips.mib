unisWIPSCtmDeviceTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSCtmDeviceEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of device information
        in static and dynamic countermeasure list."
    ::= { unisWIPSDetectGroup 15 }

unisWIPSCtmDeviceEntry OBJECT-TYPE
    SYNTAX UnisWIPSCtmDeviceEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of countermeasure device."
    INDEX { unisWIPSCtmDeviceVSD, unisWIPSCtmDeviceMAC }
    ::= { unisWIPSCtmDeviceTable 1 }

UnisWIPSCtmDeviceEntry ::=
    SEQUENCE {
        unisWIPSCtmDeviceVSD
            OCTET STRING,
        unisWIPSCtmDeviceMAC
            MacAddress,
        unisWIPSCtmDeviceType
            INTEGER,
        unisWIPSCtmDeviceState
            INTEGER,
        unisWIPSCtmDeviceStartTime
            TimeTicks,
        unisWIPSCtmDeviceCategory
            UnisWIPSDeviceCategoryType,
        unisWIPSCtmDeviceChl
            Unsigned32,
        unisWIPSCtmDevicePrecedence
            Integer32
     }

unisWIPSCtmDeviceVSD OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the VSD which the device belongs to."
    ::= { unisWIPSCtmDeviceEntry 1 }

unisWIPSCtmDeviceMAC OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address of countermeasure device."
    ::= { unisWIPSCtmDeviceEntry 2 }

unisWIPSCtmDeviceType OBJECT-TYPE
    SYNTAX INTEGER
        {
        static(1),
        dynamic(2),
        staticAnddynamic(3)
        }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the type of countermeasure device."
    ::= { unisWIPSCtmDeviceEntry 3 }

unisWIPSCtmDeviceState OBJECT-TYPE
    SYNTAX INTEGER
        {
        none(0),
        idle(1),
        pending(2),
        action(3)
        }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the state of countermeasure device."
    ::= { unisWIPSCtmDeviceEntry 4 }

unisWIPSCtmDeviceStartTime OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time when start to counter on the device."
    ::= { unisWIPSCtmDeviceEntry 5 }

unisWIPSCtmDeviceCategory OBJECT-TYPE
    SYNTAX UnisWIPSDeviceCategoryType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the category of the device."
    ::= { unisWIPSCtmDeviceEntry 6 }

unisWIPSCtmDeviceChl OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the channel on which the device is countered."
    ::= { unisWIPSCtmDeviceEntry 7 }

unisWIPSCtmDevicePrecedence OBJECT-TYPE
    SYNTAX Integer32 (0..10)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the precedence of the device."
    ::= { unisWIPSCtmDeviceEntry 8 }

unisWIPSMalPktStatTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSMalPktStatEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of malformed packet statistics information."
    ::= { unisWIPSDetectGroup 16 }

unisWIPSMalPktStatEntry OBJECT-TYPE
    SYNTAX UnisWIPSMalPktStatEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of malformed pakcet."
    INDEX { unisWIPSMalPktStatSensorName }
    ::= { unisWIPSMalPktStatTable 1 }

UnisWIPSMalPktStatEntry ::=
    SEQUENCE {
        unisWIPSMalPktStatSensorName
            OCTET STRING,
        unisWIPSMalPktStatInvalidIELength
            Counter64,
        unisWIPSMalPktStatDuplicatedIE
            Counter64,
        unisWIPSMalPktStatRedundantIE
            Counter64,
        unisWIPSMalPktStatInvalidPktLength
            Counter64,
        unisWIPSMalPktStatIllegalIBSSESS
            Counter64,
        unisWIPSMalPktStatInvalidSourceAddr
            Counter64,
        unisWIPSMalPktStatOverflowEAPOLKey
            Counter64,
        unisWIPSMalPktStatMalAuth
            Counter64,
        unisWIPSMalPktStatMalAssoReq
            Counter64,
        unisWIPSMalPktStatMalHTIE
            Counter64,
        unisWIPSMalPktStatLargeDuration
            Counter64,
        unisWIPSMalPktStatNULLProbeRes
            Counter64,
        unisWIPSMalPktStatInvalidDeAuthCode
            Counter64,
        unisWIPSMalPktStatInvalidDisAssoCode
            Counter64,
        unisWIPSMalPktStatOverflowSSID
            Counter64,
        unisWIPSMalPktStatFatajack
            Counter64,
        unisWIPSMalPktStatInvalidChannel
            Counter64
     }

unisWIPSMalPktStatSensorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of sensor."
    ::= { unisWIPSMalPktStatEntry 1 }

unisWIPSMalPktStatInvalidIELength OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the invalid IE length
        malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 2 }

unisWIPSMalPktStatDuplicatedIE OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the duplicated IE
        malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 3 }

unisWIPSMalPktStatRedundantIE OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the redundant IE
        malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 4 }

unisWIPSMalPktStatInvalidPktLength OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the invalide packet length
        malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 5 }

unisWIPSMalPktStatIllegalIBSSESS OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the illegal bits of
        representing IBSS and ESS malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 6 }

unisWIPSMalPktStatInvalidSourceAddr OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of  invalid source address combination
         malformed pakcets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 7 }

unisWIPSMalPktStatOverflowEAPOLKey OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the overflow EAPOL key
        malformed packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 8 }

unisWIPSMalPktStatMalAuth OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed authentication packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 9 }

unisWIPSMalPktStatMalAssoReq OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed association request packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 10 }

unisWIPSMalPktStatMalHTIE OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        High Throughput IE segment packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 11 }

unisWIPSMalPktStatLargeDuration OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        large duration packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 12 }

unisWIPSMalPktStatNULLProbeRes OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        null probe response packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 13 }

unisWIPSMalPktStatInvalidDeAuthCode OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        invalid deauthentication reason code packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 14 }

unisWIPSMalPktStatInvalidDisAssoCode OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        invalid disassociation reason code packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 15 }

unisWIPSMalPktStatOverflowSSID OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of the malformed
        SSID length overflow packets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 16}

unisWIPSMalPktStatFatajack OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of FATA-Jack attack pakcets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 17 }

unisWIPSMalPktStatInvalidChannel OBJECT-TYPE
    SYNTAX Counter64
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the count of Invalid-Channel attack pakcets."
    DEFVAL { 0 }
    ::= { unisWIPSMalPktStatEntry 18 }

unisWIPSDctUnassocStaTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctUnassocStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of possible information for
        Unassociated stations detected by the WIPS."
    ::= { unisWIPSDetectGroup 17 }

unisWIPSDctUnassocStaEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctUnassocStaEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible station information of each Unassociated
        station detected by WIPS."
    INDEX { unisWIPSDctUnassocStaVSD, unisWIPSDctUnassocStaMac }
    ::= { unisWIPSDctUnassocStaTable 1 }

UnisWIPSDctUnassocStaEntry ::=
    SEQUENCE {
        unisWIPSDctUnassocStaVSD
            OCTET STRING,
        unisWIPSDctUnassocStaMac
            MacAddress,
        unisWIPSDctUnassocStaCategory
            UnisWIPSClientCategoryType,
        unisWIPSDctUnassocStaRadioType
            Unsigned32,
        unisWIPSDctUnassocStaIsCountered
            TruthValue,
        unisWIPSDctUnassocStaAdd2BlackList
            TruthValue,
        unisWIPSDctUnassocStaAdd2WhiteList
            TruthValue,
        unisWIPSDctUnassocStaAdd2IgnoreList
            TruthValue,
        unisWIPSDctUnassocStaAdd2CtmList
            TruthValue,
        unisWIPSDctUnassocStaFirstDctTm
            TimeTicks,
        unisWIPSDctUnassocStaLastDctTm
            TimeTicks,
        unisWIPSDctUnassocStaRptSensorNum
            Integer32,
        unisWIPSDctUnassocStaState
            INTEGER,
        unisWIPSDctUnassocStaVendor
            OCTET STRING
     }

unisWIPSDctUnassocStaVSD OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the virtual security domain in which the Unassociated
        station was detected."
    ::= { unisWIPSDctUnassocStaEntry 1 }

unisWIPSDctUnassocStaMac OBJECT-TYPE
    SYNTAX MacAddress
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the MAC address of Unassociated station."
    ::= { unisWIPSDctUnassocStaEntry 2 }

unisWIPSDctUnassocStaCategory OBJECT-TYPE
    SYNTAX UnisWIPSClientCategoryType
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the categorized result of the Unassociated station."
    ::= { unisWIPSDctUnassocStaEntry 3 }

unisWIPSDctUnassocStaRadioType OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the radio type used by the Unassociated station.
        dot11a  0x01
        dot11b  0x02
        dot11g  0x04
        dot11n  0x08
        dot11gn 0x10
        dot11an 0x20
        dot11ac 0x40"
    ::= { unisWIPSDctUnassocStaEntry 4 }

unisWIPSDctUnassocStaIsCountered OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents whether the Unassociated station is countered by WIPS."
    ::= { unisWIPSDctUnassocStaEntry 5 }

unisWIPSDctUnassocStaAdd2BlackList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as a rogue station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSBlockListTable and the category of the station will be
        taken as rogue.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSBlockListTable."
    DEFVAL { false }
    ::= { unisWIPSDctUnassocStaEntry 6 }

unisWIPSDctUnassocStaAdd2WhiteList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as an authorized station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSTrustListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSTrustListTable."
    DEFVAL { false }
    ::= { unisWIPSDctUnassocStaEntry 7 }

unisWIPSDctUnassocStaAdd2IgnoreList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as an ignored station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSIgnoreListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSIgnoreListTable."
    DEFVAL { false }
    ::= { unisWIPSDctUnassocStaEntry 8 }

unisWIPSDctUnassocStaAdd2CtmList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the station will be taken as a countered station.
        If the value is true, the MAC address will be automatically added
        into unisWIPSCountermeasureListTable.
        If the value is false, the MAC address will be automatically deleted
        from unisWIPSCountermeasureListTable."
    DEFVAL { false }
    ::= { unisWIPSDctUnassocStaEntry 9 }

unisWIPSDctUnassocStaFirstDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that station was detected for the first time
        since system is up."
    ::= { unisWIPSDctUnassocStaEntry 10 }

unisWIPSDctUnassocStaLastDctTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that station was detected for the last time
        since system is up."
    ::= { unisWIPSDctUnassocStaEntry 11 }

unisWIPSDctUnassocStaRptSensorNum OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of sensors detecting the Unassociated station."
    ::= { unisWIPSDctUnassocStaEntry 12 }

unisWIPSDctUnassocStaState OBJECT-TYPE
    SYNTAX INTEGER
    {
        authentication(1),
        association(2),
        eapSuccess(3),
        eapLogoff(4),
        disassociation(5),
        deauthentication(6),
        unassociation(7)
    }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the authentication state of Unassociated station with AP."
    ::= { unisWIPSDctUnassocStaEntry 13 }

unisWIPSDctUnassocStaVendor OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..64))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the vendor of this Unassociated station detected by WIPS."
    ::= { unisWIPSDctUnassocStaEntry 14 }

unisWIPSDctUnassocStaRptSensorTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSDctUnassocStaRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of sensors detecting the Unassociated station."
    ::= { unisWIPSDetectGroup 18 }

unisWIPSDctUnassocStaRptSensorEntry OBJECT-TYPE
    SYNTAX UnisWIPSDctUnassocStaRptSensorEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains possible sensor information of WIPS."
    INDEX { unisWIPSDctUnassocStaVSD, unisWIPSDctUnassocStaMac, unisWIPSDctUnassocStaRtpSensorName }
    ::= { unisWIPSDctUnassocStaRptSensorTable 1 }

UnisWIPSDctUnassocStaRptSensorEntry ::=
    SEQUENCE {
        unisWIPSDctUnassocStaRtpSensorName
            OCTET STRING,
        unisWIPSDctUnassocStaRptSensorRadioId
            Integer32,
        unisWIPSDctUnassocStaRptRSSI
            Integer32,
        unisWIPSDctUnassocStaLastRptTm
            TimeTicks
     }

unisWIPSDctUnassocStaRtpSensorName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of sensor."
    ::= { unisWIPSDctUnassocStaRptSensorEntry 1 }

unisWIPSDctUnassocStaRptSensorRadioId OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents on which radio the sensor AP detected the Unassociated station."
    ::= { unisWIPSDctUnassocStaRptSensorEntry 2 }

unisWIPSDctUnassocStaRptRSSI OBJECT-TYPE
    SYNTAX Integer32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the current value of signal strength that WIPS sensor
        AP received from the Unassociated station."
    ::= { unisWIPSDctUnassocStaRptSensorEntry 3 }

unisWIPSDctUnassocStaLastRptTm OBJECT-TYPE
    SYNTAX TimeTicks
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the time that Unassociated station was detected by this sensor
        for the last time since system is up."
    ::= { unisWIPSDctUnassocStaRptSensorEntry 4 }

unisWIPSNotifyGroup OBJECT IDENTIFIER ::= { unisWIPS 3 }

END
