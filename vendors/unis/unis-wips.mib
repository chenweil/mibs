-- =============================================================================
-- Copyright (c) 2020 Unisyue Technologies Co., Ltd.  All rights reserved.
--
-- Description:
--   The file defines a MIB to provide wireless intrusion prevention service
--   feature.
-- Reference:
-- Version: V1.3
-- History:
--   V1.0 created by sunlongfei
--     Initial version 2012-01-09
--   V1.1 updated by sunlongfei 2012-12-7
--     Modify the descriptions of unisWIPSDctAPAdd2CtmList,
--     unisWIPSDctAPAdd2IgnoreList,unisWIPSDctAPAdd2WhiteList,
--     unisWIPSDctAPAdd2BlackListc,unisWIPSDctStaAdd2BlackList,
--     unisWIPSDctStaAdd2WhiteList,unisWIPSDctStaAdd2IgnoreList,
--     unisWIPSDctStaAdd2CtmList,unisWIPSDevStatTxProbeRequest.
--   V1.2 modified by sunlongfei 2013-6-7
--     In unisWIPSGlobalConfigGroup,
--     Modify the descriptions of unisWIPSEnable.
--     Add unisWIPSDynamicTrustListAgingTime, unisWIPSDevUpdateTime,
--     unisWIPSADOSEnable, unisWIPSAccessFlowScanEnable.
--     Modify unisWIPSVsdTable, unisWIPSAtkDctPolicyCfgGroup,
--     unisWIPSDctAPTable, unisWIPSDctStaTable.
--     Add unisWIPSSigConfigGroup, unisWIPSCtmConfigGroup,
--     unisWIPSMalPktDctConfigGroup, unisWIPSStaticTrustOUIListCfgTable
--     unisWIPSStaticTrustVendorListCfgTable,
--     unisWIPSCtmDeviceTable, unisWIPSMalPktStatTable
--     modified by sunlongfei 2013-11-21
--     Modify the size of unisWIPSSensorNameCfg, unisWIPSDctModeAPName,
--     unisWIPSDctAPRptSensorName, unisWIPSDctStaRptSensorName
--     from '1..32' to '1..64'.
--   V1.3 modified by jianing 2014-05-12
--     Add  unisWIPSDctUnassocStaTable, unisWIPSDctUnassocStaRptSensorTable.
--     Modify the descriptions of unisWIPSAtkDctPolicyCfgTable,
--     unisWIPSMalPktDctConfigGroup, unisWIPSMalPktStatTable,unisWIPSAPAuthType,
--     unisWIPSDctAPAuthMethod, unisWIPSDctAPRadioType, unisWIPSDctStaRadioType,
--     unisWIPSDctNetworkFirstRptTm.
-- =============================================================================
UNIS-WIPS-MIB DEFINITIONS ::= BEGIN

IMPORTS
    TimeTicks, Integer32, Unsigned32, OBJECT-TYPE, MODULE-IDENTITY, Counter64
        FROM SNMPv2-SMI
    TruthValue, RowStatus, MacAddress, TEXTUAL-CONVENTION
        FROM SNMPv2-TC
    unisCommon
        FROM UNIS-OID-MIB;


unisWIPS MODULE-IDENTITY
    LAST-UPDATED "201112291450Z"        -- December 29, 2011 at 14:50 GMT
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
        "This MIB provides information about WIPS feature.

        Wireless Intrusion Prevention System (WIPS)
        WIPS is designed to be employed in an area that is serviced
        by an existing wireless network.
        It aids in the early detection of malicious outsider attacks
        and intrusions via wireless networks, and takes corresponding
        measures in order to guarantee the wireless environment security.
        "
    REVISION "201112291450Z"        -- December 29, 2011 at 14:50 GMT
    DESCRIPTION
        "The initial revision of this MIB module."
    ::= {  unisCommon 118 }

--
-- Textual conventions
--

UnisWIPSRadioType ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents AP 802.11 radio type of 802.11a/b/g/n as per
        the standard.
        dot11a  0x01
        dot11b  0x02
        dot11g  0x04
        dot11n  0x08
        dot11gn 0x10
        dot11an 0x20
        dot11ac 0x40"
    SYNTAX Unsigned32

UnisWIPSDevStatus ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the status of devices detected by WIPS."
    SYNTAX INTEGER
        {
        active(1),
        inactive(2)
        }

UnisWIPSDevCategoryWay ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents by which way the device is categorized.
        'manual': the device is categorized by user.
        'autoByNMS': the device is automatically categorized by
        NMS(Network Management System).
        'autoByDev': the device is automatically categorized by WIPS."
    SYNTAX INTEGER
        {
        manual(1),
        autoByNMS(2),
        autoByDev(3)
        }

UnisWIPSDeviceCategoryType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the categorized type of device detected by WIPS."
    SYNTAX INTEGER
        {
        none(0),
        authorizedAP(1),
        authorizedClient(2),
        misconfiguredAP(3),
        rogueAP(4),
        unauthorizedClient(5),
        externalAP(6),
        adhoc(7),
        bridge(8),
        misassociatedClient(9),
        potentialAuthorizedAP(10),
        potentialRogueAP(11),
        potentialExternalAP(12),
        uncategorizedAP(13),
        uncategorizedClient(14)
        }

UnisWIPSAPCategoryType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the categorized type of AP detected by WIPS."
    SYNTAX INTEGER
        {
        adhoc(1),
        authorized(2),
        rogue(3),
        misconfigured(4),
        external(5),
        potentialAuthorized(6),
        potentialRogue(7),
        potentialExternal(8),
        uncategorized(9)
        }

UnisWIPSClientCategoryType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the categorized type of Client detected by WIPS."
    SYNTAX INTEGER
        {
        authorized(1),
        unauthorized(2),
        misassociated(3),
        uncategorized(4),
        unassociated(5)
        }

UnisWIPSChannel ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the channel number."
    SYNTAX Integer32 (0..224)

UnisWIPSEncryptMethod ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the frame encryption cipher types for
        frames on IEEE 802.11 radio interfaces.
        The MIB defines TC by referring to the 802.11i protocol.
        The following values are supported:
        none(1)     - clear text or no cipher method is configure,
        wep(2)      - WEP key,
        tkip(4)     - WPA Temporal Key encryption,
        ccmp(8)     - WPA AES CCMP encryption"
    SYNTAX Unsigned32

UnisWIPSAuthMethod ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the key management mode defined by 802.11i.
        The following values are supported:
        none         - No key management mode configured,
        psk          - pre-shared key authentication,
        dot1x        - 802.1x authentication.
        other        - other authentication."
    SYNTAX INTEGER
        {
        none(1),
        psk(2),
        dot1x(3),
        other(4),
        pskANDdot1x(5),
        pskANDother(6),
        dot1xANDother(7),
        pskANDdot1xANDother(8)
        }

UnisWIPSAPClassifyType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the classify type of AP.
        'other' - represents undo operation."
    SYNTAX INTEGER
        {
        other(1),
        authorized(2),
        external(3),
        misconfigured(4),
        rogue(5)
        }

UnisWIPSAPSecurityType ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the AP security type.
        clear  0x01
        wpa2   0x02
        wpa    0x04
        wep    0x08"
    SYNTAX Unsigned32

--
-- Node definitions
--

unisWIPSConfigGroup OBJECT IDENTIFIER ::= { unisWIPS 1 }

unisWIPSGlobalConfigGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 1 }

unisWIPSEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the WIPS feature is enabled or not.
        'true': enable the WIPS feature.
        'false': disable the WIPS feature."
    ::= { unisWIPSGlobalConfigGroup 1 }

unisWIPSSensorLicenseNum OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the number of sensor license."
    ::= { unisWIPSGlobalConfigGroup 2 }

unisWIPSBlocklistAction OBJECT-TYPE
    SYNTAX INTEGER
        {
        block(1),
        unblock(2)
        }
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the block list feature is enabled or not.
        'block'  : Enable the block list feature to filter unwanted devices.
        'unblock' : Disable the block list feature."
    ::= { unisWIPSGlobalConfigGroup 3 }

unisWIPSAPInactiveTime OBJECT-TYPE
    SYNTAX Integer32 (60..600)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the time for AP getting inactive."
    DEFVAL { 300 }
    ::= { unisWIPSGlobalConfigGroup 4 }

unisWIPSSTAInactiveTime OBJECT-TYPE
    SYNTAX Integer32 (120..1200)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the time for STA getting inactive."
    DEFVAL { 600 }
    ::= { unisWIPSGlobalConfigGroup 5 }

unisWIPSDevAgingTime OBJECT-TYPE
    SYNTAX Integer32 (60..2592000)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the time for device getting aged."
    DEFVAL { 86400 }
    ::= { unisWIPSGlobalConfigGroup 6 }

unisWIPSStatisticPeriod OBJECT-TYPE
    SYNTAX Integer32 (60..86400)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the period of WIPS reporting the statistic."
    DEFVAL { 900 }
    ::= { unisWIPSGlobalConfigGroup 7 }

unisWIPSReclassificationPeriod OBJECT-TYPE
    SYNTAX Integer32 (10..3600)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the period of WIPS reclassifying devices."
    DEFVAL { 600 }
    ::= { unisWIPSGlobalConfigGroup 8 }

unisWIPSResetAllTrustList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "This object is used to remove all entries from the static trust list.
        It will return false for get operation."
    ::= { unisWIPSGlobalConfigGroup 9 }

unisWIPSResetAllBlockList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "This object is used to remove all entries from the static block list.
        It will return false for get operation."
    ::= { unisWIPSGlobalConfigGroup 10 }

unisWIPSResetAllIgnoreList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "This object is used to remove all entries from the ignore list.
        It will return false for get operation.."
    ::= { unisWIPSGlobalConfigGroup 11 }

unisWIPSResetAllCtmList OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "This object is used to remove all entries from the static
        countermeasure list.
        It will return false for get operation."
    ::= { unisWIPSGlobalConfigGroup 12 }

unisWIPSPermitChlBitMap OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (32))
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the permit channel number by bitmap."
    ::= { unisWIPSGlobalConfigGroup 13 }

unisWIPSDynamicTrustListAgingTime OBJECT-TYPE
    SYNTAX Integer32 (60..86400)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the time for devices in the dynamic trust list getting aged."
    DEFVAL {300}
    ::= { unisWIPSGlobalConfigGroup 14 }

unisWIPSDevUpdateTime OBJECT-TYPE
    SYNTAX Integer32 (10..30)
    UNITS "second"
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents the period of WIPS update the status of devices."
    DEFVAL {20}
    ::= { unisWIPSGlobalConfigGroup 15 }

unisWIPSADOSEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether enable the ADOS feature.
        'true': enable the ADOS feature.
        'false': disable the ADOS feature."
    DEFVAL { false }
    ::= { unisWIPSGlobalConfigGroup 16 }

unisWIPSAccessFlowScanEnable OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "Represents whether the WIPS scanning feature during the access flow is enabled or not.
        'true': enable the feature.
        'false': disable the feature."
    DEFVAL { false }
    ::= { unisWIPSGlobalConfigGroup 17}

unisWIPSVsdConfigGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 2 }

unisWIPSVsdTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSVsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the list of virtual security domain."
    ::= { unisWIPSVsdConfigGroup 1 }

unisWIPSVsdEntry OBJECT-TYPE
    SYNTAX UnisWIPSVsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each VSD."
    INDEX { unisWIPSVsdNameCfg }
    ::= { unisWIPSVsdTable 1 }

UnisWIPSVsdEntry ::=
    SEQUENCE {
        unisWIPSVsdNameCfg
            OCTET STRING,
        unisWIPSVsdRowStatus
            RowStatus,
        unisWIPSVsdAtkDctPolicyNameCfg
            OCTET STRING,
        unisWIPSVsdCtmPolicyNameCfg
            OCTET STRING,
        unisWIPSVsdSigPolicyNameCfg
            OCTET STRING,
        unisWIPSVsdMalPktPolicyNameCfg
            OCTET STRING
     }

unisWIPSVsdNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of virtual security domain."
    ::= { unisWIPSVsdEntry 1 }

unisWIPSVsdRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSVsdEntry 2 }

unisWIPSVsdAtkDctPolicyNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of attack detect policy attached to the VSD."
    ::= { unisWIPSVsdEntry 3 }

unisWIPSVsdCtmPolicyNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of countermeasure policy attached to the VSD."
    ::= { unisWIPSVsdEntry 4 }

unisWIPSVsdSigPolicyNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of signature policy attached to the VSD"
    ::= { unisWIPSVsdEntry 5 }

unisWIPSVsdMalPktPolicyNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of malformed packet detect policy attached to the VSD"
    ::= { unisWIPSVsdEntry 6 }

unisWIPSRule2VsdTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSRule2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the AP classification rules been attached to the VSD.
        "
    ::= { unisWIPSVsdConfigGroup 2 }

unisWIPSRule2VsdEntry OBJECT-TYPE
    SYNTAX UnisWIPSRule2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each AP classification rule
        in each VSD.
        "
    INDEX { unisWIPSVsdNameCfg, unisWIPSRule2VsdAPClaRuleNameCfg }
    ::= { unisWIPSRule2VsdTable 1 }

UnisWIPSRule2VsdEntry ::=
    SEQUENCE {
        unisWIPSRule2VsdAPClaRuleNameCfg
            OCTET STRING,
        unisWIPSRule2VsdRowStatus
            RowStatus,
        unisWIPSRule2VsdPrecedence
            Integer32
     }

unisWIPSRule2VsdAPClaRuleNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of AP classification rule attached to the VSD."
    ::= { unisWIPSRule2VsdEntry 1 }

unisWIPSRule2VsdRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSRule2VsdEntry 2 }

unisWIPSRule2VsdPrecedence OBJECT-TYPE
    SYNTAX Integer32 (0..15)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the precedence of AP classification rule
        attached to the VSD."
    DEFVAL { 0 }
    ::= { unisWIPSRule2VsdEntry 3 }

unisWIPSSensor2VsdTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSSensor2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the sensor been attached to the VSD.
        "
    ::= { unisWIPSVsdConfigGroup 3 }

unisWIPSSensor2VsdEntry OBJECT-TYPE
    SYNTAX UnisWIPSSensor2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each sensor in each VSD."
    INDEX { unisWIPSVsdNameCfg, unisWIPSSensorNameCfg }
    ::= { unisWIPSSensor2VsdTable 1 }

UnisWIPSSensor2VsdEntry ::=
    SEQUENCE {
        unisWIPSSensorNameCfg
            OCTET STRING,
        unisWIPSSensor2VsdRowStatus
            RowStatus,
        unisWIPSSensorState
            INTEGER
     }

unisWIPSSensorNameCfg OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of sensor attached to the VSD."
    ::= { unisWIPSSensor2VsdEntry 1 }

unisWIPSSensor2VsdRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSSensor2VsdEntry 2 }

unisWIPSSensorState OBJECT-TYPE
    SYNTAX INTEGER
        {
        running(1),
        idle(2)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the running state of the sensor.
        It will return false for set operation."
    ::= { unisWIPSSensor2VsdEntry 3 }

unisWIPSSensorRadioTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSSensorRadioEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table represents the list of sensor radio information."
    ::= { unisWIPSVsdConfigGroup 4 }

unisWIPSSensorRadioEntry OBJECT-TYPE
    SYNTAX UnisWIPSSensorRadioEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of a radio of a sensor."
    INDEX { unisWIPSVsdNameCfg, unisWIPSSensorNameCfg, unisWIPSSensorRadioRadioId }
    ::= { unisWIPSSensorRadioTable 1 }

UnisWIPSSensorRadioEntry ::=
    SEQUENCE {
        unisWIPSSensorRadioRadioId
            Integer32,
        unisWIPSSensorRadioScanMode
            INTEGER
     }

unisWIPSSensorRadioRadioId OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the radio identifier of the sensor."
    ::= { unisWIPSSensorRadioEntry 1 }

unisWIPSSensorRadioScanMode OBJECT-TYPE
    SYNTAX INTEGER
        {
        accessFirst(1),
        detectFirst(2),
        middle(3),
        detectOnly(4)
        }
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the scanning mode configured to the radio."
    ::= { unisWIPSSensorRadioEntry 2 }

unisWIPSAPClaRuleTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSAPClaRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the parameters for WIPS AP classification rule.
        One rule could be assigned to different VSDs.
        "
    ::= { unisWIPSConfigGroup 3 }

unisWIPSAPClaRuleEntry OBJECT-TYPE
    SYNTAX UnisWIPSAPClaRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each AP classification rule.
        "
    INDEX { unisWIPSAPClaRuleName }
    ::= { unisWIPSAPClaRuleTable 1 }

UnisWIPSAPClaRuleEntry ::=
    SEQUENCE {
        unisWIPSAPClaRuleName
            OCTET STRING,
        unisWIPSAPClaRowStatus
            RowStatus,
        unisWIPSAPClaSeverityLevel
            Unsigned32,
        unisWIPSAPClaRuleMatchAll
            TruthValue,
        unisWIPSAPClaType
            UnisWIPSAPClassifyType,
        unisWIPSAPClaSubRuleSSIDOperator
            INTEGER,
        unisWIPSAPClaSubRuleSSIDCase
            TruthValue,
        unisWIPSAPClaSubRuleSSID
            OCTET STRING,
        unisWIPSSecurityType
            UnisWIPSAPSecurityType,
        unisWIPSSecurityTypeMatch
            INTEGER,
        unisWIPSAPAuthType
            INTEGER,
        unisWIPSMaxRSSIValue
            Unsigned32,
        unisWIPSMinRSSIValue
            Unsigned32,
        unisWIPSMaxDuration
            Unsigned32,
        unisWIPSMinDuration
            Unsigned32,
        unisWIPSMaxAPNum
            Unsigned32,
        unisWIPSMinAPNum
            Unsigned32,
        unisWIPSMaxClientNum
            Unsigned32,
        unisWIPSMinClientNum
            Unsigned32,
        unisWIPSOUIInfo
            OCTET STRING,
        unisWIPSVendorInfo
            OCTET STRING,
        unisWIPSAPAuthTypeMatch
            INTEGER
     }

unisWIPSAPClaRuleName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of AP classification rule."
    ::= { unisWIPSAPClaRuleEntry 1 }

unisWIPSAPClaRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSAPClaRuleEntry 2 }

unisWIPSAPClaSeverityLevel OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the severity level of the AP classification rule.
        Available value limits from 0 to 100."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 3 }

unisWIPSAPClaRuleMatchAll OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents whether match all the AP classification sub-rules
        which have been configured."
    DEFVAL { false }
    ::= { unisWIPSAPClaRuleEntry 4 }

unisWIPSAPClaType OBJECT-TYPE
    SYNTAX UnisWIPSAPClassifyType
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the type of AP classification."
    ::= { unisWIPSAPClaRuleEntry 5 }

unisWIPSAPClaSubRuleSSIDOperator OBJECT-TYPE
    SYNTAX INTEGER
        {
        include(1),
        notinclude(2),
        equal(3),
        notequal(4)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the compare way of the SSID in the sub rule,
        including include/not include/equal/not equal."
    ::= { unisWIPSAPClaRuleEntry 6 }

unisWIPSAPClaSubRuleSSIDCase OBJECT-TYPE
    SYNTAX TruthValue
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the case sensitive or not for the SSID match.
        'true': Case insensitive.
        'false': Case sensitive."
    DEFVAL { false }
    ::= { unisWIPSAPClaRuleEntry 7 }

unisWIPSAPClaSubRuleSSID OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..32))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the SSID match template in the ap classification rule."
    ::= { unisWIPSAPClaRuleEntry 8 }

unisWIPSSecurityType OBJECT-TYPE
    SYNTAX UnisWIPSAPSecurityType
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the security type of active AP.
        "
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 9 }

unisWIPSSecurityTypeMatch OBJECT-TYPE
    SYNTAX INTEGER
        {
        equal(1),
        include(2)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents match way of the security type of active AP.
        "
    DEFVAL { include }
    ::= { unisWIPSAPClaRuleEntry 10 }

unisWIPSAPAuthType OBJECT-TYPE
    SYNTAX INTEGER
        {
        none(1),
        psk(2),
        dot1x(3),
        other(4),
        undo(5),
        pskANDdot1x(6),
        pskANDother(7),
        dot1xANDother(8),
        pskANDdot1xANDother(9),
        noneANDpsk(10),
        noneANDdot1x(11),
        noneANDother(12),
        noneANDpskANDdot1x(13),
        noneANDpskANDother(14),
        noneANDdot1xANDother(15),
        noneANDpskANDdot1xANDother(16)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the authentication type of the AP.
        undo - represents undo operation"
    DEFVAL { undo }
    ::= { unisWIPSAPClaRuleEntry 11 }

unisWIPSMaxRSSIValue OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the high-limit of the RSSI of AP.
        Available value limits from 1 to 90."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 12 }

unisWIPSMinRSSIValue OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the low-limit of the RSSI of AP.
        Available value limits from 0 to 89."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 13 }

unisWIPSMaxDuration OBJECT-TYPE
    SYNTAX Unsigned32
    UNITS "second"
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the high-limit of the duration of AP.
        Available value limits from 1 to 2592000."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 14 }

unisWIPSMinDuration OBJECT-TYPE
    SYNTAX Unsigned32
    UNITS "second"
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the low-limit of the duration of AP.
        Available value limits from 0 to 2591999."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 15 }

unisWIPSMaxAPNum OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the high-limit of the number of AP.
        Available value limits from 1 to 128."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 16 }

unisWIPSMinAPNum OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the low-limit of the number of AP.
        Available value limits from 0 to 127."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 17 }

unisWIPSMaxClientNum OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the high-limit of the number of client.
        Available value limits from 1 to 128."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 18 }

unisWIPSMinClientNum OBJECT-TYPE
    SYNTAX Unsigned32
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the low-limit of the number of client.
        Available value limits from 0 to 127."
    DEFVAL { 'ffffffff'h }
    ::= { unisWIPSAPClaRuleEntry 19 }

unisWIPSOUIInfo OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..6))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the OUI hexadecimal string of the AP."
    ::= { unisWIPSAPClaRuleEntry 20 }

unisWIPSVendorInfo OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..64))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the vendor info of the AP."
    ::= { unisWIPSAPClaRuleEntry 21 }

unisWIPSAPAuthTypeMatch OBJECT-TYPE
    SYNTAX INTEGER
        {
        equal(1),
        include(2)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents match way of the authentication type of active AP.
        "
    DEFVAL { include }
    ::= { unisWIPSAPClaRuleEntry 22 }

unisWIPSAtkDctPolicyCfgGroup OBJECT IDENTIFIER ::= { unisWIPSConfigGroup 4 }

unisWIPSAtkDctPolicyCfgSupportSet OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (16))
    MAX-ACCESS read-only
    STATUS current
    DESCRIPTION
        "Represents the bit string of supported attack detect policy.
        The specific attack detect policy is supported if its corresponding
        bit is set to 1; otherwise its corresponding bit is set to 0.
        bit0: adhoc
        bit1: ap-spoof
        bit2: client-spoof
        bit3: prohibited channel
        bit4: ap-flood
        bit5: eapol-start
        bit6: authentication
        bit7: association
        bit8: reassociation
        bit9: weak-IV
        bit10: invalid-OUI
        bit11: ps-attack
        bit12: windows-bridge
        bit13: hotspot-attack
        bit14: ap-impersonation
        bit15: soft-ap
        bit16: unencrypted-authorized-ap
        bit17: unencrypted-trust-client"
    ::= { unisWIPSAtkDctPolicyCfgGroup 1 }

unisWIPSAtkDctPolicyCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSAtkDctPolicyCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines the parameters for WIPS attack detect policy."
    ::= { unisWIPSAtkDctPolicyCfgGroup 2 }

unisWIPSAtkDctPolicyCfgEntry OBJECT-TYPE
    SYNTAX UnisWIPSAtkDctPolicyCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information of each attack detect policy."
    INDEX { unisWIPSAtkDctPolicyName }
    ::= { unisWIPSAtkDctPolicyCfgTable 1 }

UnisWIPSAtkDctPolicyCfgEntry ::=
    SEQUENCE {
        unisWIPSAtkDctPolicyName
            OCTET STRING,
        unisWIPSAtkDctPolicyCfgRowStatus
            RowStatus,
        unisWIPSAtkDctPolicyBitString
            OCTET STRING,
        unisWIPSAtkDctPolicyAPFloodQT
            Integer32,
        unisWIPSAtkDctPolicyAPSpoofQT
            Integer32,
        unisWIPSAtkDctPolicyCliSpoofQT
            Integer32,
        unisWIPSAtkDctPolicyDosAssoQT
            Integer32,
        unisWIPSAtkDctPolicyDosAuthQT
            Integer32,
        unisWIPSAtkDctPolicyDosEAPOLStartQT
            Integer32,
        unisWIPSAtkDctPolicyDosReAssoQT
            Integer32,
        unisWIPSAtkDctPolicyWeakIVQT
            Integer32,
        unisWIPSAtkDctPolicyInvalidOUIAction
            INTEGER,
        unisWIPSAtkDctPolicyUnencryptedAuthApQT
            Integer32,
        unisWIPSAtkDctPolicyUnencryptedAuthClientQT
            Integer32,
        unisWIPSAtkDctPolicyPSAttackQT
            Integer32,
        unisWIPSAtkDctPolicyPSAttackMinOffPacket
            Integer32,
        unisWIPSAtkDctPolicyPSAttackOnOffPercent
            Integer32,
        unisWIPSAtkDctPolicyApImpersonationQT
            Integer32,
        unisWIPSAtkDctPolicyApImpersonationBeaconIncThreshold
            Integer32,
        unisWIPSAtkDctPolicyApImpersonationBeaconIncWaitTime
            Integer32,
        unisWIPSAtkDctPolicySoftApConvertTime
            Integer32
     }

unisWIPSAtkDctPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..32))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of attack detect policy."
    ::= { unisWIPSAtkDctPolicyCfgEntry 1 }

unisWIPSAtkDctPolicyCfgRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisWIPSAtkDctPolicyCfgEntry 2 }

unisWIPSAtkDctPolicyBitString OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (16))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the bit string of attack detect policy configuration.
        The specific attack detect policy is enabled if its corresponding
        bit is set to 1; disabled if its corresponding bit is set to 0.
        bit0: adhoc
        bit1: ap-spoof
        bit2: client-spoof
        bit3: prohibited channel
        bit4: ap-flood
        bit5: eapol-start
        bit6: authentication
        bit7: association
        bit8: reassociation
        bit9: weak-IV
        bit10: invalid-OUI
        bit11: ps-attack
        bit12: windows-bridge
        bit13: hotspot-attack
        bit14: ap-impersonation
        bit15: soft-ap
        bit16: unencrypted-authorized-ap
        bit17: unencrypted-trust-client"
    ::= { unisWIPSAtkDctPolicyCfgEntry 3 }

unisWIPSAtkDctPolicyAPFloodQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the AP flood attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 4 }

unisWIPSAtkDctPolicyAPSpoofQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the AP spoofing attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 5 }

unisWIPSAtkDctPolicyCliSpoofQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the client spoofing attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 6 }

unisWIPSAtkDctPolicyDosAssoQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the dos of association attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 7 }

unisWIPSAtkDctPolicyDosAuthQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the dos of authentication attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 8 }

unisWIPSAtkDctPolicyDosEAPOLStartQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the dos of EAPOL-start attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 9 }

unisWIPSAtkDctPolicyDosReAssoQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the dos of reassociation attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 10 }

unisWIPSAtkDctPolicyWeakIVQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the weak-IV event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 11 }

unisWIPSAtkDctPolicyInvalidOUIAction OBJECT-TYPE
    SYNTAX INTEGER
        {
        none(0),
        rogue(1)
        }
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the action after detecting the invalid OUI,
        which classify the device as rogue device."
    ::= { unisWIPSAtkDctPolicyCfgEntry 12 }

unisWIPSAtkDctPolicyUnencryptedAuthApQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the unencrypted-authorized-ap event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 13 }

unisWIPSAtkDctPolicyUnencryptedAuthClientQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the unencrypted-trust-client event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 14 }

unisWIPSAtkDctPolicyPSAttackQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the ps-attack event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 15 }

unisWIPSAtkDctPolicyPSAttackMinOffPacket OBJECT-TYPE
    SYNTAX Integer32 (10..150)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Specify the minimum number of OFF packets
        as threshold in detecting ps-attack."
    DEFVAL { 50 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 16 }

unisWIPSAtkDctPolicyPSAttackOnOffPercent OBJECT-TYPE
    SYNTAX Integer32 (0..100)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Specify the ratio of ON packets to OFF packets
        in percentage as threshold in detecting ps-attack."
    DEFVAL { 50 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 17 }

unisWIPSAtkDctPolicyApImpersonationQT OBJECT-TYPE
    SYNTAX Integer32 (5..604800)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the quiet time after reporting
        the ap-impersonation event alarm."
    DEFVAL { 600 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 18 }

unisWIPSAtkDctPolicyApImpersonationBeaconIncThreshold OBJECT-TYPE
    SYNTAX Integer32 (1..100)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Specify the increased percentage threshold for beacon
        frames that can trigger an AP impersonation alert"
    DEFVAL { 30 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 19 }

unisWIPSAtkDctPolicyApImpersonationBeaconIncWaitTime OBJECT-TYPE
    SYNTAX Integer32 (0..360000)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Specify the waiting time before a suspected AP is
         determined as an AP impersonator.  If the beacon frames
         keep on increasing beyond the threshold during the waiting
         time, then the suspected AP should be determined as an
         AP impersonator."
    DEFVAL { 10 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 20 }

unisWIPSAtkDctPolicySoftApConvertTime OBJECT-TYPE
    SYNTAX Integer32 (5..600)
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Specify the minimum client-AP switchover threshold
         used to determine a soft AP"
    DEFVAL { 10 }
    ::= { unisWIPSAtkDctPolicyCfgEntry 21 }

unisWIPSStaticCtmListCfgTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisWIPSStaticCtmListCfgEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides the MAC address list of devices
        in the static countermeasure list."
