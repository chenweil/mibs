            Counter64,
        unisWIPSDevStatTxMalformed
            Counter64,
        unisWIPSDevStatRxTotalPkt
            Counter64,
        unisWIPSDevStatRxTotalByte
            Counter64,
        unisWIPSDevStatRxUnicastPkt
            Counter64,
        unisWIPSDevStatRxUnicastByte
            Counter64,
        unisWIPSDevStatRxMgmt
            Counter64,
