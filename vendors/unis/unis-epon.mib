            unisOnuBindMacAddress,
            unisEponOperationResult
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuAutoBindTrap notification is sent
        when a silent ONU is bound automatically.
        "
    ::= { unisEponTrapPrefix 34 }

unisEponOnuPortStpStateTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
