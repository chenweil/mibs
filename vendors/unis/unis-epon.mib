    ::= { unisEponTrapPrefix 39 }

unisEponOnuSilenceLoidTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponOnuRegSilentBindType,
            unisEponOnuRegSilentMac,
            unisEponOnuRegSilentLoid,
            unisEponOnuRegSilentLoidPwd
        }
    STATUS      current
    DESCRIPTION
        "
        The unisEponOnuSilenceLoidTrap notification is sent when an
        unbound ONU try to register to an OLT identified by LOID.
        "
    ::= { unisEponTrapPrefix 40 }

unisEponOnuSilenceLoidRecTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisEponOnuRegSilentBindType,
            unisEponOnuRegSilentMac,
            unisEponOnuRegSilentLoid,
            unisEponOnuRegSilentLoidPwd
        }
    STATUS      current
    DESCRIPTION
        "
        The unisEponOnuSilenceLoidRecTrap notification is sent when
        a silent ONU is bound in the OLT or the aging ONU MAC
        address times out identified by LOID.
        "
    ::= { unisEponTrapPrefix 41 }

unisEponOnuUpdateLoidRetTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisOnuBindLoid,
            unisOnuUpdateResult,
            unisOnuRegType,
            unisOnuUpdateFileName
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuUpdateLoidRetTrap notification is sent when
        an ONU reported its firmware update result identified by LOID.
        "
    ::= { unisEponTrapPrefix 42 }

unisEponOnuAutoBindLoidTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr,
            unisOnuBindLoid,
            unisEponOperationResult
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuAutoBindLoidTrap notification is sent
        when a silent ONU is bound automatically identified by LOID.
        "
    ::= { unisEponTrapPrefix 43 }

unisEponOnuPowerOnTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuPowerOffTrap notification is sent when ONU is powered on.
        "
    ::= { unisEponTrapPrefix 44 }

unisEponOpticalSignalLosTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOpticalSignalLosTrap notification is sent when optical signals are lost.
        "
    ::= { unisEponTrapPrefix 45 }

unisEponOpticalSignalLosRecoverTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOpticalSignalLosTrap notification is sent when optical signal loss recovers.
        "
    ::= { unisEponTrapPrefix 46 }

unisEponOnuFiberFailTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuPowerOffTrap notification is sent when the ONU fiber fails.
        "
    ::= { unisEponTrapPrefix 47 }

unisEponOnuFiberFailRecoverTrap NOTIFICATION-TYPE
    OBJECTS
        {
            ifIndex,
            ifDescr
        }
    STATUS      current
    DESCRIPTION
        "
        A unisEponOnuPowerOffTrap notification is sent when the ONU fiber failure recovers.
        "
    ::= { unisEponTrapPrefix 48 }

unisEponStat OBJECT IDENTIFIER ::= { unisEponMibObjects 9 }

--
-- unisEponStatTable
--

unisEponStatTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisEponStatEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        This table contains line code error statistics of epon port.
        "
    ::= { unisEponStat 1 }

unisEponStatEntry OBJECT-TYPE
    SYNTAX      UnisEponStatEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The entry of unisEponStatTable.
        "
    INDEX
        {
            ifIndex
        }
    ::= { unisEponStatTable 1 }

UnisEponStatEntry ::= SEQUENCE
    {
        unisEponStatFER    Counter64,
        unisEponStatBER    Counter64
    }

unisEponStatFER OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The frame error rate of epon port, measured in 1e-9 unit.
        "
    ::= { unisEponStatEntry 1 }

unisEponStatBER OBJECT-TYPE
    SYNTAX      Counter64
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The bit error rate of epon port, measured in 1e-9 unit.
        "
    ::= { unisEponStatEntry 2  }

unisEponRoltMan OBJECT IDENTIFIER ::= { unisEponMibObjects 10 }

--
-- unisRoltInterfaceTable
--

unisRoltInterfaceTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisRoltInterfaceEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The table of redundant OLT interfaces.
        "
    ::= { unisEponRoltMan 1 }

unisRoltInterfaceEntry  OBJECT-TYPE
    SYNTAX      UnisRoltInterfaceEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The entry of the table unisRoltInterfaceTable.
        "
    INDEX
        {
            unisRoltInterfaceNumber
        }
    ::= { unisRoltInterfaceTable 1 }

UnisRoltInterfaceEntry ::= SEQUENCE
    {
        unisRoltInterfaceNumber       Integer32,
        unisRoltInterfaceIfIndex      Integer32,
        unisRoltInterfaceRowStatus    RowStatus
    }

unisRoltInterfaceNumber OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The number of an ROLT interface.
        "
    ::= { unisRoltInterfaceEntry 1 }

unisRoltInterfaceIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The ifIndex of an ROLT interface.
        "
    ::= { unisRoltInterfaceEntry 2 }

unisRoltInterfaceRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        Create or delete a redundant OLT interface.
        Now only two operations are supported:
        createAndGo and destroy.
        "
    ::= { unisRoltInterfaceEntry 3 }

--
-- unisRoltMemberTable
--
unisRoltMemberTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF UnisRoltMemberEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        This table is used for adding or deleting the OLT member
        interfaces of an redundant OLT interface.
        "
    ::= { unisEponRoltMan 2 }

unisRoltMemberEntry  OBJECT-TYPE
    SYNTAX      UnisRoltMemberEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The entry of the table unisRoltMemberTable.
        "
    INDEX
        {
            unisRoltInterfaceNumber,
            unisRoltMemberOltIfindex
        }
    ::= { unisRoltMemberTable 1 }

UnisRoltMemberEntry ::= SEQUENCE
    {
        unisRoltMemberOltIfindex      Integer32,
        unisRoltMemberOltPriority     Integer32,
        unisRoltMemberRowStatus       RowStatus,
        unisRoltMemberForwardStatus   TruthValue
    }

unisRoltMemberOltIfindex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The ifindex of an OLT interface.
        "
    ::= { unisRoltMemberEntry 1 }

unisRoltMemberOltPriority OBJECT-TYPE
    SYNTAX      Integer32 (1..255)
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        The priority of an OLT interface that will be assigned to an ROLT interface.
        "
    ::= { unisRoltMemberEntry 2 }

unisRoltMemberRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        Operation status.  Now only two states are supported:
        createAndGo and destroy.
        "
    ::= { unisRoltMemberEntry 3 }

unisRoltMemberForwardStatus OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The forwarding status of an OLT member interface.
        true(1)  - Active.
        false(2) - Inactive.
        "
    ::= { unisRoltMemberEntry 4 }
END
