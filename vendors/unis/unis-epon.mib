            unisOamEventLogLocation
        }
    STATUS      current
    DESCRIPTION
        "
        A unisDot3OamNonThresholdRecoverEvent notification is sent when
        unisDot3OamNonThresholdEvent is detected and then recovered.
        "
    ::= { unisEponTrapPrefix 24 }

unisEponOnuRegExcessTrap NOTIFICATION-TYPE
    OBJECTS
