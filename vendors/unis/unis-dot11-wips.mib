-- History:
--   V1.0 created by sunanzhi
--     Initial version 2015-03-20
--        2015-12-08 updated by sunanzhi
--     Modify the node name of UnisDot11WIPSVsdEntry,UnisDot11WIPSAp2VsdEntry,
--     UnisDot11WIPSApRadioEntry,UnisDot11WIPSDctAPEntry,
--     UnisDot11WIPSDctStaEntry
--     Add new objects UnisDot11WIPSRuleEntry,UnisDot11WIPSAlySigRuleEntry,
--     UnisDot11WIPSAlyClaRuleEntry,UnisDot11WIPSTrustMacEntry,
--     UnisDot11WIPSBlockMacEntry,UnisDot11WIPSManulClaEntry,
--     UnisDot11WIPSTrustOuiEntry,UnisDot11WIPSTrustSSidEntry,
--     UnisDot11WIPSMalfDtcEntry,UnisDot11WIPSLgeDutEntry,
--     UnisDot11WIPSRtLmtEntry,UnisDot11WIPSDtcAckEntry,
--     UnisDot11WIPSDtcDevTimeEntry,UnisDot11WIPSApimperEntry,
--     UnisDot11WIPSDctSoftApEntry,UnisDot11WIPSPowerSaveEntry,
--     UnisDot11WIPSIgnListMacEntry,UnisDot11WIPSHoneyPotEntry,
--     UnisDot11WIPSAPFldEntry,UnisDot11WIPSCtmManualsEntry,
--     UnisDot11WIPSCtmSensorEntry,UnisDot11WIPSInvOuiStateEntry,
--     UnisDot11WIPSAPClaAuthEntry,UnisDot11WIPSAPClaCltOnlEntry,
--     UnisDot11WIPSAPClaDiscrEntry,UnisDot11WIPSAPClaRssiEntry,
--     UnisDot11WIPSAPClaUpdurEntry,UnisDot11WIPSAPClaOuiEntry,
--     UnisDot11WIPSAPClaSryEntry,UnisDot11WIPSAPClaSsidEntry,
--     UnisDot11WIPSDtcSigEntry,UnisDot11WIPSPolicyEntry,
--     UnisDot11WIPSSigFrameTypeEntry,UnisDot11WIPSCtmEntry,
--     UnisDot11WIPSSigPatternEntry,UnisDot11WIPSSigSeqNumEntry,
--     UnisDot11WIPSSigSsidEntry,UnisDot11WIPSSigSsidLengthEntry,
--     UnisDot11WIPSFldDetectEntry,UnisDot11WIPSSignatureMacEntry,
--     UnisDot11WIPSRadioCfgEntry,UnisDot11WIPSNatDetectEntry,
--     UnisDot11WIPSApAssoCltEntry,UnisDot11WIPSApRpSenEntry,
--     UnisDot11WIPSCtmRecEntry,UnisDot11WIPSDevEntry,UnisDot11WIPSCtmDevEntry,
--     UnisDot11WIPSCltProbeEntry,UnisDot11WIPSPbeStaEntry,
--     UnisDot11WIPSCltRptApEntry,UnisDot11WIPSNatDtcCltEntry,
--     UnisDot11WIPSAckStaEntry
--   V1.1 2016-02-17 updated by sunanzhi
--     Modify the objects UnisDot11WIPSEncryptMethod,UnisDot11WIPSAuthMethod
--     UnisDot11WIPSAPSecurityType,unisDot11WIPSDctAPSSID
--        2016-03-28 updated by sunanzhi
--     Delete the objects UnisDot11WIPSCltProbeEntry,UnisDot11WIPSPbeStaEntry
--     UnisDot11WIPSRadioCfgEntry
-- =============================================================================
UNIS-DOT11-WIPS-MIB DEFINITIONS ::= BEGIN

IMPORTS
    TimeTicks, Integer32, Unsigned32, OBJECT-TYPE, MODULE-IDENTITY
        FROM SNMPv2-SMI
    TruthValue, RowStatus, MacAddress, TEXTUAL-CONVENTION
        FROM SNMPv2-TC
    unisDot11
        FROM UNIS-OID-MIB;

unisDot11WIPS MODULE-IDENTITY
    LAST-UPDATED "201603280951Z"        -- March 28, 2016 at 09:51 GMT
    ORGANIZATION
        "Unisyue Technologies Co., Ltd."
    CONTACT-INFO
        ""
    DESCRIPTION
        "This MIB provides information about the Wireless Intrusion
        Prevention System (WIPS) feature.

        WIPS is designed to protect an area that is serviced by
        a wireless network.
        It aids in early detection of malicious outsider attacks
        and intrusions via wireless networks, and takes countermeasures
        to ensure the wireless environment security.
        "
    REVISION "201603280951Z"        -- March 28, 2016 at 09:51 GMT
    DESCRIPTION
        "Delete table for probe."
    REVISION "201602161051Z"        -- February 16, 2016 at 10:51 GMT
    DESCRIPTION
        "Modify objects."
    REVISION "201512081551Z"        -- December 08, 2015 at 15:51 GMT
    DESCRIPTION
        "Add new objects."
    REVISION "201503311351Z"        -- March 31, 2015 at 13:51 GMT
    DESCRIPTION
        "The initial revision of this MIB module."
    ::= {  unisDot11 15 }

--
-- Textual conventions
--
UnisDot11WIPSEnabledStatus ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION
        "The enable status values for objects.
        Values include enabled and disbaled."
    SYNTAX      INTEGER { enabled(1), disabled(2) }

UnisDot11WIPSRtLmtType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of rate limit configuration."
    SYNTAX INTEGER
        {
        ap(1),
        client(4)
        }

UnisDot11WIPSDeviceType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of device."
    SYNTAX INTEGER
        {
        ap(1),
        client(2)
        }

UnisDot11WIPSPolicyTypeValue ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of policy."
    SYNTAX INTEGER
        {
        classification(1),
        countermeasure(2),
        detect(3),
        signature(4)
        }

UnisDot11WIPSClassifyType ::= TEXTUAL-CONVENTION
   STATUS current
   DESCRIPTION
        "Represents the category of the device detected by WIPS."
   SYNTAX INTEGER
       {
       none(1),
       authorizedap(2),
       misconfiguredap(3),
       rogueap(4),
       externalap(5),
       adhoc(6),
       meshap(7),
       potentialauthorizedap(8),
       potentialrogueap(9),
       potentialexternalap(10),
       uncategorizedap(11),
       authorizedclient(12),
       unauthorizedclient(13),
       misassociaionclient(14),
       uncategorizedclient(15)
       }

UnisDot11WIPSRadioType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents AP 802.11 radio type of 802.11a/b/g/n as per
        the standard.
        The following values are supported:
        dot11a  - 802.11a
        dot11b  - 802.11b
        dot11g  - 802.11g
        dot11n  - 802.11n
        dot11gn  - 802.11gn
        dot11an  - 802.11an
        dot11ac  - 802.11ac
        dot11gac  - 802.11gac"
    SYNTAX INTEGER
        {
        dot11a(1),
        dot11b(2),
        dot11g(4),
        dot11n(8),
        dot11gn(16),
        dot11an(32),
        dot11ac(64),
        dot11gac(128)
        }

UnisDot11WIPSDevStatus ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the status of devices detected by WIPS."
    SYNTAX INTEGER
        {
        active(1),
        inactive(2)
        }

UnisDot11WIPSAPType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of AP detected by WIPS."
    SYNTAX INTEGER
        {
        normal(1),
        adhoc(2),
        mesh(3)
        }


UnisDot11WIPSDevClassifyWay ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the method that the device is categorized."
    SYNTAX INTEGER
        {
        manual(1),
        invalidOUI(2),
        trustlist(3),
        blocklist(4),
        associated(5),
        userdefined(6),
        auto(7)
        }

UnisDot11WIPSAPClassifyType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the category of the AP detected by WIPS."
    SYNTAX INTEGER
        {
        authorized(1),
        misconfigured(2),
        rogue(3),
        external(4),
        adhoc(5),
        mesh(6),
        potentialAuthorized(7),
        potentialRogue(8),
        potentialExternal(9),
        uncategorized(10)
        }

UnisDot11WIPSStaClassifyType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the category of the client detected by WIPS."
    SYNTAX INTEGER
        {
        authorized(1),
        unauthorized(2),
        misassociated(3),
        uncategorized(4)
        }

UnisDot11WIPSChannel ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the channel number."
    SYNTAX Integer32 (1..224)

UnisDot11WIPSEncryptMethod ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the frame encryption cipher types(bitmap) for
        frames on IEEE 802.11 radio interfaces.
        The MIB defines TC by referring to the 802.11i protocol.
        The following bits are supported:
        first bit:    none,
        second bit:   wep,
        third bit:    wep40,
        fourth bit:   tkip
        fifth bit:    reserve
        sixth bit:    ccmp
        seventh bit:  wep104
        eighth bit:   wep128"
    SYNTAX Integer32 (1..65535)

UnisDot11WIPSAuthMethod ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the key management mode(bitmap), compliant with 802.11i.
        The following bits are supported:
        first bit:   none         - No key management mode is specified,
        second bit:  dot1x        - 802.1X authentication.
        third bit:   psk          - Pre-shared key authentication,
        fourth bit:  other        - Other authentication."
    SYNTAX Integer32 (1..65535)

UnisDot11WIPSAPSecurityType ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS current
    DESCRIPTION
        "Represents the AP security type(bitmap).
        The following bits are supported:
        first bit:   none,
        second bit:  wpa2,
        third bit:   wpa,
        fourth bit:  wlanex
        fifth bit:   wep"
    SYNTAX Integer32 (1..255)

UnisDot11WIPSMalformedType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the category of malformed packet."
    SYNTAX INTEGER
        {
        duplicatedie(1),
        fatajack(2),
        illegalibssess(3),
        invalidaddresscombination(4),
        invalidassocreq(5),
        invalidauth(6),
        invaliddeauthcode(7),
        invaliddisassoccode(8),
        invalidhtie(9),
        invalidielength(10),
        invalidpktlength(11),
        nullproberesp(13),
        overfloweapolkey(14),
        overflowssid(15),
        redundantie(16)
        }

UnisDot11WIPSCtmType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the category of countermeasure method."
    SYNTAX INTEGER
        {
        externalAp(1),
        misassociationClient(2),
        misconfiguredAp(3),
        potentialAuthorizedAp(4),
        potentialExternalAp(5),
        potentialRogueAp(6),
        rogueAp(7),
        unauthorizedClient(8),
        uncategorizedAp(9),
        uncategorizedClient(10),
        attack(11),
        adhoc(12)
        }

UnisDot11WIPSRuleTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of rule"
    SYNTAX INTEGER
        {
        signature(4),
        apclassfication(5)
        }

UnisDot11WIPSSigFrameTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of signature frame configuration."
    SYNTAX INTEGER
        {
        management(1),
        control(2),
        data(3)
        }

UnisDot11WIPSSigFrameSubTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of signature manage frame configuration."
    SYNTAX INTEGER
        {
        assocerq(1),
        assocresp(2),
        probereq(3),
        beacon(4),
        disasso(5),
        auth(6),
        deauth(7)
        }

UnisDot11WIPSSigSsidMatchTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the match type of signature ssid configuration."
    SYNTAX INTEGER
        {
        equal(1),
        notequal(2),
        include(3),
        notinclude(4)
        }

UnisDot11WIPSSigMacMacType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the mac type of signature ssid configuration."
    SYNTAX INTEGER
        {
        source(1),
        destination(2),
        bssid(3)
        }

UnisDot11WIPSManualAPType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of AP manual classification."
    SYNTAX INTEGER
        {
       authap(1),
       misconfiguredap(2),
        rogueap(3),
        externalap(4)
        }

UnisDot11WIPSDtcAckTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of attack detect."
    SYNTAX INTEGER
        {
        apspoof(1),
        clientspoof(4),
        weakiv(6),
        windowsbridge(7),
        fortymhz(8),
        omerta(11),
        disassoc(12),
        deauth(13),
        prohibitedchannel(14),
        authunencryptedap(16),
        authunencryptedclient(17),
        hotspot(18),
        greenmode(19),
        tableoverflow(20),
        mitm(22),
        wirelessbridge(23),
        apchannelchange(25)
        }

UnisDot11WIPSDtcDevTimeTypes ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of device time."
    SYNTAX INTEGER
        {
        deviceap(1),
        deviceclient(2)
        }

UnisDot11WIPSFldDctType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of flood detect."
    SYNTAX INTEGER
        {
        associationrequest(1),
        authentication(2),
        beacon(3),
        blockack(4),
        cts(5),
        deauthentication(6),
        disassociation(7),
        eapolstart(8),
        nulldata(9),
        proberequest(10),
        reassociationrequest(11),
        rts(12),
        eapollogoff(13),
        eapfailure(14),
        eapsuccess(15)
        }

UnisDot11WIPSAPClaAuthMethods ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of AP classification method."
    SYNTAX INTEGER
        {
        none(1),
        dot1x(2),
        psk(3),
        other(5)
        }


UnisDot11WIPSAPClassifyCmpType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the compare type of AP classification method.
        The following values are supported:
        equal         - equal.
        include       - include."
    SYNTAX INTEGER
        {
        equal(1),
        include(3)
        }

UnisDot11WIPSAPClasSsidCmpType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the compare type of AP classification ssid.
        The following values are supported:
        equal         - equal.
        not equal     - not equal.
        include       - include.
        not include   - not include."
    SYNTAX INTEGER
        {
        equal(1),
        notequal(2),
        include(3),
        notinclude(4)
        }


UnisDot11WIPSAPClaSecurityType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the type of AP classification security.
        clear   1
        wpa2   2
        wpa    3
        wep    9"
    SYNTAX INTEGER
        {
        clear(1),
        wpa2(2),
        wpa(3),
        wep(9)
        }

UnisDot11WIPSAlyAPClaRuleType ::= TEXTUAL-CONVENTION
    STATUS current
    DESCRIPTION
        "Represents the category of apply AP classification rule."
    SYNTAX INTEGER
        {
        rogue(1),
        external(2),
        misconfigured(3),
        authorized(4)
        }

UnisDot11WIPSOuiAddress ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "1x:"
    STATUS       current
    DESCRIPTION
        "Represents an 802 OUI address represented in the
        `canonical' order defined by IEEE 802.1a, i.e., as if it
        were transmitted least significant bit first, even though
        802.5 (in contrast to other 802.x protocols) requires MAC
        addresses to be transmitted most significant bit first."
    SYNTAX       OCTET STRING (SIZE (3))

--
-- Node definitions
--
unisDot11WIPSConfigGroup OBJECT IDENTIFIER ::= { unisDot11WIPS 1 }
unisDot11WIPSDataGroup OBJECT IDENTIFIER ::= { unisDot11WIPS 2 }

unisDot11WIPSVsdTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11WIPSVsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides information about virtual security domains (VSDs)."
    ::= { unisDot11WIPSConfigGroup 1 }

unisDot11WIPSVsdEntry OBJECT-TYPE
    SYNTAX UnisDot11WIPSVsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information about one VSD."
    INDEX { unisDot11WIPSVsdName }
    ::= { unisDot11WIPSVsdTable 1 }

UnisDot11WIPSVsdEntry ::= SEQUENCE {
        unisDot11WIPSVsdName                      OCTET STRING,
        unisDot11WIPSVsdRowStatus                 RowStatus,
        unisDot11WIPSVsdDetectPolicy              OCTET STRING,
        unisDot11WIPSVsdCtmPolicy                 OCTET STRING,
        unisDot11WIPSVsdSignaturePolicy           OCTET STRING,
        unisDot11WIPSVsdClasPolicy                OCTET STRING
     }

unisDot11WIPSVsdName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..63))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the name of the virtual security domain."
    ::= { unisDot11WIPSVsdEntry 1 }

unisDot11WIPSVsdRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIPSVsdEntry 2 }

unisDot11WIPSVsdDetectPolicy OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of the attack detect policy attached to the VSD,
        zero-length for not config."
    ::= { unisDot11WIPSVsdEntry 3 }

unisDot11WIPSVsdCtmPolicy OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of the countermeasure policy attached to the VSD,
        zero-length for not config."
    ::= { unisDot11WIPSVsdEntry 4 }

unisDot11WIPSVsdSignaturePolicy OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of the signature policy attached to the VSD,
        zero-length for not config."
    ::= { unisDot11WIPSVsdEntry 5 }

unisDot11WIPSVsdClasPolicy OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (0..63))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of the malformed packet detect policy attached
        to the VSD,zero-length for not config."
    ::= { unisDot11WIPSVsdEntry 6 }

unisDot11WIPSAp2VsdTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11WIPSAp2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines sensors attached to VSDs."
    ::= { unisDot11WIPSConfigGroup 2 }

unisDot11WIPSAp2VsdEntry OBJECT-TYPE
    SYNTAX UnisDot11WIPSAp2VsdEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information about a sensor in a VSD."
    INDEX { unisDot11WIPSAp2VsdApName }
    ::= { unisDot11WIPSAp2VsdTable 1 }

UnisDot11WIPSAp2VsdEntry ::= SEQUENCE {
        unisDot11WIPSAp2VsdApName        OCTET STRING,
        unisDot11WIPSAp2VsdRowStatus     RowStatus,
        unisDot11WIPSAp2VsdVsdName       OCTET STRING
     }

unisDot11WIPSAp2VsdApName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the sensor name."
    ::= { unisDot11WIPSAp2VsdEntry 1 }

unisDot11WIPSAp2VsdRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIPSAp2VsdEntry 2 }

unisDot11WIPSAp2VsdVsdName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..63))
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "Represents the name of a virtual security domain."
    ::= { unisDot11WIPSAp2VsdEntry 3 }


unisDot11WIPSApRadioTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11WIPSApRadioEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table contains the enable status of WIPS on radios of sensors."
    ::= { unisDot11WIPSConfigGroup 3 }

unisDot11WIPSApRadioEntry OBJECT-TYPE
    SYNTAX UnisDot11WIPSApRadioEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains the enable status
         of WIPS on one radio of a sensor."
    INDEX { unisDot11WIPSApRadioApName, unisDot11WIPSApRadioRadioID }
    ::= { unisDot11WIPSApRadioTable 1 }

UnisDot11WIPSApRadioEntry ::= SEQUENCE {
        unisDot11WIPSApRadioApName       OCTET STRING,
        unisDot11WIPSApRadioRadioID      Integer32,
        unisDot11WIPSApRadioStatus       UnisDot11WIPSEnabledStatus
     }

unisDot11WIPSApRadioApName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..64))
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the sensor name."
    ::= { unisDot11WIPSApRadioEntry 1 }

unisDot11WIPSApRadioRadioID OBJECT-TYPE
    SYNTAX Integer32 (1..4)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents a radio identifier."
    ::= { unisDot11WIPSApRadioEntry 2 }

unisDot11WIPSApRadioStatus OBJECT-TYPE
    SYNTAX  UnisDot11WIPSEnabledStatus
    MAX-ACCESS read-write
    STATUS current
    DESCRIPTION
        "The enable status of WIPS on the radio."
    ::= { unisDot11WIPSApRadioEntry 3 }

unisDot11WIPSRuleTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11WIPSRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table defines signature rule or ap-class rule."
    ::= { unisDot11WIPSConfigGroup 4 }

unisDot11WIPSRuleEntry OBJECT-TYPE
    SYNTAX UnisDot11WIPSRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information about
         signature rule or ap-class rule."
    INDEX { unisDot11WIPSRuleType, unisDot11WIPSRuleId }
    ::= { unisDot11WIPSRuleTable 1 }

UnisDot11WIPSRuleEntry ::= SEQUENCE {
        unisDot11WIPSRuleType                UnisDot11WIPSRuleTypes,
        unisDot11WIPSRuleId                  Integer32,
        unisDot11WIPSRuleRowStatus           RowStatus
     }

unisDot11WIPSRuleType OBJECT-TYPE
    SYNTAX UnisDot11WIPSRuleTypes
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the rule type."
    ::= { unisDot11WIPSRuleEntry 1 }

unisDot11WIPSRuleId OBJECT-TYPE
    SYNTAX Integer32 (1..65535)
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Represents the rule id."
    ::= { unisDot11WIPSRuleEntry 2 }

unisDot11WIPSRuleRowStatus OBJECT-TYPE
    SYNTAX RowStatus
    MAX-ACCESS read-create
    STATUS current
    DESCRIPTION
        "The status of this table entry."
    ::= { unisDot11WIPSRuleEntry 3 }

unisDot11WIPSAlySigRuleTable OBJECT-TYPE
    SYNTAX SEQUENCE OF UnisDot11WIPSAlySigRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "The table provides information about applying signature rule."
    ::= { unisDot11WIPSConfigGroup 5 }

unisDot11WIPSAlySigRuleEntry OBJECT-TYPE
    SYNTAX UnisDot11WIPSAlySigRuleEntry
    MAX-ACCESS not-accessible
    STATUS current
    DESCRIPTION
        "Each entry contains information about applying signature rule."
    INDEX { unisDot11WIPSAlySigPolicyName, unisDot11WIPSAlySigRuleID }
    ::= { unisDot11WIPSAlySigRuleTable 1 }

UnisDot11WIPSAlySigRuleEntry ::= SEQUENCE {
        unisDot11WIPSAlySigPolicyName                OCTET STRING,
        unisDot11WIPSAlySigRuleID                    Integer32,
        unisDot11WIPSAlySigRowStatus                 RowStatus
     }

unisDot11WIPSAlySigPolicyName OBJECT-TYPE
    SYNTAX OCTET STRING (SIZE (1..63))
    MAX-ACCESS not-accessible
