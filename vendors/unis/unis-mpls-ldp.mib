--   MPLS Label Distribution Protocol MIB Definitions
UNIS-MPLS-LDP-MIB DEFINITIONS ::= BEGIN

     IMPORTS                  
         unisMpls
             FROM UNIS-OID-MIB
         OBJECT-TYPE, MODULE-IDENTITY, NOTIFICATION-TYPE,
         Integer32, Counter32, Unsigned32,IpAddress
             FROM SNMPv2-SMI
         MODULE-COMPLIANCE, OBJECT-GROUP, NOTIFICATION-GROUP
             FROM SNMPv2-CONF
         TEXTUAL-CONVENTION, TruthValue, RowStatus, TimeInterval
             FROM SNMPv2-TC;
             
     unisMplsLdp MODULE-IDENTITY
         LAST-UPDATED "9906301200Z"     -- June 30, 1999 at 12:00 GMT
         ORGANIZATION
             "Unisyue Technologies Co., Ltd."
         CONTACT-INFO
             ""
         DESCRIPTION  "All rights reserved"
         REVISION     "9611082155Z"
         DESCRIPTION  "The MIB for MPLS LDP module.
                       This MIB has been derived from the MPLS Working 
                       group LDP MIB <drst-ietf-mpls-ldp-mib-01.txt> and
                       MPLS Working group TE MIB <draft-ietf-mpls-te-mib
                       -01.txt>."

         ::= { unisMpls 2 }

     --********************************************************************
     -- MPLS LDP Textual Conventions
     --********************************************************************
     --

           DisplayString ::=
               OCTET STRING
          -- This data type is used to model textual information taken
          -- from the NVT ASCII character set.  By convention, objects
          -- with this syntax are declared as having
          --
                (SIZE (0..255))

           PhysAddress ::=
               OCTET STRING
          -- This data type is used to model media addresses.  For many
          -- types of media, this will be in a binary representation.
          -- For example, an ethernet address would be represented as
          -- a string of 6 octets.

	BitRate ::= INTEGER
	
	BurstSize ::= INTEGER
	
	
     MplsLsrIdentifier ::= TEXTUAL-CONVENTION
         STATUS      current
         DESCRIPTION
             "The Label Switch Router (LSR) identifier
             is the first 4 bytes or the IP Address component
             of the Label Distribution Protocol (LDP) identifier."
         SYNTAX      OCTET STRING (SIZE (4))

     MplsLdpGenAddr ::= TEXTUAL-CONVENTION
         STATUS      current
         DESCRIPTION
             "The value of an network layer or data link layer address."
         SYNTAX      OCTET STRING (SIZE (0..64))

     MplsLdpIdentifier ::= TEXTUAL-CONVENTION
         STATUS      current
         DESCRIPTION
             "The LDP identifier is a six octet quantity
             which is used to identify an Label Switch Router
             (LSR) label space.

             The first four octets encode an IP address
             assigned to the LSR, and the last two octets
             identify a specific label space within the LSR."
         SYNTAX      OCTET STRING (SIZE (6))

     AtmVpIdentifier ::= TEXTUAL-CONVENTION
          STATUS      current
          DESCRIPTION
              "The VPI value for a VPL. The value VPI=0 is not
              used for a VPL not associated with a VCL. For ATM
              UNIs supporting VPCs the VPI value ranges from 1
              to 255. For ATM UNIs supporting VCCs the VPI value
              ranges from 0 to 255.  The maximum VPI value
              cannot exceed the value allowable by
              atmInterfaceMaxVpiBits defined in ATM-MIB."
          SYNTAX INTEGER (0..4095)

     AtmVcIdentifier ::= TEXTUAL-CONVENTION
          STATUS      current
          DESCRIPTION
              "The VCI value for a VCL. The maximum VCI value
              cannot exceed the value allowable by
              atmInterfaceMaxVciBits defined in ATM-MIB."
          SYNTAX INTEGER (0..65535)

     AddressFamilyNumbers ::= TEXTUAL-CONVENTION
        STATUS        current
        DESCRIPTION
            "An address family.  Values are defined in RFC 1700 -
             Assigned Numbers.  All values may not be relevant in
             all contexts when used in this MIB, but are included
             for completeness."
        REFERENCE
            "RFC  1700   Assigned Numbers, Reynolds and  Postel,
             Oct. 1994"
        SYNTAX        INTEGER {
                        other(0),
                         ipv4(1),
                         ipv6(2),
                         nsap(3),
                         hdlc(4),
                         bbn1822(5),
                         ieee802(6),
                         e163(7),
                         e164(8),
                         f69(9),
                         x121(10),
                         ipx(11),
                         appleTalk(12),
                         decnetIV(13),
                         banyanVines(14),
                         e164WithNsap(15)
                     }


     MplsLabel ::= TEXTUAL-CONVENTION
        STATUS        current
        DESCRIPTION
            "Represents an MPLS label.  Note that the contents of
             a  label  field are interpreted in an interface-type
             specific fashion.  For example, the label carried in
             the MPLS shim header is 20 bits wide and the top  12
             bits  must  be zero.  The frame relay label  can  be
             either 10, 17 or 23 bits wide depending on the  size
             of the DLCI field size and the top 22, 15, or 9 bits
             must  be  zero, respectively.  For an ATM interface,
             the  lowermost 16 bits are interpreted as  the  VCI,
             the  next  8 bits as the VPI and the remaining  bits
             must  be  zero.   Also  note the  permissible  label
             values  are  also a function of the interface  type.
             For  example,  the value 3 has special semantics  in
             the  control plane for an MPLS shim header label and
             is not a valid label value in the datapath."
        REFERENCE
            "1.  MPLS  Label Stack Encoding, Rosen et al,  draft-
             ietf-mpls-label-encaps-04.txt, April 1999.
            2.  Use  of  Label Switching on Frame Relay Networks,
             Conta et al, draft-ietf-mpls-fr-03.txt, Nov. 1998."
        SYNTAX INTEGER
     
     MplsTunnelIndex ::= TEXTUAL-CONVENTION
        STATUS        current
        DESCRIPTION
            "Index into mplsTunnelTable."
        SYNTAX        INTEGER (0..65535)
     
     unisMplsLdpObjects       OBJECT IDENTIFIER ::= { unisMplsLdp 1 }
     unisMplsLdpNotifications OBJECT IDENTIFIER ::= { unisMplsLdp 2 }

     --****************************************************************
     -- MPLS LDP Objects
     --****************************************************************

     unisMplsLdpLsrObjects            OBJECT IDENTIFIER ::= { unisMplsLdpObjects 1 }
     unisMplsLdpEntityObjects         OBJECT IDENTIFIER ::= { unisMplsLdpObjects 2 }
     unisMplsLdpPeerObjects           OBJECT IDENTIFIER ::= { unisMplsLdpObjects 3 }
     unisMplsLdpSessionObjects        OBJECT IDENTIFIER ::= { unisMplsLdpObjects 4 }
     unisMplsLdpHelloAdjacencyObjects OBJECT IDENTIFIER ::= { unisMplsLdpObjects 5 }
     unisMplsLdpCrlspTnlObjects       OBJECT IDENTIFIER ::= { unisMplsLdpObjects 6 }

     --
     -- The MPLS Label Distribution Protocol Label Switch Router Objects
     --
     unisMplsLdpLsrIncarnTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpLsrIncarnEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "MPLS provides support for multiple incarnations of the 
              MPLS Stack in a target. The LSR defined in the standard <IETF
              DRAFT> MIB is treated as an incarnation in this MIB. Using a
              local policy the Network administrator must group the LDP Entities
              that should be placed in an incarnation."
         ::= { unisMplsLdpLsrObjects 1 }

     unisMplsLdpLsrIncarnEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpLsrIncarnEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An entry in this table represents an LSR incarnation.
              All the entries in this table are created initially when the 
              LDP is initiated. The row status of each entry will be in 
              'notInService' state initially. The row status must be set to
              'active' after the necessary configurations are complete with
              respect to an incarnation.

              Currenlty the LSR ID of the incarnation is the only mandatory
              parameter that must be set before the rowStatus is set to 
              'active'.

              An LSR Incarnation Entity is uniquely indexed by its Incarnation
              Identifier."
         INDEX       {  unisMplsLdpLsrIncarnID }
         ::= { unisMplsLdpLsrIncarnTable 1 }

     UnisMplsLdpLsrIncarnEntry ::= SEQUENCE {
         unisMplsLdpLsrID                                MplsLsrIdentifier,
         unisMplsLdpLsrLoopDetectionPresent              TruthValue,
         unisMplsLdpLsrLoopDetectionAdminStatus          INTEGER,
         unisMplsLdpLsrPathVectorLimit                   INTEGER,
         unisMplsLdpLsrHopCountLimit                     INTEGER,
         unisMplsLdpLsrLoopPreventionPresent             TruthValue,
         unisMplsLdpLsrLoopPreventionAdminStatus         INTEGER,
         unisMplsLdpLsrLabelRetentionMode                INTEGER,
         unisMplsLdpLsrIncarnID                          INTEGER,
         unisMplsLdpLsrMaxLdpEntities                    INTEGER,
         unisMplsLdpLsrMaxLocalPeers                     INTEGER,
         unisMplsLdpLsrMaxRemotePeers                    INTEGER,
         unisMplsLdpLsrMaxIfaces                         INTEGER,
         unisMplsLdpLsrMaxLsps                           INTEGER,
         unisMplsLdpLsrMaxCrlspTnls                      INTEGER,
         unisMplsLdpLsrMaxErhopPerCrlspTnl               INTEGER,
         unisMplsLdpLsrRowStatus                         RowStatus,
         unisMplsLdpLsrMaxVcmCapability                  INTEGER,  
         unisMplsLdpLsrVcmPathVecInAllLblMapPresent      TruthValue,
         unisMplsLdpLsrRequestRetrytimerValue            INTEGER,
         unisMplsLdpLsrNumOfRequestRetryAttempts         INTEGER
    }

     unisMplsLdpLsrID OBJECT-TYPE
         SYNTAX      MplsLsrIdentifier
         MAX-ACCESS  read-write   
         STATUS      current
         DESCRIPTION
             "The LSR's Identifier."
         ::= { unisMplsLdpLsrIncarnEntry 1 }

     unisMplsLdpLsrLoopDetectionPresent OBJECT-TYPE
         SYNTAX      TruthValue
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "A indication of whether this LSR supports loop detection.  A 
             value of 'true' indicates this LSR does support loop detection.  
             A value of 'false' indicates this LSR does not support
             loop detection."
         DEFVAL  { true }
         ::= { unisMplsLdpLsrIncarnEntry 2 }

     unisMplsLdpLsrLoopDetectionAdminStatus OBJECT-TYPE
         SYNTAX      INTEGER {
                         enabled(1),
                         disabled(2)
                     }
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "To enable loop detection the value of this object should be 
             'enabled(1)'.  Otherwise, to turn off loop detection, set this 
             value to 'disabled(2)'."
         DEFVAL  { enabled }
         ::= { unisMplsLdpLsrIncarnEntry 3 }

     unisMplsLdpLsrPathVectorLimit OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "This object only has meaning if unisMplsLdpLsrLoopDetectionPresent 
             has the value of 'true'.

             The value of this object represents the limit of path vectors which
             this LSR uses to treat the message as if it had traversed a loop."
         DEFVAL  { 32 }
         ::= { unisMplsLdpLsrIncarnEntry 4 }

     unisMplsLdpLsrHopCountLimit OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "This object only has meaning if unisMplsLdpLsrLoopDetectionPresent 
             has the value of 'true'.

             The value of this object represents the limit on the Hop Count 
             which this LSR uses to treat the message as if it had traversed a 
             loop."
         DEFVAL  { 32 }
         ::= { unisMplsLdpLsrIncarnEntry 5 }

     unisMplsLdpLsrLoopPreventionPresent OBJECT-TYPE
         SYNTAX      TruthValue
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "A indication of whether this LSR supports loop prevention.  A 
             value of 'true' indicates this LSR does support loop prevention.  
             A value of 'false' indicates this LSR does not support loop 
             prevention.

             Current release of MPLS does not provide support to assign
             this MIB object with a value 'true'."
         DEFVAL  { false }
         ::= { unisMplsLdpLsrIncarnEntry 6 }

     unisMplsLdpLsrLoopPreventionAdminStatus OBJECT-TYPE
         SYNTAX      INTEGER {
                         enabled(1),
                         disabled(2)
                     }
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "To enable loop prevention the value of this object should be 
             'enabled(1)'.  Otherwise, to turn off loop prevention, set this 
             value to 'disabled(2)'.

             Current release of MPLS does not provide support to assign
             this MIB object with a value 'enabled'."
         DEFVAL  { disabled }
         ::= { unisMplsLdpLsrIncarnEntry 7 }

     unisMplsLdpLsrLabelRetentionMode OBJECT-TYPE
         SYNTAX      INTEGER {
                         conservative(1),
                         liberal(2)
                     }
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The LSR can be configured to use either conservative or liberal 
              label retention mode.

             If the value of this object is conservative(1) then advertized 
             label mappings are retained only if they will be used to forward 
             packets, i.e. if label came from a valid next hop.  If the value of
             this object is liberal(2) then all advertized label mappings are 
             retained whether they are from a valid next hop or not.

             Current release of MPLS does not provide support to assign
             this MIB object with a value 'liberal'."
         DEFVAL  { conservative }
         ::= { unisMplsLdpLsrIncarnEntry 8 }

     unisMplsLdpLsrIncarnID   OBJECT-TYPE
         SYNTAX     INTEGER
         MAX-ACCESS read-only
         STATUS     current
         DESCRIPTION 
             "The incarnation acts as index to all the elements in this
              table."
         ::= { unisMplsLdpLsrIncarnEntry  9 }
 
     unisMplsLdpLsrMaxLdpEntities OBJECT-TYPE
         SYNTAX      INTEGER (1..1024)
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of LDP entities that can be supported by this
              Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 10 }

     unisMplsLdpLsrMaxLocalPeers OBJECT-TYPE
         SYNTAX      INTEGER (1..1024)
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of Local LDP peers that can be supported by 
              this Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 11 }

     unisMplsLdpLsrMaxRemotePeers OBJECT-TYPE
         SYNTAX      INTEGER (1..1024)
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of Remote LDP peers that can be supported by 
              this Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 12 }

     unisMplsLdpLsrMaxIfaces OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of Label enabled Interfaces that can be 
              supported by this Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 13 }

     unisMplsLdpLsrMaxLsps OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of Label Switched Paths that can be 
              supported by this Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 14 }

     unisMplsLdpLsrMaxCrlspTnls OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             "The maximum number of CRLSPs that can be supported by this
             Incarnation."
         ::= { unisMplsLdpLsrIncarnEntry 15 }


     unisMplsLdpLsrMaxErhopPerCrlspTnl OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
             " The maximum number of ER-Hops that can be supported in a 
              CRLSP tunnel."
         ::= { unisMplsLdpLsrIncarnEntry 16 }

     unisMplsLdpLsrRowStatus OBJECT-TYPE
         SYNTAX      RowStatus
         MAX-ACCESS  read-create
         STATUS      current
              DESCRIPTION
                  "An object that allows entries in this table to
                  be created and deleted using the
                  RowStatus convention."
         ::= { unisMplsLdpLsrIncarnEntry 17 }

     unisMplsLdpLsrMaxVcmCapability OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
                  "  "
         ::= { unisMplsLdpLsrIncarnEntry 18 }

     unisMplsLdpLsrVcmPathVecInAllLblMapPresent OBJECT-TYPE
         SYNTAX      TruthValue
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
                  "  "
         ::= { unisMplsLdpLsrIncarnEntry 19 }

     unisMplsLdpLsrRequestRetrytimerValue  OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
                  "  "
         ::= { unisMplsLdpLsrIncarnEntry 20 }

     unisMplsLdpLsrNumOfRequestRetryAttempts OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-write
         STATUS      current
         DESCRIPTION
                  "  "
         ::= { unisMplsLdpLsrIncarnEntry 21 }


     --
     -- The MPLS Label Distribution Protocol Entity Table
     --

     unisMplsLdpEntityTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpEntityEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "This table contains information about the
             MPLS Label Distribution Protocol Entities which
             exist on this Label Switch Router (LSR)."
         ::= { unisMplsLdpEntityObjects 1 }

     unisMplsLdpEntityEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpEntityEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An entry in this table represents an LDP entity.
             An entry can be created by a network administrator
             or by an SNMP agent as instructed by LDP.

             An LPD Entity is uniquely indexed by its LPD
             Identifier."
         INDEX       {   unisMplsLdpLsrIncarnID, unisMplsLdpEntityIfIndex  }
         ::= { unisMplsLdpEntityTable 1 }

     UnisMplsLdpEntityEntry ::= SEQUENCE {
         unisMplsLdpEntityID                            MplsLdpIdentifier,
         unisMplsLdpEntityLabelSpaceType                INTEGER,
         unisMplsLdpEntityDefVpi                        AtmVpIdentifier,
         unisMplsLdpEntityDefVci                        AtmVcIdentifier,
         unisMplsLdpEntityUnlabTrafVpi                  AtmVpIdentifier,
         unisMplsLdpEntityUnlabTrafVci                  AtmVcIdentifier,
         unisMplsLdpEntityMergeCapability               INTEGER,
         unisMplsLdpEntityVcDirectionality              INTEGER,
         unisMplsLdpEntityWellKnownDiscoveryPort        INTEGER,
         unisMplsLdpEntityMtu                           INTEGER,
         unisMplsLdpEntityKeepAliveHoldTimer            INTEGER,
         unisMplsLdpEntityFailedInitSessionThreshold    INTEGER,
         unisMplsLdpEntityLabelDistributionMethod       INTEGER,
         unisMplsLdpEntityLabelAllocationMethod         INTEGER,
         unisMplsLdpEntityHelloHoldTimer                INTEGER,
         unisMplsLdpEntityRowStatus                     RowStatus
     }

     unisMplsLdpEntityID OBJECT-TYPE
         SYNTAX      MplsLdpIdentifier
         MAX-ACCESS  accessible-for-notify
         STATUS      current
         DESCRIPTION
             "The LDP identifier which uniquely identifies
             the LDP Entity.  This is s six octet quantity
             which is used to identify an Label Switch Router
             (LSR) label space.

             The first four octets encode an IP address
             assigned to the LSR, and the last two octets
             identify a specific label space within the
             LSR."
         REFERENCE
             "LDP Specification, Section on LDP Identifiers."
         ::= { unisMplsLdpEntityEntry 1 }


     unisMplsLdpEntityLabelSpaceType OBJECT-TYPE
         SYNTAX      INTEGER {
                         unknown(1),
                         perInterface(2),
                         perPlatform(3)
                         }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The type of label spaces associated with this
             LDP Entity.  The values are

                'unknown(1)'        The type of label space is
                                    not known.

                'perInterface(2)'   The type of label space is
                                    tied to an interface.
                'perPlatform(3)'    The type of label space is
                                    tied to the platform."
         REFERENCE
             "LDP Specification, Section on Label Spaces."
         ::= { unisMplsLdpEntityEntry 2 }

     unisMplsLdpEntityDefVpi OBJECT-TYPE
         SYNTAX      AtmVpIdentifier
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The Default VPI value used in the label for the default
             VPI."
         ::= { unisMplsLdpEntityEntry 3 }

     unisMplsLdpEntityDefVci OBJECT-TYPE
         SYNTAX      AtmVcIdentifier
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The Default VCI value used in the label for the default
             VCI."
         ::= { unisMplsLdpEntityEntry  4 }

     unisMplsLdpEntityUnlabTrafVpi OBJECT-TYPE
         SYNTAX      AtmVpIdentifier
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "VPI value of the VCC supporting unlabeled traffic."
         DEFVAL  { 0 }
         ::= { unisMplsLdpEntityEntry 5 }

     unisMplsLdpEntityUnlabTrafVci OBJECT-TYPE
         SYNTAX      AtmVcIdentifier
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "VCI value of the VCC supporting unlabeled traffic."
         DEFVAL  { 32 }
         ::= { unisMplsLdpEntityEntry 6 }

     unisMplsLdpEntityMergeCapability OBJECT-TYPE
         SYNTAX      INTEGER {
                         noMerge(0),
                         vpMerge(1),
                         vcMerge(2),
                         vpVcMerge(3)
                      }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "Sets the merge capability for this LDP entity.

              Current Release of MPLS does not provide support for
              any kind of Merge."
         REFERENCE
             "draft-ietf-mpls-ldp-04.txt, Section 3.5.3"
         ::= { unisMplsLdpEntityEntry 7 }

     unisMplsLdpEntityVcDirectionality OBJECT-TYPE
         SYNTAX      INTEGER {
                         bidirectional(1),
                         unidirectional(2)
                     }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "Sets the VC directionality for this LDP entity."
         REFERENCE
             "draft-ietf-mpls-ldp-04.txt, Section 3.5.3"
         ::= { unisMplsLdpEntityEntry 8 }

     unisMplsLdpEntityWellKnownDiscoveryPort OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The well known LDP Discovery Port."
         ::= { unisMplsLdpEntityEntry 9 }

     unisMplsLdpEntityMtu OBJECT-TYPE
         SYNTAX      INTEGER (0..65535)
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The maximum transmission unit (MTU) that was configured
             for this entity."
         ::= { unisMplsLdpEntityEntry 10 }

     unisMplsLdpEntityKeepAliveHoldTimer OBJECT-TYPE
         SYNTAX      INTEGER (1..65535)
         UNITS       "seconds"
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The two octet value which is the proposed keep alive hold
             timer for this LDP Entity."
         ::= { unisMplsLdpEntityEntry 11 }

     unisMplsLdpEntityFailedInitSessionThreshold OBJECT-TYPE
         SYNTAX      INTEGER
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "When attempting to establish a session with a
             given Peer, the given LDP Entity should
             send out a notification when exceeding this threshold.
             A value of 0 (zero) for this object
             indicates that the threshold is infinity.
             In other words, a notification will not
             be sent if the value of this object is 0 (zero)."
         ::= { unisMplsLdpEntityEntry 12 }


     unisMplsLdpEntityLabelDistributionMethod OBJECT-TYPE
         SYNTAX      INTEGER {
                        downstreamOnDemand(1),
                        downstreamUnsolicited(2)
                     }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "For any given LDP session, the method of
             label distribution must be specified.
 
             Current release of MPLS does not provide support for
             'downstreamUnsolicited'."
         REFERENCE
             "draft-ietf-mpls-arch-04.txt [20]."
         ::= { unisMplsLdpEntityEntry 13 }

     unisMplsLdpEntityLabelAllocationMethod OBJECT-TYPE
         SYNTAX      INTEGER {
                        ordered(1),
                        independent(2)
                     }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "For any given LDP session, the method of
             label allocation must be specified. Label can be allocated
             in either ordered mode or in the independent mode."
         DEFVAL  { ordered }
         ::= { unisMplsLdpEntityEntry 14 }

     unisMplsLdpEntityHelloHoldTimer OBJECT-TYPE
         SYNTAX      INTEGER (1..65535)
         UNITS       "seconds"
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The two octet value which is the proposed hello hold
             timer for this LDP Entity."
         ::= { unisMplsLdpEntityEntry 15 }
     
     unisMplsLdpEntityRowStatus OBJECT-TYPE
         SYNTAX      RowStatus
         MAX-ACCESS  read-create
         STATUS      current
              DESCRIPTION
                  "An object that allows entries in this table to
                  be created and deleted using the
                  RowStatus convention."
         ::= { unisMplsLdpEntityEntry 16 }

     --
     -- The MPLS LDP Entity Interface Table
     --

     unisMplsLdpEntityIfTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpEntityIfEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "This table contains information about the
             interfaces that are associated with an LDP Entity.
             There should be atleast one interface associated with
             each LDP Entity. If the LDP Entity supports 'per interface
             based label space' label type then, atmost one interface can be 
             associated with the LDP entity. If the LDP Entity supports
             'per platform based label space' label type then, more than one
             interface can be associated with the LDP Entity."
         ::= { unisMplsLdpEntityObjects 2 }

     unisMplsLdpEntityIfEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpEntityIfEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An entry in this table represents an Interface that is
             associated with a LDP entity.

             An entry can be created by a network administrator
             or by an SNMP agent as instructed by LDP.

             An interface (row in this table) can be created/deleted only when 
             the associted LDP Entity row status has the value notInService 
             or notReady."
         INDEX       {   unisMplsLdpLsrIncarnID, unisMplsLdpEntityIfIndex }
         ::= { unisMplsLdpEntityIfTable 1 }

     UnisMplsLdpEntityIfEntry ::= SEQUENCE {
         unisMplsLdpEntityIfIndex                       Unsigned32,
         unisMplsLdpEntityIfIpv4Address                 IpAddress,
         unisMplsLdpEntityIfRowStatus                   RowStatus
     }

     unisMplsLdpEntityIfIndex OBJECT-TYPE
         SYNTAX      Unsigned32 (1..4294967295)
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "Identifier that uniquely identifies the Interface with 
             respect to an LDP Entity.
             
             The ifIndex value corresponds to the IfIndex value of the
             MIB-II"
         ::= { unisMplsLdpEntityIfEntry 1 }

     unisMplsLdpEntityIfIpv4Address OBJECT-TYPE
        SYNTAX        IpAddress
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The IPv4 address associated with the interface."
        ::= { unisMplsLdpEntityIfEntry 2 }

     unisMplsLdpEntityIfRowStatus OBJECT-TYPE
         SYNTAX      RowStatus
         MAX-ACCESS  read-create
         STATUS      current
              DESCRIPTION
                  "An object that allows entries in this table to
                  be created and deleted using the
                  RowStatus convention."
         ::= { unisMplsLdpEntityIfEntry 3 }

     --
     -- The MPLS LDP Entity Configurable ATM Label Range Table
     --

     unisMplsLdpEntityConfAtmLabelRangeTable OBJECT-TYPE
         SYNTAX SEQUENCE OF UnisMplsLdpEntityConfAtmLabelRangeEntry
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The MPLS LDP Entity Configurable ATM Label Range Table.
             The purpose of this table is to provide a mechanism
             for specifying a contiguous range of vpi's
             with a contiguous range of vci's, or a 'label range'
             for LDP Entities.

             LDP Entities which use ATM must have at least one
             entry in this table."
         ::= { unisMplsLdpEntityObjects 3 }

     unisMplsLdpEntityConfAtmLabelRangeEntry OBJECT-TYPE
         SYNTAX UnisMplsLdpEntityConfAtmLabelRangeEntry
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "A row in the LDP Entity Configurable ATM Label
             Range Table.  One entry in this table contains
             information on a single range of labels
             represented by the configured Upper and Lower
             Bounds VPI/VCI pairs.
             NOTE:  The ranges for a specific LDP Entity
             are UNIQUE and non-overlapping.  For example,
             for a specific LDP Entity index, there could
             be one entry having ConfLowerBound vpi/vci == 0/32, and
             ConfUpperBound vpi/vci == 0/100, and a second entry for this
             same interface with ConfLowerBound vpi/vci == 0/101 and
             ConfUpperBound vpi/vci == 0/200.  However, there could not be
             a third entry with ConfLowerBound vpi/vci == 0/200 and
             ConfUpperBound vpi/vci == 0/300 because this label range overlaps
             with the second entry (i.e. both entries now have 0/200).

             A row will not be created unless a unique and non-overlapping
             range is specified.  Thus, row creation implies a one-shot
             row creation of LDP EntityID and ConfLowerBound vpi/vci and
             ConfUpperBound vpi/vci.  At least one label range entry
             for a specific LDP Entity MUST include the default VPI/VCI
             values denoted in the LDP Entity Table."
         INDEX { unisMplsLdpLsrIncarnID, unisMplsLdpEntityIfIndex,
                 unisMplsLdpEntityConfAtmLabelRangeLowerBoundVPI,
                 unisMplsLdpEntityConfAtmLabelRangeLowerBoundVCI  }
         ::= { unisMplsLdpEntityConfAtmLabelRangeTable 1 }

     UnisMplsLdpEntityConfAtmLabelRangeEntry ::= SEQUENCE {
         unisMplsLdpEntityConfAtmLabelRangeLowerBoundVPI  AtmVpIdentifier,
         unisMplsLdpEntityConfAtmLabelRangeLowerBoundVCI  AtmVcIdentifier,
         unisMplsLdpEntityConfAtmLabelRangeUpperBoundVPI  AtmVpIdentifier,
         unisMplsLdpEntityConfAtmLabelRangeUpperBoundVCI  AtmVcIdentifier,
         unisMplsLdpEntityConfAtmLabelRangeRowStatus      RowStatus
     }

     unisMplsLdpEntityConfAtmLabelRangeLowerBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The minimum VPI number configured for this range."
         ::= { unisMplsLdpEntityConfAtmLabelRangeEntry 1 }

     unisMplsLdpEntityConfAtmLabelRangeLowerBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The minimum VCI number configured for this range."
         ::= { unisMplsLdpEntityConfAtmLabelRangeEntry 2 }

     unisMplsLdpEntityConfAtmLabelRangeUpperBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS read-create
         STATUS current
         DESCRIPTION
             "The maximum VPI number configured for this range."
         ::= { unisMplsLdpEntityConfAtmLabelRangeEntry 3 }

     unisMplsLdpEntityConfAtmLabelRangeUpperBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS read-create
         STATUS current
         DESCRIPTION
             "The maximum VCI number configured for this range."
        ::= { unisMplsLdpEntityConfAtmLabelRangeEntry 4 }

     unisMplsLdpEntityConfAtmLabelRangeRowStatus OBJECT-TYPE
         SYNTAX RowStatus
         MAX-ACCESS read-create
         STATUS current
              DESCRIPTION
                  "An object that allows entries in this
                  table to be created and deleted using
                  the RowStatus convention."
         ::= { unisMplsLdpEntityConfAtmLabelRangeEntry 5 }


     --
     -- The MPLS LDP Entity Statistics Table
     --

     unisMplsLdpEntityStatsTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpEntityStatsEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "This table is a read-only table which augments
             the MplsLdpConfEntityTable.  The purpose of this
             table is to keep statistical information about
             the LDP Entities on the LSR."
         ::= { unisMplsLdpEntityObjects 4 }

     unisMplsLdpEntityStatsEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpEntityStatsEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "A row in this table contains statistical information
             about an LDP Entity."
         AUGMENTS       {   unisMplsLdpEntityEntry  }
         ::= { unisMplsLdpEntityStatsTable 1 }

     UnisMplsLdpEntityStatsEntry ::= SEQUENCE {
         unisMplsLdpAttemptedSessions      Counter32
     }

     unisMplsLdpAttemptedSessions OBJECT-TYPE
         SYNTAX      Counter32
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "A count of the total attempted sessions for
             this LDP Entity."
         ::= { unisMplsLdpEntityStatsEntry 1 }


     --
     -- The MPLS LDP Peer Table
     --


     unisMplsLdpPeerTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpPeerEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "Information about LDP peers which have been discovered
             by the LDP Entities that are managed by this agent."
         ::= { unisMplsLdpPeerObjects 1 }

     unisMplsLdpPeerEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpPeerEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "Information about a single Peer."
         INDEX       { unisMplsLdpLsrIncarnID, unisMplsLdpEntityIfIndex,
                       unisMplsLdpPeerIndex }
         ::= { unisMplsLdpPeerTable 1 }

     UnisMplsLdpPeerEntry ::= SEQUENCE {
         unisMplsLdpPeerIndex                      Unsigned32,
         unisMplsLdpPeerID                         MplsLdpIdentifier,
         unisMplsLdpPeerInternetworkAddrType       AddressFamilyNumbers,
         unisMplsLdpPeerInternetworkAddr           MplsLdpGenAddr,
         unisMplsLdpPeerDefaultMtu                 INTEGER,
         unisMplsLdpPeerKeepAliveHoldTimer         INTEGER,
         unisMplsLdpPeerLabelDistributionMethod    INTEGER,
         unisMplsLdpPeerType                       INTEGER,
         unisMplsLdpPeerRowStatus                  RowStatus
     }

     unisMplsLdpPeerIndex OBJECT-TYPE
         SYNTAX      Unsigned32 (1..4294967295)
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An identifier for the LDP peer that is unique within the
              scope of this agent."
         ::= { unisMplsLdpPeerEntry 1 }

     unisMplsLdpPeerID OBJECT-TYPE
         SYNTAX      MplsLdpIdentifier
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The LDP identifier of this LDP Peer."
         ::= { unisMplsLdpPeerEntry 2 }

     unisMplsLdpPeerInternetworkAddrType OBJECT-TYPE
         SYNTAX      AddressFamilyNumbers
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The type of the internetwork layer address of this
             LDP peer. This object indicates how the value of
             unisMplsLdpPeerInternetworkAddr is to be interpreted."
         ::= { unisMplsLdpPeerEntry 3 }

     unisMplsLdpPeerInternetworkAddr OBJECT-TYPE
         SYNTAX      MplsLdpGenAddr
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The value of the internetwork layer address of this LDP peer."
         ::= { unisMplsLdpPeerEntry 4 }

     unisMplsLdpPeerDefaultMtu OBJECT-TYPE
         SYNTAX      INTEGER (0..65535)
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The default maximum transmission unit (MTU) of the
             LDP Peer."
         DEFVAL      { 9180 }
         ::= { unisMplsLdpPeerEntry 5 }

     unisMplsLdpPeerKeepAliveHoldTimer OBJECT-TYPE
         SYNTAX      INTEGER (1..65535)
         UNITS       "seconds"
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "The two octet unsigned non zero INTEGER that indicates
             the number of seconds that this Peer proposes for the
             value of the KeepAlive Interval."
         ::= { unisMplsLdpPeerEntry 6 }

     unisMplsLdpPeerLabelDistributionMethod OBJECT-TYPE
         SYNTAX      INTEGER {
                        downstreamOnDemand(1),
                        downstreamUnsolicited(2)
                     }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "For any given LDP session, the method of
             label distribution must be specified."
         REFERENCE
             "draft-ietf-mpls-arch-05.txt [20]."
         ::= { unisMplsLdpPeerEntry 7 }

     unisMplsLdpPeerType OBJECT-TYPE
         SYNTAX      INTEGER {
                        local(1),
                        remote(2)
                     }
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "Indicates whether a peer is a local peer or a remote peer"
         ::= { unisMplsLdpPeerEntry 8 } 
     
     unisMplsLdpPeerRowStatus OBJECT-TYPE
         SYNTAX      RowStatus
         MAX-ACCESS  read-create
         STATUS      current
         DESCRIPTION
             "An object that allows entries in this table to be created
             and deleted using the RowStatus convention."
         ::= { unisMplsLdpPeerEntry 9 }

     --
     -- The MPLS LDP Peer Configurable ATM Label Range Table
     --

     unisMplsLdpPeerConfAtmLabelRangeTable OBJECT-TYPE
         SYNTAX SEQUENCE OF UnisMplsLdpPeerConfAtmLabelRangeEntry
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The MPLS LDP Peer Configurable ATM Label Range Table.
             The purpose of this table is to provide a mechanism
             for specifying a contiguous range of vpi's with a contiguous
             range of vci's, or a 'label range' for LDP Peers.
             LDP Peers which use ATM must have at least one
             entry in this table."
         ::= { unisMplsLdpPeerObjects 2 }

     unisMplsLdpPeerConfAtmLabelRangeEntry OBJECT-TYPE
         SYNTAX UnisMplsLdpPeerConfAtmLabelRangeEntry
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "A row in the LDP Peer Configurable ATM Label Range Table.
             One entry in this table contains information
             on a single range of labels represented by
             the configured Upper and Lower Bounds VPI/VCI pairs.

             NOTE:  The ranges for a specific LDP Peer
             are UNIQUE and non-overlapping.  For example,
             for a specific LDP Peer index, there could
             be one entry having ConfLowerBound vpi/vci == 0/32, and
             ConfUpperBound vpi/vci == 0/100, and a second entry for this
             same interface with ConfLowerBound vpi/vci == 0/101 and
             ConfUpperBound vpi/vci == 0/200.  However, there could not be
             a third entry with ConfLowerBound vpi/vci == 0/200 and
             ConfUpperBound vpi/vci == 0/300 because this label range overlaps
             with the second entry (i.e. both entries now have 0/200).

             A row will not be created unless a unique and non-overlapping
             range is specified.  Thus, row creation implies a one-shot
             row creation of LDP PeerIndex and ConfLowerBound vpi/vci and
             ConfUpperBound vpi/vci.  At least one label range entry
             for a specific LDP Peer MUST include the default VPI/VCI
             values denoted in the LDP Peer Table."
         INDEX { unisMplsLdpLsrIncarnID, unisMplsLdpEntityIfIndex,
                 unisMplsLdpPeerIndex,
                 unisMplsLdpPeerConfAtmLabelRangeLowerBoundVPI,
                 unisMplsLdpPeerConfAtmLabelRangeLowerBoundVCI  }
         ::= { unisMplsLdpPeerConfAtmLabelRangeTable 1 }

     UnisMplsLdpPeerConfAtmLabelRangeEntry ::= SEQUENCE {
         unisMplsLdpPeerConfAtmLabelRangeLowerBoundVPI      AtmVpIdentifier,
         unisMplsLdpPeerConfAtmLabelRangeLowerBoundVCI      AtmVcIdentifier,
         unisMplsLdpPeerConfAtmLabelRangeUpperBoundVPI      AtmVpIdentifier,
         unisMplsLdpPeerConfAtmLabelRangeUpperBoundVCI      AtmVcIdentifier
     }

     unisMplsLdpPeerConfAtmLabelRangeLowerBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The minimum VPI number configured for this range."
         ::= { unisMplsLdpPeerConfAtmLabelRangeEntry 1 }

     unisMplsLdpPeerConfAtmLabelRangeLowerBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS not-accessible
         STATUS current
         DESCRIPTION
             "The minimum VCI number configured for this range."
         ::= { unisMplsLdpPeerConfAtmLabelRangeEntry 2 }

     unisMplsLdpPeerConfAtmLabelRangeUpperBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS read-only  
         STATUS current
         DESCRIPTION
             "The maximum VPI number configured for this range."
         ::= { unisMplsLdpPeerConfAtmLabelRangeEntry 3 }

     unisMplsLdpPeerConfAtmLabelRangeUpperBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS read-only  
         STATUS current
         DESCRIPTION
             "The maximum VCI number configured for this range."
        ::= { unisMplsLdpPeerConfAtmLabelRangeEntry 4 }

     --
     -- The MPLS LDP Sessions Table
     --


     unisMplsLdpSessionTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpSessionEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "A table of Sessions between the LDP Entities and
             LDP Peers."
         ::= { unisMplsLdpSessionObjects 1 }

     unisMplsLdpSessionEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpSessionEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An entry in this table represents information on a
             single session between an LDP Entity and LDP Peer."
         INDEX       { unisMplsLdpLsrIncarnID,
                       unisMplsLdpEntityIfIndex,
                       unisMplsLdpPeerIndex,
                       unisMplsLdpSessionIndex
                     }
         ::= { unisMplsLdpSessionTable 1 }

     UnisMplsLdpSessionEntry ::= SEQUENCE {
         unisMplsLdpSessionIndex                          Unsigned32,
         unisMplsLdpSessionID                             MplsLdpIdentifier,
         unisMplsLdpSessionProtocolVersion                INTEGER,
         unisMplsLdpSessionKeepAliveHoldTimeRemaining     TimeInterval,
         unisMplsLdpSessionRole                           INTEGER,
         unisMplsLdpSessionState                          INTEGER,
         unisMplsLdpSessionAtmLabelRangeLowerBoundVPI     AtmVpIdentifier,
         unisMplsLdpSessionAtmLabelRangeLowerBoundVCI     AtmVcIdentifier,
         unisMplsLdpSessionAtmLabelRangeUpperBoundVPI     AtmVpIdentifier,
         unisMplsLdpSessionAtmLabelRangeUpperBoundVCI     AtmVcIdentifier
     }

     unisMplsLdpSessionIndex OBJECT-TYPE
         SYNTAX      Unsigned32 (1..4294967295)
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An unique identifier for this entry such that it
             identifies a specific LDP Session."
         ::= { unisMplsLdpSessionEntry 1 }

     unisMplsLdpSessionID OBJECT-TYPE
         SYNTAX      MplsLdpIdentifier
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "The LDP Session identifier."
         ::= { unisMplsLdpSessionEntry 2 }

     unisMplsLdpSessionProtocolVersion OBJECT-TYPE
              SYNTAX      INTEGER(0..65535)
              MAX-ACCESS  read-only
              STATUS      current
              DESCRIPTION
                  "The version of the LDP Protocol which
                  this session is using."
              ::= { unisMplsLdpSessionEntry 3 }

     unisMplsLdpSessionKeepAliveHoldTimeRemaining OBJECT-TYPE
         SYNTAX      TimeInterval
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "The keep alive hold time remaining for this session."
         ::= { unisMplsLdpSessionEntry 4 }

     unisMplsLdpSessionRole OBJECT-TYPE
         SYNTAX      INTEGER {
                        active(1),
                        passive(2)
                     }
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "An indication of whether the LDP Entity associated with
             this session is acting in an 'active' role or
             a 'passive' role."
         ::= { unisMplsLdpSessionEntry 5 }

     unisMplsLdpSessionState OBJECT-TYPE
         SYNTAX      INTEGER {
                        nonexistent(1),
                        initialized(2),
                        openrec(3),
                        opensent(4),
                        operational(5)
                     }
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "The current state of the session, all of the
             states 1 - 5 are based on the state machine for
             session negotiation behavior."
         ::= { unisMplsLdpSessionEntry 6 }

     unisMplsLdpSessionAtmLabelRangeLowerBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS read-only
         STATUS current
         DESCRIPTION
             "The minimum VPI number for this range."
         ::= { unisMplsLdpSessionEntry 7 }

     unisMplsLdpSessionAtmLabelRangeLowerBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS read-only
         STATUS current
         DESCRIPTION
             "The minimum VCI number for this range."
         ::= { unisMplsLdpSessionEntry 8 }

     unisMplsLdpSessionAtmLabelRangeUpperBoundVPI OBJECT-TYPE
         SYNTAX AtmVpIdentifier
         MAX-ACCESS read-only
         STATUS current
         DESCRIPTION
             "The maximum VPI number for this range."
         ::= { unisMplsLdpSessionEntry 9 }

     unisMplsLdpSessionAtmLabelRangeUpperBoundVCI OBJECT-TYPE
         SYNTAX AtmVcIdentifier
         MAX-ACCESS read-only
         STATUS current
         DESCRIPTION
             "The maximum VCI number for this range."
         ::= { unisMplsLdpSessionEntry 10 }



     --
     -- The MPLS LDP Hello Adjacency Table
     --


     unisMplsLdpHelloAdjacencyTable OBJECT-TYPE
         SYNTAX      SEQUENCE OF UnisMplsLdpHelloAdjacencyEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "A table of Hello Adjacencies for Sessions."
         ::= { unisMplsLdpHelloAdjacencyObjects 1 }

     unisMplsLdpHelloAdjacencyEntry OBJECT-TYPE
         SYNTAX      UnisMplsLdpHelloAdjacencyEntry
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "Each row represents a single LDP Hello Adjacency.
             An LDP Session can have one or more Hello adjacencies."
         INDEX       { unisMplsLdpLsrIncarnID,
                       unisMplsLdpEntityIfIndex, 
                       unisMplsLdpPeerIndex,
                       unisMplsLdpSessionIndex,
                       unisMplsLdpHelloAdjacencyIndex }
         ::= { unisMplsLdpHelloAdjacencyTable 1 }

     UnisMplsLdpHelloAdjacencyEntry ::= SEQUENCE {
         unisMplsLdpHelloAdjacencyIndex                  Unsigned32,
         unisMplsLdpHelloAdjacencyHoldTimeRemaining      TimeInterval
     }

     unisMplsLdpHelloAdjacencyIndex OBJECT-TYPE
         SYNTAX      Unsigned32 (1..4294967295)
         MAX-ACCESS  not-accessible
         STATUS      current
         DESCRIPTION
             "An identifier for the adjacency."
         ::= { unisMplsLdpHelloAdjacencyEntry 1 }

     unisMplsLdpHelloAdjacencyHoldTimeRemaining OBJECT-TYPE
         SYNTAX      TimeInterval
         MAX-ACCESS  read-only
         STATUS      current
         DESCRIPTION
             "The time remaining for this Hello Adjacency."
         ::= { unisMplsLdpHelloAdjacencyEntry 2 }

     --
     -- FSMPLS- CRLSP Table
     --

     unisMplsLdpCrlspTnlTable OBJECT-TYPE
        SYNTAX        SEQUENCE OF UnisMplsLdpCrlspTnlEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "The unisMplsLdpCrlspTnlTable allows new CRLSP MPLS tunnels
             to be created. The ER hops associated with a CRLSP tunnel
             are to be configured using the unisMplsLdpCrlspErHopTable."
        ::= { unisMplsLdpCrlspTnlObjects 1 }
     
     unisMplsLdpCrlspTnlEntry OBJECT-TYPE
        SYNTAX        UnisMplsLdpCrlspTnlEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "An  entry  in this table represents an CRLSP MPLS  tunnel.
             An  entry  can be created by a network administrator."
        INDEX  {  unisMplsLdpLsrIncarnID,  unisMplsLdpCrlspTnlIndex  }
           ::= { unisMplsLdpCrlspTnlTable 1 }
     
     UnisMplsLdpCrlspTnlEntry ::= SEQUENCE {
           unisMplsLdpCrlspTnlIndex                 MplsTunnelIndex,
           unisMplsLdpCrlspTnlName                  DisplayString,
           unisMplsLdpCrlspTnlDirection             INTEGER,
           unisMplsLdpCrlspTnlSignallingProto       INTEGER,
           unisMplsLdpCrlspTnlSetupPrio             INTEGER,
           unisMplsLdpCrlspTnlHoldingPrio           INTEGER,
           unisMplsLdpCrlspTnlPeakDataRate          BitRate,
           unisMplsLdpCrlspTnlPeakBurstSize         BurstSize,
           unisMplsLdpCrlspTnlCommittedDataRate     BitRate,
           unisMplsLdpCrlspTnlCommittedBurstSize    BurstSize,
           unisMplsLdpCrlspTnlExcessBurstSize       BurstSize,
           unisMplsLdpCrlspTnlIsPinned              TruthValue,
           unisMplsLdpCrlspTnlFrequency             INTEGER,
           unisMplsLdpCrlspTnlWeight                INTEGER,
           unisMplsLdpCrlspTnlRowStatus             RowStatus
        }
     
     unisMplsLdpCrlspTnlIndex OBJECT-TYPE
        SYNTAX        MplsTunnelIndex
        MAX-ACCESS    accessible-for-notify
        STATUS        current
        DESCRIPTION
            "Uniquely identifies this row."
        ::= { unisMplsLdpCrlspTnlEntry 1 }
     
     unisMplsLdpCrlspTnlName OBJECT-TYPE
        SYNTAX        DisplayString
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The 'canonical' name assigned to the tunnel that can
             be  used  to refer to it on the 'console' port."
        ::= { unisMplsLdpCrlspTnlEntry 2 }
     
     
     unisMplsLdpCrlspTnlDirection OBJECT-TYPE
        SYNTAX        INTEGER { in(1), out(2), inOut(3) }
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Whether   this  tunnel  is  unidirectional-incoming,
             unidirectional-outgoing, or bidirectional."
        ::= { unisMplsLdpCrlspTnlEntry 3 }
     
     
     unisMplsLdpCrlspTnlSignallingProto OBJECT-TYPE
        SYNTAX        INTEGER { none(1), ldp(2), rsvp(3) }
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The  signaling protocol, if any, that  set  up  this
             tunnel."
        DEFVAL        { none }
        ::= { unisMplsLdpCrlspTnlEntry 4 }
     
     unisMplsLdpCrlspTnlSetupPrio OBJECT-TYPE
        SYNTAX        INTEGER (0..7)
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The setup priority of this tunnel."
        REFERENCE
            "Extensions to RSVP for LSP Tunnels, Awduche  et  al,
             Internet  Draft <draft-mpls-rsvp-lsp-tunnel-02.txt>,
             March  1999., Constraint-Based LSP Setup using  LDP,
             Jamoussi,  Internet  Draft  <draft-ietf-mpls-cr-ldp-
             01.txt>, Feb. 1999."
        ::= { unisMplsLdpCrlspTnlEntry 5 }
     
     unisMplsLdpCrlspTnlHoldingPrio OBJECT-TYPE
        SYNTAX        INTEGER (0..7)
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The holding priority for this tunnel."
        REFERENCE
            "  Extensions to RSVP for LSP Tunnels, Awduche et al,
             Internet  Draft <draft-mpls-rsvp-lsp-tunnel-02.txt>,
             March  1999., Constraint-Based LSP Setup using  LDP,
             Jamoussi,  Internet  Draft  <draft-ietf-mpls-cr-ldp-
             01.txt>, Feb. 1999."
        ::= { unisMplsLdpCrlspTnlEntry 6 }
     
     unisMplsLdpCrlspTnlPeakDataRate OBJECT-TYPE
        SYNTAX        BitRate
        UNITS         "bits per second"
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The peak rate - the maximum rate at which traffic will be sent on the
             CRLSP."
        REFERENCE
            "Section 4.3.1.2, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        DEFVAL        { 0 }
        ::= { unisMplsLdpCrlspTnlEntry 7 }
     
     unisMplsLdpCrlspTnlPeakBurstSize OBJECT-TYPE
        SYNTAX        BurstSize
        UNITS         "bytes"
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The peak burst size - the maximum burst size of the traffic that can 
             occur in the established CRLSP."
        REFERENCE
            "Section 4.3, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        DEFVAL        { 0 }
        ::= { unisMplsLdpCrlspTnlEntry 8 }
     
     unisMplsLdpCrlspTnlCommittedDataRate OBJECT-TYPE
        SYNTAX        BitRate
        UNITS         "bits per second"
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The committed rate - the committed rate at which traffic will be sent on the
             CRLSP."
        REFERENCE
            "Section 4.3.1.3, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        DEFVAL        { 0 }
        ::= { unisMplsLdpCrlspTnlEntry 9 }
     
     unisMplsLdpCrlspTnlCommittedBurstSize OBJECT-TYPE
        SYNTAX        BurstSize
        UNITS         "bytes"
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The committed burst size - the committed burst size of the traffic 
             that will be handled in the established CRLSP."
        REFERENCE
            "Section 4.3, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        DEFVAL        { 0 }
        ::= { unisMplsLdpCrlspTnlEntry 10 }
     
     unisMplsLdpCrlspTnlExcessBurstSize OBJECT-TYPE
        SYNTAX        BurstSize
        UNITS         "bytes"
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "The Excess burst size - the excess burst size limit to be used
             for traffic conditioning at the ingress of the CRLSP."
        REFERENCE
            "Section 4.3.1.4, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        DEFVAL        { 0 }
        ::= { unisMplsLdpCrlspTnlEntry 11 }
     
     unisMplsLdpCrlspTnlIsPinned OBJECT-TYPE
        SYNTAX        TruthValue
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Indicates  whether  the loose-routed  hops  of  this
             tunnel are to be pinned."
        DEFVAL        { false }
        ::= { unisMplsLdpCrlspTnlEntry 12 }
     
     unisMplsLdpCrlspTnlFrequency OBJECT-TYPE
        SYNTAX        INTEGER (0..2)
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Indicates the frequency of usage of the established CRLSP."
        REFERENCE
            "Section 4.3.1.1, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        ::= { unisMplsLdpCrlspTnlEntry 13 }
     
     unisMplsLdpCrlspTnlWeight OBJECT-TYPE
        SYNTAX        INTEGER (0..255)
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Indicates the weight that is the established CRLSP."
        REFERENCE
            "Section 4.3, Constraint-Based LSP Setup using LDP, Jamoussi, et.
             al, <draft-ietf-mpls-crldp-02.txt>, August 1999."
        ::= { unisMplsLdpCrlspTnlEntry 14 }
     
     unisMplsLdpCrlspTnlRowStatus OBJECT-TYPE
        SYNTAX        RowStatus
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "For controlling the state of this row.
             The status can be set to 'active' only when atleast one ERHOP
             is created in the unisMplsLdpErHopTable, associated with this
             tunnel."
        ::= { unisMplsLdpCrlspTnlEntry 15 }

    -- 
    -- Er-Hop Table
    --

     unisMplsLdpCrlspErHopTable  OBJECT-TYPE
        SYNTAX        SEQUENCE OF UnisMplsLdpCrlspErHopEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "The unisMplsLdpCrlspErHopTable is used to indicate the hops,
             strict  or  loose,  for an MPLS  CRLSP tunnel  defined  in
             unisMplsLdpCrlspTnlTable. 
     
             There must be atleast one entry in this table for each CRLSP tunnel 
             that is supported in the unisMplsLdpCrlspTnlTable.
             
             The first row in the table  is  the
             first hop after the origination point of the tunnel."
        ::= { unisMplsLdpCrlspTnlObjects 2 }
     
     unisMplsLdpCrlspErHopEntry  OBJECT-TYPE
        SYNTAX        UnisMplsLdpCrlspErHopEntry
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "An  entry in this table represents a tunnel hop.  An
             entry  is  created  by a network  administrator  for
             signalled ERLSP set up by LDP or RSVP."
        INDEX  {  unisMplsLdpLsrIncarnID, 
                  unisMplsLdpCrlspTnlIndex, unisMplsLdpCrlspErHopIndex  }
           ::= { unisMplsLdpCrlspErHopTable 1 }
     
     UnisMplsLdpCrlspErHopEntry ::= SEQUENCE {
           unisMplsLdpCrlspErHopIndex              INTEGER,
           unisMplsLdpCrlspErHopAddrType           INTEGER,
           unisMplsLdpCrlspErHopIpv4Addr           IpAddress,
           unisMplsLdpCrlspErHopIpv4PrefixLen      INTEGER,
           unisMplsLdpCrlspErHopStrictOrLoose      INTEGER,
           unisMplsLdpCrlspErHopRowStatus          RowStatus
        }
     
     unisMplsLdpCrlspErHopIndex OBJECT-TYPE
        SYNTAX        INTEGER
        MAX-ACCESS    not-accessible
        STATUS        current
        DESCRIPTION
            "Secondary  index  into  this table  identifying  the
             particular hop."
        ::= { unisMplsLdpCrlspErHopEntry 1 }
     
     unisMplsLdpCrlspErHopAddrType OBJECT-TYPE
        SYNTAX        INTEGER { ipV4(1) }
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Address type of this hop."
        DEFVAL        { ipV4 }
        ::= { unisMplsLdpCrlspErHopEntry 2 }
     
     unisMplsLdpCrlspErHopIpv4Addr OBJECT-TYPE
        SYNTAX        IpAddress
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "If unisMplsLdpCrlspErHopAddrType is ipV4(1), IPv4 address of
             this  hop.  This object is not significant otherwise
             and should return a value of 0."
        ::= { unisMplsLdpCrlspErHopEntry 3 }
     
     unisMplsLdpCrlspErHopIpv4PrefixLen OBJECT-TYPE
        SYNTAX        INTEGER (1..32)
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "If  unisMplsLdpCrlspErHopAddrType is ipV4(1), prefix  length
             for  this  hop's IPv4 address.  This object  is  not
             significant otherwise and should return a  value  of
             0."
        ::= { unisMplsLdpCrlspErHopEntry 4 }
     
     unisMplsLdpCrlspErHopStrictOrLoose OBJECT-TYPE
        SYNTAX        INTEGER { strict(1), loose(2) }
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "Whether this is a strict or loose hop."
        ::= { unisMplsLdpCrlspErHopEntry 5 }
     
     unisMplsLdpCrlspErHopRowStatus OBJECT-TYPE
        SYNTAX        RowStatus
        MAX-ACCESS    read-create
        STATUS        current
        DESCRIPTION
            "For creating, modifying and deleting this row."
        ::= { unisMplsLdpCrlspErHopEntry 6 }

     ---
     --- Notifications
     ---

     unisMplsLdpNotificationPrefix   OBJECT IDENTIFIER ::=
                                      { unisMplsLdpNotifications 0 }

     unisMplsLdpFailedInitSessionThresholdExceeded NOTIFICATION-TYPE
     OBJECTS     {
			unisMplsLdpLsrIncarnID, unisMplsLdpEntityID,
                        unisMplsLdpEntityFailedInitSessionThreshold
                 }
     STATUS      current
   DESCRIPTION   "This notification is generated whenever the value
             of unisMplsLdpEntityFailedInitSessionThreshold is
             exceeded."
   ::= { unisMplsLdpNotificationPrefix 1 }

--          OBJECTS     { unisMplsLdpLsrIncarnID, unisMplsLdpEntityID,
--                        unisMplsLdpEntityFailedInitSessionThreshold
--                      }
--          STATUS      current
--          DESCRIPTION
--             "This notification is generated whenever the value
--             of unisMplsLdpEntityFailedInitSessionThreshold is
--             exceeded."
--          ::= { unisMplsLdpNotificationPrefix 1 }

     unisMplsLdpCrlspTunnelUp NOTIFICATION-TYPE
     OBJECTS     {
			unisMplsLdpLsrIncarnID, unisMplsLdpEntityID,
                  unisMplsLdpCrlspTnlIndex 
                 }
        STATUS      current
        DESCRIPTION
            "This notification is generated by the Ingress LSR of the CRLSP tunnel
             on the receipt of Label mapping message from the downstream LSR for
             the LAbel request sent for the CRLSP tunnel."
        ::= { unisMplsLdpNotificationPrefix 2 }
  
     unisMplsLdpCrlspTunnelDown NOTIFICATION-TYPE
     OBJECTS     {
		unisMplsLdpLsrIncarnID, unisMplsLdpEntityID,
                  unisMplsLdpCrlspTnlIndex }
        STATUS      current
        DESCRIPTION
            "This notification is generated when a CRLSP Row status is modified
             to destroy the CRLSP tunnel.  - due to pre-emption etc.,"
        ::= { unisMplsLdpNotificationPrefix 3 }
     
     unisMplsLdpCrlspTunnelSetupFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpLsrIncarnID, unisMplsLdpEntityID,
                  unisMplsLdpCrlspTnlIndex }
        STATUS      current
        DESCRIPTION
            "This notification is generated by the Ingress LSR of the CRLSP tunnel
             on the receipt of Nak message from the downstream LSR for
             the Label request sent for the CRLSP tunnel. This can occur due to
             improper ER hop values being set, or Traffic resources not available
             etc.,"
        ::=  { unisMplsLdpNotificationPrefix 4 } 


     unisMplsLdpIncarnUpEventFailure  NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpLsrIncarnID}
        STATUS      current
        DESCRIPTION
            "This notification is generated by LDP to notify 
             the Incarnation UP Event failure"
        ::= { unisMplsLdpNotificationPrefix 11 } 

     unisMplsLdpIncarnDownEventFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpLsrIncarnID }
        STATUS      current
        DESCRIPTION
            "This notification is generated by LDP to notify 
             the Incarnation DOWN Event failure"
        ::= { unisMplsLdpNotificationPrefix 12 } 

     unisMplsLdpEntityUpEventFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpLsrIncarnID, unisMplsLdpEntityID}
        STATUS      current
        DESCRIPTION
            "This notification is generated by LDP to notify 
             the ENTITY UP Event failure"
        ::= { unisMplsLdpNotificationPrefix 13 }


     unisMplsLdpEntityDownEventFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpLsrIncarnID, unisMplsLdpEntityID }
        STATUS      current
        DESCRIPTION
            "This notification is generated by LDP to notify 
             the ENTITY  DOWN Event failure"
        ::= { unisMplsLdpNotificationPrefix 14 }
        unisMplsLdpSessionUpEventFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpSessionID, unisMplsLdpSessionState }
        STATUS      current
        DESCRIPTION
            "Generation of this trap occurs when the 
            value of 'unisMplsLdpSessionState' enters
             the 'operational(5)' state."
        ::= { unisMplsLdpNotificationPrefix 15 }  
        
     unisMplsLdpSessionDownEventFailure NOTIFICATION-TYPE
     OBJECTS     { unisMplsLdpSessionID, unisMplsLdpSessionState }
        STATUS      current
        DESCRIPTION
            "Generation of this trap occurs when the 
            value of 'unisMplsLdpSessionState' leaves 
            the 'operational(5)' state."
        ::= { unisMplsLdpNotificationPrefix 16 }      

-- End of notifications.
END

