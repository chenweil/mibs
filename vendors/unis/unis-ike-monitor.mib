                                unisIKECertUnavailableTrapCntl,
                                unisIKEProposalAddTrapCntl,
                                unisIKEProposalDelTrapCntl
                                }
            STATUS current
            DESCRIPTION
                "The group contains all of trap switches of IKE tunnels."
            ::= { unisIKEGroups 5 }

        unisIKETrapGroup  NOTIFICATION-GROUP
            NOTIFICATIONS {
                                unisIKETunnelStart,
                                unisIKETunnelStop,
                                unisIKENoSaFailure,
                                unisIKEEncryFailFailure,
                                unisIKEDecryFailFailure,
                                unisIKEInvalidProposalFailure,
                                unisIKEAuthFailFailure,
                                unisIKEInvalidCookieFailure,
                                unisIKEAttrNotSuppFailure,
                                unisIKEUnsportExchTypeFailure,
                                unisIKEInvalidIdFailure,
                                unisIKEInvalidProtocolFailure,
                                unisIKECertTypeUnsuppFailure,
                                unisIKEInvalidCertAuthFailure,
                                unisIKElInvalidSignFailure,
                                unisIKECertUnavailableFailure,
                                unisIKEProposalAdd,
                                unisIKEProposalDel
                           }
            STATUS current
            DESCRIPTION
                "The group contains all of trap of IKE tunnels."
            ::= { unisIKEGroups 6 }

        unisIKEScalarObjectsGroup OBJECT-GROUP
            OBJECTS {
                        unisIKEMIBVersion
                    }
            STATUS current
            DESCRIPTION
                "The group contains all of scalar objects of the MIB."
            ::= { unisIKEGroups 7 }

    END
