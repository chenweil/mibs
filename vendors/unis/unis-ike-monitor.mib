-- ================================================
-- definition of traps.
-- ================================================

        unisIKETrap OBJECT IDENTIFIER ::= { unisIKEObjects 6 }
        unisIKENotifications OBJECT IDENTIFIER ::= { unisIKETrap 1 }

        unisIKETunnelStart NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunLifeTime,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                 "This notification is generated when an IPsec Phase-1
                  IKE Tunnel is created."
                    ::= { unisIKENotifications 1 }

        unisIKETunnelStop NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunActiveTime,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when an IPsec Phase-1
                IKE Tunnel is deleted."
                    ::= { unisIKENotifications 2 }

        unisIKENoSaFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IKE tunnel
                 has a non-existent SA error."
        ::= { unisIKENotifications 3 }

        unisIKEEncryFailFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IKE tunnel
                 has an encrypting failure."
                    ::= { unisIKENotifications 4 }

        unisIKEDecryFailFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
                    DESCRIPTION
                "This notification is generated when the IKE tunnel
                has a decrypting failure."
                    ::= { unisIKENotifications 5 }

        unisIKEInvalidProposalFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                invalid proposal occurs."
                    ::= { unisIKENotifications 6 }

        unisIKEAuthFailFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                authentication failure occurs."
            ::= { unisIKENotifications 7 }

        unisIKEInvalidCookieFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                invalid cookie failure occurs."
            ::= { unisIKENotifications 8 }

        unisIKEAttrNotSuppFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1 unsupported
                attribute failure occurs."
            ::= { unisIKENotifications 9 }

        unisIKEUnsportExchTypeFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                unsupported exchange type failure occurs."
            ::= { unisIKENotifications 10 }

        unisIKEInvalidIdFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKEIdInformation,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                invalid id failure occurs."
            ::= { unisIKENotifications 11 }

        unisIKEInvalidProtocolFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKEProtocolNum,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                        }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the processing for
                an IPsec Phase-1 IKE Tunnel has a protocol related errors."
            ::= { unisIKENotifications 12 }

        unisIKECertTypeUnsuppFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKECertInformation,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                unsupported certificate type failure occurs."
            ::= { unisIKENotifications 13 }

        unisIKEInvalidCertAuthFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKECertInformation,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                invalid certificate authorization failure occurs."
            ::= { unisIKENotifications 14 }

        unisIKElInvalidSignFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKECertInformation,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                invalid signature failure occurs."
            ::= { unisIKENotifications 15 }

        unisIKECertUnavailableFailure NOTIFICATION-TYPE
            OBJECTS {
                        unisIKETunLocalAddr,
                        unisIKETunRemoteAddr,
                        unisIKECertInformation,
                        unisIKETunIndex,
                        unisIKETunLocalInetAddrType,
                        unisIKETunLocalInetAddr,
                        unisIKETunRemoteInetAddrType,
                        unisIKETunRemoteInetAddr
                    }
            STATUS     current
            DESCRIPTION
                "This notification is generated when the IPsec phase-1
                certificate unavailable failure occurs."
            ::= { unisIKENotifications 16 }

        unisIKEProposalAdd NOTIFICATION-TYPE
                    OBJECTS { unisIKEProposalNumber,
                              unisIKEProposalSize
                            }
                    STATUS     current
                    DESCRIPTION
                "This notification is generated when an IKE proposal is added."
                    ::= { unisIKENotifications 17 }

        unisIKEProposalDel NOTIFICATION-TYPE
                    OBJECTS { unisIKEProposalNumber,
                              unisIKEProposalSize
                            }
                    STATUS     current
                    DESCRIPTION
                "This notification is generated when an IKE proposal is deleted."
                    ::= { unisIKENotifications 18 }

-- =======================================
-- Begin the unisIKEScalarObjects.
-- =======================================
    unisIKEScalarObjects OBJECT IDENTIFIER ::= { unisIKEObjects 7 }

    unisIKEMIBVersion OBJECT-TYPE
        SYNTAX DisplayString
        MAX-ACCESS read-only
        STATUS current
        DESCRIPTION
            "Version string of this MIB."
        ::= { unisIKEScalarObjects 1 }

-- =======================================
-- Conformance Information
-- =======================================
        unisIKEConformance   OBJECT IDENTIFIER
                                 ::= { unisIKEMonitor 2 }
        unisIKECompliances   OBJECT IDENTIFIER
                                 ::= { unisIKEConformance 1 }
        unisIKEGroups        OBJECT IDENTIFIER
                                 ::= { unisIKEConformance 2 }

-- =======================================
-- Compliance Statements
-- =======================================
        unisIKECompliance MODULE-COMPLIANCE
            STATUS current
            DESCRIPTION
                " "
            MODULE -- this module
            MANDATORY-GROUPS
                {
                    unisIKETunnelTableGroup,
                    unisIKETunnelStatTableGroup,
                    unisIKEGlobalStatsGroup,
                    unisIKETrapObjectGroup,
                    unisIKETrapCntlGroup,
                    unisIKETrapGroup,
                    unisIKEScalarObjectsGroup
                }
            ::= { unisIKECompliances 1 }

    unisIKETunnelTableGroup OBJECT-GROUP
        OBJECTS {
            unisIKETunLocalType,
            unisIKETunLocalValue1,
            unisIKETunLocalValue2,
            unisIKETunLocalAddr,
            unisIKETunRemoteType,
            unisIKETunRemoteValue1,
            unisIKETunRemoteValue2,
            unisIKETunRemoteAddr,
            unisIKETunInitiator,
            unisIKETunNegoMode,
            unisIKETunDiffHellmanGrp,
            unisIKETunEncryptAlgo,
            unisIKETunHashAlgo,
            unisIKETunAuthMethod,
            unisIKETunLifeTime,
            unisIKETunActiveTime,
            unisIKETunRemainTime,
            unisIKETunTotalRefreshes,
            unisIKETunState,
            unisIKETunDpdIntervalTime,
            unisIKETunDpdTimeOut,
            unisIKETunLocalInetAddrType,
            unisIKETunLocalInetAddr,
            unisIKETunRemoteInetAddrType,
            unisIKETunRemoteInetAddr
        }
        STATUS current
        DESCRIPTION
            "The group contains the IKE tunnel's property information."
        ::= { unisIKEGroups 1 }


        unisIKETunnelStatTableGroup OBJECT-GROUP
            OBJECTS {
                                unisIKETunInOctets ,
                                unisIKETunInPkts,
                                unisIKETunInDropPkts,
                                unisIKETunInP2Exchgs,
                                unisIKETunInP2ExchgRejets,
                                unisIKETunInP2SaDelRequests,
                                unisIKETunInP1SaDelRequests,
                                unisIKETunInNotifys,
                                unisIKETunOutOctets,
                                unisIKETunOutPkts,
                                unisIKETunOutDropPkts,
                                unisIKETunOutP2Exchgs,
                                unisIKETunOutP2ExchgRejects,
                                unisIKETunOutP2SaDelRequests,
                                unisIKETunOutP1SaDelRequests,
                                unisIKETunOutNotifys
                                }
            STATUS current
            DESCRIPTION
                "The group contains the IKE tunnel's statistic information."
            ::= { unisIKEGroups 2 }

        unisIKEGlobalStatsGroup OBJECT-GROUP
            OBJECTS {
                                unisIKEGlobalActiveTunnels,
                                unisIKEGlobalInOctets,
                                unisIKEGlobalInPkts,
                                unisIKEGlobalInDropPkts,
                                unisIKEGlobalInP2Exchgs,
                                unisIKEGlobalInP2ExchgRejects,
                                unisIKEGlobalInP2SaDelRequests,
                                unisIKEGlobalInNotifys,
                                unisIKEGlobalOutOctets,
                                unisIKEGlobalOutPkts,
                                unisIKEGlobalOutDropPkts,
                                unisIKEGlobalOutP2Exchgs,
                                unisIKEGlobalOutP2ExchgRejects,
                                unisIKEGlobalOutP2SaDelRequests,
                                unisIKEGlobalOutNotifys,
                                unisIKEGlobalInitTunnels,
                                unisIKEGlobalInitTunnelFails,
                                unisIKEGlobalRespTunnels,
                                unisIKEGlobalRespTunnelFails,
                                unisIKEGlobalAuthFails,
                                unisIKEGlobalNoSaFails,
                                unisIKEGlobalInvalidCookieFails,
                                unisIKEGlobalAttrNotSuppFails,
                                unisIKEGlobalNoProposalChosenFails,
                                unisIKEGlobalUnsportExchTypeFails,
                                unisIKEGlobalInvalidIdFails,
                                unisIKEGlobalInvalidProFails,
                                unisIKEGlobalCertTypeUnsuppFails,
                                unisIKEGlobalInvalidCertAuthFails,
                                unisIKEGlobalInvalidSignFails,
                                unisIKEGlobalCertUnavailableFails
                                }
            STATUS current
            DESCRIPTION
                "The group contains all of the IKE tunnel's statistic information."
            ::= { unisIKEGroups 3 }

        unisIKETrapObjectGroup OBJECT-GROUP
            OBJECTS {
                                unisIKEProposalNumber,
                                unisIKEProposalSize,
                                unisIKEIdInformation,
                                unisIKEProtocolNum,
                                unisIKECertInformation
                    }
            STATUS current
            DESCRIPTION
                "The group contains all of trap objects of IKE tunnels."
            ::= { unisIKEGroups 4 }

        unisIKETrapCntlGroup OBJECT-GROUP
            OBJECTS {
                                unisIKETrapGlobalCntl,
                                unisIKETunnelStartTrapCntl,
                                unisIKETunnelStopTrapCntl,
