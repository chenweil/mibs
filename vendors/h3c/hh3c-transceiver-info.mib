        DESCRIPTION
            "Maximum optical signal-to-noise ratio during the statistical period,
            in hundredths of dB."
        ::= { hh3cTransceiverChannelEntry 35 }

    hh3cTransceiverChanCurEsnr    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
