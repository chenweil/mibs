    hh3cTransceiverChanCurLgSoPmd     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current value of low granularity second-order polarization mode dispersion,
            in hundredths of a picosecond^2."
        ::= { hh3cTransceiverChannelEntry 62 }

    hh3cTransceiverChanLgSoPmdAvg     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average value of low granularity second-order polarization mode color
             within a statistical period, in hundredths of a picosecond^2."
