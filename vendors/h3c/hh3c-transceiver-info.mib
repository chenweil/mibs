    hh3cTransceiverChanCurOsnr    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current optical signal-to-noise ratio, in hundredths of dB."
        ::= { hh3cTransceiverChannelEntry 32 }

    hh3cTransceiverChanOsnrAvg    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average optical signal-to-noise ratio during the statistical period,
            in hundredths of dB."
        ::= { hh3cTransceiverChannelEntry 33 }

    hh3cTransceiverChanOsnrMin    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum optical signal-to-noise ratio within the statistical period,
