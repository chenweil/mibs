-- Transceiver Channel Table

    hh3cTransceiverChannelTable OBJECT-TYPE
        SYNTAX SEQUENCE OF Hh3cTransceiverChannelEntry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "This table provides statistics about transceiver with multi-channel."
        ::= { hh3cTransceiverInfoAdm 2 }

    hh3cTransceiverChannelEntry OBJECT-TYPE
        SYNTAX Hh3cTransceiverChannelEntry
        MAX-ACCESS not-accessible
        STATUS current
        DESCRIPTION
            "The entry of the hh3cTransceiverChannelTable."
        INDEX { ifIndex, hh3cTransceiverChannelIndex }
        ::= { hh3cTransceiverChannelTable 1 }

    Hh3cTransceiverChannelEntry ::=
        SEQUENCE {
            hh3cTransceiverChannelIndex             Integer32,
            hh3cTransceiverChannelCurTXPower        Integer32,
            hh3cTransceiverChannelCurRXPower        Integer32,
            hh3cTransceiverChannelTemperature       Integer32,
            hh3cTransceiverChannelBiasCurrent       Integer32,
            hh3cTransceiverChannelBiasHiAm          Integer32,
            hh3cTransceiverChannelBiasLoAm          Integer32,
            hh3cTransceiverChannelTXPwrHiAm         Integer32,
            hh3cTransceiverChannelTXPwrLoAm         Integer32,
            hh3cTransceiverChanTXPwrHiAmDbm         Integer32,
            hh3cTransceiverChanTXPwrLoAmDbm         Integer32,
            hh3cTransceiverChanCfgTxPower        Integer32,
            hh3cTransceiverChanLoopback       INTEGER,
            hh3cTransceiverChanFrequence         Unsigned32,
            hh3cTransceiverChanGrid              Unsigned32,
            hh3cTransceiverChanCurCD           Integer32,
            hh3cTransceiverChanCDAvg           Integer32,
            hh3cTransceiverChanCDMin           Integer32,
            hh3cTransceiverChanCDMax           Integer32,
            hh3cTransceiverChanCurPMD          Integer32,
            hh3cTransceiverChanPMDAvg          Integer32,
            hh3cTransceiverChanPMDMin          Integer32,
            hh3cTransceiverChanPMDMax          Integer32,
            hh3cTransceiverChanCurPDL          Integer32,
            hh3cTransceiverChanPDLAvg          Integer32,
            hh3cTransceiverChanPDLMin          Integer32,
            hh3cTransceiverChanPDLMax          Integer32,
            hh3cTransceiverChanCurSopRoc         Integer32,
            hh3cTransceiverChanSopRocAvg         Integer32,
            hh3cTransceiverChanSopRocMin         Integer32,
            hh3cTransceiverChanSopRocMax         Integer32,
            hh3cTransceiverChanCurOsnr         Integer32,
            hh3cTransceiverChanOsnrAvg         Integer32,
            hh3cTransceiverChanOsnrMin         Integer32,
            hh3cTransceiverChanOsnrMax         Integer32,
            hh3cTransceiverChanCurEsnr         Integer32,
            hh3cTransceiverChanEsnrAvg         Integer32,
            hh3cTransceiverChanEsnrMin         Integer32,
            hh3cTransceiverChanEsnrMax         Integer32,
            hh3cTransceiverChanCurCFO          Integer32,
            hh3cTransceiverChanCFOAvg          Integer32,
            hh3cTransceiverChanCFOMin          Integer32,
            hh3cTransceiverChanCFOMax          Integer32,
            hh3cTransceiverChanCurPreFecBer         Integer32,
            hh3cTransceiverChanPreFecBerAvg         Integer32,
            hh3cTransceiverChanPreFecBerMin         Integer32,
            hh3cTransceiverChanPreFecBerMax         Integer32,
            hh3cTransceiverChanPostFecFer           Integer32,
            hh3cTransceiverChanFecUEBlocks        Unsigned32,
            hh3cTransceiverChanEcBits             Unsigned32,
            hh3cTransceiverChanLaserTemp          Integer32,
            hh3cTransceiverChanTXPowerAvg         Integer32,
            hh3cTransceiverChanTXPowerMin         Integer32,
            hh3cTransceiverChanTXPowerMax         Integer32,
            hh3cTransceiverChanRXPowerAvg         Integer32,
            hh3cTransceiverChanRXPowerMin         Integer32,
            hh3cTransceiverChanRXPowerMax         Integer32,
            hh3cTransceiverChanCurHgSoPmd         Integer32,
            hh3cTransceiverChanHgSoPmdAvg         Integer32,
            hh3cTransceiverChanHgSoPmdMin         Integer32,
            hh3cTransceiverChanHgSoPmdMax         Integer32,
            hh3cTransceiverChanCurLgSoPmd         Integer32,
            hh3cTransceiverChanLgSoPmdAvg         Integer32,
            hh3cTransceiverChanLgSoPmdMin         Integer32,
            hh3cTransceiverChanLgSoPmdMax         Integer32
        }

    hh3cTransceiverChannelIndex OBJECT-TYPE
        SYNTAX      Integer32(1..2147483647)
        MAX-ACCESS  not-accessible
        STATUS      current
        DESCRIPTION
            "The channel index of transceiver.
            Indicating one channel of the interface."
        ::= { hh3cTransceiverChannelEntry 1 }

    hh3cTransceiverChannelCurTXPower OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Indicating the current transmission power.
            The unit is in hundredths of dBm."
