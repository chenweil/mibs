    hh3cTransceiverChanCDMax   OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum dispersion value within the statistical period,
            in hundredths of a picosecond per nanometer."
        ::= { hh3cTransceiverChannelEntry 19 }

    hh3cTransceiverChanCurPMD   OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current polarization mode dispersion, in hundredths of a picosecond."
        ::= { hh3cTransceiverChannelEntry 20 }

    hh3cTransceiverChanPMDAvg   OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average polarization mode dispersion within a statistical period,
            in hundredths of a picosecond."
        ::= { hh3cTransceiverChannelEntry 21 }

    hh3cTransceiverChanPMDMin   OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum polarization mode dispersion within a statistical period,
            in hundredths of a picosecond."
