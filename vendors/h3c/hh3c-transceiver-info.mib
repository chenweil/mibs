    hh3cTransceiverChanEsnrMin    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum electrical signal-to-noise ratio during the statistical period,
            in hundredths of dB."
        ::= { hh3cTransceiverChannelEntry 38 }

    hh3cTransceiverChanEsnrMax    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum electrical signal-to-noise ratio during the statistical period,
            in hundredths of dB."
        ::= { hh3cTransceiverChannelEntry 39 }

    hh3cTransceiverChanCurCFO    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current carrier frequency offset of the transceiver channel,
            in tenths of MHZ."
        ::= { hh3cTransceiverChannelEntry 40 }

    hh3cTransceiverChanCFOAvg    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average carrier frequency offset of the transceiver channel in the statistical period,
            in tenths of MHZ."
        ::= { hh3cTransceiverChannelEntry 41 }

    hh3cTransceiverChanCFOMin    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum carrier frequency offset of the transceiver channel in the statistical period,
            in tenths of MHZ."
        ::= { hh3cTransceiverChannelEntry 42 }

    hh3cTransceiverChanCFOMax    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum carrier frequency offset of the transceiver channel in the statistical period,
            in tenths of MHZ."
        ::= { hh3cTransceiverChannelEntry 43 }

    hh3cTransceiverChanCurPreFecBer    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current pre-FEC bit error rate on the media side, in 10^-18."
        ::= { hh3cTransceiverChannelEntry 44 }

    hh3cTransceiverChanPreFecBerAvg    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average pre-FEC bit error rate on the media side during the statistical period,
            in units of 10^-18."
        ::= { hh3cTransceiverChannelEntry 45 }

    hh3cTransceiverChanPreFecBerMin    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum pre-FEC bit error rate on the medium side within the statistical cycle,
            in 10^-18."
        ::= { hh3cTransceiverChannelEntry 46 }

    hh3cTransceiverChanPreFecBerMax    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum pre-FEC bit error rate on the media side during the statistical period,
            in 10^-18."
        ::= { hh3cTransceiverChannelEntry 47 }

    hh3cTransceiverChanPostFecFer    OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current post-FEC frame error rate on the media side, in 10^-10."
        ::= { hh3cTransceiverChannelEntry 48 }

    hh3cTransceiverChanFecUEBlocks    OBJECT-TYPE
        SYNTAX      Unsigned32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Uncorrectable blocks or frames by FEC."
        ::= { hh3cTransceiverChannelEntry 49 }

    hh3cTransceiverChanEcBits     OBJECT-TYPE
        SYNTAX      Unsigned32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Number of error bits on the media side."
        ::= { hh3cTransceiverChannelEntry 50 }

    hh3cTransceiverChanLaserTemp     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current laser temperature, in hundredths of degrees Celsius."
        ::= { hh3cTransceiverChannelEntry 51 }

    hh3cTransceiverChanTXPowerAvg     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average transmit optical power of the transceiver channel in the statistical period,
            in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 52 }

    hh3cTransceiverChanTXPowerMin     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum transmit power of the transceiver channel in the statistical period,
           in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 53 }

    hh3cTransceiverChanTXPowerMax     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum transmit power of the transceiver channel in the statistical period.
            in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 54 }

    hh3cTransceiverChanRXPowerAvg     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average receive power of the transceiver channel in the statistical period.
            in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 55 }

    hh3cTransceiverChanRXPowerMin     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum receive power of the transceiver channel in the statistical period.
            in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 56 }

    hh3cTransceiverChanRXPowerMax     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum receive power of the transceiver channel in the statistical period.
            in hundredths of dBM."
        ::= { hh3cTransceiverChannelEntry 57 }

    hh3cTransceiverChanCurHgSoPmd     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Current value of high granularity second-order polarization mode dispersion,
            in hundredths of a picosecond^2."
        ::= { hh3cTransceiverChannelEntry 58 }

    hh3cTransceiverChanHgSoPmdAvg     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Average value of high granularity second-order polarization mode color
             within a statistical period, in hundredths of a picosecond^2."
        ::= { hh3cTransceiverChannelEntry 59 }

    hh3cTransceiverChanHgSoPmdMin     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Minimum value of high granularity second-order polarization mode color
             within a statistical period, in hundredths of a picosecond^2."
        ::= { hh3cTransceiverChannelEntry 60 }

    hh3cTransceiverChanHgSoPmdMax     OBJECT-TYPE
        SYNTAX      Integer32
        MAX-ACCESS  read-only
        STATUS      current
        DESCRIPTION
            "Maximum value of high granularity second-order polarization mode color
             within a statistical period, in hundredths of a picosecond^2."
