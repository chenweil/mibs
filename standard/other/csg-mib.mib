        csgSpanningTreeEnable
        "
    ::= { csgSpanningTree 7 }

csgSpanningTreeType OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgSpanningTreeType
        "
    ::= { csgSpanningTree 8 }

--
-- RSTP Table
--

csgSpanningTreeTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgSpanningTreeEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        csgSpanningTreeTable
        "
    ::= { csgSpanningTree 6 }

csgSpanningTreeEntry OBJECT-TYPE
    SYNTAX      CsgSpanningTreeEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        csgSpanningTreeEntry
        "
    INDEX
        {
            csgSpanningTreeIndex
        }
    ::= {csgSpanningTreeTable 1 }

CsgSpanningTreeEntry ::= SEQUENCE
    {
        csgSpanningTreeIndex        Integer32,
        csgEnableSpanningTree       INTEGER,
        csgSpanningTreePortPriority Integer32,
        csgSpanningTreePortCost     Integer32,
        csgSpanningTreePortStatus   INTEGER,
        csgSpanningTreePortRole     INTEGER,
        csgSpanningTreePortEdge     Integer32
    }

csgSpanningTreeIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
