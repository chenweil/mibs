        {
            disabled(1),
            blocking(2),
            listening(3),
            learning(4),
            forwarding(5),
            broken(6)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        csgSpanningTreePortStatus
        "
    ::= { csgSpanningTreeEntry 5 }

csgSpanningTreePortRole OBJECT-TYPE
