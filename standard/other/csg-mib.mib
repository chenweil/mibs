-- begin

-- csg Agent
-- csgAgent OBJECT IDENTIFIER ::= { csg 1 }

-- ===================================================================================
-- csg-qos-mib.mib
-- ===================================================================================
csgQosMIB OBJECT IDENTIFIER ::= { csgAgent 33 }

------------------------------------------------------------------------------
--  define groups in raisecomQosMIB
------------------------------------------------------------------------------
csgQosCfg OBJECT IDENTIFIER ::={ csgQosMIB 1 }
csgPortRateControl OBJECT IDENTIFIER ::={ csgQosMIB 7 }
-- ----------------------------------------------------------------------------
-- csgQosCfg group------------
-- csgQosCfg group scale MIB--
-- ----------------------------------

csgQosQueueScheduler OBJECT-TYPE
    SYNTAX      INTEGER
        {
            sp(1),
            wrr(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        the global mode queue scheduler mode on the port.
        sp indicates strict priority queue mode.
        wrr indicates Weighted Round Robin queue mode.
        drr indicates Deficit Round Robin queue mode.
        wfq indicates Weighted Fair Queuing queue mode.
        "
    ::= { csgQosCfg 3 }

-----------------------------------------------------------
-- csgQosCfg group csgQosCosMapingTable ----
-----------------------------------------------------------

csgQosCosMappingTable OBJECT-TYPE
    SYNTAX     SEQUENCE OF CsgQosCosMappingEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        This table describes the mapping from the cos to the local priority.
        "
    ::= { csgQosCfg 13 }

csgQosCosMappingEntry OBJECT-TYPE
    SYNTAX     CsgQosCosMappingEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        Table entry for cos mapping to local priority
        "
    INDEX
        {
            csgQosCosValue
        }
    ::= { csgQosCosMappingTable 1 }

CsgQosCosMappingEntry ::= SEQUENCE
    {
        csgQosCosValue          Integer32,
        csgQosCosLocalPriority  Integer32
    }

csgQosCosValue OBJECT-TYPE
    SYNTAX      Integer32(0..7)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        Cos value,the index of rcQosCosMappingEntry.
        "
    ::= { csgQosCosMappingEntry 1}

csgQosCosLocalPriority OBJECT-TYPE
    SYNTAX      Integer32(0..7)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        The local priority which the cos value mapped to.
        "
    ::= { csgQosCosMappingEntry 2 }

-----------------------------------------------------------
-- csgQosCfg group csgPortRateControlTable ----
-----------------------------------------------------------

csgIfProtect OBJECT-TYPE
    SYNTAX      INTEGER
        {
            enable(0),
            disable(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Enable port protect.
        "
    ::= { csgPortRateControl 1 }

csgPortRateControlTable OBJECT-TYPE
    SYNTAX     SEQUENCE OF CsgPortRateControlEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        A configable table for rate limit base on port.
        "
    ::= { csgPortRateControl 2 }

csgPortRateControlEntry OBJECT-TYPE
    SYNTAX     CsgPortRateControlEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        Table entry for for rate limit base on port.
        "
    INDEX
        {
            csgPortRateIndex
        }
    ::= { csgPortRateControlTable 1 }

CsgPortRateControlEntry ::= SEQUENCE
    {
        csgPortRateIndex                 Integer32,
        csgPorttwowayRate                Integer32,
        csgPortIngressRate               Integer32,
        csgPortEgressRate                Integer32,
        csgPortRateLimitUnitDescr        Integer32,
        csgPortInFrameCon                Integer32,
        csgPortOutFrameCon               Integer32
    }

csgPortRateIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The ifIndex of the port.
        "
    ::= { csgPortRateControlEntry 1}

csgPorttwowayRate OBJECT-TYPE
    SYNTAX        Integer32
    UNITS         "kbps"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Speed limit configuration in both way. Unit: kbps.
        "
    ::= { csgPortRateControlEntry 2 }

csgPortIngressRate OBJECT-TYPE
    SYNTAX        Integer32
    UNITS         "kbps"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Speed limit configuration in ingress way. Unit: kbps.
        "
    ::= { csgPortRateControlEntry 3 }

csgPortEgressRate OBJECT-TYPE
    SYNTAX        Integer32
    UNITS         "kbps"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Speed limit configuration in egress way. Unit: kbps.
        "
    ::= { csgPortRateControlEntry 4 }

csgPortRateLimitUnitDescr OBJECT-TYPE
    SYNTAX        Integer32
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Port Speed limit configuration in the bandwidth. Unit: 64kbps.
        "
    ::= { csgPortRateControlEntry 5 }

csgPortInFrameCon OBJECT-TYPE
    SYNTAX        Integer32
    UNITS         "B"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Inbound frame gap configuration in ingress way. Unit: B.
        "
    ::= { csgPortRateControlEntry 6 }

csgPortOutFrameCon OBJECT-TYPE
    SYNTAX        Integer32
    UNITS         "B"
    MAX-ACCESS    read-write
    STATUS        current
    DESCRIPTION
        "
        Inbound frame gap configuration in egress way. Unit: B.
        "
    ::= { csgPortRateControlEntry 7 }

