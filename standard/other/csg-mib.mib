    ::= { csgBaseConfig 1 }

csgMirrorToPort OBJECT-TYPE
    SYNTAX     Integer32
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        The monitor port.
        "
    ::= { csgBaseConfig 2}

csgIngressMirrorPorts OBJECT-TYPE
    SYNTAX     PortList
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        Ingress Monitored ports mask. Bit mask which selectively allows any port with
        its corresponding bit set, to be mirrored to the monitor port.
        "
    ::= { csgBaseConfig 4 }

csgEgressMirrorPorts OBJECT-TYPE
    SYNTAX     PortList
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        Egress Monitored ports mask. Bit mask which selectively allows any port with
        its corresponding bit set, to be mirrored to the monitor port.
        "
    ::= { csgBaseConfig 5 }

