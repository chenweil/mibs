        csgSpanningTreeIndex
        "
    ::= { csgSpanningTreeEntry 1 }

csgEnableSpanningTree OBJECT-TYPE
    SYNTAX      INTEGER
        {
            disable(0),
            enable(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgEnableSpanningTree
        "
    ::= { csgSpanningTreeEntry 2 }

csgSpanningTreePortPriority OBJECT-TYPE
    SYNTAX      Integer32 (16..255)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
