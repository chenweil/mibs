-- CSG SNTP

csgSntp OBJECT IDENTIFIER ::= { csgAgent 231 }

csgSntpServer OBJECT IDENTIFIER ::= { csgSntp 1 }

csgSntpClient OBJECT IDENTIFIER ::= { csgSntp 2 }

csgSntpServerEnable OBJECT-TYPE
    SYNTAX      INTEGER
        {
            disable(0),
            enable(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        SNTP server enable.
        "
    ::= { csgSntpServer 1 }

csgSntpClinetEnable OBJECT-TYPE
    SYNTAX      INTEGER
        {
            disable(0),
            enable(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        SNTP client enable.
        "
    ::= { csgSntpClient 1 }

csgSntpClinetTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgSntpClinetEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of SNTP client parameter table entries.
        "
    ::= { csgSntpClient 2 }

csgSntpClinetEntry OBJECT-TYPE
    SYNTAX      CsgSntpClinetEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A collection of SNTP client parameter set table.
        "
    INDEX
        {
            csgSntpServerIp
        }
    ::= { csgSntpClinetTable 1 }

CsgSntpClinetEntry ::= SEQUENCE
    {
        csgSntpServerIp     IpAddress,
        csgSntpServerStatus INTEGER,
        csgSntpInterval     Integer32
    }

csgSntpServerIp OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        SNTP server IP address.
        "
    ::= { csgSntpClinetEntry 1 }

csgSntpServerStatus OBJECT-TYPE
    SYNTAX      INTEGER
        {
            active(1),
            notInService(2),
            notReady(3),
            createAndGo(4),
            createAndWait(5),
            destroy(6)
        }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        SNTP server status.
        "
    ::= { csgSntpClinetEntry 2 }

csgSntpInterval OBJECT-TYPE
    SYNTAX      Integer32 (10..16284)
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        SNTP server packet sending interval.
        "
    ::= { csgSntpClinetEntry 3 }


-- begin

-- CSG Series
-- csgSeries OBJECT IDENTIFIER ::= { csg 6 }

-- =======================================================================
--
--   Common Switch management root MIB
-- =======================================================================
-- CSG Switch
-- csgSwitch OBJECT IDENTIFIER ::= { csgSeries 1 }

-- ============================================================================
-- csgSwSystem OBJECT IDENTIFIER ::= { csgSwitch 1 }

-- =====================================================================================
-- CSG-STATIC-ROUTE-MIB
-- =====================================================================================
csgStaticRounteConfig OBJECT IDENTIFIER ::= { csgSwSystem 21 }

-- csgStaticRounteConfig

csgIpStaticRouteTable OBJECT-TYPE
    SYNTAX     SEQUENCE OF CsgIpStaticRouteEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        A table of static route information.
        "
    ::= { csgStaticRounteConfig 1 }

csgIpStaticRouteEntry OBJECT-TYPE
    SYNTAX     CsgIpStaticRouteEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        An entry in csgIpStaticRouteTable.
        "
    INDEX
        {
            csgIpStaticRouteDest,
            csgIpStaticRouteMask,
            csgIpStaticNextHop
        }
    ::= { csgIpStaticRouteTable 1 }

CsgIpStaticRouteEntry ::= SEQUENCE
    {
        csgIpStaticRouteDest        IpAddress,
        csgIpStaticRouteMask        IpAddress,
        csgIpStaticNextHop          IpAddress,
        csgIpStaticRouteIfIndex     Integer32,
        csgIpStaticDistance         Unsigned32,
        csgIpStaticDescription      OCTET STRING,
        csgIpStaticRouteTag         Unsigned32,
        csgIpStaticValid            TruthValue,
        csgIpStaticRowStatus        RowStatus
    }

csgIpStaticRouteDest OBJECT-TYPE
    SYNTAX     IpAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        The static route host or subnet IP destination address.All IP destination addresses must be non-zero.
        "
    ::= { csgIpStaticRouteEntry 1 }

csgIpStaticRouteMask OBJECT-TYPE
    SYNTAX     IpAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        The mask for this IP destination.
        It contains 1's in the bit positions for the net and subnet IDs and 0's in the bit positions for host ID.
        The 1's must be contiguous,starting with the left most bit.
        "
    ::= { csgIpStaticRouteEntry 2 }

csgIpStaticNextHop OBJECT-TYPE
    SYNTAX     IpAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        The IP address of the next hop of this route.
        "
    ::= { csgIpStaticRouteEntry 3 }

csgIpStaticRouteIfIndex OBJECT-TYPE
    SYNTAX     Integer32
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
        "
        The index value which uniquely identifies the local interface
        through which the next hop of this route should be reached.
        "
    ::= { csgIpStaticRouteEntry 4 }

csgIpStaticDistance OBJECT-TYPE
    SYNTAX     Unsigned32(1.. 255)
    MAX-ACCESS read-create
    STATUS     current
    DESCRIPTION
        "
        the AD lower,the priority higher.
        "
    ::= { csgIpStaticRouteEntry 5 }

csgIpStaticDescription OBJECT-TYPE
    SYNTAX     OCTET STRING (SIZE(1..60))
    MAX-ACCESS read-create
    STATUS     current
    DESCRIPTION
        "
        Description of the route.
        "
    ::= { csgIpStaticRouteEntry 6 }

csgIpStaticRouteTag OBJECT-TYPE
    SYNTAX     Unsigned32(1..4294967295)
    MAX-ACCESS read-create
    STATUS     current
    DESCRIPTION
        "
        Used to tag external routes.
        "
    ::= { csgIpStaticRouteEntry 7 }

csgIpStaticValid OBJECT-TYPE
    SYNTAX     TruthValue
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
        "
        By setting this object to true(1), the user indicates the
        desire to use hardware routing for this entry.
        To disable hardware routing for this entry, set this object to false(2).
        "
    DEFVAL { false }
    ::= { csgIpStaticRouteEntry 8 }

csgIpStaticRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        DURABLE:
        This object indicates the status of this entry.  A row in this
        table must be created using the createAndWait(5) action state
        (i.e., createAndGo(4) is not supported).  This object can only
        be set to active(1) after all objects for this row are valid.
        The 'raisecomL3IpStaticName' is optional.
        Note that the notInService(2) state is not supported. Objects
        in this table row can be changed when this object is notReady(3)
        or active(1).
        "
    ::= { csgIpStaticRouteEntry 9 }

-- begin

-- CSG Series
-- csgSeries OBJECT IDENTIFIER ::= { csg 6 }

-- =======================================================================
--
--   Common Switch management root MIB
-- =======================================================================
-- CSG Switch

-- csgSwSystem OBJECT IDENTIFIER ::= { csgSwitch 1 }

-- =====================================================================================
-- csg-system-mib.smi
-- =====================================================================================
csgSwitchConfig OBJECT IDENTIFIER ::= { csgSwSystem 3 }

csgStormControlBcastEnable OBJECT-TYPE
    SYNTAX     EnableVar
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        Set the Storm control for broadcast on the interface to enable(1) or disable(2).
        "
     DEFVAL { enable }
    ::= { csgSwitchConfig 2 }

csgStormControlMcastEnable OBJECT-TYPE
    SYNTAX     EnableVar
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        Set the Storm control for multicast on the interface to enable(1) or disable(2).
        "
    DEFVAL { disable }
    ::= { csgSwitchConfig 3 }

csgStormControlDlfEnable OBJECT-TYPE
    SYNTAX     EnableVar
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        Set the Storm control for DLF on the interface to enable(1) or disable(2).
        "
    DEFVAL { disable }
    ::= { csgSwitchConfig 4 }

csgStormControlpps OBJECT-TYPE
    SYNTAX     Integer32 (1..262143)
    UNITS      "pps"
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        The limit number for storm control on the interface.
        "
    ::= { csgSwitchConfig 5 }

csgStormControlbps OBJECT-TYPE
    SYNTAX     Integer32 (0..1073741823)
    UNITS      "bps"
    MAX-ACCESS read-write
    STATUS     current
    DESCRIPTION
        "
        The limit number for storm control on the interface.
        "
    ::= { csgSwitchConfig 6 }

 csgStormControlUnit OBJECT-TYPE
    SYNTAX     INTEGER
        {
            pps(1),
            bps(2),
            all(3)
        }
    MAX-ACCESS read-only
    STATUS     current
    DESCRIPTION
        "
        unit of value for storm control.
        "
    ::= { csgSwitchConfig 7}

-- begin


-- CSG Series
-- csgSeries OBJECT IDENTIFIER ::= { csg 6 }

-- =======================================================================
--
--   Common Switch management root MIB
-- =======================================================================
-- CSG Switch
-- csgSwitch OBJECT IDENTIFIER ::= { csgSeries 1 }

-- =======================================================================
--
--   CSG-VLAN-MIB
-- =======================================================================
csgVlanExt OBJECT IDENTIFIER ::= { csgSwitch 182 }
csgdot1qPortVlanExt OBJECT IDENTIFIER ::= { csgVlanExt 1 }

-- =======================================================================
--
--   csgdot1qPortVlanExtTable
-- =======================================================================
csgdot1qPortVlanExtTable OBJECT-TYPE
    SYNTAX     SEQUENCE OF Csgdot1qPortVlanExtEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        " "
    ::= { csgdot1qPortVlanExt 3 }

csgdot1qPortVlanExtEntry OBJECT-TYPE
    SYNTAX     Csgdot1qPortVlanExtEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        " "
    INDEX
        {
            csgDot1Port
        }
    ::= { csgdot1qPortVlanExtTable 1 }

Csgdot1qPortVlanExtEntry ::= SEQUENCE
    {
        csgDot1Port                  Integer32,
        csgDot1qPvid                 Integer32,
        csgdot1qPortSwitchingMode    INTEGER,
        csgdot1qPortAllowedVlans     Vlanset,
        csgdot1qPortUntaggedVlans    Vlanset
    }

csgDot1Port OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgDot1Port
        "
    ::= { csgdot1qPortVlanExtEntry 1}

csgDot1qPvid OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgDot1qPvid
        "
    ::= { csgdot1qPortVlanExtEntry 2 }

csgdot1qPortSwitchingMode OBJECT-TYPE
    SYNTAX      INTEGER
        {
            access(1),
            trunk(2),
            hybrid(3)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgdot1qPortSwitchingMode
        "
    ::= { csgdot1qPortVlanExtEntry 3 }

csgdot1qPortAllowedVlans OBJECT-TYPE
    SYNTAX      Vlanset
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgdot1qPortAllowedVlans
        "
    ::= { csgdot1qPortVlanExtEntry 4 }

csgdot1qPortUntaggedVlans OBJECT-TYPE
    SYNTAX      Vlanset
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        csgdot1qPortUntaggedVlans
        "
    ::= { csgdot1qPortVlanExtEntry 5 }


-- begin

-- CSG Series
-- csgSeries OBJECT IDENTIFIER ::= { csg 6 }

-- =======================================================================
--
--   Common Switch management root MIB
-- =======================================================================
-- CSG Switch
-- csgSwitch OBJECT IDENTIFIER ::= { csgSeries 1 }

-- =======================================================================
--  TFTP/FTP mib
-- =======================================================================

csgfileTransfer OBJECT IDENTIFIER ::= { csgSwitch 222 }

csgFileTransferServe OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Server IP address. the format is just as followed by '172.29.80.101'.
        "
    ::= { csgfileTransfer 1 }

csgFirmwarePath OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        File path name in the firmware of server.
        "
    ::= { csgfileTransfer 2 }

csglogPathName OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Log file path name in the server.
        "
    ::= { csgfileTransfer 3 }

csgconfPathName OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        Config file path name in the server.
        "
    ::= { csgfileTransfer 4 }

csgFileTransferUpdate OBJECT-TYPE
    SYNTAX      INTEGER
        {
            importFirmware(1),
            importConfig(2),
            exportConfig(3),
            exportLog(4)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        File transfer mode.
        "
    ::= { csgfileTransfer 5 }

csgFileTransferType OBJECT-TYPE
    SYNTAX      INTEGER
        {
            tFTP(1),
            fTP(2)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        File transfer type.
        "
    ::= { csgfileTransfer 6 }

csgUsername OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        the ftp User name.
        "
    ::= { csgfileTransfer 7 }

csgPassword OBJECT-TYPE
    SYNTAX      DisplayString
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        the ftp Password.
        "
    ::= { csgfileTransfer 8 }

-- begin

-- csg Agent
-- csgAgent OBJECT IDENTIFIER ::= { csg 1 }
-- csgSyslogServer
csgSyslogServer OBJECT IDENTIFIER ::= { csgAgent 235}

csgSyslogSetting OBJECT IDENTIFIER ::= { csgSyslogServer 1 }

csgLogServerOff OBJECT-TYPE
    SYNTAX      INTEGER
        {
            on(0),
            off(1)
        }
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        This enable the system log.
        "
    ::= { csgSyslogSetting 1 }

csgLogServerTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgLogServerEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The GMRP setting table.
        "
    ::= { csgSyslogSetting 2 }

csgLogServerEntry OBJECT-TYPE
    SYNTAX     CsgLogServerEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        "
        The GMRP Setting Entry.
        "
    INDEX
        {
            csgLogServeLevel,
            csgLogServeAddr
        }
    ::= { csgLogServerTable 1 }

CsgLogServerEntry ::= SEQUENCE
    {
        csgLogServeLevel          INTEGER,
        csgLogServeAddr           IpAddress,
        csgLogServeAddrRowStatus  INTEGER
    }

csgLogServeLevel OBJECT-TYPE
    SYNTAX     INTEGER
        {
            emerg(0),
            alert(1),
            critical(2),
            error(3),
            warning(4),
            notice(5),
            info(6),
            debug(7)
        }
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        " "
    ::= { csgLogServerEntry 1 }

csgLogServeAddr OBJECT-TYPE
    SYNTAX     IpAddress
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
        " "
    ::= { csgLogServerEntry 2 }

csgLogServeAddrRowStatus OBJECT-TYPE
    SYNTAX     INTEGER
        {
            active(1),
            notInService(2),
            notReady(3),
            createAndGo(4),
            createAndWait(5),
            destroy(6)
        }
    MAX-ACCESS read-create
    STATUS     current
    DESCRIPTION
        " "
    ::= { csgLogServerEntry 3 }

END
