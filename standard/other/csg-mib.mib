        {
            disabledPort(0),
            alternatePort(1),
            backupPort(2),
            rootPort(3),
            designatedPort(4)
        }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        csgSpanningTreePortRole
        "
    ::= { csgSpanningTreeEntry 6 }

csgSpanningTreePortEdge OBJECT-TYPE
    SYNTAX      Integer32
