csgLldp OBJECT IDENTIFIER ::= { csgSwitch 57 }

csgLldpFuncSet OBJECT IDENTIFIER ::= { csgLldp 2 }

--
-- Sections of the CSG LLDP MIB
--

csgLldpConfig OBJECT IDENTIFIER ::= { csgLldpFuncSet 1 }

csgLldpEnable OBJECT-TYPE
    SYNTAX      TruthValue
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        The vlalue indicats that LLDP is valid when it is set TRUE.
        The default value is FALSE.
        "
    DEFVAL { false }
    ::= { csgLldpConfig 1 }

csgPortFunction OBJECT IDENTIFIER ::= { csgSwitch 58 }

csgPortAdminStatusAutoShutdown OBJECT IDENTIFIER ::= { csgPortFunction 1 }

csgPortAdminStatusAutoShutdownTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgPortAdminStatusAutoShutdownEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PortAdminStatusAutoShutdown parameter table.
        "
    ::= { csgPortAdminStatusAutoShutdown 1 }

csgPortAdminStatusAutoShutdownEntry OBJECT-TYPE
    SYNTAX      CsgPortAdminStatusAutoShutdownEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PortAdminStatusAutoShutdown parameter table entries.
        "
    INDEX
        {
            csgPortAdminStatusAutoShutdownIfIndex
        }
    ::= { csgPortAdminStatusAutoShutdownTable 1 }

CsgPortAdminStatusAutoShutdownEntry ::=SEQUENCE
    {
        csgPortAdminStatusAutoShutdownIfIndex Integer32,
        csgPortAdminStatusAutoShutdownEnable  INTEGER
    }

csgPortAdminStatusAutoShutdownIfIndex OBJECT-TYPE
    SYNTAX          Integer32
    MAX-ACCESS      not-accessible
    STATUS          current
    DESCRIPTION
        "
        ifIndex
        "
    ::= { csgPortAdminStatusAutoShutdownEntry 1 }

csgPortAdminStatusAutoShutdownEnable OBJECT-TYPE
    SYNTAX          INTEGER
        {
            open(1),
            close(2)
        }
    MAX-ACCESS      read-write
    STATUS          current
    DESCRIPTION
        "
        Whether the port management status is automatically closed or not.
        "
    ::= { csgPortAdminStatusAutoShutdownEntry 2 }

csgPortAdminStatusAutoShutdownTime OBJECT-TYPE
    SYNTAX          Integer32(30..600)
    MAX-ACCESS      read-write
    STATUS          current
    DESCRIPTION
        "
        Port management status auto shutdown configuration time.
        "
    ::= { csgPortAdminStatusAutoShutdown 2 }

csgPortIpMacBind OBJECT IDENTIFIER ::= { csgPortFunction 2}

csgPortIpMacBindTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgPortIpMacBindEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PORT IP MAC BIND parameter table.
        "
    ::= { csgPortIpMacBind 1 }

csgPortIpMacBindEntry OBJECT-TYPE
    SYNTAX      CsgPortIpMacBindEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PORT IP MAC BIND parameter table entries.
        "
    INDEX
        {
            ifIndex,
            csgPortIpMacBindNum
        }
    ::= { csgPortIpMacBindTable 1 }

CsgPortIpMacBindEntry ::= SEQUENCE
    {
        csgPortIpMacBindNum       Integer32,
        csgPortIpMacBindMac       MacAddress,
        csgPortIpMacBindIpAddress IpAddress,
        csgPortIpMacBindRowStatus INTEGER
    }

csgPortIpMacBindNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        TABLE NUM
        "
    ::= { csgPortIpMacBindEntry 1 }

csgPortIpMacBindMac OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        PORT BIND MAC
        "
    ::= { csgPortIpMacBindEntry 2 }

csgPortIpMacBindIpAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        PORT BIND IPADDRESS
        "
    ::= { csgPortIpMacBindEntry 3 }

csgPortIpMacBindRowStatus OBJECT-TYPE
    SYNTAX      INTEGER
        {
            active(1),
            notInService(2),
            notReady(3),
            createAndGo(4),
            createAndWait(5),
            destroy(6)
        }
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        ROW STATUS
        "
    ::= { csgPortIpMacBindEntry 4 }

csgPortDeviceIpMac OBJECT IDENTIFIER ::= { csgPortFunction 3 }

csgPortDeviceIpMacBindWrongfulAlarm NOTIFICATION-TYPE
    OBJECTS
        {
            csgPortDeviceIfIndex,
            csgPortDeviceMac,
            csgPortDeviceIpAddress
        }
    STATUS      current
    DESCRIPTION
        "
        PortDeviceBindWrongfulAlarm
        "
    ::= { csgPortDeviceIpMac 2 }

csgPortDeviceIpMacBindCorrectAlarm NOTIFICATION-TYPE
    OBJECTS
        {
            csgPortDeviceIfIndex,
            csgPortDeviceMac,
            csgPortDeviceIpAddress
        }
    STATUS      current
    DESCRIPTION
        "
        PortDeviceBindWrongfulAlarm
        "
    ::= { csgPortDeviceIpMac 3 }

csgPortDeviceIpMacTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgPortDeviceIpMacEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PORT IP_MAC parameter table.
        "
    ::= { csgPortDeviceIpMac 1 }

csgPortDeviceIpMacEntry OBJECT-TYPE
    SYNTAX      CsgPortDeviceIpMacEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        A list of PORT DEVICE IP_MAC parameter table entries.
        "
    INDEX
        {
            csgPortDeviceIfIndex
        }
    ::= { csgPortDeviceIpMacTable 1 }

CsgPortDeviceIpMacEntry ::= SEQUENCE
    {
        csgPortDeviceIfIndex      Integer32,
        csgPortDeviceMac          MacAddress,
        csgPortDeviceIpAddress    IpAddress
    }

csgPortDeviceIfIndex OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "
        IFINDEX
        "
    ::= { csgPortDeviceIpMacEntry 1 }

csgPortDeviceMac OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        PORT DEVICE MAC
        "
    ::= { csgPortDeviceIpMacEntry 2 }

csgPortDeviceIpAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        PORT DEVICE IPADDRESS
        "
    ::= { csgPortDeviceIpMacEntry 3 }

-- begin

-- csg Agent
-- csgAgent OBJECT IDENTIFIER ::= { csg 1 }

-- ======================================================================================
-- csg-mcast-mib.mib
-- ======================================================================================

csgMcast OBJECT IDENTIFIER ::= { csgAgent 27 }
csgMcastObjects OBJECT IDENTIFIER ::= { csgMcast 2 }
csgMcastScalar OBJECT IDENTIFIER ::= { csgMcastObjects 1}
csgMcastL2 OBJECT IDENTIFIER ::= { csgMcastObjects 2}

--
-- Global Group
--

csgMulticastFilterEnable OBJECT-TYPE
    SYNTAX      EnableVar
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION
        "
        False indicates forward unregistered multicast traffic of the device;
        True indicates filter all unregistered multicast traffic.
        "
    DEFVAL { 2 }
    ::= { csgMcastScalar 1 }

--
-- csgMcastL2
--

csgL2MulticastMaxGroupNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The max number of L2 multicast group supported by hardware.
        "
    DEFVAL { 0 }
    ::= { csgMcastL2 1 }

csgL2MulticastCurrentGroupNum OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The current number of multicast groups in the l2 multicast address table.
        "
    DEFVAL { 0 }
    ::= { csgMcastL2 2 }

--
-- L2MulticastAddressTable
--

csgL2MulticastAddressTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF CsgL2MulticastAddressEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        This table provides the information of l2 multicast address.
        "
    ::= { csgMcastL2 3 }

csgL2MulticastAddressEntry OBJECT-TYPE
    SYNTAX      CsgL2MulticastAddressEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        Each entry provides a l2 multicast address information. Entries
        can be created as a static multicast address.
        "
    INDEX
        {
            csgL2MulticastMVlan,
            csgL2MulticastAddress
        }
    ::= { csgL2MulticastAddressTable 1 }

CsgL2MulticastAddressEntry ::= SEQUENCE
    {
        csgL2MulticastMVlan               Integer32,
        csgL2MulticastAddress             MacAddress,
        csgL2MulticastEgressPortlist      PortList,
        csgL2MulticastStaticPortlist      PortList,
        csgL2MulticastRowStatus           RowStatus
    }

csgL2MulticastMVlan OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The vlan-id in a frame to which this entry's forwarding information applies.
        "
    ::= { csgL2MulticastAddressEntry 1 }

csgL2MulticastAddress OBJECT-TYPE
    SYNTAX      MacAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION
        "
        The destination MAC address in a frame to which this entry's forwarding
        information applies. This object must take the value of a Multicast or
        Broadcast address.
        "
    ::= { csgL2MulticastAddressEntry 2 }

csgL2MulticastEgressPortlist OBJECT-TYPE
    SYNTAX      PortList
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION
        "
        The set of ports to which frames destined for a specific Multicast must be forwarded.
        "
    ::= { csgL2MulticastAddressEntry 3 }

csgL2MulticastStaticPortlist OBJECT-TYPE
    SYNTAX      PortList
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
          "
          The set of ports to which frames received destined for a specific Multicast must be
          forwarded, regardless of any dynamic information e.g. from GMRP.
          "
    ::= { csgL2MulticastAddressEntry 4 }

csgL2MulticastRowStatus OBJECT-TYPE
    SYNTAX      RowStatus
    MAX-ACCESS  read-create
    STATUS      current
    DESCRIPTION
        "
        The row status of the csgL2MulticastAddress table.
        "
    ::= { csgL2MulticastAddressEntry 5 }

