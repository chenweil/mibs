csg MODULE-IDENTITY
    LAST-UPDATED "201809210000Z"  -- Sep 21, 2018
    ORGANIZATION
        "csg Technology Co., Ltd."
    CONTACT-INFO
        "csg Science & Technology Co., ltd.
        E-mail: support@csg.com"
